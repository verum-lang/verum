// =============================================================================
// mutex.vr - Mutual exclusion lock
// =============================================================================
// Layer: 2.5 (Sync)
// Dependencies: core, sync/atomic
// =============================================================================
//
// Mutex<T> provides mutual exclusion for shared mutable state.
// Uses a futex-based implementation for efficient OS-level blocking.
//
// Performance:
// - Uncontended: ~25ns
// - Contended: ~1-10μs (OS-level sleep, no CPU waste)
//
// Spec: docs/audit1.md Section 11.5
//
// =============================================================================

module core.sync.mutex;
mount core.*;
mount .atomic.*;

// =============================================================================
// Mutex<T>
// =============================================================================

// Mutual exclusion lock protecting data of type T.
// Uses FutexLock (OS-backed) instead of SpinLock for efficient contention handling.
public type Mutex<T> is {
    futex: FutexLock,
    data: T,
    // Poisoned flag for panic safety
    poisoned: AtomicBool,
};

implement<T> Mutex<T> {
    // Create new mutex with initial value.
    public fn new(data: T) -> Mutex<T> {
        Mutex {
            futex: FutexLock.new(),
            data: data,
            poisoned: AtomicBool.new(false),
        }
    }

    // Acquire lock && return guard.
    // Blocks until lock is available.
    public fn lock(&self) -> Result<MutexGuard<T>, PoisonError<MutexGuard<T>>> {
        self.futex.lock();

        let guard = MutexGuard {
            mutex: self,
        };

        if self.poisoned.load(MemoryOrdering.Acquire) {
            Err(PoisonError.new(guard))
        } else {
            Ok(guard)
        }
    }

    // Try to acquire lock without blocking.
    // Returns None if lock is held by another thread.
    public fn try_lock(&self) -> TryLockResult<MutexGuard<T>> {
        if self.futex.try_lock() {
            let guard = MutexGuard {
                mutex: self,
            };

            if self.poisoned.load(MemoryOrdering.Acquire) {
                Err(TryLockError.Poisoned(PoisonError.new(guard)))
            } else {
                Ok(guard)
            }
        } else {
            Err(TryLockError.WouldBlock)
        }
    }

    /// Check if mutex is poisoned (previous holder marked it as poisoned).
    ///
    /// # Note on poisoning semantics
    ///
    /// Verum does NOT yet expose a "currently unwinding a panic" predicate
    /// at the language level (the Rust `std::thread::panicking()` analogue),
    /// so `MutexGuard::drop` cannot poison the mutex automatically when
    /// dropped during a panic. As a result, the poison flag is only set
    /// when callers explicitly invoke `poison()` before raising — typically
    /// right before a `panic(...)` site that observes inconsistent state
    /// while holding the guard. This API is therefore advisory: a mutex
    /// reports `is_poisoned() == true` only if some thread previously
    /// called `poison()` on it.
    public fn is_poisoned(&self) -> Bool {
        self.poisoned.load(MemoryOrdering.Acquire)
    }

    /// Mark this mutex as poisoned.
    ///
    /// Subsequent `lock()` and `try_lock()` calls will return
    /// `Err(PoisonError)` until `clear_poison()` is invoked. Intended for
    /// callers that detect inconsistent state while holding the guard
    /// and want to flag recovery for later acquirers — call `poison()`
    /// immediately before the `panic(...)` (or before propagating an
    /// unrecoverable error up the stack), so the next acquirer sees the
    /// poison flag.
    ///
    /// Uses Release ordering so the poison flag write is visible to the
    /// next acquirer through the lock's release-acquire pair.
    public fn poison(&self) {
        self.poisoned.store(true, MemoryOrdering.Release);
    }

    /// Clear poison state.
    ///
    /// Subsequent acquirers will not see this mutex as poisoned. Caller
    /// is responsible for ensuring the protected data is in a valid state
    /// before clearing.
    public fn clear_poison(&self) {
        self.poisoned.store(false, MemoryOrdering.Release);
    }

    // Get mutable reference without locking.
    // SAFETY: Caller must ensure exclusive access.
    public fn get_mut(&mut self) -> LockResult<&mut T> {
        if self.poisoned.load(MemoryOrdering.Acquire) {
            Err(PoisonError.new(&mut self.data))
        } else {
            Ok(&mut self.data)
        }
    }

    // Consume mutex && return inner value.
    public fn into_inner(self) -> LockResult<T> {
        if self.poisoned.load(MemoryOrdering.Acquire) {
            Err(PoisonError.new(self.data))
        } else {
            Ok(self.data)
        }
    }

    /// Check if the mutex is currently locked.
    /// This is a best-effort check — the lock state may change immediately after.
    public fn is_locked(&self) -> Bool {
        self.futex.is_locked()
    }
}

implement<T: Default> Default for Mutex<T> {
    fn default() -> Mutex<T> {
        Mutex.new(T.default())
    }
}

implement<T: Debug> Debug for Mutex<T> {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self.try_lock() {
            Ok(guard) => {
                f.write_str("Mutex { data: ")?;
                (*guard).fmt_debug(f)?;
                f.write_str(" }")
            }
            Err(_) => {
                f.write_str("Mutex { <locked> }")
            }
        }
    }
}

// =============================================================================
// MutexGuard<T>
// =============================================================================

// RAII guard for Mutex. Releases lock when dropped.
public type MutexGuard<T> is {
    mutex: &Mutex<T>,
};

implement<T> MutexGuard<T> {
    // Get reference to protected data.
    fn data(&self) -> &T {
        &self.mutex.data
    }

    // Get mutable reference to protected data.
    fn data_mut(&mut self) -> &mut T {
        unsafe { &mut *(&self.mutex.data as *const T as *mut T) }
    }
}

implement<T> Deref for MutexGuard<T> {
    type Target = T;

    fn deref(&self) -> &T {
        self.data()
    }
}

implement<T> DerefMut for MutexGuard<T> {
    fn deref_mut(&mut self) -> &mut T {
        self.data_mut()
    }
}

implement<T> Drop for MutexGuard<T> {
    fn drop(&mut self) {
        // Release the lock
        self.mutex.futex.unlock();
    }
}

// =============================================================================
// Error Types
// =============================================================================

// Result type for lock operations.
public type LockResult<T> is Result<T, PoisonError<T>>;

// Result type for try_lock operations.
public type TryLockResult<T> is Result<T, TryLockError<T>>;

// Error when mutex was held by panicking thread.
public type PoisonError<T> is {
    guard: T,
};

implement<T> PoisonError<T> {
    fn new(guard: T) -> PoisonError<T> {
        PoisonError { guard: guard }
    }

    // Get reference to protected data despite poison.
    public fn get_ref(&self) -> &T {
        &self.guard
    }

    // Get mutable reference to protected data despite poison.
    public fn get_mut(&mut self) -> &mut T {
        &mut self.guard
    }

    // Consume error && return data.
    public fn into_inner(self) -> T {
        self.guard
    }
}

implement<T: Debug> Debug for PoisonError<T> {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("PoisonError { .. }")
    }
}

implement<T> Display for PoisonError<T> {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("poisoned lock: another task failed while holding the lock")
    }
}

// Error for try_lock operations.
public type TryLockError<T> is
    | WouldBlock                    // Lock is held by another thread
    | Poisoned(PoisonError<T>);     // Previous holder panicked

implement<T: Debug> Debug for TryLockError<T> {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            WouldBlock => f.write_str("WouldBlock"),
            Poisoned(_) => f.write_str("Poisoned"),
        }
    }
}

implement<T> Display for TryLockError<T> {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            WouldBlock => f.write_str("try_lock failed because the lock is already held"),
            Poisoned(_) => f.write_str("poisoned lock: another task failed while holding the lock"),
        }
    }
}
