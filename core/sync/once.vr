// =============================================================================
// once.vr - One-time initialization
// =============================================================================
// Layer: 2.5 (Sync)
// Dependencies: core, sync/atomic
// =============================================================================
//
// Once ensures a function is called exactly once, even with concurrent access.
// Useful for lazy static initialization.
//
// =============================================================================

module core.sync.once;
mount core.*;
mount .atomic.*;
mount core.intrinsics.compiler_fence;
mount core.intrinsics.spin_hint;

// =============================================================================
// Once
// =============================================================================

// State values
const INCOMPLETE: Int = 0;
const RUNNING: Int = 1;
const COMPLETE: Int = 2;
const POISONED: Int = 3;

// State for querying Once status.
public type OnceState is
    | New           // Not yet called
    | InProgress    // Currently running
    | Done          // Successfully completed
    | Poisoned;     // Panicked during execution

// Guard that sets POISONED if dropped without completing.
// This handles the case where the initialization function panics.
type OnceGuard is {
    state: &AtomicInt,
    completed: Bool,
};

implement Drop for OnceGuard {
    /// Drop semantics — poison the Once iff our RUNNING claim is
    /// still live.
    ///
    /// SOUNDNESS: previous revision did an unconditional
    /// `self.state.store(POISONED, ...)` when `!self.completed`.  The
    /// `call_once_slow` path stores `state = COMPLETE` BEFORE setting
    /// `guard.completed = true`; if a panic fires in that narrow
    /// window (between the COMPLETE publication and the disarm
    /// flag), the guard's drop runs with `completed: false` and
    /// SILENTLY OVERWRITES a successful COMPLETE with POISONED.
    /// Future callers then see POISONED and refuse to use a
    /// fully-initialised value — a real soundness bug.
    ///
    /// The fix: poison via CAS that only succeeds when state is
    /// still RUNNING (i.e. our claim never advanced).  Any
    /// already-published COMPLETE / POISONED observed by the CAS is
    /// preserved — the drop becomes a no-op in those cases, which
    /// matches the documented contract ("guard panic-poisons only
    /// the slot it owns").
    fn drop(&mut self) {
        if !self.completed {
            let _ = self.state.compare_exchange(
                RUNNING,
                POISONED,
                MemoryOrdering.Release,
                MemoryOrdering.Relaxed,
            );
        }
    }
}

// Synchronization primitive for one-time initialization.
public type Once is {
    state: AtomicInt,
};

implement Once {
    // Create new Once that hasn't been called.
    public fn new() -> Once {
        Once { state: AtomicInt.new(INCOMPLETE) }
    }

    // Run function if not yet called.
    // Blocks if another thread is currently running the function.
    // Returns Ok if function completed, Err if it panicked.
    public fn call_once<F: fn()>(&self, f: F) {
        // Fast path: already complete
        if self.is_completed() {
            return;
        }

        self.call_once_slow(f);
    }

    // Slow path for call_once.
    fn call_once_slow<F: fn()>(&self, f: F) {
        loop {
            match self.state.compare_exchange(INCOMPLETE, RUNNING, MemoryOrdering.AcqRel, MemoryOrdering.Acquire) {
                Ok(_) => {
                    // We won the race - use a guard to handle panics
                    // The guard will set POISONED if dropped without completing
                    let mut guard = OnceGuard { state: &self.state, completed: false };

                    // Run the initialization function
                    f();

                    // Mark as completed && disarm the guard
                    self.state.store(COMPLETE, MemoryOrdering.Release);
                    guard.completed = true;
                    // Guard will be dropped here but won't poison since completed=true

                    return;
                }
                Err(COMPLETE) => {
                    // Already done
                    return;
                }
                Err(POISONED) => {
                    // Previous attempt panicked
                    panic("Once.call_once called after panic");
                }
                Err(RUNNING) => {
                    // Another thread is running. Wait with
                    // spin_hint() so the CPU can issue PAUSE
                    // (x86) / YIELD (aarch64) and not burn
                    // 100% on the polling loop.  For very-
                    // short init functions the wait
                    // typically resolves in a handful of
                    // iterations; for longer ones a futex
                    // wait would be better but requires a
                    // sequenced state-and-waiter counter
                    // pair (tracked as a follow-up).
                    while self.state.load(MemoryOrdering.Acquire) == RUNNING {
                        spin_hint();
                    }
                }
                Err(_) => {
                    // Unexpected state, retry
                    compiler_fence(MemoryOrdering.SeqCst);
                }
            }
        }
    }

    /// Run a fallible initialization function at most once.
    ///
    /// Like `call_once` but `f` returns `Result<(), E>`:
    ///   - If `f` returns `Ok(())`, the Once becomes COMPLETE and
    ///     subsequent callers will see `Ok(false)` ("another
    ///     thread completed it").
    ///   - If `f` returns `Err(e)`, the Once is RESET to INCOMPLETE
    ///     and the next caller may retry — the Err is propagated to
    ///     this caller.
    ///   - If the Once is already COMPLETE on entry, returns
    ///     `Ok(false)` immediately (no retry, no `f` execution).
    ///
    /// Returns `Ok(true)` when this caller's `f` ran AND succeeded;
    /// `Ok(false)` when another thread already completed init;
    /// `Err(e)` when this caller's `f` ran AND failed.
    ///
    /// This is the foundation primitive for `OnceLock.get_or_try_init`
    /// — the previous implementation ran `f()` BEFORE entering
    /// `call_once`, which let multiple racing callers all execute
    /// `f` concurrently (contract violation: `f` must run at most
    /// once across the program lifetime).  Routing through
    /// `try_call_once` serialises `f` properly inside the
    /// CAS-protected critical section.
    public fn try_call_once<E, F: fn() -> Result<(), E>>(&self, f: F) -> Result<Bool, E> {
        // Fast path: already complete
        if self.is_completed() {
            return Ok(false);
        }

        loop {
            match self.state.compare_exchange(INCOMPLETE, RUNNING, MemoryOrdering.AcqRel, MemoryOrdering.Acquire) {
                Ok(_) => {
                    // We won the race - use a guard to handle panics
                    let mut guard = OnceGuard { state: &self.state, completed: false };

                    match f() {
                        Ok(()) => {
                            // Init succeeded — publish COMPLETE
                            self.state.store(COMPLETE, MemoryOrdering.Release);
                            guard.completed = true;
                            return Ok(true);
                        }
                        Err(e) => {
                            // Init failed — reset to INCOMPLETE so a future
                            // caller can retry.  Disarm the guard explicitly
                            // (completed=true) so its Drop doesn't poison
                            // the slot — we are intentionally surrendering
                            // the RUNNING claim, not panicking through it.
                            self.state.store(INCOMPLETE, MemoryOrdering.Release);
                            guard.completed = true;
                            return Err(e);
                        }
                    }
                }
                Err(COMPLETE) => {
                    // Another thread completed it
                    return Ok(false);
                }
                Err(POISONED) => {
                    panic("Once.try_call_once called after panic — use call_once_force to recover");
                }
                Err(RUNNING) => {
                    // Another thread is initialising. Spin-wait until it
                    // either completes or surrenders the RUNNING claim.
                    while self.state.load(MemoryOrdering.Acquire) == RUNNING {
                        spin_hint();
                    }
                    // Then retry the CAS (will hit COMPLETE on success
                    // or INCOMPLETE if the winning thread surrendered).
                }
                Err(_) => {
                    compiler_fence(MemoryOrdering.SeqCst);
                }
            }
        }
    }

    /// Run function if !yet called, ignoring poison.
    ///
    /// Unlike `call_once`, this will attempt initialization even if a
    /// previous attempt panicked. Useful for recovery scenarios.
    public fn call_once_force<F: fn()>(&self, f: F) {
        // Fast path: already complete
        if self.state.load(MemoryOrdering.Acquire) == COMPLETE {
            return;
        }

        loop {
            let state = self.state.load(MemoryOrdering.Acquire);
            if state == COMPLETE {
                return;
            }

            // Accept any state except RUNNING
            match self.state.compare_exchange(state, RUNNING, MemoryOrdering.AcqRel, MemoryOrdering.Acquire) {
                Ok(_) => {
                    // Use guard for panic safety
                    let mut guard = OnceGuard { state: &self.state, completed: false };

                    f();

                    self.state.store(COMPLETE, MemoryOrdering.Release);
                    guard.completed = true;
                    return;
                }
                Err(COMPLETE) => {
                    return;
                }
                Err(RUNNING) => {
                    // Wait for current attempt to finish
                    while self.state.load(MemoryOrdering.Acquire) == RUNNING {
                        compiler_fence(MemoryOrdering.SeqCst);
                    }
                    // Then retry
                }
                Err(_) => {
                    // Retry
                    compiler_fence(MemoryOrdering.SeqCst);
                }
            }
        }
    }

    // Check if initialization is complete.
    public fn is_completed(&self) -> Bool {
        self.state.load(MemoryOrdering.Acquire) == COMPLETE
    }

    // Get current state.
    public fn state(&self) -> OnceState {
        match self.state.load(MemoryOrdering.Acquire) {
            INCOMPLETE => New,
            RUNNING => InProgress,
            COMPLETE => Done,
            POISONED => Poisoned,
            _ => New,
        }
    }
}

implement Default for Once {
    fn default() -> Once {
        Once.new()
    }
}

implement Debug for Once {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("Once { state: ")?;
        self.state().fmt_debug(f)?;
        f.write_str(" }")
    }
}

implement Debug for OnceState {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            New => f.write_str("New"),
            InProgress => f.write_str("InProgress"),
            Done => f.write_str("Done"),
            Poisoned => f.write_str("Poisoned"),
        }
    }
}

// =============================================================================
// OnceLock<T> - Lazy initialization with stored value
// =============================================================================

// Lazy-initialized value that can only be set once.
public type OnceLock<T> is {
    once: Once,
    value: Maybe<T>,
};

implement<T> OnceLock<T> {
    // Create new empty OnceLock.
    public fn new() -> OnceLock<T> {
        OnceLock {
            once: Once.new(),
            value: None,
        }
    }

    // Get value, initializing with function if needed.
    public fn get_or_init<F: fn() -> T>(&self, f: F) -> &T {
        self.once.call_once(|| {
            let v = f();
            unsafe {
                let ptr = &self.value as *const Maybe<T> as *mut Maybe<T>;
                *ptr = Some(v);
            }
        });

        self.value.as_ref().expect("OnceLock invariant: value must be Some after call_once completed")
    }

    // Get value if initialized.
    public fn get(&self) -> Maybe<&T> {
        if self.once.is_completed() {
            self.value.as_ref()
        } else {
            None
        }
    }

    // Set value if not already set.
    //
    // Returns Ok(()) on success, Err(value) if already initialised
    // OR if another thread won the initialisation race.  Rejected
    // value is returned unchanged so the caller can decide what to
    // do with it.
    //
    // Implemented as a thin wrapper over `try_get_or_set` — the
    // earlier impl had a latent `panic("lost a race window…")`
    // because it tried to drive the init through `call_once` which
    // moves the value into a closure that may never run.  The new
    // race-safe primitive handles every contention path without
    // ever panicking, so `set` now upholds its `Result` contract
    // strictly.
    public fn set(&self, value: T) -> Result<(), T> {
        match self.try_get_or_set(value) {
            Ok(_) => Ok(()),
            Err(rejected) => Err(rejected),
        }
    }

    // Take value, leaving None.
    public fn take(&mut self) -> Maybe<T> {
        if self.once.is_completed() {
            self.value.take()
        } else {
            None
        }
    }

    // Check if initialized.
    public fn is_initialized(&self) -> Bool {
        self.once.is_completed()
    }

    /// Get value, initializing with a fallible function if needed.
    /// If the function returns Err, the OnceLock remains uninitialized
    /// and the error is returned (a future caller can retry).
    ///
    /// **Race-fix**: previous implementation ran `f()` BEFORE
    /// entering `call_once`, so multiple racing callers could each
    /// execute their own copy of `f`.  Now `f()` runs INSIDE
    /// `try_call_once`'s CAS-protected critical section so it runs
    /// at most once across all racers — matches the contract its
    /// docstring claims.
    public fn get_or_try_init<E, F: fn() -> Result<T, E>>(&self, f: F) -> Result<&T, E> {
        // Fast path: already initialised
        if self.once.is_completed() {
            return Ok(self.value.as_ref().expect("OnceLock invariant: value must be Some after call_once completed"));
        }

        // Slow path: race for INCOMPLETE → RUNNING transition.
        //
        // Drives the state CAS directly (parallel to try_get_or_set)
        // instead of going through try_call_once + closure.  Reasons:
        //   1. Tier-0 closure-context codegen for `unsafe { *ptr =
        //      Some(v) }` doesn't currently round-trip the captured
        //      `&self.value` correctly when invoked indirectly through
        //      `f()` (separate codegen issue tracked at task #40
        //      follow-up).  The direct-CAS pattern bypasses that
        //      entirely.
        //   2. Slightly faster — one CAS + one store on the win path
        //      instead of CAS + closure-call + CAS + store.
        //   3. Same `f()`-runs-at-most-once contract as the
        //      try_call_once version: only the RUNNING-winning thread
        //      ever invokes `f`; losers spin on RUNNING then either
        //      observe COMPLETE (return Ok) or INCOMPLETE-after-
        //      surrender (retry their own CAS attempt).
        loop {
            let cas = self.once.state.compare_exchange(
                INCOMPLETE,
                RUNNING,
                MemoryOrdering.AcqRel,
                MemoryOrdering.Acquire,
            );
            if cas.is_ok() {
                // We won — invoke `f` and either store on success or
                // surrender RUNNING → INCOMPLETE on failure (so the
                // next caller can retry).
                match f() {
                    Ok(v) => {
                        unsafe {
                            let ptr = &self.value as *const Maybe<T> as *mut Maybe<T>;
                            *ptr = Some(v);
                        }
                        self.once.state.store(COMPLETE, MemoryOrdering.Release);
                        return Ok(self.value.as_ref().expect("OnceLock invariant: value must be Some after call_once completed"));
                    }
                    Err(e) => {
                        self.once.state.store(INCOMPLETE, MemoryOrdering.Release);
                        return Err(e);
                    }
                }
            }
            // CAS lost — observe the actual state and dispatch.
            let observed: Int = match cas {
                Err(actual) => actual,
                Ok(_) => unsafe { unreachable_unchecked() },
            };
            if observed == COMPLETE {
                return Ok(self.value.as_ref().expect("OnceLock invariant: value must be Some after call_once completed"));
            }
            if observed == POISONED {
                panic("OnceLock.get_or_try_init on poisoned Once");
            }
            if observed == RUNNING {
                while self.once.state.load(MemoryOrdering.Acquire) == RUNNING {
                    spin_hint();
                }
                continue;
            }
            compiler_fence(MemoryOrdering.SeqCst);
        }
    }

    /// Try to set the value to `value`.  Race-safe single-shot
    /// counterpart of `set` — never moves `value` into a closure
    /// that might not run, so the rejected value is preserved
    /// across every contention path.
    ///
    /// Returns `Ok(&T)` (the just-stored value) on successful set,
    /// or `Err(value)` if either the OnceLock was already
    /// initialised on entry OR another thread won the
    /// initialisation race.  In both Err paths the original
    /// `value` is returned unchanged so the caller can decide
    /// what to do with it (retry, drop, log, etc.).
    ///
    /// Why not just use `set`?  `set` captures `value` into the
    /// `call_once` closure to allow it to run at most once; if
    /// the closure doesn't run because another thread won the
    /// race between the `is_completed` fast-path check and the
    /// closure entry, the captured `value` is dropped and there
    /// is no way to materialise a `T` for the caller — the prior
    /// `set` impl honestly panicked at that race window.
    /// `try_get_or_set` avoids the moved-into-closure dance by
    /// driving the state CAS directly: only the winning thread
    /// stores its value; losing threads return their `value`
    /// untouched.
    public fn try_get_or_set(&self, value: T) -> Result<&T, T> {
        // Fast path: already initialised
        if self.once.is_completed() {
            return Err(value);
        }

        // Slow path: race for the INCOMPLETE → RUNNING transition.
        // We MUST drive the CAS directly (not through call_once)
        // because the value can only be moved into storage on the
        // winning path; any closure capture would burn the value
        // on the losing thread.
        //
        // Refactor: outer loop with a Bool wait flag instead of
        // nested `Err(POISONED)` / `Err(RUNNING)` / `Err(_)` arms.
        // Pattern matching `Err(<const>)` against Result's Int
        // payload is brittle in the current codegen — see task
        // #40 — so we destructure into the actual i64 first then
        // do plain integer comparisons.
        loop {
            let cas = self.once.state.compare_exchange(
                INCOMPLETE,
                RUNNING,
                MemoryOrdering.AcqRel,
                MemoryOrdering.Acquire,
            );
            if cas.is_ok() {
                // We won — store value, publish COMPLETE.
                unsafe {
                    let ptr = &self.value as *const Maybe<T> as *mut Maybe<T>;
                    *ptr = Some(value);
                }
                self.once.state.store(COMPLETE, MemoryOrdering.Release);
                return Ok(self.value.as_ref().expect("OnceLock invariant: value must be Some after call_once completed"));
            }
            let observed: Int = match cas {
                Err(actual) => actual,
                Ok(_) => unsafe { unreachable_unchecked() },
            };
            if observed == COMPLETE {
                return Err(value);
            }
            if observed == POISONED {
                panic("OnceLock.try_get_or_set on poisoned Once — use try_get_or_set_force to recover");
            }
            if observed == RUNNING {
                // Spin until the winning thread releases RUNNING
                // (either completes → COMPLETE, or surrenders →
                // INCOMPLETE).
                while self.once.state.load(MemoryOrdering.Acquire) == RUNNING {
                    spin_hint();
                }
                // Loop continues — next CAS sees the resolved state.
                continue;
            }
            // Unexpected state — fence and retry.
            compiler_fence(MemoryOrdering.SeqCst);
        }
    }
}

implement<T: Default> Default for OnceLock<T> {
    fn default() -> OnceLock<T> {
        OnceLock.new()
    }
}
