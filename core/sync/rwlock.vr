// =============================================================================
// rwlock.vr - Read-Write Lock
// =============================================================================
// Layer: 2.5 (Sync)
// Dependencies: core, sync/atomic
// =============================================================================
//
// RwLock<T> allows multiple readers or a single writer.
// Uses atomic counters for efficient reader tracking.
//
// =============================================================================

module core.sync.rwlock;
mount core.*;
mount .atomic.*;

// Cross-platform futex imports for OS-level blocking
@cfg(target_os = "linux")
mount sys.linux.thread.{
    futex_wait as sys_futex_wait,
    futex_wake as sys_futex_wake,
};

@cfg(target_os = "macos")
mount sys.darwin.thread.{
    futex_wait as sys_futex_wait,
    futex_wake as sys_futex_wake,
};

@cfg(target_os = "windows")
mount sys.windows.thread.{
    futex_wait as sys_futex_wait,
    futex_wake as sys_futex_wake,
};

mount core.intrinsics.spin_hint;

// =============================================================================
// RwLock<T>
// =============================================================================

// Read-write lock allowing multiple readers or one writer.
//
// **Fairness model: writer-preferred.**  When at least one
// writer is queued (`writers_waiting > 0`), incoming readers
// step aside and sleep on the futex even if they could
// otherwise CAS the reader count up.  This prevents the
// classic readers-preferred starvation pattern where a steady
// stream of new readers keeps the state positive and writers
// never observe the `state == 0` window they need.  The cost
// is mild reader latency under sustained writer pressure;
// the benefit is bounded writer wait-time.
//
// `writers_waiting` is incremented by `write()` BEFORE its
// futex_wait registration (Release, paired with the
// `read()`-side Acquire load) and decremented after the CAS
// from 0 → WRITE_LOCKED succeeds (or after we exit the loop
// via giving up — none of the current paths give up, but
// future try_write_for_timeout would).
public type RwLock<T> is {
    // State encoding:
    // - 0: unlocked
    // - positive: number of readers
    // - -1: write locked
    state: AtomicInt,
    // Number of writers blocked in write() awaiting state==0.
    // Readers must yield to queued writers.
    writers_waiting: AtomicInt,
    data: T,
    poisoned: AtomicBool,
};

const WRITE_LOCKED: Int = -1;

implement<T> RwLock<T> {
    // Create new unlocked RwLock.
    public fn new(data: T) -> RwLock<T> {
        RwLock {
            state: AtomicInt.new(0),
            writers_waiting: AtomicInt.new(0),
            data: data,
            poisoned: AtomicBool.new(false),
        }
    }

    // Acquire read lock.
    //
    // Blocks via futex until no writer holds the lock AND no writer
    // is queued. The "no writer queued" check is the writer-preference
    // gate: when `writers_waiting > 0`, incoming readers step aside
    // and sleep, letting the queued writer drain the reader pile and
    // acquire the lock. Without this gate a steady stream of new
    // readers could keep `state` positive indefinitely and starve
    // every writer.
    public fn read(&self) -> LockResult<RwLockReadGuard<T>> {
        loop {
            let state = self.state.load(MemoryOrdering.Acquire);
            // Yield to any queued writer (writer-preference fairness).
            let queued_writers = self.writers_waiting.load(MemoryOrdering.Acquire);
            if state >= 0 && queued_writers == 0 {
                // Try to increment reader count
                if self.state.compare_exchange(state, state + 1, MemoryOrdering.AcqRel, MemoryOrdering.Relaxed).is_ok() {
                    let guard = RwLockReadGuard { rwlock: self };
                    if self.poisoned.load(MemoryOrdering.Acquire) {
                        return Err(PoisonError.new(guard));
                    }
                    return Ok(guard);
                }
            } else {
                // Writer present OR queued — sleep via futex until state changes.
                // futex_wait checks state.value == state and returns
                // EAGAIN if it doesn't match (covers the race where
                // state changes between our load and our wait).
                let _ = sys_futex_wait(&self.state.value, state, None);
            }
        }
    }

    // Try to acquire read lock without blocking.
    //
    // Honours the writer-preference gate identically to `read()`:
    // returns `WouldBlock` when a writer is queued even if `state >= 0`.
    public fn try_read(&self) -> TryLockResult<RwLockReadGuard<T>> {
        let state = self.state.load(MemoryOrdering.Acquire);
        let queued_writers = self.writers_waiting.load(MemoryOrdering.Acquire);
        if state >= 0 && queued_writers == 0 {
            if self.state.compare_exchange(state, state + 1, MemoryOrdering.AcqRel, MemoryOrdering.Relaxed).is_ok() {
                let guard = RwLockReadGuard { rwlock: self };
                if self.poisoned.load(MemoryOrdering.Acquire) {
                    return Err(TryLockError.Poisoned(PoisonError.new(guard)));
                }
                return Ok(guard);
            }
        }
        Err(TryLockError.WouldBlock)
    }

    // Acquire write lock.
    //
    // Blocks via futex until no readers or writers hold the lock.
    // Increments `writers_waiting` on entry to gate incoming readers
    // (writer-preference fairness — see `read()` doc). The counter
    // is decremented exactly once: on successful CAS into
    // WRITE_LOCKED state. The `Release` ordering on the increment
    // synchronises-with the `Acquire` load in `read()` / `try_read()`
    // so an incoming reader observing our registration yields.
    public fn write(&self) -> LockResult<RwLockWriteGuard<T>> {
        self.writers_waiting.fetch_add(1, MemoryOrdering.Release);
        loop {
            let state = self.state.load(MemoryOrdering.Acquire);
            if state == 0 {
                if self.state.compare_exchange(0, WRITE_LOCKED, MemoryOrdering.AcqRel, MemoryOrdering.Relaxed).is_ok() {
                    self.writers_waiting.fetch_sub(1, MemoryOrdering.Release);
                    let guard = RwLockWriteGuard { rwlock: self };
                    if self.poisoned.load(MemoryOrdering.Acquire) {
                        return Err(PoisonError.new(guard));
                    }
                    return Ok(guard);
                }
            } else {
                // Readers or writer present — sleep via futex until state changes
                let _ = sys_futex_wait(&self.state.value, state, None);
            }
        }
    }

    // Try to acquire write lock without blocking.
    public fn try_write(&self) -> TryLockResult<RwLockWriteGuard<T>> {
        if self.state.compare_exchange(0, WRITE_LOCKED, MemoryOrdering.AcqRel, MemoryOrdering.Relaxed).is_ok() {
            let guard = RwLockWriteGuard { rwlock: self };
            if self.poisoned.load(MemoryOrdering.Acquire) {
                return Err(TryLockError.Poisoned(PoisonError.new(guard)));
            }
            return Ok(guard);
        }
        Err(TryLockError.WouldBlock)
    }

    /// Check if rwlock is poisoned (previous holder marked it as poisoned).
    ///
    /// See `Mutex::is_poisoned` for notes on poisoning semantics — Verum
    /// does not yet expose a "currently unwinding" predicate, so the
    /// poison flag is only set when callers explicitly invoke `poison()`.
    public fn is_poisoned(&self) -> Bool {
        self.poisoned.load(MemoryOrdering.Acquire)
    }

    /// Mark this rwlock as poisoned.
    ///
    /// Subsequent acquirers will receive `Err(PoisonError)` until
    /// `clear_poison()` is invoked. Intended for callers that detect
    /// inconsistent state while holding a guard and want to flag
    /// recovery for later acquirers.
    public fn poison(&self) {
        self.poisoned.store(true, MemoryOrdering.Release);
    }

    /// Clear poison state.
    ///
    /// Caller is responsible for ensuring the protected data is in a
    /// valid state before clearing.
    public fn clear_poison(&self) {
        self.poisoned.store(false, MemoryOrdering.Release);
    }

    // Get mutable reference without locking.
    public fn get_mut(&mut self) -> LockResult<&mut T> {
        if self.poisoned.load(MemoryOrdering.Acquire) {
            Err(PoisonError.new(&mut self.data))
        } else {
            Ok(&mut self.data)
        }
    }

    // Consume && return inner value.
    public fn into_inner(self) -> LockResult<T> {
        if self.poisoned.load(MemoryOrdering.Acquire) {
            Err(PoisonError.new(self.data))
        } else {
            Ok(self.data)
        }
    }

    // Internal: release read lock.
    fn release_read(&self) {
        let prev = self.state.fetch_sub(1, MemoryOrdering.Release);
        if prev == 1 {
            // Last reader — wake one writer that may be waiting
            let _ = sys_futex_wake(&self.state.value, 1);
        }
    }

    // Internal: release write lock.
    fn release_write(&self) {
        self.state.store(0, MemoryOrdering.Release);
        // Wake all waiters — both readers and writers may be waiting
        let _ = sys_futex_wake(&self.state.value, Int.MAX);
    }
}

implement<T: Default> Default for RwLock<T> {
    fn default() -> RwLock<T> {
        RwLock.new(T.default())
    }
}

implement<T: Debug> Debug for RwLock<T> {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("RwLock { ... }")
    }
}

// =============================================================================
// RwLockReadGuard<T>
// =============================================================================

// RAII guard for read access.
public type RwLockReadGuard<T> is {
    rwlock: &RwLock<T>,
};

implement<T> Deref for RwLockReadGuard<T> {
    type Target = T;

    fn deref(&self) -> &T {
        &self.rwlock.data
    }
}

implement<T> Drop for RwLockReadGuard<T> {
    fn drop(&mut self) {
        self.rwlock.release_read();
    }
}

// =============================================================================
// RwLockWriteGuard<T>
// =============================================================================

// RAII guard for write access.
public type RwLockWriteGuard<T> is {
    rwlock: &RwLock<T>,
};

implement<T> Deref for RwLockWriteGuard<T> {
    type Target = T;

    fn deref(&self) -> &T {
        &self.rwlock.data
    }
}

implement<T> DerefMut for RwLockWriteGuard<T> {
    fn deref_mut(&mut self) -> &mut T {
        unsafe { &mut *(&self.rwlock.data as *const T as *mut T) }
    }
}

implement<T> Drop for RwLockWriteGuard<T> {
    fn drop(&mut self) {
        self.rwlock.release_write();
    }
}

implement<T: Debug> Debug for RwLockReadGuard<T> {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("RwLockReadGuard { .. }")
    }
}

implement<T: Debug> Debug for RwLockWriteGuard<T> {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("RwLockWriteGuard { .. }")
    }
}

// =============================================================================
// Re-export error types from mutex
// =============================================================================

public mount super.mutex.LockResult;
public mount super.mutex.TryLockResult;
public mount super.mutex.PoisonError;
public mount super.mutex.TryLockError;
