// =============================================================================
// metrics/instrument.vr — Counter / UpDownCounter / Gauge
// =============================================================================
// One-per-cardinality scalar instruments. Each records a single Float
// value atomically.
// =============================================================================

module core.metrics.instrument;

mount core.*;
mount core.sync.atomic.{MemoryOrdering};
mount core.metrics.value.{AtomicF64};

// =============================================================================
// Counter — monotonically-increasing float
// =============================================================================

public type Counter is {
    value: AtomicF64,
};

implement Counter {
    public fn new() -> Counter {
        Counter { value: AtomicF64.new(0.0) }
    }

    /// Increment by 1.
    public fn inc(&self) { self.add(1.0); }

    /// Add `v`. Panics if `v < 0` (counters are monotonic per Prometheus
    /// spec). Callers that need decrement semantics use UpDownCounter.
    ///
    /// Silently ignores `NaN` and infinite inputs: a single
    /// `Counter.add(NaN)` would otherwise contaminate the value
    /// permanently (NaN absorbs every subsequent fetch_add) and any
    /// `inf` input would saturate the counter, both of which violate
    /// the Prometheus monotonic-counter contract. Sound floor is
    /// "drop the bad sample" — exporters never emit corrupted values.
    public fn add(&self, v: Float) {
        if v.is_nan() || v.is_infinite() {
            return;
        }
        if v < 0.0 {
            panic("Counter.add: negative delta");
        }
        let _ = self.value.fetch_add(v, MemoryOrdering.Relaxed);
    }

    public fn value(&self) -> Float {
        self.value.load(MemoryOrdering.Relaxed)
    }
}

// =============================================================================
// UpDownCounter — bi-directional float (OTel-style)
// =============================================================================

public type UpDownCounter is {
    value: AtomicF64,
};

implement UpDownCounter {
    public fn new() -> UpDownCounter {
        UpDownCounter { value: AtomicF64.new(0.0) }
    }

    /// Add `v`. NaN / infinite inputs are silently dropped — see
    /// `Counter.add` for rationale.
    public fn add(&self, v: Float) {
        if v.is_nan() || v.is_infinite() {
            return;
        }
        let _ = self.value.fetch_add(v, MemoryOrdering.Relaxed);
    }

    /// Subtract `v`. NaN / infinite inputs are silently dropped.
    public fn sub(&self, v: Float) {
        if v.is_nan() || v.is_infinite() {
            return;
        }
        let _ = self.value.fetch_sub(v, MemoryOrdering.Relaxed);
    }

    public fn inc(&self) { self.add(1.0); }
    public fn dec(&self) { self.sub(1.0); }

    public fn value(&self) -> Float {
        self.value.load(MemoryOrdering.Relaxed)
    }
}

// =============================================================================
// Gauge — arbitrary settable float
// =============================================================================

public type Gauge is {
    value: AtomicF64,
};

implement Gauge {
    public fn new() -> Gauge {
        Gauge { value: AtomicF64.new(0.0) }
    }

    /// Set the gauge to `v`. NaN / infinite inputs are silently
    /// dropped — see `Counter.add` for rationale.
    public fn set(&self, v: Float) {
        if v.is_nan() || v.is_infinite() {
            return;
        }
        self.value.store(v, MemoryOrdering.Relaxed);
    }

    public fn inc(&self) { self.add(1.0); }
    public fn dec(&self) { self.sub(1.0); }

    public fn add(&self, v: Float) {
        if v.is_nan() || v.is_infinite() {
            return;
        }
        let _ = self.value.fetch_add(v, MemoryOrdering.Relaxed);
    }

    public fn sub(&self, v: Float) {
        if v.is_nan() || v.is_infinite() {
            return;
        }
        let _ = self.value.fetch_sub(v, MemoryOrdering.Relaxed);
    }

    public fn value(&self) -> Float {
        self.value.load(MemoryOrdering.Relaxed)
    }
}
