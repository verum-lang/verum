// =============================================================================
// system_time.vr - Wall-clock system time
// =============================================================================
// Layer: 3 (I/O adjacent)
// Dependencies: core, time/duration, sys/{linux,darwin,windows}/time
// =============================================================================
//

// # V-LLSI Migration Status
//

// Uses native platform wall-clock time instead of verum_runtime FFI:
// - Linux: clock_gettime(CLOCK_REALTIME) via sys/linux/time.realtime_nanos
// - macOS: clock_gettime(CLOCK_REALTIME) via sys/darwin/time.realtime_nanos
// - Windows: GetSystemTimePreciseAsFileTime() via sys/windows/time.realtime_nanos
//

// =============================================================================
//

// SystemTime represents wall-clock time, suitable for timestamps.
// Unlike Instant, SystemTime can go backwards (e.g., due to NTP sync).
//

// # Example
// ```verum
// let now = SystemTime.now();
// let epoch_secs = now.duration_since_epoch().as_secs();
// print(f"Unix timestamp: {epoch_secs}");
// ```
//

// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.time.system_time;
mount core.*;
mount time.duration.{Duration, NANOS_PER_SEC, NANOS_PER_MILLI, NANOS_PER_MICRO, MILLIS_PER_SEC};

// =============================================================================
// V-LLSI Native Time Imports
// =============================================================================
// Uses native platform syscalls instead of verum_runtime FFI.
// - Linux: clock_gettime(CLOCK_REALTIME)
// - macOS: clock_gettime(CLOCK_REALTIME)
// - Windows: GetSystemTimePreciseAsFileTime()
// =============================================================================

@cfg(target_os = "linux")
mount sys.linux.time.realtime_nanos;

@cfg(target_os = "macos")
mount sys.darwin.time.realtime_nanos;

@cfg(target_os = "windows")
mount sys.windows.time.realtime_nanos;

// =============================================================================
// SystemTime
// =============================================================================

/// Wall-clock time, represented as duration since Unix epoch.
///

/// SystemTime is suitable for:
/// - File timestamps
/// - Logging timestamps
/// - Formatting dates and times
///

/// **WARNING**: SystemTime can go backwards! Use Instant for measuring
/// elapsed time in performance-sensitive code.
///

/// # Example
/// ```verum
/// let now = SystemTime.now();
/// let since_epoch = now.duration_since_epoch();
/// print(f"Seconds since epoch: {since_epoch.as_secs()}");
/// ```
public type SystemTime is {
    /// Seconds since Unix epoch (1970-01-01 00:00:00 UTC)
    secs: Int,
    /// Additional nanoseconds [0, 999_999_999]
    nanos: Int,
};

implement SystemTime {
    /// The Unix epoch: January 1, 1970, 00:00:00 UTC.
    @inline(always)
    public fn UNIX_EPOCH() -> SystemTime {
        SystemTime { secs: 0, nanos: 0 }
    }

    /// Get the current system time.
    ///

    /// Uses native platform wall-clock time:
    /// - Linux: clock_gettime(CLOCK_REALTIME)
    /// - macOS: clock_gettime(CLOCK_REALTIME)
    /// - Windows: GetSystemTimePreciseAsFileTime()
    @inline(always)
    public fn now() -> SystemTime {
        let total_nanos = realtime_nanos() as Int;
        let secs = total_nanos / NANOS_PER_SEC;
        let nanos = total_nanos % NANOS_PER_SEC;
        SystemTime { secs: secs, nanos: nanos }
    }

    /// Get the duration since the Unix epoch.
    ///

    /// Returns None if the time is before the epoch (rare, but possible
    /// on misconfigured systems).
    @inline(always)
    public fn duration_since_epoch(&self) -> Duration {
        Duration.new(self.secs, self.nanos)
    }

    /// Get the duration since another system time.
    ///

    /// Returns:
    ///   - `Ok(d)` when `self` is later than `earlier` (or equal).
    ///   - `Err(WentBackwards(gap))` when `earlier` is later than `self`.
    ///   - `Err(Overflow)` when either secs value puts the nanosecond
    ///     product outside `Int64` range (year ≈ 2262 boundary).
    public fn duration_since(&self, earlier: &SystemTime) -> Result<Duration, SystemTimeError> {
        // Year-2262 overflow guard: `secs * NANOS_PER_SEC` must fit in Int64.
        // Int64.MAX / NANOS_PER_SEC ≈ 9_223_372_036.
        let max_safe_secs: Int = 9_223_372_036;
        if self.secs > max_safe_secs || self.secs < -max_safe_secs
            || earlier.secs > max_safe_secs || earlier.secs < -max_safe_secs {
            return Err(SystemTimeError.Overflow);
        }
        let self_nanos = self.secs * NANOS_PER_SEC + self.nanos;
        let earlier_nanos = earlier.secs * NANOS_PER_SEC + earlier.nanos;

        if self_nanos >= earlier_nanos {
            Ok(Duration.from_nanos(self_nanos - earlier_nanos))
        } else {
            Err(SystemTimeError.WentBackwards(Duration.from_nanos(earlier_nanos - self_nanos)))
        }
    }

    /// Get the elapsed time since this system time.
    ///

    /// May return an error if the system clock was adjusted backwards.
    public fn elapsed(&self) -> Result<Duration, SystemTimeError> {
        SystemTime.now().duration_since(self)
    }

    /// Add a duration to this time.
    public fn checked_add(&self, duration: Duration) -> Maybe<SystemTime> {
        let total_nanos = self.nanos + duration.subsec_nanos();
        let extra_secs = total_nanos / NANOS_PER_SEC;
        let remaining_nanos = total_nanos % NANOS_PER_SEC;

        let new_secs = self.secs + duration.as_secs() + extra_secs;
        if new_secs < self.secs {
            // Overflow
            None
        } else {
            Some(SystemTime { secs: new_secs, nanos: remaining_nanos })
        }
    }

    /// Subtract a duration from this time.
    public fn checked_sub(&self, duration: Duration) -> Maybe<SystemTime> {
        let total_nanos = self.secs * NANOS_PER_SEC + self.nanos;
        let dur_nanos = duration.as_nanos();

        if dur_nanos > total_nanos {
            None
        } else {
            let res_nanos = total_nanos - dur_nanos;
            Some(SystemTime {
                secs: res_nanos / NANOS_PER_SEC,
                nanos: res_nanos % NANOS_PER_SEC,
            })
        }
    }

    /// Get Unix timestamp in seconds.
    @inline(always)
    public fn timestamp(&self) -> Int {
        self.secs
    }

    /// Get Unix timestamp in milliseconds.
    @inline(always)
    public fn timestamp_millis(&self) -> Int {
        self.secs * MILLIS_PER_SEC + self.nanos / NANOS_PER_MILLI
    }

    /// Get Unix timestamp in nanoseconds.
    @inline(always)
    public fn timestamp_nanos(&self) -> Int {
        self.secs * NANOS_PER_SEC + self.nanos
    }

    /// Create from Unix timestamp in seconds.
    @inline(always)
    public fn from_timestamp(secs: Int) -> SystemTime {
        SystemTime { secs: secs, nanos: 0 }
    }

    /// Create from Unix timestamp in milliseconds.
    @inline(always)
    public fn from_timestamp_millis(ms: Int) -> SystemTime {
        SystemTime {
            secs: ms / MILLIS_PER_SEC,
            nanos: (ms % MILLIS_PER_SEC) * NANOS_PER_MILLI,
        }
    }
}

// =============================================================================
// SystemTimeError
// =============================================================================

/// Error returned when computing duration between system times.
///

/// `WentBackwards(d)` — `self` is earlier than the comparison instant by
/// magnitude `d` (sign reversed).  Carries the gap as a `Duration`.
///

/// `Overflow` — `secs * NANOS_PER_SEC + nanos` exceeds `Int64` range.
/// For practical wall-clock timestamps this happens only at `secs >=
/// 9_223_372_036` (year ≈ 2262); guards against corrupted-mtime / hostile
/// timestamp inputs that would otherwise wrap silently.  See
/// `audit.md §A`.
public type SystemTimeError is
    | WentBackwards(Duration)
    | Overflow;

implement SystemTimeError {
    /// Get the duration by which time went backwards.  Zero for `Overflow`.
    public fn duration(&self) -> Duration {
        match self {
            WentBackwards(d) => *d,
            Overflow => Duration.zero(),
        }
    }
}

implement Debug for SystemTimeError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            WentBackwards(d) => f.write_str(f"SystemTimeError.WentBackwards({d})"),
            Overflow => f.write_str("SystemTimeError.Overflow"),
        }
    }
}

implement Display for SystemTimeError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            WentBackwards(d) => f.write_str(f"system time went backwards by {d}"),
            Overflow => f.write_str("system time overflow (secs out of Int64 nanosecond range)"),
        }
    }
}

implement Eq for SystemTimeError {
    fn eq(&self, other: &SystemTimeError) -> Bool {
        match (self, other) {
            (SystemTimeError.WentBackwards(a), SystemTimeError.WentBackwards(b)) => a == b,
            (SystemTimeError.Overflow, SystemTimeError.Overflow) => true,
            _ => false,
        }
    }
}

// =============================================================================
// Operator Implementations
// =============================================================================

implement Add<Duration> for SystemTime {
    type Output = SystemTime;

    fn add(self, duration: Duration) -> SystemTime {
        self.checked_add(duration).expect("SystemTime overflow")
    }
}

implement Sub<Duration> for SystemTime {
    type Output = SystemTime;

    fn sub(self, duration: Duration) -> SystemTime {
        self.checked_sub(duration).expect("SystemTime underflow")
    }
}

// =============================================================================
// Comparison Implementations
// =============================================================================

implement Eq for SystemTime {
    fn eq(&self, other: &SystemTime) -> Bool {
        self.secs == other.secs && self.nanos == other.nanos
    }
}

implement Ord for SystemTime {
    fn cmp(&self, other: &SystemTime) -> Ordering {
        match self.secs.cmp(&other.secs) {
            Equal => self.nanos.cmp(&other.nanos),
            ord => ord,
        }
    }
}

implement PartialOrd for SystemTime {
    fn partial_cmp(&self, other: &SystemTime) -> Maybe<Ordering> {
        Some(self.cmp(other))
    }
}

// =============================================================================
// Other Implementations
// =============================================================================

implement Clone for SystemTime {
    fn clone(&self) -> SystemTime {
        SystemTime { secs: self.secs, nanos: self.nanos }
    }
}

implement Copy for SystemTime {}

implement Hash for SystemTime {
    fn hash<H: Hasher>(&self, hasher: &mut H) {
        self.secs.hash(hasher);
        self.nanos.hash(hasher);
    }
}

implement Debug for SystemTime {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"SystemTime {{ secs: {self.secs}, nanos: {self.nanos} }}")
    }
}

implement Display for SystemTime {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        // Display as Unix timestamp with subsecond precision
        let ms = self.nanos / NANOS_PER_MILLI;
        f.write_str(f"{self.secs}.{ms:03}s")
    }
}

// =============================================================================
// Module-level free function exports
// =============================================================================

/// Wall-clock timestamp in nanoseconds since the Unix epoch.
///

/// Convenience for `SystemTime.now().duration_since_epoch().as_nanos()`
/// without bringing the unit-marker `SystemTime` into scope.
///

/// **Range note**: returns a signed `Int` (Int64).  `secs * NANOS_PER_SEC`
/// overflows when `secs >= Int64.MAX / 1_000_000_000 ≈ 9.2e9` — corresponds
/// to year ≈ 2262.  Practical wall-clock timestamps are safely far below
/// this bound; only adversarial / corrupted mtime values would exercise
/// the overflow.  For overflow-safe arithmetic use
/// `SystemTime.duration_since(...)` which surfaces `SystemTimeError.Overflow`
/// on the boundary.
public fn now_unix_ns() -> Int {
    let st = SystemTime.now();
    st.secs * NANOS_PER_SEC + st.nanos
}

/// Wall-clock timestamp in microseconds since the Unix epoch.
public fn now_unix_us() -> Int {
    now_unix_ns() / NANOS_PER_MICRO
}

/// Wall-clock timestamp in milliseconds since the Unix epoch.
public fn now_unix_ms() -> Int {
    now_unix_ns() / NANOS_PER_MILLI
}

/// Wall-clock timestamp in seconds since the Unix epoch.
public fn now_unix_s() -> Int {
    SystemTime.now().secs
}


/// Convenience alias for `now_unix_s()` — wall-clock seconds since
/// Unix epoch.  Exists for callers that import `epoch_seconds`
/// (security/x509 / security/sigstore / storage/s3).
public fn epoch_seconds() -> Int {
    now_unix_s()
}

