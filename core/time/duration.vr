// =============================================================================
// duration.vr - Duration type
// =============================================================================
// Layer: 3 (I/O adjacent)
// Dependencies: core
// =============================================================================
//

// Duration represents a signed span of time stored as nanoseconds (Int64).
// It provides constructors for common time units and methods for conversion.
//
// Duration values can be negative — `Duration.secs(-1)` represents "one
// second backwards" relative to a reference instant.  This matches
// `Go time.Duration`, `Java java.time.Duration`, and `C++ chrono::duration`
// semantics, and aligns with the runtime intrinsic identity surface used
// by `time_duration_from_nanos` and friends.
//
// To clamp at zero use `Duration.saturating_sub` (returns zero on
// underflow), or the idiom `if d.as_nanos() < 0 { Duration.zero() } else { d }`.
//

// # Example
// ```verum
// let timeout = Duration.secs(30);
// let delay = Duration.millis(100);
// let combined = timeout + delay;
//

// print(f"Total: {combined.as_secs()} seconds");
// print(f"Total: {combined.as_millis()} milliseconds");
// ```
//

// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.time.duration;
mount core.*;
mount core.base.coercion.{IntCoercible, SizedNumeric};

// =============================================================================
// Constants
// =============================================================================

/// Nanoseconds per microsecond.
public const NANOS_PER_MICRO: Int = 1_000;

/// Nanoseconds per millisecond.
public const NANOS_PER_MILLI: Int = 1_000_000;

/// Nanoseconds per second.
public const NANOS_PER_SEC: Int = 1_000_000_000;

/// Nanoseconds per minute.
public const NANOS_PER_MIN: Int = 60_000_000_000;

/// Nanoseconds per hour.
public const NANOS_PER_HOUR: Int = 3_600_000_000_000;

/// Milliseconds per second.
public const MILLIS_PER_SEC: Int = 1_000;

/// Microseconds per second.
public const MICROS_PER_SEC: Int = 1_000_000;

// =============================================================================
// Duration
// =============================================================================

/// A signed time span in nanoseconds (Int64).
///

/// Negative durations represent past-relative spans (e.g.
/// `Duration.secs(-3600)` is "one hour before").  This matches
/// `Go time.Duration` / `Java Duration` / `C++ chrono::duration`
/// semantics and aligns with the runtime intrinsic identity surface
/// (`time_duration_from_nanos` etc. are pure identity / scale-multiply).
///

/// To clamp at zero use `saturating_sub` (returns zero on underflow), or
/// the idiom `if d.as_nanos() < 0 { Duration.zero() } else { d }`.
///

/// # Example
/// ```verum
/// let five_secs = Duration.secs(5);
/// let half_sec = Duration.millis(500);
/// let total = five_secs + half_sec; // 5.5 seconds
///

/// assert(total.as_millis() == 5500);
/// assert(total.as_secs() == 5); // truncated
///

/// let backwards = Duration.secs(1) - Duration.secs(5);
/// assert(backwards.as_secs() == -4);  // signed subtraction
/// ```
public type Duration is {
    /// Signed nanoseconds (Int64).
    nanos: Int,
};

implement Duration {
    // =========================================================================
    // Constructors
    // =========================================================================

    /// The maximum representable duration.
    @inline(always)
    public fn max_value() -> Duration {
        Duration { nanos: Int.max_value() }
    }

    /// Create a duration of zero.
    @inline(always)
    public fn zero() -> Duration {
        Duration { nanos: 0 }
    }

    /// Create a duration from nanoseconds (signed; negatives preserved).
    @inline(always)
    public fn nanos(n: Int) -> Duration {
        Duration { nanos: n }
    }

    /// Create a duration from nanoseconds (alias).
    @inline(always)
    public fn from_nanos(n: Int) -> Duration {
        Duration.nanos(n)
    }

    /// Create a duration from microseconds (signed).
    @inline(always)
    public fn micros(n: Int) -> Duration {
        Duration { nanos: n * NANOS_PER_MICRO }
    }

    /// Create a duration from microseconds (alias).
    @inline(always)
    public fn from_micros(n: Int) -> Duration {
        Duration.micros(n)
    }

    /// Create a duration from milliseconds (signed).
    @inline(always)
    public fn millis(n: Int) -> Duration {
        Duration { nanos: n * NANOS_PER_MILLI }
    }

    /// Create a duration from milliseconds (alias).
    @inline(always)
    public fn from_millis(n: Int) -> Duration {
        Duration.millis(n)
    }

    /// Create a duration from seconds (signed).
    @inline(always)
    public fn secs(n: Int) -> Duration {
        Duration { nanos: n * NANOS_PER_SEC }
    }

    /// Create a duration from seconds (alias).
    @inline(always)
    public fn from_secs(n: Int) -> Duration {
        Duration.secs(n)
    }

    /// Create a duration from a floating-point number of seconds (signed).
    ///

    /// Converts fractional seconds to nanosecond precision.  Negative
    /// inputs preserved; underlying `as Int` truncates toward zero.
    public fn from_secs_f64(secs: Float) -> Duration {
        let whole_secs: Int = secs as Int;
        let frac: Float = secs - (whole_secs as Float);
        let nanos: Int = (frac * (NANOS_PER_SEC as Float)) as Int;
        Duration { nanos: whole_secs * NANOS_PER_SEC + nanos }
    }

    /// Create a duration from seconds && nanoseconds (signed).
    @inline(always)
    public fn new(secs: Int, nanos: Int) -> Duration {
        Duration { nanos: secs * NANOS_PER_SEC + nanos }
    }

    /// Create a duration from minutes (signed).
    @inline(always)
    public fn mins(n: Int) -> Duration {
        Duration { nanos: n * NANOS_PER_MIN }
    }

    /// Create a duration from hours (signed).
    @inline(always)
    public fn hours(n: Int) -> Duration {
        Duration { nanos: n * NANOS_PER_HOUR }
    }

    /// Create a duration from minutes (alias for `Duration.mins`).
    @inline(always)
    public fn from_minutes(n: Int) -> Duration {
        Duration.mins(n)
    }

    /// Create a duration from hours (alias for `Duration.hours`).
    @inline(always)
    public fn from_hours(n: Int) -> Duration {
        Duration.hours(n)
    }

    /// Create a duration from days (signed).
    @inline(always)
    public fn from_days(n: Int) -> Duration {
        Duration { nanos: n * NANOS_PER_HOUR * 24 }
    }

    /// Create a duration from weeks (signed).
    @inline(always)
    public fn from_weeks(n: Int) -> Duration {
        Duration { nanos: n * NANOS_PER_HOUR * 24 * 7 }
    }

    // =========================================================================
    // Accessors
    // =========================================================================

    /// Get total nanoseconds.
    @inline(always)
    public fn as_nanos(&self) -> Int {
        self.nanos
    }

    /// Get total microseconds (truncated).
    @inline(always)
    public fn as_micros(&self) -> Int {
        self.nanos / NANOS_PER_MICRO
    }

    /// Get total milliseconds (truncated).
    @inline(always)
    public fn as_millis(&self) -> Int {
        self.nanos / NANOS_PER_MILLI
    }

    /// Get total seconds (truncated).
    @inline(always)
    public fn as_secs(&self) -> Int {
        self.nanos / NANOS_PER_SEC
    }

    /// Get the fractional seconds part as nanoseconds.
    ///

    /// This is the nanoseconds remaining after whole seconds are removed.
    /// Always in range [0, 999_999_999].
    @inline(always)
    public fn subsec_nanos(&self) -> Int {
        self.nanos % NANOS_PER_SEC
    }

    /// Get the fractional seconds part as microseconds.
    @inline(always)
    public fn subsec_micros(&self) -> Int {
        (self.nanos % NANOS_PER_SEC) / NANOS_PER_MICRO
    }

    /// Get the fractional seconds part as milliseconds.
    @inline(always)
    public fn subsec_millis(&self) -> Int {
        (self.nanos % NANOS_PER_SEC) / NANOS_PER_MILLI
    }

    /// Get total seconds as floating point.
    @inline(always)
    public fn as_secs_f64(&self) -> Float {
        (self.nanos as Float) / (NANOS_PER_SEC as Float)
    }

    // =========================================================================
    // Predicates
    // =========================================================================

    /// Check if this duration is zero.
    @inline(always)
    public fn is_zero(&self) -> Bool {
        self.nanos == 0
    }

    // =========================================================================
    // Arithmetic
    // =========================================================================

    /// Checked addition.  Returns None on Int64 overflow.
    ///

    /// Detects signed-overflow via sign-flip: if both operands have the
    /// same sign and the result has the opposite sign, overflow has
    /// occurred.  Returns the wrapped sum otherwise.
    public fn checked_add(&self, other: Duration) -> Maybe<Duration> {
        let res = self.nanos + other.nanos;
        // Signed overflow detection: same-sign inputs producing wrong-sign result.
        let same_sign = (self.nanos < 0) == (other.nanos < 0);
        let sign_flipped = (res < 0) != (self.nanos < 0);
        if same_sign && sign_flipped {
            None
        } else {
            Some(Duration { nanos: res })
        }
    }

    /// Saturating addition.  Clamps to `Int.max_value()` / `Int.min_value()`
    /// on overflow / underflow rather than wrapping.
    public fn saturating_add(&self, other: Duration) -> Duration {
        match self.checked_add(other) {
            Some(d) => d,
            None => {
                // Saturate at MAX if operands were both positive, MIN otherwise.
                if self.nanos >= 0 {
                    Duration { nanos: Int.max_value() }
                } else {
                    Duration { nanos: Int.min_value() }
                }
            },
        }
    }

    /// Checked subtraction.  Returns None on Int64 underflow.
    ///

    /// Detects signed-underflow via sign-flip rule for `a - b == a + (-b)`.
    /// Preserves negative results (Duration is signed; see top of module).
    public fn checked_sub(&self, other: Duration) -> Maybe<Duration> {
        let res = self.nanos - other.nanos;
        // Signed subtraction overflow: opposite-sign inputs producing wrong-sign result.
        let opposite_sign = (self.nanos < 0) != (other.nanos < 0);
        let sign_flipped = (res < 0) != (self.nanos < 0);
        if opposite_sign && sign_flipped {
            None
        } else {
            Some(Duration { nanos: res })
        }
    }

    /// Saturating subtraction.  Clamps at `Duration.zero()` when the
    /// result would be negative — preserves the legacy "floor at zero"
    /// behaviour from the non-negative-Duration era, useful for timers
    /// counting down toward a deadline that cannot represent "elapsed
    /// past the deadline" as a negative span.
    ///

    /// Use plain `-` for signed subtraction; use this for clamp-to-zero
    /// timer semantics.
    public fn saturating_sub(&self, other: Duration) -> Duration {
        match self.checked_sub(other) {
            Some(d) => {
                if d.nanos < 0 { Duration.zero() } else { d }
            },
            None => {
                // Underflow at Int.min_value boundary → saturate at zero
                // for consistency with the "timer floor" semantic.
                Duration.zero()
            },
        }
    }

    /// Checked multiplication.  Returns None on Int64 overflow.
    ///

    /// Allows negative scalar (Duration is signed); detects overflow
    /// by re-deriving the divisor.
    public fn checked_mul(&self, rhs: Int) -> Maybe<Duration> {
        if rhs == 0 || self.nanos == 0 {
            return Some(Duration.zero());
        }
        let res = self.nanos * rhs;
        // Overflow check: if res / rhs != self.nanos, overflow occurred.
        if res / rhs != self.nanos {
            None
        } else {
            Some(Duration { nanos: res })
        }
    }

    /// Saturating multiplication.
    public fn saturating_mul(&self, rhs: Int) -> Duration {
        match self.checked_mul(rhs) {
            Some(d) => d,
            None => {
                // Saturate at MAX or MIN depending on product sign.
                let sign_negative = (self.nanos < 0) != (rhs < 0);
                if sign_negative {
                    Duration { nanos: Int.min_value() }
                } else {
                    Duration { nanos: Int.max_value() }
                }
            },
        }
    }

    /// Checked division.  Returns None if rhs is zero.
    public fn checked_div(&self, rhs: Int) -> Maybe<Duration> {
        if rhs == 0 {
            None
        } else {
            Some(Duration { nanos: self.nanos / rhs })
        }
    }
}

// =============================================================================
// Operator Implementations
// =============================================================================

implement Add for Duration {
    type Output = Duration;

    fn add(self, other: Duration) -> Duration {
        // Typed-local extraction pattern (see Sub impl) — forces
        // BinaryIntOp::Add over the field arithmetic.  Without it,
        // the codegen has historically dispatched Duration+Duration via
        // Float addition, producing NaN-boxed payloads.  This is
        // routed via the `time_duration_add` intrinsic at Tier 0, but
        // the Verum body is the AOT fallback; keep both safe.
        let a_ns: Int = self.nanos;
        let b_ns: Int = other.nanos;
        let sum_ns: Int = a_ns + b_ns;
        Duration { nanos: sum_ns }
    }
}

implement Sub for Duration {
    type Output = Duration;

    fn sub(self, other: Duration) -> Duration {
        // Signed subtraction — preserves negative results.  Use
        // `saturating_sub` if you need clamp-to-zero semantics.
        //
        // Typed-local extraction pattern: the codegen path for
        // `Duration - Duration` previously dispatched via Float subtraction
        // (the SizedNumeric/IntCoercible lattice misroute) which produced
        // NaN-boxed payloads when both operands were Int-tagged.  The
        // pre-fix `.max(0)` clamp inadvertently masked NaN→0; removing
        // it exposed the underlying codegen defect.  Loading the fields
        // into typed Int locals before the arithmetic forces the
        // BinaryIntOp::Sub path.  Same workaround pattern as
        // `core/base/iterator.vr` Range<Int>::next.
        let a_ns: Int = self.nanos;
        let b_ns: Int = other.nanos;
        let diff_ns: Int = a_ns - b_ns;
        Duration { nanos: diff_ns }
    }
}

implement Mul<Int> for Duration {
    type Output = Duration;

    fn mul(self, rhs: Int) -> Duration {
        // Signed multiplication — negative scalar produces a signed
        // (past-relative) Duration.
        let a_ns: Int = self.nanos;
        let res_ns: Int = a_ns * rhs;
        Duration { nanos: res_ns }
    }
}

implement Div<Int> for Duration {
    type Output = Duration;

    fn div(self, rhs: Int) -> Duration {
        // Signed division — rhs must be non-zero.  Negative divisors
        // produce sign-flipped Duration results.
        assert(rhs != 0, "Duration division by zero");
        let a_ns: Int = self.nanos;
        let res_ns: Int = a_ns / rhs;
        Duration { nanos: res_ns }
    }
}

// =============================================================================
// Comparison Implementations
// =============================================================================

implement Eq for Duration {
    fn eq(&self, other: &Duration) -> Bool {
        self.nanos == other.nanos
    }
}

implement Ord for Duration {
    fn cmp(&self, other: &Duration) -> Ordering {
        self.nanos.cmp(&other.nanos)
    }
}

implement PartialOrd for Duration {
    fn partial_cmp(&self, other: &Duration) -> Maybe<Ordering> {
        Some(self.cmp(other))
    }
}

// =============================================================================
// Other Implementations
// =============================================================================

implement Default for Duration {
    fn default() -> Duration {
        Duration.zero()
    }
}

implement Clone for Duration {
    fn clone(&self) -> Duration {
        Duration { nanos: self.nanos }
    }
}

implement Copy for Duration {}

// IntCoercible (core.base.coercion) — Duration carries an Int-encoded
// nanosecond count, so the unifier should accept Duration ↔ Int
// bidirectional coercion in arithmetic / comparison contexts. Marker
// protocol with no methods; the implementation block alone signals
// the intent to the compiler.
implement IntCoercible for Duration {}

// SizedNumeric (core.base.coercion) — Duration sits in the
// cross-coercion lattice with the language's sized-numeric
// primitives: a `Duration` value coerces with `Int64` /
// `UInt64` / `USize` for nanosecond-bound APIs, and with
// `Instant` (the other stdlib sized-numeric) for elapsed-time
// arithmetic.  The marker eliminates the previous hardcoded
// fallback at `verum_compiler::stdlib_coercion_registry::
// SIZED_NUMERIC_STDLIB_NAMES`.
implement SizedNumeric for Duration {}

implement Hash for Duration {
    fn hash<H: Hasher>(&self, hasher: &mut H) {
        self.nanos.hash(hasher);
    }
}

implement Debug for Duration {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        let secs = self.as_secs();
        let subsec_nanos = self.subsec_nanos();

        if secs == 0 {
            if subsec_nanos == 0 {
                f.write_str("0ns")
            } else if subsec_nanos < NANOS_PER_MICRO {
                f.write_str(f"{subsec_nanos}ns")
            } else if subsec_nanos < NANOS_PER_MILLI {
                f.write_str(f"{subsec_nanos / NANOS_PER_MICRO}µs")
            } else {
                f.write_str(f"{subsec_nanos / NANOS_PER_MILLI}ms")
            }
        } else {
            if subsec_nanos == 0 {
                f.write_str(f"{secs}s")
            } else {
                let ms = subsec_nanos / NANOS_PER_MILLI;
                f.write_str(f"{secs}.{ms:03}s")
            }
        }
    }
}

implement Display for Duration {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        self.fmt_debug(f)
    }
}
