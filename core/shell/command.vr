// =============================================================================
// shell/command.vr ‚Äî ShellCommand: typed surface of `sh#"..."` literals
// =============================================================================
// Layer: 5 (Shell)
// Dependencies: core, shell.{exec, result, context}, async.cancellation
// =============================================================================
//
// `ShellCommand` is the materialised type of `sh#"..."` tagged literals. The
// type-inference layer (verum_types::infer) maps every `sh` tag to
// `ShellCommand`; the macro-expansion layer lowers the literal into a
// `ShellCommand { text: <concat> }` constructor. Together they give the
// surface its load-bearing semantics:
//
//   1. Constructing a `ShellCommand` does NOT execute anything ‚Äî it just
//      captures the (auto-escaped) text that will be passed to `sh()`.
//   2. Executing happens through `cmd.run().await` (or the explicit
//      `cmd.run_check().await` / `cmd.run_with_cancel(token).await` /
//      `cmd.run_streaming().await` variants).
//   3. The pipeline algebra (`|>`) plus `.pipe_to()` composes commands at
//      the shell layer (`a | b`) without re-spawning intermediate shells ‚Äî
//      the joined text is a single `<shell> -c "<a> | <b>"` invocation.
//   4. Mutation methods (`with_env`, `with_cwd`, `with_stdin`) return new
//      `ShellCommand` instances; the type is value-semantic and Clone.
//
// The pre-fix state of the world: `sh` tag mapped to `ShellCommand` in the
// type inferencer but NO `ShellCommand` type was declared anywhere in core/
// shell, so every script using `sh#"..."` literals had a phantom type whose
// methods could never be called. Closes that architectural gap.
// =============================================================================

module command;

mount core.{Text, Result};
mount core.base.protocols.{Display, Debug, Clone};
mount core.shell.result.{ShellResult, ShellError};
mount core.shell.context.{ShellContext};
mount core.shell.stream.{StreamConfig, LineStream};
mount core.async.cancellation.{CancellationToken};
mount core.time.duration.{Duration};

// =============================================================================
// ShellCommand ‚Äî captured-but-unexecuted shell command
// =============================================================================

/// `ShellCommand` ‚Äî the canonical surface returned by `sh#"..."` literals.
///
/// Captures the FINAL text that would be passed to `<shell> -c "<text>"`:
/// every `${expr}` interpolation in the source literal has already been
/// auto-escaped via `ShellEscape` at lowering time, so the contained text
/// is shell-safe by construction. There is no escape-check at execution
/// time ‚Äî that boundary was crossed when the literal was parsed.
///
/// Use:
///
/// ```verum
/// let cmd: ShellCommand = sh#"echo hello, ${name}";
/// let result = cmd.run().await;
/// ```
@derive(Clone)
public type ShellCommand is {
    /// The fully-escaped command text ready for `<shell> -c "<text>"`.
    /// Constructed by macro-expansion of `sh#"..."` literals; should not
    /// be mutated post-construction by user code (the auto-escape
    /// invariant would no longer hold).
    text: Text,
};

implement ShellCommand {
    /// Construct a `ShellCommand` from a raw, already-escaped text.
    /// Intended for macro-expansion lowering of `sh#"..."` literals
    /// AND for the rare use-case of building a command from a Verum-
    /// computed text where the caller has already validated the
    /// content (e.g. concatenating two trusted ShellCommand texts via
    /// `pipe_to`). User scripts should prefer `sh#"..."` literals
    /// because their auto-escape is type-safe by construction.
    public fn new(text: Text) -> ShellCommand {
        ShellCommand { text: text }
    }

    /// Returns the underlying text (for diagnostics / logging only ‚Äî
    /// the text is auto-escaped, so it's NOT a sensible thing to
    /// re-execute outside the shell-dispatch path).
    public fn as_text(&self) -> &Text {
        &self.text
    }

    /// Execute the command through `<shell> -c "<text>"` and return the
    /// `ShellResult` regardless of exit status. Failures (spawn errors,
    /// non-zero exits, signals) surface in the result; call `.ok()?` to
    /// convert to a `Result`.
    ///
    /// Honours the active `ShellContext` for cwd, env, mock, permissions.
    public async fn run(&self) -> ShellResult {
        core.shell.exec.sh(&self.text).await
    }

    /// Like `run()` but returns `Result<ShellResult, ShellError>` so the
    /// `?` operator works at the call site:
    ///
    /// ```verum
    /// let r: ShellResult = sh#"echo ${msg}".run_check().await?;
    /// ```
    public async fn run_check(&self) -> Result<ShellResult, ShellError> {
        core.shell.exec.sh_check(&self.text).await
    }

    /// Run with a `CancellationToken` ‚Äî when the token fires, the
    /// child process receives SIGTERM (graceful) and after the
    /// `grace` period (default 5s) SIGKILL (forced).
    ///
    /// Returns `Ok(ShellResult)` on normal completion, `Err(Cancelled
    /// { reason })` if the token fired before the child exited, or
    /// `Err(SpawnFailed)` if the child couldn't even start. The
    /// returned signature matches `sh_with_cancel` 1:1 so the `?`
    /// operator threads cleanly:
    ///
    /// ```verum
    /// let token = CancellationToken.new();
    /// let result = sh#"sleep 60"
    ///     .run_with_cancel(&token, Duration.from_secs(2))
    ///     .await?;
    /// ```
    ///
    /// Pass `Duration.from_millis(0)` for the default 5-second
    /// grace period; pass any positive duration to override.
    public async fn run_with_cancel(
        &self,
        token: &CancellationToken,
        grace: Duration,
    ) -> Result<ShellResult, ShellError> {
        core.shell.exec.sh_with_cancel(&self.text, token, grace).await
    }

    /// Convenience wrapper: cancel after a wall-clock timeout.
    /// Constructs a fresh `CancellationToken.with_timeout(after)`
    /// and forwards through `run_with_cancel`. Default grace
    /// (5s) is used for the SIGTERM-to-SIGKILL window.
    ///
    /// ```verum
    /// // Hard kill after 30s if not done.
    /// let r = sh#"./long-running-script.sh"
    ///     .run_with_timeout(Duration.from_secs(30))
    ///     .await;
    /// ```
    public async fn run_with_timeout(
        &self,
        after: Duration,
    ) -> Result<ShellResult, ShellError> {
        let token = CancellationToken.with_timeout(after);
        self.run_with_cancel(&token, Duration.from_millis(0)).await
    }

    /// Stream stdout LINE-BY-LINE as an async generator.  Each yield is
    /// `Result<Text, ShellError>` carrying one line (newline stripped).
    /// Use with `for await` for ergonomic consumption:
    ///
    /// ```verum
    /// for await line in sh#"git log --oneline".stream_lines() {
    ///     match line {
    ///         Ok(text) => print(&text),
    ///         Err(e)   => eprintln(f"stream error: {e}"),
    ///     }
    /// }
    /// ```
    ///
    /// Backpressure: relies on the kernel pipe buffer.  For
    /// fast-producer / slow-consumer scenarios prefer
    /// `stream_lines_bounded(config)` which adds an explicit channel
    /// + cancellation surface.  Forwards to `core.shell.stream.
    /// stream_lines` ‚Äî same auto-escape invariant: `self.text` is
    /// shell-safe by construction.
    public async fn* stream_lines(&self) -> Result<Text, ShellError> {
        for await line in core.shell.stream.stream_lines(&self.text) {
            yield line;
        }
    }

    /// Stream stdout line-by-line through a BOUNDED channel with
    /// explicit cancellation handle.  The returned `LineStream`
    /// carries:
    ///
    ///   * `receiver: Receiver<Result<Text, ShellError>>` ‚Äî the
    ///     consumer endpoint with bounded backpressure
    ///   * `job: Job` ‚Äî the spawned producer task; `job.kill()`
    ///     terminates the child process AND closes the channel
    ///
    /// Use this variant when:
    ///   * the producer is much faster than the consumer (e.g.
    ///     `cat huge.log` piped to a slow downstream parser);
    ///   * you need to `select!` over multiple streams;
    ///   * you need to cancel the producer on a timeout / signal.
    ///
    /// ```verum
    /// let stream = sh#"tail -F /var/log/syslog"
    ///     .stream_lines_bounded(StreamConfig.default()).await?;
    /// // ... consume from stream.receiver ...
    /// stream.job.kill();
    /// ```
    public async fn stream_lines_bounded(
        &self,
        config: StreamConfig,
    ) -> Result<LineStream, ShellError> {
        core.shell.stream.stream_lines_bounded(&self.text, config).await
    }

    /// Compose two commands as a shell pipeline: `self | other`. The
    /// joined command runs as a single `<shell> -c "<a> | <b>"`
    /// invocation ‚Äî no intermediate shell process. Both `self.text`
    /// and `other.text` are already auto-escaped by their respective
    /// `sh#"..."` literals, so the concatenation is shell-safe.
    ///
    /// ```verum
    /// let lines = sh#"git log --oneline".pipe_to(sh#"head -n 10").run().await;
    /// ```
    public fn pipe_to(self, other: ShellCommand) -> ShellCommand {
        ShellCommand {
            text: self.text.concat(" | ").concat(other.text),
        }
    }

    /// Append a stderr-redirect-to-stdout suffix (`2>&1`). The combined
    /// stream lands in `ShellResult.stdout` for downstream consumption.
    public fn merge_stderr(self) -> ShellCommand {
        ShellCommand {
            text: self.text.concat(" 2>&1"),
        }
    }

    /// Append a stdout-redirect-to-file suffix (`> path`). The path
    /// MUST be auto-escaped by the caller ‚Äî most ergonomically by
    /// constructing through a `sh#"..."` literal that includes the
    /// redirect, OR by composing two `ShellCommand`s via `pipe_to`.
    public fn redirect_stdout(self, path: Text) -> ShellCommand {
        ShellCommand {
            text: self.text.concat(" > ").concat(path),
        }
    }
}

// =============================================================================
// Display / Debug
// =============================================================================

implement Display for ShellCommand {
    /// Renders the captured text verbatim ‚Äî useful for diagnostic
    /// `print!("{}", cmd)` calls.
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(self.text.as_str())
    }
}

implement Debug for ShellCommand {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("ShellCommand { text: ")?;
        f.write_str(self.text.as_str())?;
        f.write_str(" }")
    }
}
