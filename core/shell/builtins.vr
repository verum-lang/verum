// =============================================================================
// shell/builtins.vr — Cross-platform built-in shell utilities
// =============================================================================
// Layer: 5 (Shell)
// Dependencies: core, io.fs, base.env, shell.{result, context}
// =============================================================================
//
// Pure-Verum implementations of common shell utilities. Avoids spawning
// `cp`/`mv`/`rm` on every call (which would cost ~2 ms per spawn on Unix
// and ~3 ms on Windows) and works identically across platforms.
//
// All functions are `using [ShellContext]` so cwd / env overrides apply
// transparently to relative paths.
//
// =============================================================================

module builtins;

mount core.{Maybe, Result, List, Text, Byte, Bool, Int};
mount core.base.env.{var_opt as env_var_opt, temp_dir as host_temp_dir, args, exit};
mount core.io.path.{Path, PathBuf};
mount core.io.fs.{
    metadata as fs_metadata,
    Metadata,
    create_dir as fs_create_dir,
    create_dir_all as fs_create_dir_all,
    remove_dir as fs_remove_dir,
    remove_dir_all as fs_remove_dir_all,
    read_dir as fs_read_dir,
    remove_file as fs_remove_file,
    rename as fs_rename,
    copy as fs_copy,
    read as fs_read,
    read_to_string as fs_read_to_string,
    write as fs_write,
    write_str as fs_write_str,
    IoResult, IoError,
};
mount core.shell.context.{ShellContext};
mount core.shell.result.{ShellError};

// =============================================================================
// File operations — all return Result<…, ShellError> for uniform error model
// =============================================================================

/// Copy a file. Overwrites destination if it exists.
public fn cp(from: &Path, to: &Path) -> Result<Int, ShellError> {
    fs_copy(from, to).map_err(|io| ShellError.SpawnFailed {
        command: f"cp {from:?} {to:?}",
        reason:  f"{io:?}",
    })
}

/// Move/rename. Atomic on the same volume, falls back to copy+delete across volumes.
public fn mv(from: &Path, to: &Path) -> Result<(), ShellError> {
    match fs_rename(from, to) {
        Ok(_)  => Ok(()),
        Err(_) => {
            let _ = cp(from, to)?;
            fs_remove_file(from).map_err(|io| ShellError.SpawnFailed {
                command: f"mv {from:?} {to:?}",
                reason:  f"{io:?}",
            })
        }
    }
}

/// Remove a single file.
public fn rm(path: &Path) -> Result<(), ShellError> {
    fs_remove_file(path).map_err(|io| ShellError.SpawnFailed {
        command: f"rm {path:?}",
        reason:  f"{io:?}",
    })
}

/// Recursive remove — directory and all its contents. Equivalent to `rm -rf`.
public fn rm_rf(path: &Path) -> Result<(), ShellError> {
    match fs_metadata(path) {
        Ok(m) if m.is_dir() =>
            fs_remove_dir_all(path).map_err(|io| ShellError.SpawnFailed {
                command: f"rm -rf {path:?}",
                reason:  f"{io:?}",
            }),
        Ok(_) => rm(path),
        Err(_) => Ok(()),  // already gone
    }
}

/// Create directory. Errors if it already exists.
public fn mkdir(path: &Path) -> Result<(), ShellError> {
    fs_create_dir(path).map_err(|io| ShellError.SpawnFailed {
        command: f"mkdir {path:?}",
        reason:  f"{io:?}",
    })
}

/// Create directory and all missing parents (mkdir -p).
public fn mkdir_p(path: &Path) -> Result<(), ShellError> {
    fs_create_dir_all(path).map_err(|io| ShellError.SpawnFailed {
        command: f"mkdir -p {path:?}",
        reason:  f"{io:?}",
    })
}

/// Read entire file as bytes.
public fn cat_bytes(path: &Path) -> Result<List<Byte>, ShellError> {
    fs_read(path).map_err(|io| ShellError.SpawnFailed {
        command: f"cat {path:?}",
        reason:  f"{io:?}",
    })
}

/// Read entire file as Text (UTF-8). Errors on invalid UTF-8.
public fn cat(path: &Path) -> Result<Text, ShellError> {
    fs_read_to_string(path).map_err(|io| ShellError.SpawnFailed {
        command: f"cat {path:?}",
        reason:  f"{io:?}",
    })
}

/// Write bytes — overwrites.
public fn write(path: &Path, content: &[Byte]) -> Result<(), ShellError> {
    fs_write(path, content).map_err(|io| ShellError.SpawnFailed {
        command: f"write {path:?}",
        reason:  f"{io:?}",
    })
}

/// Write text — overwrites.
public fn write_str(path: &Path, content: &Text) -> Result<(), ShellError> {
    fs_write_str(path, content).map_err(|io| ShellError.SpawnFailed {
        command: f"write_str {path:?}",
        reason:  f"{io:?}",
    })
}

/// Append bytes to a file (creates if missing).
public fn append(path: &Path, content: &[Byte]) -> Result<(), ShellError> {
    let mut existing: List<Byte> = match fs_read(path) {
        Ok(v) => v,
        Err(_) => [],  // file may not exist yet
    };
    for b in content.iter() { existing.push(*b); }
    fs_write(path, &existing).map_err(|io| ShellError.SpawnFailed {
        command: f"append {path:?}",
        reason:  f"{io:?}",
    })
}

// =============================================================================
// Filesystem queries
// =============================================================================

public fn path_exists(path: &Path) -> Bool {
    fs_metadata(path).is_ok()
}

public fn is_file(path: &Path) -> Bool {
    match fs_metadata(path) { Ok(m) => m.is_file(), Err(_) => false }
}

public fn is_dir(path: &Path) -> Bool {
    match fs_metadata(path) { Ok(m) => m.is_dir(), Err(_) => false }
}

/// Locate a program in PATH (cross-platform `which`).
/// Returns the absolute path of the first match or None.
public fn which(program: &Text) -> Maybe<PathBuf> {
    let path_var = match env_var_opt(&"PATH".into()) {
        Some(p) => p,
        None    => return None,
    };
    let separator: Char = path_separator();
    for entry in path_var.split(separator) {
        let mut candidate = PathBuf.from(entry);
        candidate.push(&PathBuf.from(program));
        // On Windows also check .exe / .cmd / .bat suffixes
        @cfg(target_os = "windows") {
            let suffixes: List<Text> = [".exe".into(), ".cmd".into(), ".bat".into()];
            for suffix in suffixes.iter() {
                let mut with_suf = candidate.clone();
                with_suf.set_extension(suffix.trim_start_matches('.'));
                if is_file(with_suf.as_path()) { return Some(with_suf); }
            }
        }
        if is_file(candidate.as_path()) { return Some(candidate); }
    }
    None
}

/// Ergonomic wrapper: returns true iff the program exists in PATH.
public fn command_exists(program: &Text) -> Bool {
    which(program).is_some()
}

// =============================================================================
// Temp dir / file helpers
// =============================================================================

public fn temp_dir() -> PathBuf {
    PathBuf.from(host_temp_dir())
}

/// Convenience that re-exports `core.shell.resources.TempFile.new()`
/// without callers needing to import resources.
public fn temp_file() -> Result<core.shell.resources.TempFile, ShellError> {
    core.shell.resources.TempFile.new()
}

@cfg(target_os = "windows")
fn path_separator() -> Char { ';' }

@cfg(any(target_os = "linux", target_os = "macos"))
fn path_separator() -> Char { ':' }
