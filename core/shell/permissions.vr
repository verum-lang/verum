// =============================================================================
// shell/permissions.vr — Capability gate (extension of shell.context.PermissionSet)
// =============================================================================
// Layer: 5 (Shell)
// Dependencies: core, io.path, base.glob, shell.{context, result}
// =============================================================================
//
// Extension API for `PermissionSet` providing path/host matching with glob
// semantics. The base `PermissionSet` (in `shell.context`) carries the
// allow-lists; this module adds:
//
//   * `check_fs_read` / `check_fs_write` — canonicalise the requested path
//     and prefix-match against the allow-list (each entry interpreted as
//     a glob pattern).
//   * `check_net` — match host:port against the `net` list, supporting
//     plain hostnames, wildcards (*.example.com) and CIDRs.
//   * `check_env` — exact-match for env-var read/write capability.
//   * Frontmatter parser for `// !@permission(...)` blocks.
//
// =============================================================================

module permissions;

mount core.{Maybe, Result, List, Text, Byte, Bool, Int};
mount core.base.glob.{GlobPattern, compile as glob_compile};
mount core.intrinsics.bitwise.{bitand, bitor, shl, shr};
mount core.io.path.{Path, PathBuf};
mount core.io.fs.{current_dir as fs_current_dir};
mount core.shell.context.{PermissionSet};
mount core.shell.result.{ShellError};

// =============================================================================
// Path checks — read / write
// =============================================================================

implement PermissionSet {
    /// Validate that `path` is permitted for read access.
    public fn check_fs_read(&self, path: &Path) -> Result<(), ShellError> {
        check_path(&self.fs_read, path, "fs_read")
    }

    /// Validate that `path` is permitted for write access.
    public fn check_fs_write(&self, path: &Path) -> Result<(), ShellError> {
        check_path(&self.fs_write, path, "fs_write")
    }

    /// Validate that `host:port` is permitted for outbound network.
    /// `port` may be 0 to skip port matching.
    public fn check_net(&self, host: &Text, port: Int) -> Result<(), ShellError> {
        match &self.net {
            None => Ok(()),
            Some(allowed) => {
                for pat in allowed.iter() {
                    if host_matches(pat, host, port) { return Ok(()); }
                }
                Err(ShellError.PermissionDenied {
                    command: f"net({host}:{port})",
                    kind:    "net".into(),
                })
            }
        }
    }

    /// Validate env-var read/write access by name.
    public fn check_env(&self, name: &Text) -> Result<(), ShellError> {
        match &self.env {
            None => Ok(()),
            Some(allowed) => {
                for n in allowed.iter() {
                    if n == name { return Ok(()); }
                }
                Err(ShellError.PermissionDenied {
                    command: f"env({name})",
                    kind:    "env".into(),
                })
            }
        }
    }
}

fn check_path(
    allowed: &Maybe<List<Text>>,
    path:    &Path,
    kind:    &str,
) -> Result<(), ShellError> {
    match allowed {
        None => Ok(()),
        Some(rules) => {
            let canonical = canonicalise(path);
            for pat_str in rules.iter() {
                if path_matches(pat_str, &canonical) { return Ok(()); }
            }
            Err(ShellError.PermissionDenied {
                command: f"{kind}({path:?})",
                kind:    kind.into(),
            })
        }
    }
}

fn canonicalise(path: &Path) -> Text {
    // Best-effort: prepend cwd if the path is relative. Avoids symlink
    // resolution to keep the check deterministic and side-effect-free.
    let p = path.to_text();
    if p.starts_with("/") || p.starts_with("\\") || (p.len() >= 2 && p.byte_at(1) == (':' as Byte)) {
        return p;
    }
    match fs_current_dir() {
        Ok(cwd) => f"{cwd:?}/{p}",
        Err(_)  => p,
    }
}

fn path_matches(pattern: &Text, path: &Text) -> Bool {
    // 1. Exact prefix match
    if path.starts_with(pattern) { return true; }
    // 2. Glob match (supports ** for recursive any-directory, * within component)
    match glob_compile(pattern.as_str()) {
        Ok(g)  => g.matches_path(path.as_str()),
        Err(_) => false,
    }
}

fn host_matches(pattern: &Text, host: &Text, port: Int) -> Bool {
    // pattern forms (in dispatch order):
    //   "[2001:db8::1]:443"    — bracketed IPv6 + port (RFC 3986 §3.2.2)
    //   "[2001:db8::]/32:443"  — bracketed IPv6 CIDR + port
    //   "[2001:db8::1]"        — bracketed IPv6 (no port)
    //   "2001:db8::/32"        — IPv6 CIDR (no port)
    //   "10.0.0.0/8"           — IPv4 CIDR (any port)
    //   "10.0.0.0/8:443"       — IPv4 CIDR + port
    //   "2001:db8::1"          — bare IPv6 literal, exact (no port)
    //   "example.com"          — exact host, any port
    //   "example.com:443"      — exact host + port
    //   "*.example.com"        — suffix wildcard
    //
    // The bracketed form must be checked FIRST since `[…]:port` would
    // otherwise be misparsed by the colon-splitter; CIDR is checked
    // BEFORE the colon-splitter so `/N` isn't read as part of host.
    // Bare IPv6 literals are detected by `is_v6_literal` (multiple
    // colons or `::`) so a single `:` still reads as `host:port`.
    if pattern.starts_with("[") {
        return bracketed_v6_matches(pattern, host, port);
    }
    if let Some(slash_idx) = pattern.find('/') {
        return cidr_host_matches(pattern, slash_idx, host, port);
    }
    if is_v6_literal(pattern) {
        return match (parse_ipv6(pattern), parse_ipv6(host)) {
            (Some(p), Some(h)) => p.hi == h.hi && p.lo == h.lo,
            _                  => false,
        };
    }
    let (pat_host, pat_port): (Text, Int) = match pattern.find(':') {
        Some(idx) => {
            let h: Text = pattern.slice(0, idx).into();
            let p_str: Text = pattern.slice(idx + 1, pattern.len()).into();
            let p: Int = p_str.parse_int().unwrap_or(0);
            (h, p)
        }
        None => (pattern.clone(), 0),
    };
    if pat_port != 0 && port != 0 && pat_port != port { return false; }
    if pat_host.starts_with("*.") {
        let suffix: Text = pat_host.slice(1, pat_host.len()).into();  // ".example.com"
        host.ends_with(&suffix) || (suffix.starts_with(".") && {
            let bare: Text = suffix.slice(1, suffix.len()).into();
            host == &bare
        })
    } else {
        host == &pat_host
    }
}

// Match "<addr>/<prefix>[:port]" against (host, port).
// `slash_idx` is the byte offset of the '/' in `pattern`.  The address
// family is detected from `addr_text`: a colon-bearing addr is IPv6
// (prefix 0..=128), otherwise IPv4 (prefix 0..=32).  Both addr and
// host must parse as the SAME family — a hostname never matches a
// CIDR rule, and an IPv4 host never matches an IPv6 CIDR rule.
fn cidr_host_matches(pattern: &Text, slash_idx: Int, host: &Text, port: Int) -> Bool {
    let addr_text: Text = pattern.slice(0, slash_idx).into();
    let rest:      Text = pattern.slice(slash_idx + 1, pattern.len()).into();
    let (prefix_text, pat_port): (Text, Int) = match rest.find(':') {
        Some(idx) => {
            let pre: Text = rest.slice(0, idx).into();
            let p_str: Text = rest.slice(idx + 1, rest.len()).into();
            let p: Int = p_str.parse_int().unwrap_or(0);
            (pre, p)
        }
        None => (rest, 0),
    };
    if pat_port != 0 && port != 0 && pat_port != port { return false; }
    let prefix: Int = match prefix_text.parse_int() {
        Ok(n)  => n,
        Err(_) => return false,
    };
    if is_v6_literal(&addr_text) {
        if prefix < 0 || prefix > 128 { return false; }
        let pat_addr  = match parse_ipv6(&addr_text) { Some(a) => a, None => return false };
        let host_addr = match parse_ipv6(host)       { Some(a) => a, None => return false };
        cidr_v6_match(&pat_addr, &host_addr, prefix)
    } else {
        if prefix < 0 || prefix > 32 { return false; }
        let pat_addr  = match parse_ipv4(&addr_text) { Some(a) => a, None => return false };
        let host_addr = match parse_ipv4(host)       { Some(a) => a, None => return false };
        // mask = top `prefix` bits of a 32-bit word.  prefix == 0 → mask = 0
        // (matches everything); prefix == 32 → mask = 0xFFFFFFFF (exact).
        let mask: Int = if prefix == 0 {
            0
        } else {
            bitand(shl(0xFFFFFFFF, 32 - prefix), 0xFFFFFFFF)
        };
        bitand(pat_addr, mask) == bitand(host_addr, mask)
    }
}

// Bracketed IPv6 form (RFC 3986 §3.2.2).  Three accepted shapes:
//   "[v6]"                  — exact match, any port
//   "[v6]:port"             — exact match, specific port
//   "[v6]/prefix[:port]"    — CIDR + optional port
fn bracketed_v6_matches(pattern: &Text, host: &Text, port: Int) -> Bool {
    let close = match pattern.find(']') { Some(i) => i, None => return false };
    if close < 1 { return false; }
    let addr_text: Text = pattern.slice(1, close).into();
    let after:     Text = pattern.slice(close + 1, pattern.len()).into();
    if after.is_empty() {
        return match (parse_ipv6(&addr_text), parse_ipv6(host)) {
            (Some(p), Some(h)) => p.hi == h.hi && p.lo == h.lo,
            _                  => false,
        };
    }
    if after.starts_with("/") {
        // CIDR + optional :port  →  reuse the unified cidr path by
        // re-stitching "addr/rest" so cidr_host_matches sees a
        // canonical pattern.  rest is `after[1..]` (without the slash).
        let rest: Text = after.slice(1, after.len()).into();
        // Build "addr/rest" and dispatch.
        let combined: Text = addr_text.concat("/").concat(&rest);
        return cidr_host_matches(&combined, addr_text.len(), host, port);
    }
    if after.starts_with(":") {
        let p_str: Text = after.slice(1, after.len()).into();
        let pat_port: Int = p_str.parse_int().unwrap_or(0);
        if pat_port != 0 && port != 0 && pat_port != port { return false; }
        return match (parse_ipv6(&addr_text), parse_ipv6(host)) {
            (Some(p), Some(h)) => p.hi == h.hi && p.lo == h.lo,
            _                  => false,
        };
    }
    false
}

// 128-bit IPv6 address stored as two 64-bit halves.  Verum's `Int` is
// signed 64-bit, so the low 64 bits of each half carry one half of
// the address; bitwise comparisons and masks treat them as unsigned
// (sign-extension does not affect bitand/bitor/shl/shr identity).
type Ipv6Addr is { hi: Int, lo: Int };

// Heuristic: a textual IPv6 literal contains either `::` (the
// zero-run shorthand) or two-or-more `:` separators.  Single-colon
// strings are read as `host:port`, hostnames have no colons.
fn is_v6_literal(text: &Text) -> Bool {
    if text.find("::").is_some() { return true; }
    let mut n: Int = 0;
    let mut i: Int = 0;
    let len = text.len();
    while i < len {
        if text.byte_at(i) == (':' as Byte) { n = n + 1; }
        i = i + 1;
    }
    n >= 2
}

// Match `pat` against `host` under a `prefix`-bit IPv6 CIDR mask.
// `prefix` MUST be in 0..=128 (caller pre-validates).
fn cidr_v6_match(pat: &Ipv6Addr, host: &Ipv6Addr, prefix: Int) -> Bool {
    let (hi_bits, lo_bits): (Int, Int) = if prefix <= 64 {
        (prefix, 0)
    } else {
        (64, prefix - 64)
    };
    let hi_mask = mask_top_bits_u64(hi_bits);
    let lo_mask = mask_top_bits_u64(lo_bits);
    bitand(pat.hi, hi_mask) == bitand(host.hi, hi_mask)
        && bitand(pat.lo, lo_mask) == bitand(host.lo, lo_mask)
}

// 64-bit mask covering the top `bits` bits.  `bits == 0 → 0`,
// `bits == 64 → -1` (all-ones in two's complement), else
// `(-1) << (64 - bits)` — left-shifting -1 produces a top-aligned
// run of ones with the correct width regardless of sign because
// shl is bitwise.
fn mask_top_bits_u64(bits: Int) -> Int {
    if bits <= 0 { 0 }
    else if bits >= 64 { -1 }
    else { shl(-1, 64 - bits) }
}

// Parse RFC 4291 IPv6 textual form.  Supports:
//   * Full form:        2001:0db8:85a3:0000:0000:8a2e:0370:7334
//   * Compressed form:  2001:db8::8a2e:370:7334
//   * Loopback:         ::1
//   * Unspecified:      ::
//   * IPv4-mapped tail: ::ffff:192.168.1.1  (last 32 bits = IPv4)
//
// Returns None on any malformed input: unrecognised characters,
// >4 hex chars per group, multiple `::` zones, total != 8 groups,
// or invalid IPv4 tail.
fn parse_ipv6(text: &Text) -> Maybe<Ipv6Addr> {
    if text.is_empty() { return None; }

    // Reject inputs with more than one `::` zone — `split(":")` can't
    // distinguish "a:::b" (illegal) from "a::b" (legal) on its own
    // because both produce ≥3 consecutive empties.  RFC 4291 §2.2
    // permits exactly one `::`, anywhere.
    if let Some(first) = text.find("::") {
        let after: Text = text.slice(first + 2, text.len()).into();
        if after.find("::").is_some() { return None; }
    }

    let mut groups: List<Text> = text.split(":");
    if groups.len() < 3 || groups.len() > 9 { return None; }

    // IPv4-mapped tail: if the LAST group contains '.', parse it as
    // IPv4 and replace it in-place with TWO equivalent hex groups.
    let last_idx = groups.len() - 1;
    if groups[last_idx].find(".").is_some() {
        let v4 = match parse_ipv4(&groups[last_idx]) { Some(a) => a, None => return None };
        let high: Int = bitand(shr(v4, 16), 0xFFFF);
        let low:  Int = bitand(v4, 0xFFFF);
        let mut rebuilt: List<Text> = List.new();
        let mut i: Int = 0;
        while i < last_idx {
            rebuilt.push(groups[i].clone());
            i = i + 1;
        }
        rebuilt.push(int_to_hex_text(high));
        rebuilt.push(int_to_hex_text(low));
        groups = rebuilt;
    }

    // Locate the empty-group span (the `::` zone).  Empty groups can
    // appear at most ONE contiguous run, but the leading/trailing `::`
    // produces TWO adjacent empties (e.g. `::1` -> ["", "", "1"]).
    let n = groups.len();
    let mut first_empty: Maybe<Int> = None;
    let mut last_empty:  Maybe<Int> = None;
    let mut empty_count: Int = 0;
    let mut idx: Int = 0;
    while idx < n {
        if groups[idx].is_empty() {
            if first_empty.is_none() { first_empty = Some(idx); }
            last_empty = Some(idx);
            empty_count = empty_count + 1;
        } else if last_empty.is_some() {
            // Non-empty AFTER the empty-zone closes — verify no further
            // empties follow (would indicate two separate `::`).
            let mut k: Int = idx + 1;
            while k < n {
                if groups[k].is_empty() { return None; }
                k = k + 1;
            }
            break;
        }
        idx = idx + 1;
    }

    let mut final_groups: List<Int> = List.new();
    if empty_count == 0 {
        if n != 8 { return None; }
        for g in groups.iter() {
            match parse_hex_group(g) {
                Some(v) => final_groups.push(v),
                None    => return None,
            }
        }
    } else {
        // `::` zone present.  zeros_to_fill = 8 - non-empty groups.
        let real_groups = n - empty_count;
        let zeros_to_fill = 8 - real_groups;
        if zeros_to_fill < 1 || zeros_to_fill > 8 { return None; }
        let pre_end    = first_empty.unwrap_or(0);
        let post_start = last_empty.unwrap_or(0) + 1;
        let mut i: Int = 0;
        while i < pre_end {
            match parse_hex_group(&groups[i]) {
                Some(v) => final_groups.push(v),
                None    => return None,
            }
            i = i + 1;
        }
        let mut z: Int = 0;
        while z < zeros_to_fill {
            final_groups.push(0);
            z = z + 1;
        }
        let mut j: Int = post_start;
        while j < n {
            match parse_hex_group(&groups[j]) {
                Some(v) => final_groups.push(v),
                None    => return None,
            }
            j = j + 1;
        }
    }

    if final_groups.len() != 8 { return None; }

    let hi: Int = bitor(
        bitor(shl(final_groups[0], 48), shl(final_groups[1], 32)),
        bitor(shl(final_groups[2], 16), final_groups[3]),
    );
    let lo: Int = bitor(
        bitor(shl(final_groups[4], 48), shl(final_groups[5], 32)),
        bitor(shl(final_groups[6], 16), final_groups[7]),
    );
    Some(Ipv6Addr { hi: hi, lo: lo })
}

fn parse_hex_group(text: &Text) -> Maybe<Int> {
    if text.is_empty() || text.len() > 4 { return None; }
    match text.parse_int_radix(16) {
        Ok(n) if n >= 0 && n <= 0xFFFF => Some(n),
        _                              => None,
    }
}

// Lowercase-hex-encode a 0..=0xFFFF value (no leading zeros, no
// "0x" prefix).  Used internally to splice an IPv4-mapped tail back
// into a pure-hex IPv6 textual form before re-tokenisation.
fn int_to_hex_text(n: Int) -> Text {
    if n == 0 { return "0".into(); }
    let digits = "0123456789abcdef";
    let mut bytes: List<Byte> = List.new();
    let mut v = n;
    while v > 0 {
        let nibble = bitand(v, 0xF);
        bytes.push(digits.byte_at(nibble));
        v = shr(v, 4);
    }
    // bytes is little-end; reverse for printable form.
    let mut out: List<Byte> = List.new();
    let mut i: Int = bytes.len() - 1;
    while i >= 0 {
        out.push(bytes[i]);
        i = i - 1;
    }
    Text.from_utf8_lossy(&out)
}

// Parse a dotted-decimal IPv4 address into its 32-bit big-endian
// numeric form (low 32 bits of the returned Int).  Returns None on
// any parse failure: wrong number of octets, non-numeric octets,
// out-of-range octets (>255), leading-zero octets are accepted.
fn parse_ipv4(text: &Text) -> Maybe<Int> {
    let mut octets: List<Int> = List.new();
    let mut start: Int = 0;
    let len = text.len();
    let mut i: Int = 0;
    while i < len {
        if text.byte_at(i) == ('.' as Byte) {
            let part: Text = text.slice(start, i).into();
            match part.parse_int() {
                Ok(n) if n >= 0 && n <= 255 => octets.push(n),
                _ => return None,
            }
            start = i + 1;
        }
        i = i + 1;
    }
    let last: Text = text.slice(start, len).into();
    match last.parse_int() {
        Ok(n) if n >= 0 && n <= 255 => octets.push(n),
        _ => return None,
    }
    if octets.len() != 4 { return None; }
    Some(
        bitor(
            bitor(shl(octets[0], 24), shl(octets[1], 16)),
            bitor(shl(octets[2], 8),  octets[3]),
        ),
    )
}

// =============================================================================
// Frontmatter — parse `// !@permission(...)` blocks
// =============================================================================
//
// Recognises lines of the form:
//   // !@permission(run: ["git", "kubectl"], fs_read: ["/etc/kube/*"])
//   // !@permission(net: ["api.github.com:443"])
//
// The grammar is intentionally simple — single-line per directive,
// comma-separated key=value pairs, lists in `["..."]` syntax. Multiple
// directives accumulate into the same PermissionSet.

public fn parse_frontmatter(source: &Text) -> Result<PermissionSet, ShellError> {
    let mut perms = PermissionSet.deny_all();
    let mut started = false;

    for line in source.lines() {
        let trimmed: Text = line.trim().into();
        if !trimmed.starts_with("//") { continue; }
        let body: Text = trimmed.slice(2, trimmed.len()).trim().into();
        if !body.starts_with("!@permission") {
            // First non-permission line ends the frontmatter section
            if started { break; }
            continue;
        }
        started = true;
        // Parse the body: !@permission(...)
        let inner = match (body.find('('), body.rfind(')')) {
            (Some(l), Some(r)) if r > l => body.slice(l + 1, r),
            _ => continue,
        };
        let inner_text: Text = inner.into();
        merge_directive(&mut perms, &inner_text)?;
    }

    if started {
        // Frontmatter present — we keep deny-all baseline + explicit allows.
        Ok(perms)
    } else {
        // No frontmatter — leave permissions unrestricted (legacy mode).
        Ok(PermissionSet.unrestricted())
    }
}

fn merge_directive(p: &mut PermissionSet, body: &Text) -> Result<(), ShellError> {
    // Format: key: ["a", "b", ...], key2: [...], ...
    let mut depth = 0;
    let mut current = Text.with_capacity(64);
    let mut entries: List<Text> = [];
    for ch in body.chars() {
        if ch == '[' { depth = depth + 1; current.push(ch); }
        else if ch == ']' { depth = depth - 1; current.push(ch); }
        else if ch == ',' && depth == 0 {
            entries.push(current.trim().into());
            current = Text.with_capacity(64);
        } else {
            current.push(ch);
        }
    }
    if !current.is_empty() { entries.push(current.trim().into()); }

    for entry in entries.iter() {
        let kv: List<Text> = entry.splitn(2, ":").map(|s| s.trim().into()).collect();
        if kv.len() != 2 { continue; }
        let key: &Text = &kv[0];
        let values: List<Text> = parse_string_list(&kv[1]);
        match key.as_str() {
            "run"      => p.run      = Some(merge_lists(&p.run,      values)),
            "fs_read"  => p.fs_read  = Some(merge_lists(&p.fs_read,  values)),
            "fs_write" => p.fs_write = Some(merge_lists(&p.fs_write, values)),
            "net"      => p.net      = Some(merge_lists(&p.net,      values)),
            "env"      => p.env      = Some(merge_lists(&p.env,      values)),
            _ => {},  // unknown key — ignored
        }
    }
    Ok(())
}

fn parse_string_list(text: &Text) -> List<Text> {
    let mut out: List<Text> = [];
    let trimmed: Text = text.trim().into();
    if !trimmed.starts_with("[") || !trimmed.ends_with("]") { return out; }
    let inner: Text = trimmed.slice(1, trimmed.len() - 1).into();
    for token in inner.split(',') {
        let t: Text = token.trim().trim_matches('"').into();
        if !t.is_empty() { out.push(t); }
    }
    out
}

fn merge_lists(prev: &Maybe<List<Text>>, new: List<Text>) -> List<Text> {
    let mut out: List<Text> = match prev {
        None => [],
        Some(v) => v.clone(),
    };
    for x in new.into_iter() { out.push(x); }
    out
}
