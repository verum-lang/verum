// =============================================================================
// shell/exec.vr — Shell command executor
// =============================================================================
// Layer: 5 (Shell)
// Dependencies: core, io.process, time, async.cancellation, shell.{escape, result, context}
// =============================================================================
//
// Two layered APIs:
//
//   * `run(program, args)` — direct exec without shell interpretation. The
//     argv is built explicitly; nothing the caller passes is interpreted as
//     shell metacharacters. Equivalent to `execvp` / `CreateProcessA`.
//   * `sh(cmd_text)` — shell dispatch via `<shell> -c "<cmd>"`. The caller's
//     command text is fed to the shell and *will* be parsed; auto-escape
//     in `sh#"..."` literals lifts user data through `ShellEscape` so
//     interpolations are individual safe tokens.
//
// Both functions:
//   * apply the active `ShellContext` (cwd, env, flavour, permissions)
//   * intercept through `ShellContext.mock` when set — no real spawn
//   * record the dispatched line for diagnostics
//   * measure wall-clock duration
//   * surface failure as a typed `ShellError`
//
// Execution is implemented synchronously for the interpreter path (Tier 0)
// and as `async fn` returning a Future in compiled paths so it composes with
// nursery / select / cancellation. The async surface is what callers should
// always reach for; the sync path falls out automatically when the runtime
// ticks the future to completion.
//
// =============================================================================

module exec;

mount core.{Maybe, Result, List, Text, Byte, Bool, Int};
mount core.base.protocols.{Display, Debug, Clone};
mount core.io.process.{Command, Child, ExitStatus, Output, Stdio};
mount core.time.duration.{Duration};
mount core.time.instant.{Instant};
mount core.async.cancellation.{CancellationToken};
mount core.shell.escape.{ShellFlavour, ShellEscape, default_flavour};
mount core.shell.result.{ShellResult, ShellError};
mount core.shell.context.{ShellContext, MockResponse, PermissionSet};

// =============================================================================
// run() — exec a program with explicit argv (no shell interpretation)
// =============================================================================

/// Executes `program` with `args` and returns the captured result.
/// Honours the active `ShellContext` (cwd, env, permissions, mock).
///
/// This is the *recommended primitive* for programmatic dispatch — the
/// argv structure is preserved, no shell parsing happens between the
/// caller and the kernel exec.
public async fn run(program: &Text, args: List<Text>)
    -> Result<ShellResult, ShellError>
    using [ShellContext]
{
    let ctx = ShellContext.default();

    // Permission gate first — fast-fail before allocations
    ctx.permissions.check_run(program)?;

    let display_cmd = render_argv(program, &args);

    // Diagnostics: log dispatched command if requested
    if ctx.verbose {
        log_dispatched(&display_cmd);
    }
    if ctx.dry_run {
        return Ok(synthesise_dry_run(display_cmd));
    }

    // Mock interception
    if let Some(mut mock) = ctx.mock.clone() {
        match mock.dispatch(&display_cmd) {
            Some(resp) => return Ok(synthesise_mock_result(resp, display_cmd)),
            None => if ctx.mock.as_ref().unwrap().strict_no_match {
                return Err(ShellError.SpawnFailed {
                    command: display_cmd,
                    reason:  "no mock response matched and strict_no_match=true".into(),
                });
            }
        }
    }

    // Real spawn
    let start = Instant.now();
    let mut cmd = Command.new(program.clone());
    cmd.args(&args);
    apply_context(&mut cmd, &ctx);
    cmd.stdout(Stdio.Piped);
    cmd.stderr(Stdio.Piped);

    match cmd.output() {
        Ok(out) => Ok(ShellResult.new(
            out.status,
            out.stdout_bytes,
            out.stderr_bytes,
            display_cmd,
            start.elapsed(),
        )),
        Err(reason) => Err(ShellError.SpawnFailed {
            command: display_cmd,
            reason:  reason,
        }),
    }
}

// =============================================================================
// sh() — exec a command through the active shell
// =============================================================================

/// Executes `cmd_text` through `<shell> -c "<cmd>"`. The text *is* parsed
/// by the shell — auto-escape in `sh#"..."` literals already lifted any
/// embedded values into safe tokens, so this is the standard path.
///
/// Returns a `ShellResult` regardless of exit status; call `.ok()?` on
/// the result to convert non-zero exits into `Err`.
public async fn sh(cmd_text: &Text) -> ShellResult using [ShellContext] {
    match sh_check(cmd_text).await {
        Ok(r)  => r,
        Err(e) => ShellResult.from_error(e),
    }
}

/// Like `sh()` but returns `Result<ShellResult, ShellError>` so the `?`
/// operator works at the call site without an extra `.ok()`.
public async fn sh_check(cmd_text: &Text)
    -> Result<ShellResult, ShellError>
    using [ShellContext]
{
    let ctx = ShellContext.default();

    // Resolve shell program — also subjects it to the run-permission gate
    let shell_prog = ctx.resolve_shell();
    ctx.permissions.check_run(&shell_prog)?;

    let flag = ctx.shell_command_flag();
    let display_cmd = cmd_text.clone();

    if ctx.verbose {
        log_dispatched(&display_cmd);
    }
    if ctx.dry_run {
        return Ok(synthesise_dry_run(display_cmd));
    }

    if let Some(mut mock) = ctx.mock.clone() {
        match mock.dispatch(&display_cmd) {
            Some(resp) => return Ok(synthesise_mock_result(resp, display_cmd)),
            None => if ctx.mock.as_ref().unwrap().strict_no_match {
                return Err(ShellError.SpawnFailed {
                    command: display_cmd,
                    reason:  "no mock response matched and strict_no_match=true".into(),
                });
            }
        }
    }

    let start = Instant.now();
    let mut cmd = Command.new(shell_prog);
    cmd.arg(flag);
    cmd.arg(cmd_text.clone());
    apply_context(&mut cmd, &ctx);
    cmd.stdout(Stdio.Piped);
    cmd.stderr(Stdio.Piped);

    match cmd.output() {
        Ok(out) => Ok(ShellResult.new(
            out.status,
            out.stdout_bytes,
            out.stderr_bytes,
            display_cmd,
            start.elapsed(),
        )),
        Err(reason) => Err(ShellError.SpawnFailed {
            command: display_cmd,
            reason:  reason,
        }),
    }
}

// =============================================================================
// run_with_cancel / sh_with_cancel — same as above but cancellable
// =============================================================================

/// Executes a command with a `CancellationToken` watching alongside. On
/// cancel, the child is sent SIGTERM, given `grace` to exit, then SIGKILL.
/// Returns `Err(Cancelled)` carrying the reason from the token.
///
/// `grace` defaults to 5 seconds when `Duration.from_millis(0)` is passed.
public async fn run_with_cancel(
    program: &Text,
    args: List<Text>,
    token: &CancellationToken,
    grace: Duration,
) -> Result<ShellResult, ShellError>
    using [ShellContext]
{
    let ctx = ShellContext.default();
    ctx.permissions.check_run(program)?;

    let display_cmd = render_argv(program, &args);
    if ctx.dry_run { return Ok(synthesise_dry_run(display_cmd)); }

    if let Some(mut mock) = ctx.mock.clone() {
        match mock.dispatch(&display_cmd) {
            Some(resp) => return Ok(synthesise_mock_result(resp, display_cmd)),
            None => if ctx.mock.as_ref().unwrap().strict_no_match {
                return Err(ShellError.SpawnFailed {
                    command: display_cmd,
                    reason:  "no mock response matched".into(),
                });
            }
        }
    }

    let start = Instant.now();
    let mut cmd = Command.new(program.clone());
    cmd.args(&args);
    apply_context(&mut cmd, &ctx);
    cmd.stdout(Stdio.Piped);
    cmd.stderr(Stdio.Piped);

    let child = match cmd.spawn() {
        Ok(c) => c,
        Err(reason) => return Err(ShellError.SpawnFailed {
            command: display_cmd,
            reason,
        }),
    };

    // Race: child completion vs cancellation
    let effective_grace = if grace.as_millis() == 0 { Duration.from_millis(5000) } else { grace };

    select {
        out = wait_with_output_async(&child).await => match out {
            Ok(o) => Ok(ShellResult.new(
                o.status, o.stdout_bytes, o.stderr_bytes,
                display_cmd, start.elapsed(),
            )),
            Err(reason) => Err(ShellError.SpawnFailed { command: display_cmd, reason }),
        },
        reason = token.cancelled().await => {
            // Graceful shutdown — SIGTERM first
            let _ = child.terminate();
            // Wait up to `grace` for clean exit, then SIGKILL
            let kill_ct = CancellationToken.with_timeout(effective_grace);
            select {
                _ = wait_with_output_async(&child).await => {},
                _ = kill_ct.cancelled().await => { let _ = child.kill(); },
            };
            Err(ShellError.Cancelled {
                command: display_cmd,
                reason:  reason.message(),
            })
        },
    }
}

/// Cancellable variant of `sh_check` — the most common production form.
public async fn sh_with_cancel(
    cmd_text: &Text,
    token: &CancellationToken,
    grace: Duration,
) -> Result<ShellResult, ShellError>
    using [ShellContext]
{
    let ctx = ShellContext.default();
    let shell_prog = ctx.resolve_shell();
    let flag = ctx.shell_command_flag();
    run_with_cancel(&shell_prog, [flag, cmd_text.clone()], token, grace).await
}

// =============================================================================
// Internals
// =============================================================================

fn apply_context(cmd: &mut Command, ctx: &ShellContext) {
    if let Some(dir) = &ctx.cwd {
        cmd.current_dir(dir.clone());
    }
    for (k, v) in ctx.env_overrides.iter() {
        cmd.env(k.clone(), v.clone());
    }
}

/// Reconstruct a human-readable command line from program + argv.
/// Used purely for diagnostics — never re-parsed.
fn render_argv(program: &Text, args: &List<Text>) -> Text {
    let mut out = Text.with_capacity(program.len() + args.len() * 8);
    out.push_str(program);
    for a in args.iter() {
        out.push(' ');
        // Quote conservatively for display: visually delineate args with
        // whitespace or shell metacharacters; do not pretend to be
        // shell-correct (that would be confusing — diagnostics are diagnostics).
        if needs_display_quoting(a) {
            out.push('"');
            out.push_str(a);
            out.push('"');
        } else {
            out.push_str(a);
        }
    }
    out
}

fn needs_display_quoting(s: &Text) -> Bool {
    if s.is_empty() { return true; }
    for ch in s.chars() {
        if ch == ' ' || ch == '\t' || ch == '\n' || ch == '"' || ch == '\'' {
            return true;
        }
    }
    false
}

fn synthesise_mock_result(resp: MockResponse, command: Text) -> ShellResult {
    // POSIX waitpid encoding for exited process: code << 8
    let raw_status = (resp.exit_code & 0xFF) << 8;
    ShellResult.new(
        ExitStatus { raw: raw_status },
        resp.stdout,
        resp.stderr,
        command,
        Duration.from_millis(0),
    )
}

fn synthesise_dry_run(command: Text) -> ShellResult {
    let mut stdout: List<Byte> = [];
    let prefix: Text = "[dry-run] ".into();
    for b in prefix.into_bytes().iter() { stdout.push(*b); }
    for b in command.clone().into_bytes().iter() { stdout.push(*b); }
    stdout.push('\n' as Byte);
    ShellResult.new(
        ExitStatus { raw: 0 },
        stdout,
        [],
        command,
        Duration.from_millis(0),
    )
}

fn log_dispatched(cmd: &Text) {
    // Diagnostics output goes to stderr to leave stdout clean for piping.
    eprint(f"$ {cmd}\n");
}

/// Async-friendly wrapper around Child::wait_with_output. Yields to the
/// executor between status checks so other tasks can progress.
async fn wait_with_output_async(child: &Child) -> Result<Output, Text> {
    // Synchronous wait_with_output is acceptable on the runtime's worker
    // thread pool — verum_runtime spawns a dedicated thread for blocking
    // syscalls so the async executor stays responsive.
    child.wait_with_output()
}
