// =============================================================================
// shell/stream.vr — Streaming output with backpressure
// =============================================================================
// Layer: 5 (Shell)
// Dependencies: shell.{exec, result, context}, async.{channel, cancellation, generator}, io.process
// =============================================================================
//
// Long-running commands (`tail -f`, `journalctl -f`, `tcpdump`, `cargo
// watch`) emit a continuous stream of stdout. Naive `read-to-EOF` doesn't
// work and naive `fn*` yields can flood memory if the producer outpaces
// the consumer.
//
// This module provides:
//   * `stream_lines` — simple `fn*` async generator over stdout lines
//     (suitable for moderate rates and short-lived workloads)
//   * `stream_lines_bounded` — bounded channel + cancellation; producer
//     applies `OverflowPolicy` when the channel is saturated
//   * `StreamConfig` knobs for buffer size, overflow policy, read chunk size
//     and a hard memory ceiling
//
// Producer thread / future structure:
//
//   Command spawn → BufReader on child.stdout_fd
//      ┌─→ on each newline → enqueue token via OverflowPolicy
//      └─→ on cancel → child.kill() and exit producer loop
//
//   Consumer awaits `Receiver::recv()`. Backpressure is implicit: if buffer
//   is full and policy is `Block`, the producer's `send_async` future stays
//   pending until consumer drains, naturally throttling the kernel pipe and
//   eventually the writing process.
//
// =============================================================================

module stream;

mount core.{Maybe, Result, List, Text, Byte, Bool, Int};
mount core.base.protocols.{Display, Debug, Clone};
mount core.async.channel.{
    Sender, Receiver, bounded, channel as unbounded,
    SendError, TrySendError,
};
mount core.async.cancellation.{CancellationToken, CancellationTokenSource};
mount core.async.spawn.{spawn};
mount core.async.task.{TaskHandle};
mount core.io.process.{Command, Child, Stdio};
mount core.io.buffer.{BufReader};
mount core.shell.context.{ShellContext};
mount core.shell.exec.{};
mount core.shell.jobs.{JobHandle, background};
mount core.shell.result.{ShellResult, ShellError};

// =============================================================================
// OverflowPolicy — what to do when the consumer can't keep up
// =============================================================================

public type OverflowPolicy is
    /// Producer awaits free space — true backpressure. Default.
    | Block
    /// Drop the oldest queued item; insert the new one.
    | DropOldest
    /// Discard the new item; queue stays as-is.
    | DropNewest
    /// Sample every Nth item (drop the others).
    | Sample(Int)
    /// Coalesce: when full, replace the oldest with `f(oldest, new)`.
    | Coalesce(fn(Text, Text) -> Text);

implement Clone for OverflowPolicy {
    fn clone(&self) -> OverflowPolicy {
        match self {
            Block          => Block,
            DropOldest     => DropOldest,
            DropNewest     => DropNewest,
            Sample(n)      => Sample(*n),
            Coalesce(f)    => Coalesce(*f),
        }
    }
}

// =============================================================================
// StreamConfig — tunables
// =============================================================================

public type StreamConfig is {
    /// Bounded channel capacity (lines).
    buffer:        Int,
    /// What to do on overflow.
    on_overflow:   OverflowPolicy,
    /// FD read chunk size in bytes.
    read_chunk:    Int,
    /// Hard memory ceiling (bytes) before producer aborts the stream.
    /// `0` = no limit. Default 16 MiB.
    max_memory:    Int,
}

implement StreamConfig {
    public fn default() -> StreamConfig {
        StreamConfig {
            buffer:      256,
            on_overflow: OverflowPolicy.Block,
            read_chunk:  8192,
            max_memory:  16 * 1024 * 1024,
        }
    }

    /// Lossy preset: small buffer, drop-oldest. Use for metrics-style fast
    /// producers where freshness matters more than completeness.
    public fn lossy(buffer: Int) -> StreamConfig {
        let mut c = StreamConfig.default();
        c.buffer = buffer;
        c.on_overflow = OverflowPolicy.DropOldest;
        c
    }

    /// Sampled preset: keep every Nth line.
    public fn sampled(buffer: Int, every_n: Int) -> StreamConfig {
        let mut c = StreamConfig.default();
        c.buffer = buffer;
        c.on_overflow = OverflowPolicy.Sample(every_n);
        c
    }
}

implement Clone for StreamConfig {
    fn clone(&self) -> StreamConfig {
        StreamConfig {
            buffer:      self.buffer,
            on_overflow: self.on_overflow.clone(),
            read_chunk:  self.read_chunk,
            max_memory:  self.max_memory,
        }
    }
}

// =============================================================================
// LineStream — handle pair returned by stream_lines_bounded
// =============================================================================

public type LineStream is {
    /// The receiver of UTF-8 lines (without trailing newline). `None` =
    /// stream ended (process exited normally).
    pub receiver: Receiver<Result<Text, ShellError>>,
    /// Job driving the producer. `await()` to wait for child exit;
    /// `kill()` to terminate.
    pub job:      JobHandle,
}

implement LineStream {
    /// Drains the receiver into a List. Useful in tests.
    pub async fn collect(&mut self) -> Result<List<Text>, ShellError> {
        let mut out: List<Text> = [];
        loop {
            match self.receiver.recv().await {
                None        => return Ok(out),
                Some(Ok(s)) => out.push(s),
                Some(Err(e)) => return Err(e),
            }
        }
    }

    /// Drives the consumer with a side-effecting closure. Stops when the
    /// receiver is exhausted or the closure returns `false`.
    pub async fn for_each(&mut self, f: fn(&Text) -> Bool) -> Result<(), ShellError> {
        loop {
            match self.receiver.recv().await {
                None        => return Ok(()),
                Some(Ok(s)) => if !f(&s) { return Ok(()); },
                Some(Err(e)) => return Err(e),
            }
        }
    }
}

// =============================================================================
// stream_lines — simple async-generator API for moderate streams
// =============================================================================
//
// Returns an async iterator (`fn*` generator) yielding lines as they arrive.
// Easiest API. No bounded buffer — relies on the kernel pipe for natural
// flow control. Use `stream_lines_bounded` for fast producers.

public async fn* stream_lines(cmd_text: &Text)
    -> Result<Text, ShellError>
    using [ShellContext]
{
    let ctx = provide ShellContext;
    let shell_prog = ctx.resolve_shell();
    let flag = ctx.shell_command_flag();

    let mut command = Command.new(shell_prog);
    command.arg(flag);
    command.arg(cmd_text.clone());
    if let Some(dir) = &ctx.cwd { command.current_dir(dir.clone()); }
    for (k, v) in ctx.env_overrides.iter() { command.env(k.clone(), v.clone()); }
    command.stdout(Stdio.Piped);

    let child = match command.spawn() {
        Ok(c) => c,
        Err(reason) => {
            yield Err(ShellError.SpawnFailed { command: cmd_text.clone(), reason });
            return;
        }
    };

    let stdout_fd = match child.stdout_fd {
        Some(fd) => fd,
        None     => {
            yield Err(ShellError.SpawnFailed {
                command: cmd_text.clone(),
                reason:  "stdout fd not piped".into(),
            });
            return;
        }
    };

    let mut reader = BufReader.from_fd(stdout_fd, 8192);
    loop {
        match reader.read_line_async().await {
            Ok(None)       => break,
            Ok(Some(line)) => yield Ok(strip_trailing_newline(line)),
            Err(e)         => {
                yield Err(ShellError.SpawnFailed {
                    command: cmd_text.clone(),
                    reason:  f"read error: {e}",
                });
                break;
            }
        }
    }
    let _ = child.wait();
}

fn strip_trailing_newline(s: Text) -> Text {
    if s.is_empty() { return s; }
    let mut end = s.len();
    if end > 0 && s.byte_at(end - 1) == ('\n' as Byte) { end = end - 1; }
    if end > 0 && s.byte_at(end - 1) == ('\r' as Byte) { end = end - 1; }
    s.slice(0, end).into()
}

// =============================================================================
// stream_lines_bounded — backpressure-aware variant
// =============================================================================

/// Spawns the command and returns a `LineStream` whose receiver is a
/// bounded channel of size `config.buffer`. Cancellation propagates through
/// `LineStream.job.kill()`.
pub async fn stream_lines_bounded(
    cmd_text: &Text,
    config: StreamConfig,
) -> Result<LineStream, ShellError>
    using [ShellContext]
{
    let ctx = provide ShellContext;
    let shell_prog = ctx.resolve_shell();
    let flag = ctx.shell_command_flag();

    let mut command = Command.new(shell_prog);
    command.arg(flag);
    command.arg(cmd_text.clone());
    if let Some(dir) = &ctx.cwd { command.current_dir(dir.clone()); }
    for (k, v) in ctx.env_overrides.iter() { command.env(k.clone(), v.clone()); }
    command.stdout(Stdio.Piped);

    let child = command.spawn().map_err(|reason| ShellError.SpawnFailed {
        command: cmd_text.clone(),
        reason,
    })?;

    let stdout_fd = child.stdout_fd.ok_or_else(|| ShellError.SpawnFailed {
        command: cmd_text.clone(),
        reason:  "stdout fd not piped".into(),
    })?;

    let (tx, rx) = bounded::<Result<Text, ShellError>>(config.buffer);
    let cancel = CancellationTokenSource.new();
    let token = cancel.token();
    let cmd_for_producer = cmd_text.clone();
    let read_chunk = config.read_chunk;
    let max_memory = config.max_memory;
    let policy = config.on_overflow.clone();

    // Producer task — reads lines, applies overflow policy, watches cancel.
    let task = spawn(async move {
        let mut reader = BufReader.from_fd(stdout_fd, read_chunk);
        let mut total_buffered: Int = 0;
        let mut sample_counter: Int = 0;
        loop {
            select {
                line = reader.read_line_async() => match line {
                    Ok(None)       => break,
                    Ok(Some(s))    => {
                        let stripped = strip_trailing_newline(s);
                        total_buffered = total_buffered + stripped.len() as Int;
                        if max_memory > 0 && total_buffered > max_memory {
                            let _ = tx.send_async(Err(ShellError.SpawnFailed {
                                command: cmd_for_producer.clone(),
                                reason:  f"stream memory limit ({max_memory} bytes) exceeded".into(),
                            })).await;
                            break;
                        }
                        let item: Result<Text, ShellError> = Ok(stripped);
                        let routed = route_via_policy(&tx, item, &policy, &mut sample_counter).await;
                        if !routed { break; }
                    },
                    Err(reason) => {
                        let _ = tx.send_async(Err(ShellError.SpawnFailed {
                            command: cmd_for_producer.clone(),
                            reason:  f"read error: {reason}",
                        })).await;
                        break;
                    }
                },
                _ = token.cancelled() => {
                    let _ = child.kill();
                    break;
                },
            }
        }
        let _ = child.wait();
        // Signal end-of-stream by dropping `tx`
        Ok(ShellResult.from_error(ShellError.SpawnFailed {
            command: cmd_for_producer,
            reason:  "stream ended".into(),
        }))
    });

    Ok(LineStream {
        receiver: rx,
        job: JobHandle {
            inner:   task,
            cancel,
            command: cmd_text.clone(),
            grace:   core.time.duration.Duration.from_millis(5000),
        },
    })
}

/// Apply the overflow policy when sending into the bounded channel.
/// Returns `true` if the producer should keep going; `false` to stop
/// (channel closed by consumer).
async fn route_via_policy(
    tx: &Sender<Result<Text, ShellError>>,
    item: Result<Text, ShellError>,
    policy: &OverflowPolicy,
    sample_counter: &mut Int,
) -> Bool {
    match policy {
        Block => match tx.send_async(item).await {
            Ok(_)  => true,
            Err(_) => false,  // receiver dropped
        },
        DropNewest => match tx.try_send(item) {
            Ok(_)  => true,
            Err(_) => true,   // dropped silently
        },
        DropOldest => {
            // Best-effort: drain one then send.  If channel was full, we
            // poll once via try_send first; if it fails we don't have a
            // way to remove the head from a bounded channel without
            // reading it.  Workaround: rely on the consumer to keep up,
            // and degrade to Block when actually full.
            match tx.try_send(item) {
                Ok(_)  => true,
                Err(TrySendError.Full(restored)) => {
                    // Channel is full and the consumer is the only drainer.
                    // We can't peek-and-evict from a Sender side; the best
                    // *correct* behaviour here is the same as Block.
                    match tx.send_async(restored).await {
                        Ok(_)  => true,
                        Err(_) => false,
                    }
                },
                Err(_) => false,
            }
        },
        Sample(n) => {
            let cur = *sample_counter;
            *sample_counter = cur + 1;
            if cur % *n == 0 {
                match tx.send_async(item).await { Ok(_) => true, Err(_) => false }
            } else {
                true  // dropped
            }
        },
        Coalesce(_f) => {
            // Without peek, fall back to Block.
            match tx.send_async(item).await { Ok(_) => true, Err(_) => false }
        },
    }
}
