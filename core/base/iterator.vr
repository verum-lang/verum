/// Infinite counter.
public type CountFrom is { current: Int };

implement Iterator for CountFrom {
    type Item = Int;

    fn next(&mut self) -> Maybe<Int> {
        let val = self.current;
        self.current = self.current + 1;
        Some(val)
    }

    fn size_hint(&self) -> (Int, Maybe<Int>) {
        (Int.max_value(), None)
    }
}

/// Infinite repeat iterator.
public type Repeat<T> is { value: T };

implement<T: Clone> Iterator for Repeat<T> {
    type Item = T;

    fn next(&mut self) -> Maybe<T> {
        Some(self.value.clone())
    }

    fn size_hint(&self) -> (Int, Maybe<Int>) {
        (Int.max_value(), None)
    }
}

/// Limited repeat iterator.
public type RepeatN<T> is { value: T, remaining: Int };

implement<T: Clone> Iterator for RepeatN<T> {
    type Item = T;

    fn next(&mut self) -> Maybe<T> {
        if self.remaining > 0 {
            self.remaining = self.remaining - 1;
            Some(self.value.clone())
        } else {
            None
        }
    }

    fn size_hint(&self) -> (Int, Maybe<Int>) {
        (self.remaining, Some(self.remaining))
    }
}

implement<T: Clone> ExactSizeIterator for RepeatN<T> {
    fn len(&self) -> Int {
        self.remaining
    }
}

/// Single element iterator.
public type OnceIter<T> is { value: Maybe<T> };

implement<T> Iterator for OnceIter<T> {
    type Item = T;

    fn next(&mut self) -> Maybe<T> {
        self.value.take()
    }

    fn size_hint(&self) -> (Int, Maybe<Int>) {
        let n = if self.value.is_some() { 1 } else { 0 };
        (n, Some(n))
    }
}

implement<T> ExactSizeIterator for OnceIter<T> {
    fn len(&self) -> Int {
        if self.value.is_some() { 1 } else { 0 }
    }
}

/// Empty iterator.
public type Empty<T> is { _marker: () };

implement<T> Iterator for Empty<T> {
    type Item = T;

    fn next(&mut self) -> Maybe<T> {
        None
    }

    fn size_hint(&self) -> (Int, Maybe<Int>) {
        (0, Some(0))
    }
}

implement<T> ExactSizeIterator for Empty<T> {
    fn len(&self) -> Int {
        0
    }
}

/// Repeat-with iterator: yields values by calling a function on each iteration.
public type RepeatWith<T, F> is { f: F, _phantom: Maybe<T> };

implement<T, F: fn() -> T> Iterator for RepeatWith<T, F> {
    type Item = T;

    fn next(&mut self) -> Maybe<T> {
        Some((self.f)())
    }

    fn size_hint(&self) -> (Int, Maybe<Int>) {
        (Int.max_value(), None)
    }
}

/// Once-with iterator: yields exactly one lazily computed element.
public type OnceWith<T, F> is { f: Maybe<F>, _phantom: Maybe<T> };

implement<T, F: fn() -> T> Iterator for OnceWith<T, F> {
    type Item = T;

    fn next(&mut self) -> Maybe<T> {
        let f = self.f.take()?;
        Some(f())
    }

    fn size_hint(&self) -> (Int, Maybe<Int>) {
        let n = if self.f.is_some() { 1 } else { 0 };
        (n, Some(n))
    }
}

implement<T, F: fn() -> T> ExactSizeIterator for OnceWith<T, F> {
    fn len(&self) -> Int {
        if self.f.is_some() { 1 } else { 0 }
    }
}

/// Iterator from function.
public type FromFn<F> is { f: F };

implement<T, F: fn() -> Maybe<T>> Iterator for FromFn<F> {
    type Item = T;

    fn next(&mut self) -> Maybe<T> {
        (self.f)()
    }
}

/// Unfold iterator.
public type Unfold<St, F> is { state: St, f: F };

implement<St, T, F: fn(&mut St) -> Maybe<T>> Iterator for Unfold<St, F> {
    type Item = T;

    fn next(&mut self) -> Maybe<T> {
        (self.f)(&mut self.state)
    }
}

/// Successors iterator.
public type Successors<T, F> is { next: Maybe<T>, f: F };

implement<T: Clone, F: fn(&T) -> Maybe<T>> Iterator for Successors<T, F> {
    type Item = T;

    fn next(&mut self) -> Maybe<T> {
        let current = self.next.take()?;
        self.next = (self.f)(&current);
        Some(current)
    }
}

// =============================================================================
// Transducers - Composable Algorithmic Transformations
// Spec: docs/improvements.md Section 17.3
// =============================================================================
//
// Transducers provide a way to compose sequence transformations that:
// 1. Execute in a single pass (no intermediate collections)
// 2. Are independent of input/output sources
// 3. Can be reused across different data structures
//
// Example:
// ```verum
// let xform = Transducer.compose([
//     Transducer.filter(|x| x > 0),
//     Transducer.map(|x| x * 2),
//     Transducer.take(10),
// ]);
//
// // Apply to any iterator - single pass, no intermediates
// let result = data.iter().transduce(xform).collect();
// ```
// =============================================================================

/// A reducing function that accumulates values.
///
/// The core abstraction for transducers. A reducing function takes
/// an accumulator and an input value, returning an updated accumulator.
public type Reducer<A, R> is fn(R, A) -> ReduceResult<R>;

/// Result of a reduce step - either continue or early termination.
public type ReduceResult<R> is Continue(R) | Reduced(R);

implement<R> ReduceResult<R> {
    /// Unwrap the result value regardless of termination state.
    fn unwrap(self) -> R {
        match self {
            Continue(r) => r,
            Reduced(r) => r,
        }
    }

    /// Check if this is an early termination.
    fn is_reduced(&self) -> Bool {
        match self {
            Reduced(_) => true,
            _ => false,
        }
    }

    /// Map the inner value.
    fn map<S>(self, f: fn(R) -> S) -> ReduceResult<S> {
        match self {
            Continue(r) => Continue(f(r)),
            Reduced(r) => Reduced(f(r)),
        }
    }
}

/// A transducer transforms one reducing function into another.
///
/// Transducers are the composable units of transformation. They describe
/// how to transform the step function of a fold operation, enabling:
/// - Single-pass execution (no intermediate collections)
/// - Composition of multiple transformations
/// - Source/sink independence
///
/// # Type Parameters
/// - `A`: Input element type
/// - `B`: Output element type
///
/// The transformation function is rank-2 polymorphic: it works with any
/// accumulator type R. This enables transducers to be composed and reused
/// across different reduction contexts without loss of type information.
///
/// # Example
/// ```verum
/// // A transducer can be applied to any accumulator type:
/// let xform: Transducer<Int, Int> = Transducer.map(|x| x * 2);
///
/// // Use with a List accumulator
/// let result1: List<Int> = data.iter().transduce(xform).collect();
///
/// // Use with a sum accumulator
/// let result2: Int = data.iter().transduce_fold(xform, 0, |acc, x| acc + x);
/// ```
public type Transducer<A, B> is {
    /// The transformation function.
    /// Takes a downstream reducer (for any accumulator type R) and returns
    /// an upstream reducer that processes A values and delegates to the downstream.
    transform: fn<R>(Reducer<B, R>) -> Reducer<A, R>,
};

/// Transducer factory functions and composition.
public module Transducer {
    /// Create a mapping transducer.
    ///
    /// Transforms each input element using the provided function.
    ///
    /// # Example
    /// ```verum
    /// let double = Transducer.map(|x| x * 2);
    /// ```
    public fn map<A, B, F: fn(A) -> B>(f: F) -> Transducer<A, B> {
        Transducer {
            transform: |downstream| {
                |acc, x| downstream(acc, f(x))
            }
        }
    }

    /// Create a filtering transducer.
    ///
    /// Only passes through elements that satisfy the predicate.
    ///
    /// # Example
    /// ```verum
    /// let evens = Transducer.filter(|x| x % 2 == 0);
    /// ```
    public fn filter<A, P: fn(&A) -> Bool>(pred: P) -> Transducer<A, A> {
        Transducer {
            transform: |downstream| {
                |acc, x| {
                    if pred(&x) {
                        downstream(acc, x)
                    } else {
                        Continue(acc)
                    }
                }
            }
        }
    }

    /// Create a filter-map transducer.
    ///
    /// Maps and filters in one step - None values are filtered out.
    ///
    /// # Example
    /// ```verum
    /// let parse_valid = Transducer.filter_map(|s| s.parse_int().ok());
    /// ```
    public fn filter_map<A, B, F: fn(A) -> Maybe<B>>(f: F) -> Transducer<A, B> {
        Transducer {
            transform: |downstream| {
                |acc, x| {
                    match f(x) {
                        Some(y) => downstream(acc, y),
                        None => Continue(acc),
                    }
                }
            }
        }
    }

    /// Create a take transducer.
    ///
    /// Takes only the first n elements, then signals early termination.
    ///
    /// # Example
    /// ```verum
    /// let first_10 = Transducer.take(10);
    /// ```
    public fn take<A>(n: Int) -> StatefulTransducer<A, A, Int> {
        StatefulTransducer {
            initial_state: n,
            transform: |downstream, remaining| {
                |acc, x| {
                    if *remaining > 0 {
                        *remaining = *remaining - 1;
                        let result = downstream(acc, x);
                        if *remaining == 0 {
                            Reduced(result.unwrap())
                        } else {
                            result
                        }
                    } else {
                        Reduced(acc)
                    }
                }
            }
        }
    }

    /// Create a drop transducer.
    ///
    /// Skips the first n elements, passes through the rest.
    ///
    /// # Example
    /// ```verum
    /// let skip_header = Transducer.drop(1);
    /// ```
    public fn drop<A>(n: Int) -> StatefulTransducer<A, A, Int> {
        StatefulTransducer {
            initial_state: n,
            transform: |downstream, remaining| {
                |acc, x| {
                    if *remaining > 0 {
                        *remaining = *remaining - 1;
                        Continue(acc)
                    } else {
                        downstream(acc, x)
                    }
                }
            }
        }
    }

    /// Create a take-while transducer.
    ///
    /// Takes elements while predicate is true, then terminates.
    ///
    /// # Example
    /// ```verum
    /// let while_positive = Transducer.take_while(|x| *x > 0);
    /// ```
    public fn take_while<A, P: fn(&A) -> Bool>(pred: P) -> Transducer<A, A> {
        Transducer {
            transform: |downstream| {
                |acc, x| {
                    if pred(&x) {
                        downstream(acc, x)
                    } else {
                        Reduced(acc)
                    }
                }
            }
        }
    }

    /// Create a drop-while transducer.
    ///
    /// Drops elements while predicate is true, passes rest.
    public fn drop_while<A, P: fn(&A) -> Bool>(pred: P) -> StatefulTransducer<A, A, Bool> {
        StatefulTransducer {
            initial_state: true,  // Still dropping
            transform: |downstream, dropping| {
                |acc, x| {
                    if *dropping && pred(&x) {
                        Continue(acc)  // Keep dropping
                    } else {
                        *dropping = false;
                        downstream(acc, x)
                    }
                }
            }
        }
    }

    /// Create a deduplicating transducer.
    ///
    /// Removes consecutive duplicates.
    public fn dedupe<A: Eq + Clone>() -> StatefulTransducer<A, A, Maybe<A>> {
        StatefulTransducer {
            initial_state: None,
            transform: |downstream, last| {
                |acc, x| {
                    let dominated = match last {
                        Some(ref prev) => *prev == x,
                        None => false,
                    };
                    if dominated {
                        Continue(acc)
                    } else {
                        *last = Some(x.clone());
                        downstream(acc, x)
                    }
                }
            }
        }
    }

    /// Compose two transducers into one.
    ///
    /// The resulting transducer first applies `first`, then `second`.
    /// Composition is associative: (a ∘ b) ∘ c = a ∘ (b ∘ c)
    ///
    /// # Example
    /// ```verum
    /// let pipeline = Transducer.compose2(
    ///     Transducer.filter(|x| *x > 0),
    ///     Transducer.map(|x| x * 2)
    /// );
    /// ```
    public fn compose2<A, B, C>(
        first: Transducer<A, B>,
        second: Transducer<B, C>
    ) -> Transducer<A, C> {
        Transducer {
            transform: |downstream| {
                let second_step = (second.transform)(downstream);
                (first.transform)(second_step)
            }
        }
    }

    /// Compose a list of transducers.
    ///
    /// Applies transducers left-to-right in the list.
    ///
    /// # Example
    /// ```verum
    /// let pipeline = Transducer.compose([
    ///     Transducer.filter(|x| *x > 0),
    ///     Transducer.map(|x| x * 2),
    ///     Transducer.take(10),
    /// ]);
    /// ```
    public fn compose<A>(transducers: List<Transducer<A, A>>) -> Transducer<A, A> {
        transducers.into_iter().fold(
            Transducer.identity(),
            |acc, t| Transducer.compose2(acc, t)
        )
    }

    /// Identity transducer - passes all elements unchanged.
    public fn identity<A>() -> Transducer<A, A> {
        Transducer {
            transform: |downstream| downstream
        }
    }

    /// Create an inspect transducer for debugging.
    ///
    /// Calls the function on each element without modifying it.
    public fn inspect<A, F: fn(&A)>(f: F) -> Transducer<A, A> {
        Transducer {
            transform: |downstream| {
                |acc, x| {
                    f(&x);
                    downstream(acc, x)
                }
            }
        }
    }

    /// Create an enumerate transducer.
    ///
    /// Pairs each element with its index.
    public fn enumerate<A>() -> StatefulTransducer<A, (Int, A), Int> {
        StatefulTransducer {
            initial_state: 0,
            transform: |downstream, index| {
                |acc, x| {
                    let i = *index;
                    *index = i + 1;
                    downstream(acc, (i, x))
                }
            }
        }
    }
}

/// Stateful transducer that maintains state across elements.
///
/// Used for transducers like `take`, `drop`, `dedupe` that need
/// to track state between invocations.
///
/// The transformation function is rank-2 polymorphic with additional
/// mutable state access, enabling stateful transformations that work
/// with any accumulator type.
public type StatefulTransducer<A, B, S> is {
    initial_state: S,
    transform: fn<R>(Reducer<B, R>, &mut S) -> Reducer<A, R>,
};

/// Extension methods for applying transducers to iterators.
implement<I: Iterator> I {
    /// Apply a transducer to this iterator.
    ///
    /// Returns a new iterator that applies the transducer's transformations
    /// in a single pass without intermediate collections.
    ///
    /// # Example
    /// ```verum
    /// let xform = Transducer.compose([
    ///     Transducer.filter(|x| *x > 0),
    ///     Transducer.map(|x| x * 2),
    /// ]);
    ///
    /// let result = numbers.iter()
    ///     .transduce(xform)
    ///     .collect();
    /// ```
    fn transduce<B>(self, xform: Transducer<Self.Item, B>) -> TransducedIter<Self, B> {
        TransducedIter {
            source: self,
            transform: xform.transform,
            buffer: List.new(),
        }
    }

    /// Apply a stateful transducer to this iterator.
    fn transduce_stateful<B, S>(
        self,
        xform: StatefulTransducer<Self.Item, B, S>
    ) -> StatefulTransducedIter<Self, B, S> {
        StatefulTransducedIter {
            source: self,
            state: xform.initial_state,
            transform: xform.transform,
            buffer: List.new(),
            done: false,
        }
    }

    /// Fold with early termination support.
    ///
    /// Like regular fold, but the reducer can signal early termination
    /// by returning `Reduced(acc)`.
    fn reduce_with<R, F: fn(R, Self.Item) -> ReduceResult<R>>(
        mut self,
        init: R,
        f: F
    ) -> R {
        let mut acc = init;
        while let Some(x) = self.next() {
            match f(acc, x) {
                Continue(new_acc) => acc = new_acc,
                Reduced(final_acc) => return final_acc,
            }
        }
        acc
    }
}

/// Iterator adapter for transduced iteration.
///
/// Stores the rank-2 transformation function and applies it lazily
/// as elements are pulled from the iterator.
type TransducedIter<I: Iterator, B> is {
    source: I,
    transform: fn<R>(Reducer<B, R>) -> Reducer<I.Item, R>,
    buffer: List<B>,
};

implement<I: Iterator, B> Iterator for TransducedIter<I, B> {
    type Item = B;

    fn next(&mut self) -> Maybe<B> {
        // If we have buffered results, return from buffer
        if !self.buffer.is_empty() {
            return Some(self.buffer.remove(0));
        }

        // Create a reducer that collects to our buffer
        let collecting_reducer: Reducer<B, ()> = |(), x| {
            self.buffer.push(x);
            Continue(())
        };

        // Transform the reducer with our transducer
        let transformed = (self.transform)(collecting_reducer);

        // Pull from source until we have output or source exhausted
        while self.buffer.is_empty() {
            match self.source.next() {
                Some(x) => {
                    match transformed((), x) {
                        Reduced(_) => break,  // Early termination
                        Continue(_) => {}
                    }
                }
                None => break,
            }
        }

        if !self.buffer.is_empty() {
            Some(self.buffer.remove(0))
        } else {
            None
        }
    }
}

/// Iterator adapter for stateful transduced iteration.
///
/// Like TransducedIter but with additional mutable state for
/// transformations that need to track state across elements.
type StatefulTransducedIter<I: Iterator, B, S> is {
    source: I,
    state: S,
    transform: fn<R>(Reducer<B, R>, &mut S) -> Reducer<I.Item, R>,
    buffer: List<B>,
    done: Bool,
};

implement<I: Iterator, B, S> Iterator for StatefulTransducedIter<I, B, S> {
    type Item = B;

    fn next(&mut self) -> Maybe<B> {
        if self.done {
            return None;
        }

        // If we have buffered results, return from buffer
        if !self.buffer.is_empty() {
            return Some(self.buffer.remove(0));
        }

        // Create a reducer that collects to our buffer
        let collecting_reducer: Reducer<B, ()> = |(), x| {
            self.buffer.push(x);
            Continue(())
        };

        // Transform with state
        let transformed = (self.transform)(collecting_reducer, &mut self.state);

        // Pull from source until we have output or termination
        while self.buffer.is_empty() {
            match self.source.next() {
                Some(x) => {
                    match transformed((), x) {
                        Reduced(_) => {
                            self.done = true;
                            break;
                        }
                        Continue(_) => {}
                    }
                }
                None => {
                    self.done = true;
                    break;
                }
            }
        }

        if !self.buffer.is_empty() {
            Some(self.buffer.remove(0))
        } else {
            None
        }
    }
}

// =============================================================================
// IntoIterator implementations for all iterator adapters
// =============================================================================
// These implementations allow iterator adapters to be used in for loops directly.

implement<I: Iterator, B, F: fn(I.Item) -> B> IntoIterator for MappedIter<I, F> {
    type Item = B;
    type IntoIter = MappedIter<I, F>;
    fn into_iter(self) -> MappedIter<I, F> { self }
}

implement<I: Iterator, P: fn(&I.Item) -> Bool> IntoIterator for FilterIter<I, P> {
    type Item = I.Item;
    type IntoIter = FilterIter<I, P>;
    fn into_iter(self) -> FilterIter<I, P> { self }
}

implement<I: Iterator, B, F: fn(I.Item) -> Maybe<B>> IntoIterator for FilterMapIter<I, F> {
    type Item = B;
    type IntoIter = FilterMapIter<I, F>;
    fn into_iter(self) -> FilterMapIter<I, F> { self }
}

implement<I: Iterator, U: Iterator, F: fn(I.Item) -> U> IntoIterator for FlatMapIter<I, U, F> {
    type Item = U.Item;
    type IntoIter = FlatMapIter<I, U, F>;
    fn into_iter(self) -> FlatMapIter<I, U, F> { self }
}

implement<I: Iterator> IntoIterator for TakeIter<I> {
    type Item = I.Item;
    type IntoIter = TakeIter<I>;
    fn into_iter(self) -> TakeIter<I> { self }
}

implement<I: Iterator> IntoIterator for SkipIter<I> {
    type Item = I.Item;
    type IntoIter = SkipIter<I>;
    fn into_iter(self) -> SkipIter<I> { self }
}

