implement Iterator for RangeInclusive<Int> {
    type Item = Int;

    fn next(&mut self) -> Maybe<Int> {
        if self.done {
            return None;
        }
        if self.current < self.end {
            let val = self.current;
            self.current = self.current + 1;
            Some(val)
        } else if self.current == self.end {
            self.done = true;
            Some(self.current)
        } else {
            None
        }
    }
}

implement DoubleEndedIterator for RangeInclusive<Int> {
    fn next_back(&mut self) -> Maybe<Int> {
        if self.done {
            return None;
        }
        if self.current < self.end {
            let val = self.end;
            self.end = self.end - 1;
            Some(val)
        } else if self.current == self.end {
            self.done = true;
            Some(self.end)
        } else {
            None
        }
    }
}

implement ExactSizeIterator for RangeInclusive<Int> {
    fn len(&self) -> Int {
        if self.done {
            0
        } else {
            (self.end - self.current + 1).max(0)
        }
    }
}

