    public fn to_int(self) -> Int { self as Int }
    public fn overflowing_add(self, rhs: UInt128) -> (UInt128, Bool) { overflowing_add(self, rhs) }
    public fn overflowing_sub(self, rhs: UInt128) -> (UInt128, Bool) { overflowing_sub(self, rhs) }
    public fn overflowing_mul(self, rhs: UInt128) -> (UInt128, Bool) { overflowing_mul(self, rhs) }
    public fn reverse_bits(self) -> UInt128 { bitreverse(self) }
    public fn rotate_left(self, n: Int) -> UInt128 { rotl(self, n) }
    public fn rotate_right(self, n: Int) -> UInt128 { rotr(self, n) }
    public fn to_binary(self) -> Text { self.to_int().to_binary() }
    public fn to_hex(self) -> Text { self.to_int().to_hex() }
    public fn to_octal(self) -> Text { self.to_int().to_octal() }
    public fn checked_rem(self, rhs: UInt128) -> Maybe<UInt128> {
        if rhs == (0 as UInt128) { None } else { Some(rem(self, rhs)) }
    }
    public fn wrapping_neg(self) -> UInt128 { wrapping_neg(self) }
    public fn ilog2(self) -> Int {
        assert(self.to_int() > 0);
        127 - self.leading_zeros()
    }
    public fn is_power_of_two(self) -> Bool {
        let n = self.to_int();
        n > 0 && bitand(n, n - 1) == 0
    }
    public fn checked_shl(self, shift: Int) -> Maybe<UInt128> {
        if shift < 0 || shift >= 128 { None } else { Some(shl(self, shift as UInt32)) }
    }
    public fn checked_shr(self, shift: Int) -> Maybe<UInt128> {
        if shift < 0 || shift >= 128 { None } else { Some(shr(self, shift as UInt32)) }
    }
    public fn checked_pow(self, exp: Int) -> Maybe<UInt128> {
        if exp < 0 { None }
        else if exp == 0 { Some(1 as UInt128) }
        else {
            let mut base = self;
            let mut e = exp;
            let mut result = 1 as UInt128;
            let mut overflow = false;
            while e > 0 && !overflow {
                if bitand(e, 1) == 1 {
                    match result.checked_mul(base) {
                        Some(v) => { result = v; },
                        None => { overflow = true; },
                    };
                }
                e = e >> 1;
                if e > 0 && !overflow {
                    match base.checked_mul(base) {
                        Some(v) => { base = v; },
                        None => { overflow = true; },
                    };
                }
            }
            if overflow { None } else { Some(result) }
        }
    }
    public fn wrapping_shl(self, shift: Int) -> UInt128 { shl(self, (bitand(shift, 127)) as UInt32) }
    public fn wrapping_shr(self, shift: Int) -> UInt128 { shr(self, (bitand(shift, 127)) as UInt32) }
    public fn wrapping_div(self, rhs: UInt128) -> UInt128 { div(self, rhs) }
    public fn wrapping_rem(self, rhs: UInt128) -> UInt128 { rem(self, rhs) }
    public fn div_euclid(self, rhs: UInt128) -> UInt128 { div(self, rhs) }
    public fn rem_euclid(self, rhs: UInt128) -> UInt128 { rem(self, rhs) }
    public fn saturating_pow(self, exp: Int) -> UInt128 {
        match self.checked_pow(exp) { Some(v) => v, None => UInt128.MAX }
    }
    public fn overflowing_shl(self, shift: Int) -> (UInt128, Bool) {
        (shl(self, (bitand(shift, 127)) as UInt32), shift < 0 || shift >= 128)
    }
    public fn overflowing_shr(self, shift: Int) -> (UInt128, Bool) {
        (shr(self, (bitand(shift, 127)) as UInt32), shift < 0 || shift >= 128)
    }
    public fn midpoint(self, other: UInt128) -> UInt128 {
        let a = self.to_int();
        let b = other.to_int();
        ((a >> 1) + (b >> 1) + bitand(bitand(a, b), 1)) as UInt128
    }
    public fn to_ne_bytes(self) -> List<Byte> { to_le_bytes(self) }
    public fn from_ne_bytes(bytes: List<Byte>) -> UInt128 { from_le_bytes(bytes) }
    public fn abs_diff(self, other: UInt128) -> Int {
        let a = self.to_int();
        let b = other.to_int();
        if a >= b { a - b } else { b - a }
    }
    public fn ilog10(self) -> Int {
        assert(self.to_int() > 0);
        let mut n = self.to_int();
        let mut count = 0;
        while n >= 10 {
            n = n / 10;
            count = count + 1;
        }
        count
    }
    public fn next_power_of_two(self) -> UInt128 {
        let n = self.to_int();
        if n <= 1 { 1 as UInt128 }
        else {
            let shift = 128 - (n - 1).leading_zeros();
            (1 << shift) as UInt128
        }
    }
}

// =============================================================================
