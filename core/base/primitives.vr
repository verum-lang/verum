implement Eq for Int16 {
    public fn eq(&self, other: &Int16) -> Bool { eq(*self, *other) }
}
implement Ord for Int16 {
    public fn cmp(&self, other: &Int16) -> Ordering {
        if *self < *other { Less }
        else if *self > *other { Greater }
        else { Equal }
    }
}
implement Hash for Int16 {
    public fn hash(&self, hasher: &mut Hasher) { hasher.write_int(*self as Int); }
}
implement Clone for Int16 {
    public fn clone(&self) -> Int16 { *self }
}
implement Copy for Int16 {}

