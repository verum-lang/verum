    public fn mul_assign(&mut self, rhs: Float64) { *self = *self * rhs; }
}

implement DivAssign<Float64> for Float64 {
    public fn div_assign(&mut self, rhs: Float64) { *self = *self / rhs; }
}

implement RemAssign<Float64> for Float64 {
    public fn rem_assign(&mut self, rhs: Float64) { *self = *self % rhs; }
}

