    public fn max(self, other: ISize) -> ISize { intrinsic_max(self, other) }
    public fn clamp(self, min_val: ISize, max_val: ISize) -> ISize { intrinsic_clamp(self, min_val, max_val) }
    public fn checked_add(self, rhs: ISize) -> Maybe<ISize> { checked_add(self, rhs) }
    public fn checked_sub(self, rhs: ISize) -> Maybe<ISize> { checked_sub(self, rhs) }
    public fn checked_mul(self, rhs: ISize) -> Maybe<ISize> { checked_mul(self, rhs) }
