// =============================================================================
// TryFrom Narrowing Conversions for Sized Integer Types
// =============================================================================
// These enable checked narrowing conversions from Int (i64) to smaller integer
// types. Unlike `as` casts which silently truncate, TryFrom returns an error
// when the value doesn't fit in the target range.
// =============================================================================

/// Error type for failed integer conversions.
public type TryFromIntError is {
    _private: (),
};

implement TryFromIntError {
    public fn new() -> TryFromIntError {
        TryFromIntError { _private: () }
    }
}

implement Debug for TryFromIntError {
    public fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("TryFromIntError(out of range)")
    }
}

implement Display for TryFromIntError {
    public fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("out of range integral type conversion attempted")
    }
}

implement Eq for TryFromIntError {
    public fn eq(&self, _other: &TryFromIntError) -> Bool { true }
}

// --- TryFrom<Int> for signed types ---

implement TryFrom<Int> for Int8 {
    type Error = TryFromIntError;

    public fn try_from(value: Int) -> Result<Int8, TryFromIntError> {
        if value >= -128 && value <= 127 {
            Ok(value as Int8)
        } else {
            Err(TryFromIntError.new())
        }
    }
}

implement TryFrom<Int> for Int16 {
    type Error = TryFromIntError;

    public fn try_from(value: Int) -> Result<Int16, TryFromIntError> {
        if value >= -32768 && value <= 32767 {
            Ok(value as Int16)
        } else {
            Err(TryFromIntError.new())
        }
    }
}

implement TryFrom<Int> for Int32 {
    type Error = TryFromIntError;

    public fn try_from(value: Int) -> Result<Int32, TryFromIntError> {
        if value >= -2147483648 && value <= 2147483647 {
            Ok(value as Int32)
        } else {
            Err(TryFromIntError.new())
        }
    }
}

// --- TryFrom<Int> for unsigned types ---

implement TryFrom<Int> for UInt8 {
    type Error = TryFromIntError;

    public fn try_from(value: Int) -> Result<UInt8, TryFromIntError> {
        if value >= 0 && value <= 255 {
            Ok(value as UInt8)
        } else {
            Err(TryFromIntError.new())
        }
    }
}

implement TryFrom<Int> for UInt16 {
    type Error = TryFromIntError;

    public fn try_from(value: Int) -> Result<UInt16, TryFromIntError> {
        if value >= 0 && value <= 65535 {
            Ok(value as UInt16)
        } else {
            Err(TryFromIntError.new())
        }
    }
}

implement TryFrom<Int> for UInt32 {
    type Error = TryFromIntError;

    public fn try_from(value: Int) -> Result<UInt32, TryFromIntError> {
        if value >= 0 && value <= 4294967295 {
            Ok(value as UInt32)
        } else {
            Err(TryFromIntError.new())
        }
    }
}

implement TryFrom<Int> for UInt64 {
    type Error = TryFromIntError;

    public fn try_from(value: Int) -> Result<UInt64, TryFromIntError> {
        if value >= 0 {
            Ok(value as UInt64)
        } else {
            Err(TryFromIntError.new())
        }
    }
}

// =============================================================================
// Cross-Type TryFrom Narrowing Conversions
// =============================================================================
// These enable checked narrowing between any pair of sized integer types,
// not just from Int. Essential for safe numeric interop.

// --- Int32 → smaller signed types ---

implement TryFrom<Int32> for Int16 {
    type Error = TryFromIntError;

    public fn try_from(value: Int32) -> Result<Int16, TryFromIntError> {
        let v = value.to_int();
        if v >= -32768 && v <= 32767 {
            Ok(v as Int16)
        } else {
            Err(TryFromIntError.new())
        }
    }
}

implement TryFrom<Int32> for Int8 {
    type Error = TryFromIntError;

    public fn try_from(value: Int32) -> Result<Int8, TryFromIntError> {
        let v = value.to_int();
        if v >= -128 && v <= 127 {
            Ok(v as Int8)
        } else {
            Err(TryFromIntError.new())
        }
    }
}

// --- Int16 → Int8 ---

implement TryFrom<Int16> for Int8 {
    type Error = TryFromIntError;

    public fn try_from(value: Int16) -> Result<Int8, TryFromIntError> {
        let v = value.to_int();
        if v >= -128 && v <= 127 {
            Ok(v as Int8)
        } else {
            Err(TryFromIntError.new())
        }
    }
}

// --- UInt64 → smaller unsigned types ---

implement TryFrom<UInt64> for UInt32 {
    type Error = TryFromIntError;

    public fn try_from(value: UInt64) -> Result<UInt32, TryFromIntError> {
        let v = value.to_int();
        if v >= 0 && v <= 4294967295 {
            Ok(v as UInt32)
        } else {
            Err(TryFromIntError.new())
        }
    }
}

// --- UInt32 → smaller unsigned types ---

implement TryFrom<UInt32> for UInt16 {
    type Error = TryFromIntError;

    public fn try_from(value: UInt32) -> Result<UInt16, TryFromIntError> {
        let v = value.to_int();
        if v >= 0 && v <= 65535 {
            Ok(v as UInt16)
        } else {
            Err(TryFromIntError.new())
        }
    }
}

implement TryFrom<UInt32> for UInt8 {
    type Error = TryFromIntError;

    public fn try_from(value: UInt32) -> Result<UInt8, TryFromIntError> {
        let v = value.to_int();
        if v >= 0 && v <= 255 {
            Ok(v as UInt8)
        } else {
            Err(TryFromIntError.new())
        }
    }
}

// --- UInt16 → UInt8 ---

implement TryFrom<UInt16> for UInt8 {
    type Error = TryFromIntError;

    public fn try_from(value: UInt16) -> Result<UInt8, TryFromIntError> {
        let v = value.to_int();
        if v >= 0 && v <= 255 {
            Ok(v as UInt8)
        } else {
            Err(TryFromIntError.new())
        }
    }
}

// --- Cross-sign: UInt64 → Int (overflow when > Int.MAX) ---

implement TryFrom<UInt64> for Int {
    type Error = TryFromIntError;

    public fn try_from(value: UInt64) -> Result<Int, TryFromIntError> {
        // UInt64 can hold values > Int.MAX (9223372036854775807)
        // We convert to Int; if original value was > Int.MAX, the result will be negative
        let v = value as Int;
        if v >= 0 {
            Ok(v)
        } else {
            Err(TryFromIntError.new())
        }
    }
}

// --- Cross-sign: unsigned → smaller signed ---

implement TryFrom<UInt32> for Int16 {
    type Error = TryFromIntError;

    public fn try_from(value: UInt32) -> Result<Int16, TryFromIntError> {
        let v = value.to_int();
        if v >= 0 && v <= 32767 {
            Ok(v as Int16)
        } else {
            Err(TryFromIntError.new())
        }
    }
}

implement TryFrom<UInt16> for Int8 {
    type Error = TryFromIntError;

    public fn try_from(value: UInt16) -> Result<Int8, TryFromIntError> {
        let v = value.to_int();
        if v >= 0 && v <= 127 {
            Ok(v as Int8)
        } else {
            Err(TryFromIntError.new())
        }
    }
}

// =============================================================================
// from_str_radix for all sized integer types
// =============================================================================

implement Int8 {
    /// Parse a string in the given radix (2..36) into an Int8.
    public fn from_str_radix(text: &Text, radix: Int) -> Maybe<Int8> {
        match Int.from_str_radix(text, radix) {
            None => None,
            Some(v) => {
                if v >= -128 && v <= 127 { Some(v as Int8) }
                else { None }
            }
        }
    }
}

implement Int16 {
    public fn from_str_radix(text: &Text, radix: Int) -> Maybe<Int16> {
        match Int.from_str_radix(text, radix) {
            None => None,
            Some(v) => {
                if v >= -32768 && v <= 32767 { Some(v as Int16) }
                else { None }
            }
        }
    }
}

