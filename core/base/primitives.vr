// --- Int ---

implement AddAssign<Int> for Int {
    public fn add_assign(&mut self, rhs: Int) { *self = *self + rhs; }
}

implement SubAssign<Int> for Int {
    public fn sub_assign(&mut self, rhs: Int) { *self = *self - rhs; }
}

implement MulAssign<Int> for Int {
    public fn mul_assign(&mut self, rhs: Int) { *self = *self * rhs; }
}

implement DivAssign<Int> for Int {
    public fn div_assign(&mut self, rhs: Int) { *self = *self / rhs; }
}

implement RemAssign<Int> for Int {
    public fn rem_assign(&mut self, rhs: Int) { *self = *self % rhs; }
}

implement BitAndAssign<Int> for Int {
    public fn bitand_assign(&mut self, rhs: Int) { *self = *self & rhs; }
}

implement BitOrAssign<Int> for Int {
    public fn bitor_assign(&mut self, rhs: Int) { *self = *self | rhs; }
}

implement BitXorAssign<Int> for Int {
    public fn bitxor_assign(&mut self, rhs: Int) { *self = *self ^ rhs; }
}

implement ShlAssign<Int> for Int {
    public fn shl_assign(&mut self, rhs: Int) { *self = shl(*self, rhs); }
}

implement ShrAssign<Int> for Int {
    public fn shr_assign(&mut self, rhs: Int) { *self = shr(*self, rhs); }
}

