// =============================================================================
// primitives.vr - Methods on primitive types
// =============================================================================
// Layer: 0 (Core)
// Dependencies: protocols.vr, ordering.vr, stdlib.intrinsics
// Note: Primitive types (Int, Float, Bool, Byte, Char) are built-in.
//       This file defines their methods and protocol implementations.
//
// All intrinsic operations are imported from stdlib.intrinsics and called as
// regular functions. This eliminates boilerplate and demonstrates the power
// of Verum's generic intrinsic system.
// =============================================================================

module core.primitives;

// Import intrinsics from specific submodules for reliable resolution
// (glob re-exports via core.intrinsics may not propagate properly)
mount core.intrinsics.arithmetic.{
    add, sub, mul, div, rem, neg,
    abs_signed, signum, min, max, clamp,
    checked_add, checked_sub, checked_mul, checked_div,
    checked_add_u64, checked_sub_u64, checked_mul_u64,
    overflowing_add, overflowing_sub, overflowing_mul,
    wrapping_add, wrapping_sub, wrapping_mul, wrapping_neg, wrapping_shl, wrapping_shr,
    saturating_add, saturating_sub, saturating_mul,
};
mount core.intrinsics.bitwise.{
    clz, ctz, bswap, bitreverse, rotl, rotr,
    bitand, bitor, bitxor, bitnot, shl, shr,
};
mount core.intrinsics.arithmetic.{
    eq, ne, lt, le, gt, ge,
};
mount core.intrinsics.conversion.{
    int_to_float, float_to_int,
    f32_to_bits, f32_from_bits, f64_to_bits, f64_from_bits,
    to_le_bytes, to_be_bytes, from_le_bytes, from_be_bytes,
    to_le_bytes_2, to_le_bytes_4, to_le_bytes_8,
    to_be_bytes_2, to_be_bytes_4, to_be_bytes_8,
    from_le_bytes_2, from_le_bytes_4, from_le_bytes_8,
    from_be_bytes_2, from_be_bytes_4, from_be_bytes_8,
};
mount core.intrinsics.float.{
    f32_infinity, f32_neg_infinity, f32_nan,
    sqrt, cbrt, exp, expm1, exp2,
    log, log1p, log10, log2, pow, powi,
    floor, ceil, round, trunc, fabs,
    minnum, maxnum, fma, copysign, hypot,
    sin, cos, tan, asin, acos, atan, atan2,
    sinh, cosh, tanh, asinh, acosh, atanh,
};
mount core.intrinsics.runtime.text.{
    char_is_alphabetic, char_is_numeric, char_is_whitespace, char_is_control,
    char_is_uppercase, char_is_lowercase,
    char_to_uppercase, char_to_lowercase, char_encode_utf8, char_escape_debug,
};

// Aliases for backward compatibility with code using intrinsic_min/max/clamp names
fn intrinsic_min<T>(a: T, b: T) -> T { min(a, b) }
fn intrinsic_max<T>(a: T, b: T) -> T { max(a, b) }
fn intrinsic_clamp<T>(val: T, lo: T, hi: T) -> T { clamp(val, lo, hi) }

// Popcount and bitreverse: provide as direct intrinsic calls
fn popcnt<T>(x: T) -> T { @intrinsic("ctpop", x) }

// =============================================================================
// Int - 64-bit signed integer
// =============================================================================

implement Int {
    /// Minimum value (-2^63).
    public const MIN: Int = -9223372036854775808;

    /// Maximum value (2^63 - 1).
    public const MAX: Int = 9223372036854775807;

    /// Number of bits.
    public const BITS: Int = 64;

    /// The minimum value an Int can hold (deprecated: use MIN).
    public meta fn min_value() -> Int {
        -9223372036854775808
    }

    /// The maximum value an Int can hold (deprecated: use MAX).
    public meta fn max_value() -> Int {
        9223372036854775807
    }

    /// Absolute value.
    public fn abs(self) -> Int {
        abs_signed(self)
    }

    /// Signum: -1, 0, or 1.
    public fn signum(self) -> Int {
        signum(self)
    }

    /// Check if positive (> 0).
    public fn is_positive(self) -> Bool {
        self > 0
    }

    /// Check if negative (< 0).
    public fn is_negative(self) -> Bool {
        self < 0
    }

    /// Check if zero.
    public fn is_zero(self) -> Bool {
        self == 0
    }

    /// Convert to floating point.
    public fn to_float(self) -> Float {
        int_to_float(self)
    }

    /// Minimum of two values.
    public fn min(self, other: Int) -> Int {
        intrinsic_min(self, other)
    }

    /// Maximum of two values.
    public fn max(self, other: Int) -> Int {
        intrinsic_max(self, other)
    }

    /// Clamp between min and max (inclusive).
    public fn clamp(self, min_val: Int, max_val: Int) -> Int {
        intrinsic_clamp(self, min_val, max_val)
    }

    /// Check if in range [start, end).
    public fn in_range(self, start: Int, end: Int) -> Bool {
        self >= start && self < end
    }

    /// Power (non-negative exponent).
    public fn pow(self, exp: Int) -> Int {
        assert(exp >= 0, "Negative exponent not supported for Int");
        let mut res = 1;
        let mut base = self;
        let mut e = exp;
        while e > 0 {
            if e % 2 == 1 {
                res = res * base;
            }
            base = base * base;
            e = e / 2;
        }
        res
    }

    /// Checked addition (returns None on overflow).
    public fn checked_add(self, rhs: Int) -> Maybe<Int> {
        checked_add(self, rhs)
    }

    /// Checked subtraction.
    public fn checked_sub(self, rhs: Int) -> Maybe<Int> {
        checked_sub(self, rhs)
    }

    /// Checked multiplication.
    public fn checked_mul(self, rhs: Int) -> Maybe<Int> {
        checked_mul(self, rhs)
    }

    /// Checked division (returns None on division by zero).
    public fn checked_div(self, rhs: Int) -> Maybe<Int> {
        if rhs == 0 { None }
        else { Some(self / rhs) }
    }

    /// Wrapping addition (wraps on overflow).
    public fn wrapping_add(self, rhs: Int) -> Int {
        wrapping_add(self, rhs)
    }

    /// Wrapping subtraction.
    public fn wrapping_sub(self, rhs: Int) -> Int {
        wrapping_sub(self, rhs)
    }

    /// Wrapping multiplication.
    public fn wrapping_mul(self, rhs: Int) -> Int {
        wrapping_mul(self, rhs)
    }

    /// Saturating addition (saturates at bounds instead of overflow).
    public fn saturating_add(self, rhs: Int) -> Int {
        saturating_add(self, rhs)
    }

    /// Saturating subtraction.
    public fn saturating_sub(self, rhs: Int) -> Int {
        saturating_sub(self, rhs)
    }

    /// Saturating multiplication.
    public fn saturating_mul(self, rhs: Int) -> Int {
        saturating_mul(self, rhs)
    }

    /// Overflowing addition. Returns (result, overflowed).
    public fn overflowing_add(self, rhs: Int) -> (Int, Bool) {
        let result = self.wrapping_add(rhs);
        // Overflow if signs of operands are same but sign of result differs
        let overflow = if (self >= 0 && rhs >= 0 && result < 0) || (self < 0 && rhs < 0 && result >= 0) {
            true
        } else {
            false
        };
        (result, overflow)
    }

    /// Overflowing subtraction. Returns (result, overflowed).
    public fn overflowing_sub(self, rhs: Int) -> (Int, Bool) {
        let result = self.wrapping_sub(rhs);
        let overflow = if (self >= 0 && rhs < 0 && result < 0) || (self < 0 && rhs >= 0 && result >= 0) {
            true
        } else {
            false
        };
        (result, overflow)
    }

    /// Overflowing multiplication. Returns (result, overflowed).
    ///
    /// Critical: the standard `result / rhs != self` overflow
    /// test would itself trap (SIGFPE on x86) for the
    /// `Int.MIN * -1` case — `wrapping_mul` returns `Int.MIN`,
    /// and `Int.MIN / -1` is the divide-overflow case at the
    /// hardware level (LLVM treats it as UB). We detect that
    /// pair explicitly before falling through to the generic
    /// round-trip check.
    public fn overflowing_mul(self, rhs: Int) -> (Int, Bool) {
        let result = self.wrapping_mul(rhs);
        // Special case 1: rhs == 0 ⇒ result == 0, never overflow.
        // Special case 2: Int.MIN * -1 is the unique sdiv-trap
        //   pair; mathematically the product is `Int.MAX + 1`
        //   which doesn't fit, so overflow == true.
        if rhs == 0 {
            (result, false)
        } else if self == -9223372036854775808 && rhs == -1 {
            (result, true)
        } else {
            // Generic round-trip check is now safe — we've
            // ruled out the only sdiv-overflow pair.
            let overflow = result / rhs != self;
            (result, overflow)
        }
    }

    /// Count leading zeros.
    public fn leading_zeros(self) -> Int {
        clz(self)
    }

    /// Count trailing zeros.
    public fn trailing_zeros(self) -> Int {
        ctz(self)
    }

    /// Count ones (popcount).
    public fn count_ones(self) -> Int {
        popcnt(self)
    }

    /// Count zeros.
    public fn count_zeros(self) -> Int {
        64 - self.count_ones()
    }

    /// Swap bytes.
    public fn swap_bytes(self) -> Int {
        bswap(self)
    }

    /// Reverse bits.
    public fn reverse_bits(self) -> Int {
        bitreverse(self)
    }

    /// Rotate left.
    public fn rotate_left(self, n: Int) -> Int {
        rotl(self, n)
    }

    /// Rotate right.
    public fn rotate_right(self, n: Int) -> Int {
        rotr(self, n)
    }

    /// Convert to bytes (little-endian).
    public fn to_le_bytes(self) -> [Byte; 8] {
        to_le_bytes_8(self)
    }

    /// Convert to bytes (big-endian).
    public fn to_be_bytes(self) -> [Byte; 8] {
        to_be_bytes_8(self)
    }

    /// Create from bytes (little-endian).
    public fn from_le_bytes(bytes: [Byte; 8]) -> Int {
        from_le_bytes_8(bytes)
    }

    /// Create from bytes (big-endian).
    public fn from_be_bytes(bytes: [Byte; 8]) -> Int {
        from_be_bytes_8(bytes)
    }

    /// Convert to binary string representation in math convention:
    /// negative values render as `-` followed by the magnitude
    /// bits (e.g. `(-5).to_binary() == "-101"`), not as
    /// two's-complement bits. Use [`to_bits`] + a custom
    /// formatter if you want the raw 64-bit pattern.
    ///
    /// Correctly handles `Int.MIN`: the magnitude `2^63` doesn't
    /// fit in `Int`, so we accumulate digits in `UInt64`. The
    /// previous implementation used `self.abs()` which itself
    /// panics on `Int.MIN` (per intrinsics/arithmetic.vr).
    public fn to_binary(self) -> Text {
        format_radix_signed(self, 2)
    }

    /// Convert to hexadecimal string (lowercase digits, math
    /// convention for negatives — see [`to_binary`]).
    public fn to_hex(self) -> Text {
        format_radix_signed(self, 16)
    }

    /// Convert to octal string (math convention for negatives —
    /// see [`to_binary`]).
    public fn to_octal(self) -> Text {
        format_radix_signed(self, 8)
    }

    /// Checked remainder (returns None on division by zero).
    public fn checked_rem(self, rhs: Int) -> Maybe<Int> {
        if rhs == 0 { None } else { Some(self % rhs) }
    }

    /// Return the raw bit representation of this integer.
    ///
    /// For Int (i64), this is the identity function — the value already
    /// is its two's complement bit pattern.
    public fn to_bits(self) -> Int {
        self
    }

    /// Wrapping negation.
    public fn wrapping_neg(self) -> Int { wrapping_neg(self) }

    /// Checked negation (returns None for MIN since -MIN overflows).
    public fn checked_neg(self) -> Maybe<Int> {
        if self == -9223372036854775808 { None } else { Some(0 - self) }
    }

    /// Absolute difference (always non-negative).
    public fn abs_diff(self, other: Int) -> Int {
        if self >= other { self - other } else { other - self }
    }

    /// Integer base-2 logarithm. Panics if self <= 0.
    public fn ilog2(self) -> Int {
        assert(self > 0);
        63 - self.leading_zeros()
    }

    /// Integer base-10 logarithm. Panics if self <= 0.
    public fn ilog10(self) -> Int {
        assert(self > 0);
        let mut count = 0;
        let mut n = self;
        while n >= 10 {
            n = n / 10;
            count = count + 1;
        }
        count
    }

    /// Check if value is a power of two.
    public fn is_power_of_two(self) -> Bool {
        self > 0 && bitand(self, self - 1) == 0
    }

    /// Checked left shift. Returns None if shift >= 64.
    public fn checked_shl(self, shift: Int) -> Maybe<Int> {
        if shift < 0 || shift >= 64 { None } else { Some(self << shift) }
    }

    /// Checked right shift. Returns None if shift >= 64.
    public fn checked_shr(self, shift: Int) -> Maybe<Int> {
        if shift < 0 || shift >= 64 { None } else { Some(self >> shift) }
    }

    /// Checked exponentiation. Returns None on overflow.
    public fn checked_pow(self, exp: Int) -> Maybe<Int> {
        if exp < 0 { None }
        else if exp == 0 { Some(1) }
        else {
            let mut base = self;
            let mut e = exp;
            let mut result = 1;
            let mut overflow = false;
            while e > 0 && !overflow {
                if bitand(e, 1) == 1 {
                    match result.checked_mul(base) {
                        Some(v) => { result = v; },
                        None => { overflow = true; },
                    };
                }
                e = e >> 1;
                if e > 0 && !overflow {
                    match base.checked_mul(base) {
                        Some(v) => { base = v; },
                        None => { overflow = true; },
                    };
                }
            }
            if overflow { None } else { Some(result) }
        }
    }

    /// Wrapping left shift. Shift amount is masked to BITS-1.
    public fn wrapping_shl(self, shift: Int) -> Int {
        self << bitand(shift, 63)
    }

    /// Wrapping right shift. Shift amount is masked to BITS-1.
    public fn wrapping_shr(self, shift: Int) -> Int {
        self >> bitand(shift, 63)
    }

    /// Wrapping division. Same as normal division except MIN / -1 wraps to MIN.
    public fn wrapping_div(self, rhs: Int) -> Int {
        if self == -9223372036854775808 && rhs == -1 {
            -9223372036854775808
        } else {
            self / rhs
        }
    }

    /// Wrapping remainder. Same as normal remainder except MIN % -1 returns 0.
    public fn wrapping_rem(self, rhs: Int) -> Int {
        if self == -9223372036854775808 && rhs == -1 {
            0
        } else {
            self % rhs
        }
    }

    /// Euclidean division. Result rounded towards negative infinity.
    public fn div_euclid(self, rhs: Int) -> Int {
        let q = self / rhs;
        if self % rhs < 0 {
            if rhs > 0 { q - 1 } else { q + 1 }
        } else {
            q
        }
    }

    /// Euclidean remainder. Always non-negative.
    public fn rem_euclid(self, rhs: Int) -> Int {
        let r = self % rhs;
        if r < 0 {
            if rhs > 0 { r + rhs } else { r - rhs }
        } else {
            r
        }
    }

    /// Saturating exponentiation. Clamps to MIN/MAX on overflow.
    public fn saturating_pow(self, exp: Int) -> Int {
        match self.checked_pow(exp) {
            Some(v) => v,
            None => {
                if self < 0 && bitand(exp, 1) == 1 { -9223372036854775808 }
                else { 9223372036854775807 }
            },
        }
    }

    /// Overflowing left shift. Returns (result, shift >= BITS).
    public fn overflowing_shl(self, shift: Int) -> (Int, Bool) {
        (self << bitand(shift, 63), shift >= 64)
    }

    /// Overflowing right shift. Returns (result, shift >= BITS).
    public fn overflowing_shr(self, shift: Int) -> (Int, Bool) {
        (self >> bitand(shift, 63), shift >= 64)
    }

    /// Overflow-safe midpoint (average of two values, rounded towards negative infinity).
    public fn midpoint(self, other: Int) -> Int {
        (self >> 1) + (other >> 1) + bitand(bitand(self, other), 1)
    }

    /// Native-endian byte representation (little-endian on this platform).
    public fn to_ne_bytes(self) -> List<Byte> { self.to_le_bytes() }

    /// Construct from native-endian bytes (little-endian on this platform).
    public fn from_ne_bytes(bytes: List<Byte>) -> Int { Int.from_le_bytes(bytes) }

    /// Parse integer from string in the given radix (2-36).
    ///
    /// Accepts the full signed Int range, including the
    /// asymmetric `Int.MIN` (= -9223372036854775808). The
    /// magnitude `9223372036854775808` doesn't fit in `Int`
    /// (positive range tops at `Int.MAX = Int.MIN + 1` in
    /// magnitude), so we accumulate magnitude in `UInt64` and
    /// reconstruct the signed result with sign-aware bound
    /// checks. Without this, the obvious round-trip
    /// `Int.MIN.to_string().from_str()` would round-trip back
    /// to `None` — a silent gap on the most-negative input.
    public fn from_str_radix(text: &Text, radix: Int) -> Maybe<Int> {
        if radix < 2 || radix > 36 { return None; }
        if text.len() == 0 { return None; }

        let mut negative = false;
        let mut start = 0;
        let first = text.char_at(0);
        if first == '-' { negative = true; start = 1; }
        else if first == '+' { start = 1; }

        if start >= text.len() { return None; }

        // Accumulate magnitude in unsigned 64-bit so the
        // pre-sign check fits Int.MIN's magnitude (2^63).
        let mut mag: UInt64 = 0 as UInt64;
        let radix_u: UInt64 = radix as UInt64;
        let mut i = start;
        while i < text.len() {
            let ch = text.char_at(i);
            let digit = char_to_digit(ch, radix);
            if digit < 0 { return None; }
            // mag = mag * radix + digit, with overflow detection.
            // 64-bit unsigned mul check: mag > UInt64.MAX / radix
            // would overflow. We use a saturating-style check.
            let max_u: UInt64 = 18446744073709551615 as UInt64; // UInt64.MAX
            if mag > max_u / radix_u { return None; }
            mag = mag * radix_u;
            let digit_u = digit as UInt64;
            if mag > max_u - digit_u { return None; }
            mag = mag + digit_u;
            i = i + 1;
        }

        // Sign-aware bound check.  Positive: must fit in Int.MAX
        // (= 9223372036854775807).  Negative: magnitude must fit
        // in -Int.MIN's magnitude (= 9223372036854775808 = 2^63).
        if negative {
            let neg_min_mag: UInt64 = 9223372036854775808 as UInt64;
            if mag > neg_min_mag { return None; }
            if mag == neg_min_mag {
                // Exactly Int.MIN — can't represent its magnitude
                // as a positive Int, so build directly.
                return Some(-9223372036854775808);
            }
            return Some(0 - (mag as Int));
        } else {
            let max_mag: UInt64 = 9223372036854775807 as UInt64; // Int.MAX
            if mag > max_mag { return None; }
            return Some(mag as Int);
        }
    }
}

/// Helper: convert character to digit value for the given radix. Returns -1 on invalid.
fn char_to_digit(ch: Char, radix: Int) -> Int {
    match ch.to_digit(radix) {
        Some(d) => d,
        None => -1,
    }
}

/// Helper: format `n` in the given `radix` (2..=36) using math
/// convention for negative values (`-magnitude`, not
/// two's-complement bits).  The shared backend for
/// [`Int::to_binary`], [`Int::to_hex`], and [`Int::to_octal`].
///
/// Magnitude is computed in `UInt64` so `Int.MIN`'s magnitude
/// (`2^63`, unrepresentable as a positive `Int`) is exact.
/// The previous per-radix implementations called `self.abs()`,
/// which panics on `Int.MIN` per the intrinsic contract; this
/// helper sidesteps the trap.
fn format_radix_signed(n: Int, radix: Int) -> Text {
    if n == 0 { return "0".clone(); }

    let hex_chars = "0123456789abcdefghijklmnopqrstuvwxyz";

    let mut mag: UInt64 = if n < 0 {
        // Two's-complement magnitude: exact for every Int (including
        // Int.MIN whose magnitude `2^63` is unrepresentable as a
        // positive Int but fits cleanly in UInt64).
        (((!n) as UInt64) + (1 as UInt64))
    } else {
        n as UInt64
    };
    let radix_u: UInt64 = radix as UInt64;

    // Collect digits low-to-high in a List<Char>, then iterate
    // backwards into the result Text.  Earlier impl used a fixed
    // `[Byte; 64]` buffer + `Text.from_utf8_unchecked` — that path
    // doesn't survive the Tier-0 interpreter (no byte-array
    // primitive at the @intrinsic surface), causing every
    // `to_hex / to_octal / to_binary` call to silently produce
    // empty output.  Discovered while validating task #38 (f-string
    // `:x` spec wrapping); the wrap was correct, the underlying
    // formatter was the load-bearing bug.
    let mut digits = List<Char>.new();
    while mag > (0 as UInt64) {
        let digit = (mag % radix_u) as Int;
        digits.push(hex_chars.nth_char(digit).unwrap());
        mag = mag / radix_u;
    }

    let mut out = Text.new();
    if n < 0 { out.push('-'); }
    let mut i: Int = (digits.len() as Int) - 1;
    while i >= 0 {
        out.push(digits[i]);
        i = i - 1;
    }
    out
}

// Int protocol implementations
implement Eq for Int {
    public fn eq(&self, other: &Int) -> Bool {
        eq(*self, *other)
    }
}

implement Ord for Int {
    public fn cmp(&self, other: &Int) -> Ordering {
        if *self < *other { Less }
        else if *self > *other { Greater }
        else { Equal }
    }
}

implement Hash for Int {
    public fn hash(&self, hasher: &mut Hasher) {
        hasher.write_int(*self);
    }
}

implement Clone for Int {
    public fn clone(&self) -> Int { *self }
}

implement Copy for Int {}

implement Default for Int {
    public fn default() -> Int { 0 }
}

implement Debug for Int {
    public fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(&self.to_text())
    }
}

implement Display for Int {
    public fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(&self.to_text())
    }
}

implement Zero for Int {
    public fn zero() -> Int { 0 }
    public fn is_zero(&self) -> Bool { *self == 0 }
}

implement One for Int {
    public fn one() -> Int { 1 }
    public fn is_one(&self) -> Bool { *self == 1 }
}

implement Add for Int {
    type Output = Int;
    public fn add(self, rhs: Int) -> Int { add(self, rhs) }
}

implement Sub for Int {
    type Output = Int;
    public fn sub(self, rhs: Int) -> Int { sub(self, rhs) }
}

implement Mul for Int {
    type Output = Int;
    public fn mul(self, rhs: Int) -> Int { mul(self, rhs) }
}

implement Div for Int {
    type Output = Int;
    public fn div(self, rhs: Int) -> Int { div(self, rhs) }
}

implement Rem for Int {
    type Output = Int;
    public fn rem(self, rhs: Int) -> Int { rem(self, rhs) }
}

implement Neg for Int {
    type Output = Int;
    public fn neg(self) -> Int { neg(self) }
}

implement BitAnd for Int {
    type Output = Int;
    public fn bitand(self, rhs: Int) -> Int { bitand(self, rhs) }
}

implement BitOr for Int {
    type Output = Int;
    public fn bitor(self, rhs: Int) -> Int { bitor(self, rhs) }
}

implement BitXor for Int {
    type Output = Int;
    public fn bitxor(self, rhs: Int) -> Int { bitxor(self, rhs) }
}

implement Not for Int {
    type Output = Int;
    public fn not(self) -> Int { bitnot(self) }
}

implement Shl for Int {
    type Output = Int;
    public fn shl(self, rhs: Int) -> Int { shl(self, rhs as UInt32) }
}

implement Shr for Int {
    type Output = Int;
    public fn shr(self, rhs: Int) -> Int { shr(self, rhs as UInt32) }
}

// =============================================================================
// Float - 64-bit IEEE 754 floating point
// =============================================================================

implement Float {
    /// Minimum finite value.
    public const MIN: Float = -1.7976931348623157e+308;

    /// Maximum finite value.
    public const MAX: Float = 1.7976931348623157e+308;

    /// Smallest positive normal value.
    public const MIN_POSITIVE: Float = 2.2250738585072014e-308;

    /// Machine epsilon.
    public const EPSILON: Float = 2.220446049250313e-16;

    /// Positive infinity.
    public const INFINITY: Float = 1.0 / 0.0;

    /// Negative infinity.
    public const NEG_INFINITY: Float = -1.0 / 0.0;

    /// Not a Number (NaN).
    public const NAN: Float = 0.0 / 0.0;

    /// Number of bits.
    public const BITS: Int = 64;

    /// Pi constant.
    public const PI: Float = 3.141592653589793;

    /// Euler's number.
    public const E: Float = 2.718281828459045;

    /// Positive infinity.
    public fn infinity() -> Float {
        1.0 / 0.0
    }

    /// Negative infinity.
    public fn neg_infinity() -> Float {
        -1.0 / 0.0
    }

    /// Not a Number (NaN).
    public fn nan() -> Float {
        0.0 / 0.0
    }

    /// Minimum positive value (deprecated: use MIN_POSITIVE).
    public meta fn min_positive() -> Float {
        2.2250738585072014e-308
    }

    /// Maximum finite value (deprecated: use MAX).
    public meta fn max_value() -> Float {
        1.7976931348623157e+308
    }

    /// Machine epsilon (deprecated: use EPSILON).
    public meta fn epsilon() -> Float {
        2.220446049250313e-16
    }

    /// Pi constant (deprecated: use PI).
    public meta fn pi() -> Float {
        3.141592653589793
    }

    /// Euler's number (deprecated: use E).
    public meta fn e() -> Float {
        2.718281828459045
    }

    /// Check if NaN.
    public fn is_nan(self) -> Bool {
        self != self
    }

    /// Check if infinite.
    public fn is_infinite(self) -> Bool {
        self == Float.infinity() || self == Float.neg_infinity()
    }

    /// Check if finite (not NaN and !infinite).
    public fn is_finite(self) -> Bool {
        !self.is_nan() && !self.is_infinite()
    }

    /// Check if normal (not zero, subnormal, infinite, || NaN).
    public fn is_normal(self) -> Bool {
        self.is_finite() && self.abs() >= Float.min_positive()
    }

    /// Check if strictly positive (`self > 0.0`).
    /// Returns `false` for `+0.0`, `-0.0`, and `NaN`. Use
    /// [`is_sign_positive`] for sign-bit semantics that
    /// distinguish `+0.0` from `-0.0`.
    public fn is_positive(self) -> Bool {
        self > 0.0
    }

    /// Check if strictly negative (`self < 0.0`).
    /// Returns `false` for `+0.0`, `-0.0`, and `NaN`. Use
    /// [`is_sign_negative`] for sign-bit semantics that
    /// distinguish `+0.0` from `-0.0`.
    public fn is_negative(self) -> Bool {
        self < 0.0
    }

    /// Check the sign bit is positive (IEEE 754). True for +0.0, false for -0.0.
    public fn is_sign_positive(self) -> Bool {
        !self.is_sign_negative()
    }

    /// Check the sign bit is negative (IEEE 754). True for -0.0 and negative values.
    public fn is_sign_negative(self) -> Bool {
        let bits: UInt64 = f64_to_bits(self);
        (bits >> 63) == (1 as UInt64)
    }

    /// Check if zero (positive || negative).
    public fn is_zero(self) -> Bool {
        self == 0.0 || self == -0.0
    }

    /// Sign: -1.0, 0.0, || 1.0 (NaN returns NaN).
    public fn signum(self) -> Float {
        if self.is_nan() { Float.nan() }
        else if self > 0.0 { 1.0 }
        else if self < 0.0 { -1.0 }
        else { 0.0 }
    }

    /// Absolute value, IEEE 754-conforming.
    ///
    /// Critically: `abs(-0.0) == +0.0` (IEEE 754 mandates the
    /// sign bit be cleared), `abs(NaN) == NaN`, `abs(±Inf) ==
    /// +Inf`. The previous `if self < 0.0 { -self } else { self }`
    /// returned `self` unchanged for `-0.0` (because `-0.0 < 0.0`
    /// is false in IEEE 754 — the comparison treats `-0.0 == +0.0`),
    /// silently leaking the sign bit and breaking
    /// `(-0.0).abs().is_sign_positive()` (which should be true
    /// per spec but returned false).
    ///
    /// Implementation clears the sign bit directly via the
    /// bit-pattern round-trip — this is the standard
    /// IEEE 754 `fabs` behaviour and matches what every other
    /// language's stdlib `abs` returns for the zero/NaN edge
    /// cases.
    public fn abs(self) -> Float {
        let bits: UInt64 = f64_to_bits(self);
        let mask: UInt64 = 0x7FFFFFFFFFFFFFFF as UInt64; // clear sign bit
        f64_from_bits(bits & mask)
    }

    /// Convert to integer (truncates toward zero).
    public fn to_int(self) -> Int {
        float_to_int(self)
    }

    /// Square root.
    public fn sqrt(self) -> Float {
        sqrt(self)
    }

    /// Cube root.
    public fn cbrt(self) -> Float {
        cbrt(self)
    }

    /// Exponential (e^x).
    public fn exp(self) -> Float {
        exp(self)
    }

    /// Exponential minus 1 (e^x - 1), more accurate for small x.
    public fn exp_m1(self) -> Float {
        expm1(self)
    }

    /// Base-2 exponential (2^x).
    public fn exp2(self) -> Float {
        exp2(self)
    }

    /// Natural logarithm.
    public fn ln(self) -> Float {
        log(self)
    }

    /// Natural log of (1 + x), more accurate for small x.
    public fn ln_1p(self) -> Float {
        log1p(self)
    }

    /// Base-10 logarithm.
    public fn log10(self) -> Float {
        log10(self)
    }

    /// Base-2 logarithm.
    public fn log2(self) -> Float {
        log2(self)
    }

    /// Logarithm with arbitrary base.
    public fn log_base(self, base: Float) -> Float {
        log(self) / log(base)
    }

    /// Power.
    public fn pow(self, exponent: Float) -> Float {
        pow(self, exponent)
    }

    /// Integer power.
    public fn powi(self, exponent: Int) -> Float {
        powi(self, exponent)
    }

    /// Floor (round down).
    public fn floor(self) -> Float {
        floor(self)
    }

    /// Ceiling (round up).
    public fn ceil(self) -> Float {
        ceil(self)
    }

    /// Round to nearest integer.
    public fn round(self) -> Float {
        round(self)
    }

    /// Truncate toward zero.
    public fn trunc(self) -> Float {
        trunc(self)
    }

    /// Fractional part.
    public fn fract(self) -> Float {
        self - trunc(self)
    }

    /// Minimum of two values (NaN-propagating).
    public fn min(self, other: Float) -> Float {
        minnum(self, other)
    }

    /// Maximum of two values (NaN-propagating).
    public fn max(self, other: Float) -> Float {
        maxnum(self, other)
    }

    /// Clamp between min && max.
    public fn clamp(self, min_val: Float, max_val: Float) -> Float {
        minnum(maxnum(self, min_val), max_val)
    }

    /// Fused multiply-add: self * a + b (single rounding).
    public fn mul_add(self, a: Float, b: Float) -> Float {
        fma(self, a, b)
    }

    /// Copy sign from another value.
    public fn copysign(self, sign: Float) -> Float {
        copysign(self, sign)
    }

    /// Hypotenuse: sqrt(self^2 + other^2).
    public fn hypot(self, other: Float) -> Float {
        hypot(self, other)
    }

    // Trigonometric functions

    /// Sine.
    public fn sin(self) -> Float {
        sin(self)
    }

    /// Cosine.
    public fn cos(self) -> Float {
        cos(self)
    }

    /// Tangent.
    public fn tan(self) -> Float {
        tan(self)
    }

    /// Arc sine.
    public fn asin(self) -> Float {
        asin(self)
    }

    /// Arc cosine.
    public fn acos(self) -> Float {
        acos(self)
    }

    /// Arc tangent.
    public fn atan(self) -> Float {
        atan(self)
    }

    /// Two-argument arc tangent (instance method: self is y, other is x).
    public fn atan2(self, other: Float) -> Float {
        atan2(self, other)
    }

    /// Two-argument arc tangent (static): atan2(y, x) → angle in radians.
    public fn from_atan2(y: Float, x: Float) -> Float {
        atan2(y, x)
    }

    /// Sine && cosine simultaneously.
    public fn sin_cos(self) -> (Float, Float) {
        (sin(self), cos(self))
    }

    // Hyperbolic functions

    /// Hyperbolic sine.
    public fn sinh(self) -> Float {
        sinh(self)
    }

    /// Hyperbolic cosine.
    public fn cosh(self) -> Float {
        cosh(self)
    }

    /// Hyperbolic tangent.
    public fn tanh(self) -> Float {
        tanh(self)
    }

    /// Inverse hyperbolic sine.
    public fn asinh(self) -> Float {
        asinh(self)
    }

    /// Inverse hyperbolic cosine.
    public fn acosh(self) -> Float {
        acosh(self)
    }

    /// Inverse hyperbolic tangent.
    public fn atanh(self) -> Float {
        atanh(self)
    }

    /// Convert radians to degrees.
    public fn to_degrees(self) -> Float {
        self * (180.0 / Float.pi())
    }

    /// Convert degrees to radians.
    public fn to_radians(self) -> Float {
        self * (Float.pi() / 180.0)
    }

    /// Convert to bits (for serialization).
    public fn to_bits(self) -> Int {
        f64_to_bits(self) as Int
    }

    /// Create from bits.
    public fn from_bits(bits: Int) -> Float {
        f64_from_bits(bits as UInt64)
    }

    /// Convert to little-endian byte representation.
    public fn to_le_bytes(self) -> [Byte; 8] {
        let bits = f64_to_bits(self);
        to_le_bytes_8(bits)
    }

    /// Convert to big-endian byte representation.
    public fn to_be_bytes(self) -> [Byte; 8] {
        let bits = f64_to_bits(self);
        to_be_bytes_8(bits)
    }

    /// Create from little-endian bytes.
    public fn from_le_bytes(bytes: [Byte; 8]) -> Float {
        let bits = from_le_bytes_8(bytes);
        f64_from_bits(bits)
    }

    /// Create from big-endian bytes.
    public fn from_be_bytes(bytes: [Byte; 8]) -> Float {
        let bits = from_be_bytes_8(bytes);
        f64_from_bits(bits)
    }

    /// Convert to native-endian byte representation.
    public fn to_ne_bytes(self) -> [Byte; 8] {
        self.to_le_bytes()
    }

    /// Create from native-endian bytes.
    public fn from_ne_bytes(bytes: [Byte; 8]) -> Float {
        Float.from_le_bytes(bytes)
    }

    /// Midpoint of two floats, avoiding overflow.
    public fn midpoint(self, other: Float) -> Float {
        let a: Float = self * 0.5;
        let b: Float = other * 0.5;
        a + b
    }

    /// Linear interpolation between self and other by factor t.
    /// Returns self when t=0.0, other when t=1.0.
    public fn lerp(self, other: Float, t: Float) -> Float {
        let diff: Float = other - self;
        let scaled: Float = t * diff;
        self + scaled
    }

    /// Total comparison (orders NaN after all values).
    public fn total_cmp(self, other: Float) -> Int {
        if self < other { -1 }
        else if self > other { 1 }
        else if self == other { 0 }
        else if other.is_nan() {
            if self.is_nan() { 0 } else { -1 }
        }
        else { 1 }
    }

    /// Reciprocal: 1.0 / self.
    public fn recip(self) -> Float {
        1.0 / self
    }

    /// Check if subnormal (nonzero, finite, below MIN_POSITIVE).
    public fn is_subnormal(self) -> Bool {
        self.is_finite() && !self.is_zero() && !self.is_nan() && self.abs() < Float.min_positive()
    }

    /// Euclidean division (result floored towards negative infinity).
    public fn div_euclid(self, rhs: Float) -> Float {
        let q: Float = (self / rhs).trunc();
        let r: Float = self - q * rhs;
        if r < 0.0 {
            if rhs > 0.0 { q - 1.0 } else { q + 1.0 }
        } else {
            q
        }
    }

    /// Euclidean remainder (always non-negative).
    public fn rem_euclid(self, rhs: Float) -> Float {
        let r: Float = self % rhs;
        if r < 0.0 {
            let abs_rhs: Float = if rhs < 0.0 { 0.0 - rhs } else { rhs };
            r + abs_rhs
        } else {
            r
        }
    }
}

// Float protocol implementations
implement Eq for Float {
    public fn eq(&self, other: &Float) -> Bool {
        // Note: NaN != NaN by IEEE 754
        eq(*self, *other)
    }
}

implement PartialOrd for Float {
    public fn partial_cmp(&self, other: &Float) -> Maybe<Ordering> {
        if self.is_nan() || other.is_nan() {
            None
        } else if *self < *other {
            Some(Less)
        } else if *self > *other {
            Some(Greater)
        } else {
            Some(Equal)
        }
    }
}

implement Clone for Float {
    public fn clone(&self) -> Float { *self }
}

implement Copy for Float {}

implement Default for Float {
    public fn default() -> Float { 0.0 }
}

implement Debug for Float {
    public fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(&self.to_text())
    }
}

implement Display for Float {
    public fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(&self.to_text())
    }
}

implement Zero for Float {
    public fn zero() -> Float { 0.0 }
    public fn is_zero(&self) -> Bool { *self == 0.0 }
}

implement One for Float {
    public fn one() -> Float { 1.0 }
    public fn is_one(&self) -> Bool { *self == 1.0 }
}

implement Add for Float {
    type Output = Float;
    public fn add(self, rhs: Float) -> Float { add(self, rhs) }
}

implement Sub for Float {
    type Output = Float;
    public fn sub(self, rhs: Float) -> Float { sub(self, rhs) }
}

implement Mul for Float {
    type Output = Float;
    public fn mul(self, rhs: Float) -> Float { mul(self, rhs) }
}

implement Div for Float {
    type Output = Float;
    public fn div(self, rhs: Float) -> Float { div(self, rhs) }
}

implement Rem for Float {
    type Output = Float;
    public fn rem(self, rhs: Float) -> Float { rem(self, rhs) }
}

implement Neg for Float {
    type Output = Float;
    public fn neg(self) -> Float { neg(self) }
}

implement From<Float32> for Float {
    public fn from(val: Float32) -> Float { val as Float }
}

// =============================================================================
// Bool - Boolean type
// =============================================================================

implement Bool {
    /// Logical AND (eager evaluation).
    public fn and_then(self, other: Bool) -> Bool {
        if self { other } else { false }
    }

    /// Logical OR (eager evaluation).
    public fn or_else(self, other: Bool) -> Bool {
        if self { true } else { other }
    }

    /// Logical XOR.
    public fn xor(self, other: Bool) -> Bool {
        (self || other) && !(self && other)
    }

    /// Convert to Int (0 || 1).
    public fn to_int(self) -> Int {
        if self { 1 } else { 0 }
    }

    /// Select between two values based on condition.
    public fn select<T>(self, if_true: T, if_false: T) -> T {
        if self { if_true } else { if_false }
    }
}

implement Eq for Bool {
    public fn eq(&self, other: &Bool) -> Bool {
        eq(*self, *other)
    }
}

implement Ord for Bool {
    public fn cmp(&self, other: &Bool) -> Ordering {
        // false < true
        match (*self, *other) {
            (false, false) => Equal,
            (false, true) => Less,
            (true, false) => Greater,
            (true, true) => Equal,
        }
    }
}

implement Hash for Bool {
    public fn hash(&self, hasher: &mut Hasher) {
        hasher.write_byte(if *self { 1 } else { 0 });
    }
}

implement Clone for Bool {
    public fn clone(&self) -> Bool { *self }
}

implement Copy for Bool {}

implement Default for Bool {
    public fn default() -> Bool { false }
}

implement Debug for Bool {
    public fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(if *self { "true" } else { "false" })
    }
}

implement Display for Bool {
    public fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(if *self { "true" } else { "false" })
    }
}

implement Not for Bool {
    type Output = Bool;
    public fn not(self) -> Bool { if self { false } else { true } }
}

implement BitAnd for Bool {
    type Output = Bool;
    public fn bitand(self, rhs: Bool) -> Bool { self && rhs }
}

implement BitOr for Bool {
    type Output = Bool;
    public fn bitor(self, rhs: Bool) -> Bool { self || rhs }
}

implement BitXor for Bool {
    type Output = Bool;
    public fn bitxor(self, rhs: Bool) -> Bool { self.xor(rhs) }
}

// =============================================================================
// Byte - 8-bit unsigned integer
// =============================================================================

implement Byte {
    /// Minimum value (0).
    public meta fn min_value() -> Byte { 0 }

    /// Maximum value (255).
    public meta fn max_value() -> Byte { 255 }

    /// Check if ASCII alphabetic.
    public fn is_ascii_alphabetic(self) -> Bool {
        (self >= 65 && self <= 90) || (self >= 97 && self <= 122)
    }

    /// Check if ASCII digit.
    public fn is_ascii_digit(self) -> Bool {
        self >= 48 && self <= 57
    }

    /// Check if ASCII alphanumeric.
    public fn is_ascii_alphanumeric(self) -> Bool {
        self.is_ascii_alphabetic() || self.is_ascii_digit()
    }

    /// Check if ASCII whitespace.
    ///
    /// Matches the canonical "ASCII whitespace" set defined by
    /// the WHATWG Infra spec and used by Rust's
    /// `u8::is_ascii_whitespace`: SPACE (0x20), HORIZONTAL TAB
    /// (0x09), LINE FEED (0x0A), FORM FEED (0x0C), CARRIAGE
    /// RETURN (0x0D). The previous implementation omitted FORM
    /// FEED, silently disagreeing with every other language's
    /// ASCII-whitespace classifier (and with the Verum
    /// `Char::is_whitespace` Unicode-aware classifier, which
    /// does include FF via the broader Unicode whitespace
    /// table) — the resulting inconsistency was a subtle
    /// foot-gun for parsers operating on byte streams.
    public fn is_ascii_whitespace(self) -> Bool {
        self == 32 || self == 9 || self == 10 || self == 12 || self == 13
    }

    /// Convert to uppercase (ASCII).
    public fn to_ascii_uppercase(self) -> Byte {
        if self >= 97 && self <= 122 { self - 32 } else { self }
    }

    /// Convert to lowercase (ASCII).
    public fn to_ascii_lowercase(self) -> Byte {
        if self >= 65 && self <= 90 { self + 32 } else { self }
    }

    /// Convert to Int.
    public fn to_int(self) -> Int {
        self as Int
    }

    /// Checked addition.
    public fn checked_add(self, rhs: Byte) -> Maybe<Byte> {
        let sum = (self as Int) + (rhs as Int);
        if sum > 255 { None } else { Some(sum as Byte) }
    }

    /// Saturating addition.
    public fn saturating_add(self, rhs: Byte) -> Byte {
        let sum = (self as Int) + (rhs as Int);
        if sum > 255 { 255 } else { sum as Byte }
    }

    /// Checked subtraction (returns None on underflow).
    public fn checked_sub(self, rhs: Byte) -> Maybe<Byte> {
        let diff = (self as Int) - (rhs as Int);
        if diff < 0 { None } else { Some(diff as Byte) }
    }

    /// Saturating subtraction.
    public fn saturating_sub(self, rhs: Byte) -> Byte {
        let diff = (self as Int) - (rhs as Int);
        if diff < 0 { 0 } else { diff as Byte }
    }

    /// Wrapping addition.
    public fn wrapping_add(self, rhs: Byte) -> Byte {
        ((self as Int + rhs as Int) % 256) as Byte
    }

    /// Wrapping subtraction.
    public fn wrapping_sub(self, rhs: Byte) -> Byte {
        (((self as Int - rhs as Int) % 256 + 256) % 256) as Byte
    }
}

implement Eq for Byte {
    public fn eq(&self, other: &Byte) -> Bool {
        eq(*self, *other)
    }
}

implement Ord for Byte {
    public fn cmp(&self, other: &Byte) -> Ordering {
        if *self < *other { Less }
        else if *self > *other { Greater }
        else { Equal }
    }
}

implement Hash for Byte {
    public fn hash(&self, hasher: &mut Hasher) {
        hasher.write_byte(*self);
    }
}

implement Clone for Byte {
    public fn clone(&self) -> Byte { *self }
}

implement Copy for Byte {}

implement Default for Byte {
    public fn default() -> Byte { 0 }
}

implement Debug for Byte {
    public fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(&(*self as Int).to_text())
    }
}

// =============================================================================
// Char - Unicode code point
// =============================================================================

implement Char {
    /// The replacement character (U+FFFD).
    public meta fn replacement() -> Char { '\u{FFFD}' }

    /// Maximum valid Unicode code point.
    public meta fn max_value() -> Char { '\u{10FFFF}' }

    /// Check if ASCII.
    public fn is_ascii(self) -> Bool {
        (self as Int) < 128
    }

    /// Check if alphabetic.
    public fn is_alphabetic(self) -> Bool {
        char_is_alphabetic(self)
    }

    /// Check if numeric.
    public fn is_numeric(self) -> Bool {
        char_is_numeric(self)
    }

    /// Check if alphanumeric.
    public fn is_alphanumeric(self) -> Bool {
        self.is_alphabetic() || self.is_numeric()
    }

    /// Check if whitespace.
    public fn is_whitespace(self) -> Bool {
        char_is_whitespace(self)
    }

    /// Check if control character.
    public fn is_control(self) -> Bool {
        char_is_control(self)
    }

    /// Check if digit in given radix.
    public fn is_digit(self, radix: Int) -> Bool {
        self.to_digit(radix).is_some()
    }

    /// Check if uppercase.
    public fn is_uppercase(self) -> Bool {
        char_is_uppercase(self)
    }

    /// Check if lowercase.
    public fn is_lowercase(self) -> Bool {
        char_is_lowercase(self)
    }

    /// Convert to uppercase.
    public fn to_uppercase(self) -> Char {
        char_to_uppercase(self)
    }

    /// Convert to lowercase.
    public fn to_lowercase(self) -> Char {
        char_to_lowercase(self)
    }

    /// Convert to digit value in given radix.
    public fn to_digit(self, radix: Int) -> Maybe<Int> {
        assert(radix >= 2 && radix <= 36, "radix must be 2..=36");
        let code = self as Int;
        let digit = if code >= 48 && code <= 57 {
            code - 48  // '0'-'9'
        } else if code >= 65 && code <= 90 {
            code - 55  // 'A'-'Z' -> 10-35
        } else if code >= 97 && code <= 122 {
            code - 87  // 'a'-'z' -> 10-35
        } else {
            -1
        };
        if digit >= 0 && digit < radix { Some(digit) } else { None }
    }

    /// Create from digit value in given radix.
    public fn from_digit(digit: Int, radix: Int) -> Maybe<Char> {
        assert(radix >= 2 && radix <= 36, "radix must be 2..=36");
        if digit < 0 || digit >= radix {
            None
        } else if digit < 10 {
            Some((48 + digit) as Char)  // '0'-'9'
        } else {
            Some((55 + digit) as Char)  // 'A'-'Z'
        }
    }

    /// Length in UTF-8 bytes.
    public fn len_utf8(self) -> Int {
        let code = self as Int;
        if code < 0x80 { 1 }
        else if code < 0x800 { 2 }
        else if code < 0x10000 { 3 }
        else { 4 }
    }

    /// Length in UTF-16 code units.
    public fn len_utf16(self) -> Int {
        if (self as Int) < 0x10000 { 1 } else { 2 }
    }

    /// Encode as UTF-8 bytes.
    public fn encode_utf8(self, buf: &mut [Byte]) -> Int {
        char_encode_utf8(self, buf)
    }

    /// Check if escape sequence is required.
    public fn escape_debug(self) -> Text {
        char_escape_debug(self)
    }

    /// Convert this character to a single-character Text value.
    public fn to_text(self) -> Text {
        let mut buf: [Byte; 4] = [0, 0, 0, 0];
        let n = self.encode_utf8(&mut buf);
        Text.from_utf8_unchecked(buf[0..n])
    }
}

implement Eq for Char {
    public fn eq(&self, other: &Char) -> Bool {
        (*self as Int) == (*other as Int)
    }
}

implement Ord for Char {
    public fn cmp(&self, other: &Char) -> Ordering {
        (*self as Int).cmp(&(*other as Int))
    }
}

implement Hash for Char {
    public fn hash(&self, hasher: &mut Hasher) {
        hasher.write_int(*self as Int);
    }
}

implement Clone for Char {
    public fn clone(&self) -> Char { *self }
}

implement Copy for Char {}

implement Default for Char {
    public fn default() -> Char { '\0' }
}

implement Debug for Char {
    public fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_char('\'')?;
        f.write_str(&self.escape_debug())?;
        f.write_char('\'')
    }
}

implement Display for Char {
    public fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_char(*self)
    }
}

// =============================================================================
// Unit type ()
// =============================================================================

implement Eq for () {
    public fn eq(&self, _other: &()) -> Bool { true }
}

implement Ord for () {
    public fn cmp(&self, _other: &()) -> Ordering { Equal }
}

implement Hash for () {
    public fn hash(&self, _hasher: &mut Hasher) {}
}

implement Clone for () {
    public fn clone(&self) -> () { () }
}

implement Copy for () {}

implement Default for () {
    public fn default() -> () { () }
}

implement Debug for () {
    public fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("()")
    }
}

implement Display for () {
    public fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("()")
    }
}

// =============================================================================
// Semantic Numeric Types
// =============================================================================
// Following Verum's "Semantic Honesty" principle: types describe meaning.
// Canonical names: Int8, Int16, Int32, Int64, Int128, ISize
//                  UInt8, UInt16, UInt32, UInt64, UInt128, USize
//                  Float32, Float64
// Rust-compatible aliases (i8, u64, etc.) are handled at the compiler level.
// =============================================================================

// =============================================================================
// UInt64 - 64-bit unsigned integer (semantic type)
// =============================================================================

implement UInt64 {
    /// Minimum value (0).
    public const MIN: UInt64 = 0;

    /// Maximum value (2^64 - 1).
    public const MAX: UInt64 = 0xFFFFFFFFFFFFFFFF;

    /// Number of bits.
    public const BITS: Int = 64;

    /// Minimum of two values.
    public fn min(self, other: UInt64) -> UInt64 { intrinsic_min(self, other) }

    /// Maximum of two values.
    public fn max(self, other: UInt64) -> UInt64 { intrinsic_max(self, other) }

    /// Clamp value between min and max.
    public fn clamp(self, min_val: UInt64, max_val: UInt64) -> UInt64 { intrinsic_clamp(self, min_val, max_val) }

    /// Convert to bytes (little-endian).
    public fn to_le_bytes(self) -> [Byte; 8] { to_le_bytes_8(self) }

    /// Convert to bytes (big-endian).
    public fn to_be_bytes(self) -> [Byte; 8] { to_be_bytes_8(self) }

    /// Create from bytes (little-endian).
    public fn from_le_bytes(bytes: [Byte; 8]) -> UInt64 { from_le_bytes_8(bytes) }

    /// Create from bytes (big-endian).
    public fn from_be_bytes(bytes: [Byte; 8]) -> UInt64 { from_be_bytes_8(bytes) }

    /// Checked addition (returns None on overflow).
    public fn checked_add(self, rhs: UInt64) -> Maybe<UInt64> { checked_add_u64(self, rhs) }

    /// Checked subtraction (returns None on underflow).
    public fn checked_sub(self, rhs: UInt64) -> Maybe<UInt64> { checked_sub_u64(self, rhs) }

    /// Checked multiplication (returns None on overflow).
    public fn checked_mul(self, rhs: UInt64) -> Maybe<UInt64> { checked_mul_u64(self, rhs) }

    /// Wrapping addition.
    public fn wrapping_add(self, rhs: UInt64) -> UInt64 { wrapping_add(self, rhs) }

    /// Wrapping subtraction.
    public fn wrapping_sub(self, rhs: UInt64) -> UInt64 { wrapping_sub(self, rhs) }

    /// Wrapping multiplication.
    public fn wrapping_mul(self, rhs: UInt64) -> UInt64 { wrapping_mul(self, rhs) }

    /// Saturating addition.
    public fn saturating_add(self, rhs: UInt64) -> UInt64 { saturating_add(self, rhs) }

    /// Saturating subtraction.
    public fn saturating_sub(self, rhs: UInt64) -> UInt64 { saturating_sub(self, rhs) }

    /// Saturating multiplication.
    public fn saturating_mul(self, rhs: UInt64) -> UInt64 { saturating_mul(self, rhs) }

    /// Count leading zeros.
    public fn leading_zeros(self) -> Int { clz(self) }

    /// Count trailing zeros.
    public fn trailing_zeros(self) -> Int { ctz(self) }

    /// Count ones (popcount).
    public fn count_ones(self) -> Int { popcnt(self) }

    /// Count zeros.
    public fn count_zeros(self) -> Int { 64 - popcnt(self) }

    /// Rotate left.
    public fn rotate_left(self, n: Int) -> UInt64 { rotl(self, n) }

    /// Rotate right.
    public fn rotate_right(self, n: Int) -> UInt64 { rotr(self, n) }

    /// Swap bytes (endianness conversion).
    public fn swap_bytes(self) -> UInt64 { bswap(self) }

    public fn pow(self, exp: Int) -> UInt64 {
        assert(exp >= 0);
        let mut result = 1 as UInt64;
        let mut base = self;
        let mut e = exp;
        while e > 0 {
            if e % 2 == 1 { result = result * base; }
            base = base * base;
            e = e / 2;
        }
        result
    }
    public fn checked_div(self, rhs: UInt64) -> Maybe<UInt64> {
        if rhs == (0 as UInt64) { None } else { Some(self / rhs) }
    }
    public fn in_range(self, start: UInt64, end: UInt64) -> Bool { self >= start && self < end }
    public fn to_float(self) -> Float { self.to_int().to_float() }
    public fn to_int(self) -> Int { self as Int }
    public fn overflowing_add(self, rhs: UInt64) -> (UInt64, Bool) { overflowing_add(self, rhs) }
    public fn overflowing_sub(self, rhs: UInt64) -> (UInt64, Bool) { overflowing_sub(self, rhs) }
    public fn overflowing_mul(self, rhs: UInt64) -> (UInt64, Bool) { overflowing_mul(self, rhs) }
    public fn reverse_bits(self) -> UInt64 { bitreverse(self) }
    public fn to_binary(self) -> Text { self.to_int().to_binary() }
    public fn to_hex(self) -> Text { self.to_int().to_hex() }
    public fn to_octal(self) -> Text { self.to_int().to_octal() }
    public fn checked_rem(self, rhs: UInt64) -> Maybe<UInt64> {
        if rhs == (0 as UInt64) { None } else { Some(rem(self, rhs)) }
    }
    public fn wrapping_neg(self) -> UInt64 { wrapping_neg(self) }
    public fn abs_diff(self, other: UInt64) -> Int {
        let a = self.to_int();
        let b_val = other.to_int();
        if a >= b_val { a - b_val } else { b_val - a }
    }
    public fn ilog2(self) -> Int {
        assert(self.to_int() > 0);
        63 - self.leading_zeros()
    }
    public fn ilog10(self) -> Int {
        assert(self.to_int() > 0);
        let mut count = 0;
        let mut n = self.to_int();
        while n >= 10 { n = n / 10; count = count + 1; }
        count
    }
    public fn is_power_of_two(self) -> Bool {
        let n = self.to_int();
        n > 0 && bitand(n, n - 1) == 0
    }
    public fn next_power_of_two(self) -> UInt64 {
        let n = self.to_int();
        if n <= 1 { 1 as UInt64 }
        else if n.is_power_of_two() { self }
        else {
            let shift = n.ilog2() + 1;
            assert(shift < 64);
            (1 << shift) as UInt64
        }
    }
    public fn checked_shl(self, shift: Int) -> Maybe<UInt64> {
        if shift < 0 || shift >= 64 { None } else { Some(shl(self, shift as UInt32)) }
    }
    public fn checked_shr(self, shift: Int) -> Maybe<UInt64> {
        if shift < 0 || shift >= 64 { None } else { Some(shr(self, shift as UInt32)) }
    }
    public fn checked_pow(self, exp: Int) -> Maybe<UInt64> {
        if exp < 0 { None }
        else if exp == 0 { Some(1 as UInt64) }
        else {
            let mut base = self;
            let mut e = exp;
            let mut result = 1 as UInt64;
            let mut overflow = false;
            while e > 0 && !overflow {
                if bitand(e, 1) == 1 {
                    match result.checked_mul(base) {
                        Some(v) => { result = v; },
                        None => { overflow = true; },
                    };
                }
                e = e >> 1;
                if e > 0 && !overflow {
                    match base.checked_mul(base) {
                        Some(v) => { base = v; },
                        None => { overflow = true; },
                    };
                }
            }
            if overflow { None } else { Some(result) }
        }
    }
    public fn wrapping_shl(self, shift: Int) -> UInt64 { shl(self, (bitand(shift, 63)) as UInt32) }
    public fn wrapping_shr(self, shift: Int) -> UInt64 { shr(self, (bitand(shift, 63)) as UInt32) }
    public fn wrapping_div(self, rhs: UInt64) -> UInt64 { div(self, rhs) }
    public fn wrapping_rem(self, rhs: UInt64) -> UInt64 { rem(self, rhs) }
    public fn div_euclid(self, rhs: UInt64) -> UInt64 { div(self, rhs) }
    public fn rem_euclid(self, rhs: UInt64) -> UInt64 { rem(self, rhs) }
    public fn saturating_pow(self, exp: Int) -> UInt64 {
        match self.checked_pow(exp) { Some(v) => v, None => 18446744073709551615 as UInt64 }
    }
    public fn overflowing_shl(self, shift: Int) -> (UInt64, Bool) {
        (shl(self, (bitand(shift, 63)) as UInt32), shift < 0 || shift >= 64)
    }
    public fn overflowing_shr(self, shift: Int) -> (UInt64, Bool) {
        (shr(self, (bitand(shift, 63)) as UInt32), shift < 0 || shift >= 64)
    }
    public fn midpoint(self, other: UInt64) -> UInt64 {
        let a = self.to_int();
        let b = other.to_int();
        ((a >> 1) + (b >> 1) + bitand(bitand(a, b), 1)) as UInt64
    }
    public fn to_ne_bytes(self) -> List<Byte> { to_le_bytes(self) }
    public fn from_ne_bytes(bytes: List<Byte>) -> UInt64 { from_le_bytes(bytes) }
}

// =============================================================================
// UInt32 - 32-bit unsigned integer
// =============================================================================

implement UInt32 {
    public const MIN: UInt32 = 0;
    public const MAX: UInt32 = 4294967295;
    public const BITS: Int = 32;

    public fn min(self, other: UInt32) -> UInt32 { intrinsic_min(self, other) }
    public fn max(self, other: UInt32) -> UInt32 { intrinsic_max(self, other) }
    public fn clamp(self, min_val: UInt32, max_val: UInt32) -> UInt32 { intrinsic_clamp(self, min_val, max_val) }

    public fn to_le_bytes(self) -> [Byte; 4] { to_le_bytes_4(self) }
    public fn to_be_bytes(self) -> [Byte; 4] { to_be_bytes_4(self) }
