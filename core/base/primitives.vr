    public fn to_int(self) -> Int { self as Int }
    public fn overflowing_add(self, rhs: Int8) -> (Int8, Bool) { overflowing_add(self, rhs) }
    public fn overflowing_sub(self, rhs: Int8) -> (Int8, Bool) { overflowing_sub(self, rhs) }
    public fn overflowing_mul(self, rhs: Int8) -> (Int8, Bool) { overflowing_mul(self, rhs) }
    public fn reverse_bits(self) -> Int8 { bitreverse(self) }
    public fn leading_zeros(self) -> Int { clz(self) }
    public fn trailing_zeros(self) -> Int { ctz(self) }
    public fn count_ones(self) -> Int { popcnt(self) }
    public fn count_zeros(self) -> Int { (8 as Int8).to_int() - popcnt(self) }
    public fn rotate_left(self, n: Int) -> Int8 { rotl(self, n) }
    public fn rotate_right(self, n: Int) -> Int8 { rotr(self, n) }
    public fn swap_bytes(self) -> Int8 { bswap(self) }
    public fn to_le_bytes(self) -> List<Byte> { to_le_bytes(self) }
    public fn to_be_bytes(self) -> List<Byte> { to_be_bytes(self) }
    public fn from_le_bytes(bytes: List<Byte>) -> Int8 { from_le_bytes(bytes) }
    public fn from_be_bytes(bytes: List<Byte>) -> Int8 { from_be_bytes(bytes) }
    public fn to_binary(self) -> Text { self.to_int().to_binary() }
    public fn to_hex(self) -> Text { self.to_int().to_hex() }
    public fn to_octal(self) -> Text { self.to_int().to_octal() }
    public fn checked_rem(self, rhs: Int8) -> Maybe<Int8> {
        if rhs == (0 as Int8) { None } else { Some(rem(self, rhs)) }
    }
    public fn wrapping_neg(self) -> Int8 { wrapping_neg(self) }
    public fn checked_neg(self) -> Maybe<Int8> {
        let neg = wrapping_neg(self);
        if neg == self && self.to_int() != 0 { None } else { Some(neg) }
    }
    public fn abs_diff(self, other: Int8) -> Int {
        let diff = self.to_int() - other.to_int();
        if diff < 0 { 0 - diff } else { diff }
    }
    public fn ilog2(self) -> Int {
        assert(self.to_int() > 0);
        7 - self.leading_zeros()
    }
    public fn ilog10(self) -> Int {
        assert(self.to_int() > 0);
        let mut count = 0;
        let mut n = self.to_int();
        while n >= 10 { n = n / 10; count = count + 1; }
        count
    }
    public fn is_power_of_two(self) -> Bool {
        let n = self.to_int();
        n > 0 && bitand(n, n - 1) == 0
    }
    public fn checked_shl(self, shift: Int) -> Maybe<Int8> {
        if shift < 0 || shift >= 8 { None } else { Some(shl(self, shift as UInt32)) }
    }
    public fn checked_shr(self, shift: Int) -> Maybe<Int8> {
        if shift < 0 || shift >= 8 { None } else { Some(shr(self, shift as UInt32)) }
    }
    public fn checked_pow(self, exp: Int) -> Maybe<Int8> {
        if exp < 0 { None }
        else if exp == 0 { Some(1 as Int8) }
        else {
            let mut base = self;
            let mut e = exp;
            let mut result = 1 as Int8;
            let mut overflow = false;
            while e > 0 && !overflow {
                if bitand(e, 1) == 1 {
                    match result.checked_mul(base) {
                        Some(v) => { result = v; },
                        None => { overflow = true; },
                    };
                }
                e = e >> 1;
                if e > 0 && !overflow {
                    match base.checked_mul(base) {
                        Some(v) => { base = v; },
                        None => { overflow = true; },
                    };
                }
            }
            if overflow { None } else { Some(result) }
        }
    }
    public fn wrapping_shl(self, shift: Int) -> Int8 { shl(self, (bitand(shift, 7)) as UInt32) }
    public fn wrapping_shr(self, shift: Int) -> Int8 { shr(self, (bitand(shift, 7)) as UInt32) }
    public fn wrapping_div(self, rhs: Int8) -> Int8 {
        if self.to_int() == -128 && rhs.to_int() == -1 { self } else { div(self, rhs) }
    }
    public fn wrapping_rem(self, rhs: Int8) -> Int8 {
        if self.to_int() == -128 && rhs.to_int() == -1 { 0 as Int8 } else { rem(self, rhs) }
    }
    public fn div_euclid(self, rhs: Int8) -> Int8 {
        let q = self.to_int() / rhs.to_int();
        let r = self.to_int() % rhs.to_int();
        if r < 0 { if rhs.to_int() > 0 { (q - 1) as Int8 } else { (q + 1) as Int8 } }
        else { q as Int8 }
    }
    public fn rem_euclid(self, rhs: Int8) -> Int8 {
        let r = self.to_int() % rhs.to_int();
        if r < 0 { if rhs.to_int() > 0 { (r + rhs.to_int()) as Int8 } else { (r - rhs.to_int()) as Int8 } }
        else { r as Int8 }
    }
    public fn saturating_pow(self, exp: Int) -> Int8 {
        match self.checked_pow(exp) {
            Some(v) => v,
            None => { if self.to_int() < 0 && bitand(exp, 1) == 1 { -128 as Int8 } else { 127 as Int8 } },
        }
    }
    public fn overflowing_shl(self, shift: Int) -> (Int8, Bool) {
        (shl(self, (bitand(shift, 7)) as UInt32), shift < 0 || shift >= 8)
    }
    public fn overflowing_shr(self, shift: Int) -> (Int8, Bool) {
        (shr(self, (bitand(shift, 7)) as UInt32), shift < 0 || shift >= 8)
    }
    public fn midpoint(self, other: Int8) -> Int8 {
        let a = self.to_int();
        let b = other.to_int();
        ((a >> 1) + (b >> 1) + bitand(bitand(a, b), 1)) as Int8
    }
    public fn to_ne_bytes(self) -> List<Byte> { to_le_bytes(self) }
    public fn from_ne_bytes(bytes: List<Byte>) -> Int8 { from_le_bytes(bytes) }
}

// =============================================================================
// Int16 - 16-bit signed integer
// =============================================================================

implement Int16 {
    public const MIN: Int16 = -32768;
    public const MAX: Int16 = 32767;
    public const BITS: Int = 16;

    public fn to_le_bytes(self) -> [Byte; 2] { to_le_bytes_2(self) }
    public fn to_be_bytes(self) -> [Byte; 2] { to_be_bytes_2(self) }
    public fn from_le_bytes(bytes: [Byte; 2]) -> Int16 { from_le_bytes_2(bytes) }
    public fn from_be_bytes(bytes: [Byte; 2]) -> Int16 { from_be_bytes_2(bytes) }

    public fn abs(self) -> Int16 { abs_signed(self) }
    public fn signum(self) -> Int16 { signum(self) }
    public fn min(self, other: Int16) -> Int16 { intrinsic_min(self, other) }
    public fn max(self, other: Int16) -> Int16 { intrinsic_max(self, other) }
    public fn clamp(self, min_val: Int16, max_val: Int16) -> Int16 { intrinsic_clamp(self, min_val, max_val) }
    public fn checked_add(self, rhs: Int16) -> Maybe<Int16> { checked_add(self, rhs) }
    public fn checked_sub(self, rhs: Int16) -> Maybe<Int16> { checked_sub(self, rhs) }
    public fn wrapping_add(self, rhs: Int16) -> Int16 { wrapping_add(self, rhs) }
    public fn wrapping_sub(self, rhs: Int16) -> Int16 { wrapping_sub(self, rhs) }
    public fn wrapping_mul(self, rhs: Int16) -> Int16 { wrapping_mul(self, rhs) }
    public fn saturating_add(self, rhs: Int16) -> Int16 { saturating_add(self, rhs) }
    public fn saturating_sub(self, rhs: Int16) -> Int16 { saturating_sub(self, rhs) }
    public fn saturating_mul(self, rhs: Int16) -> Int16 { saturating_mul(self, rhs) }
    public fn checked_mul(self, rhs: Int16) -> Maybe<Int16> { checked_mul(self, rhs) }
    public fn leading_zeros(self) -> Int { clz(self) }
    public fn trailing_zeros(self) -> Int { ctz(self) }
    public fn count_ones(self) -> Int { popcnt(self) }
    public fn count_zeros(self) -> Int { 16 - popcnt(self) }
    public fn rotate_left(self, n: Int) -> Int16 { rotl(self, n) }
    public fn rotate_right(self, n: Int) -> Int16 { rotr(self, n) }
    public fn swap_bytes(self) -> Int16 { bswap(self) }
    public fn pow(self, exp: Int) -> Int16 {
        assert(exp >= 0);
        let mut result = 1 as Int16;
        let mut base = self;
        let mut e = exp;
        while e > 0 {
            if e % 2 == 1 { result = result * base; }
            base = base * base;
            e = e / 2;
        }
        result
    }
    public fn is_positive(self) -> Bool { self > (0 as Int16) }
    public fn is_negative(self) -> Bool { self < (0 as Int16) }
    public fn checked_div(self, rhs: Int16) -> Maybe<Int16> {
        if rhs == (0 as Int16) { None } else { Some(self / rhs) }
    }
    public fn in_range(self, start: Int16, end: Int16) -> Bool { self >= start && self < end }
    public fn to_float(self) -> Float { self.to_int().to_float() }
    public fn to_int(self) -> Int { self as Int }
    public fn overflowing_add(self, rhs: Int16) -> (Int16, Bool) { overflowing_add(self, rhs) }
    public fn overflowing_sub(self, rhs: Int16) -> (Int16, Bool) { overflowing_sub(self, rhs) }
    public fn overflowing_mul(self, rhs: Int16) -> (Int16, Bool) { overflowing_mul(self, rhs) }
    public fn reverse_bits(self) -> Int16 { bitreverse(self) }
    public fn to_binary(self) -> Text { self.to_int().to_binary() }
    public fn to_hex(self) -> Text { self.to_int().to_hex() }
    public fn to_octal(self) -> Text { self.to_int().to_octal() }
    public fn checked_rem(self, rhs: Int16) -> Maybe<Int16> {
        if rhs == (0 as Int16) { None } else { Some(rem(self, rhs)) }
    }
    public fn wrapping_neg(self) -> Int16 { wrapping_neg(self) }
    public fn checked_neg(self) -> Maybe<Int16> {
        let neg = wrapping_neg(self);
        if neg == self && self.to_int() != 0 { None } else { Some(neg) }
    }
    public fn abs_diff(self, other: Int16) -> Int {
        let diff = self.to_int() - other.to_int();
        if diff < 0 { 0 - diff } else { diff }
    }
    public fn ilog2(self) -> Int {
        assert(self.to_int() > 0);
        15 - self.leading_zeros()
    }
    public fn ilog10(self) -> Int {
        assert(self.to_int() > 0);
        let mut count = 0;
        let mut n = self.to_int();
        while n >= 10 { n = n / 10; count = count + 1; }
        count
    }
    public fn is_power_of_two(self) -> Bool {
        let n = self.to_int();
        n > 0 && bitand(n, n - 1) == 0
    }
    public fn checked_shl(self, shift: Int) -> Maybe<Int16> {
        if shift < 0 || shift >= 16 { None } else { Some(shl(self, shift as UInt32)) }
    }
    public fn checked_shr(self, shift: Int) -> Maybe<Int16> {
        if shift < 0 || shift >= 16 { None } else { Some(shr(self, shift as UInt32)) }
    }
    public fn checked_pow(self, exp: Int) -> Maybe<Int16> {
        if exp < 0 { None }
        else if exp == 0 { Some(1 as Int16) }
        else {
            let mut base = self;
            let mut e = exp;
            let mut result = 1 as Int16;
            let mut overflow = false;
            while e > 0 && !overflow {
                if bitand(e, 1) == 1 {
                    match result.checked_mul(base) {
                        Some(v) => { result = v; },
                        None => { overflow = true; },
                    };
                }
                e = e >> 1;
                if e > 0 && !overflow {
                    match base.checked_mul(base) {
                        Some(v) => { base = v; },
                        None => { overflow = true; },
                    };
                }
            }
            if overflow { None } else { Some(result) }
        }
    }
    public fn wrapping_shl(self, shift: Int) -> Int16 { shl(self, (bitand(shift, 15)) as UInt32) }
    public fn wrapping_shr(self, shift: Int) -> Int16 { shr(self, (bitand(shift, 15)) as UInt32) }
    public fn wrapping_div(self, rhs: Int16) -> Int16 {
        if self.to_int() == -32768 && rhs.to_int() == -1 { self } else { div(self, rhs) }
    }
    public fn wrapping_rem(self, rhs: Int16) -> Int16 {
        if self.to_int() == -32768 && rhs.to_int() == -1 { 0 as Int16 } else { rem(self, rhs) }
    }
    public fn div_euclid(self, rhs: Int16) -> Int16 {
        let q = self.to_int() / rhs.to_int();
        let r = self.to_int() % rhs.to_int();
        if r < 0 { if rhs.to_int() > 0 { (q - 1) as Int16 } else { (q + 1) as Int16 } }
        else { q as Int16 }
    }
    public fn rem_euclid(self, rhs: Int16) -> Int16 {
        let r = self.to_int() % rhs.to_int();
        if r < 0 { if rhs.to_int() > 0 { (r + rhs.to_int()) as Int16 } else { (r - rhs.to_int()) as Int16 } }
        else { r as Int16 }
    }
    public fn saturating_pow(self, exp: Int) -> Int16 {
        match self.checked_pow(exp) {
            Some(v) => v,
            None => { if self.to_int() < 0 && bitand(exp, 1) == 1 { -32768 as Int16 } else { 32767 as Int16 } },
        }
    }
    public fn overflowing_shl(self, shift: Int) -> (Int16, Bool) {
        (shl(self, (bitand(shift, 15)) as UInt32), shift < 0 || shift >= 16)
    }
    public fn overflowing_shr(self, shift: Int) -> (Int16, Bool) {
        (shr(self, (bitand(shift, 15)) as UInt32), shift < 0 || shift >= 16)
    }
    public fn midpoint(self, other: Int16) -> Int16 {
        let a = self.to_int();
        let b = other.to_int();
        ((a >> 1) + (b >> 1) + bitand(bitand(a, b), 1)) as Int16
    }
    public fn to_ne_bytes(self) -> List<Byte> { to_le_bytes(self) }
    public fn from_ne_bytes(bytes: List<Byte>) -> Int16 { from_le_bytes(bytes) }
}

