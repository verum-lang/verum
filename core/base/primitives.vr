        else if exp == 0 { Some(1 as USize) }
        else {
            let mut base = self;
            let mut e = exp;
            let mut result = 1 as USize;
            let mut overflow = false;
            while e > 0 && !overflow {
                if bitand(e, 1) == 1 {
                    match result.checked_mul(base) {
                        Some(v) => { result = v; },
                        None => { overflow = true; },
                    };
                }
                e = e >> 1;
                if e > 0 && !overflow {
                    match base.checked_mul(base) {
                        Some(v) => { base = v; },
                        None => { overflow = true; },
                    };
                }
            }
            if overflow { None } else { Some(result) }
        }
    }
    public fn wrapping_shl(self, shift: Int) -> USize { shl(self, (bitand(shift, 63)) as UInt32) }
    public fn wrapping_shr(self, shift: Int) -> USize { shr(self, (bitand(shift, 63)) as UInt32) }
