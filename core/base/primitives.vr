    public fn count_zeros(self) -> Int { 64 - popcnt(self) }
    public fn rotate_left(self, n: Int) -> ISize { rotl(self, n) }
    public fn rotate_right(self, n: Int) -> ISize { rotr(self, n) }
    public fn swap_bytes(self) -> ISize { bswap(self) }
    public fn pow(self, exp: Int) -> ISize {
        assert(exp >= 0);
        let mut result = 1 as ISize;
        let mut base = self;
        let mut e = exp;
        while e > 0 {
            if e % 2 == 1 { result = result * base; }
            base = base * base;
            e = e / 2;
        }
        result
    }
    public fn is_positive(self) -> Bool { self > (0 as ISize) }
    public fn is_negative(self) -> Bool { self < (0 as ISize) }
    public fn checked_div(self, rhs: ISize) -> Maybe<ISize> {
        if rhs == (0 as ISize) { None } else { Some(self / rhs) }
    }
    public fn in_range(self, start: ISize, end: ISize) -> Bool { self >= start && self < end }
    public fn to_float(self) -> Float { self.to_int().to_float() }
    public fn to_int(self) -> Int { self as Int }
    public fn overflowing_add(self, rhs: ISize) -> (ISize, Bool) { overflowing_add(self, rhs) }
    public fn overflowing_sub(self, rhs: ISize) -> (ISize, Bool) { overflowing_sub(self, rhs) }
    public fn overflowing_mul(self, rhs: ISize) -> (ISize, Bool) { overflowing_mul(self, rhs) }
    public fn reverse_bits(self) -> ISize { bitreverse(self) }
    public fn to_le_bytes(self) -> List<Byte> { to_le_bytes(self) }
    public fn to_be_bytes(self) -> List<Byte> { to_be_bytes(self) }
    public fn from_le_bytes(bytes: List<Byte>) -> ISize { from_le_bytes(bytes) }
    public fn from_be_bytes(bytes: List<Byte>) -> ISize { from_be_bytes(bytes) }
    public fn to_binary(self) -> Text { self.to_int().to_binary() }
    public fn to_hex(self) -> Text { self.to_int().to_hex() }
    public fn to_octal(self) -> Text { self.to_int().to_octal() }
    public fn checked_rem(self, rhs: ISize) -> Maybe<ISize> {
        if rhs == (0 as ISize) { None } else { Some(rem(self, rhs)) }
    }
    public fn wrapping_neg(self) -> ISize { wrapping_neg(self) }
    public fn checked_neg(self) -> Maybe<ISize> {
        let neg = wrapping_neg(self);
        if neg == self && self.to_int() != 0 { None } else { Some(neg) }
    }
    public fn abs_diff(self, other: ISize) -> Int {
        let diff = self.to_int() - other.to_int();
        if diff < 0 { 0 - diff } else { diff }
    }
    public fn ilog2(self) -> Int {
        assert(self.to_int() > 0);
        63 - self.leading_zeros()
    }
    public fn ilog10(self) -> Int {
        assert(self.to_int() > 0);
        let mut count = 0;
        let mut n = self.to_int();
        while n >= 10 { n = n / 10; count = count + 1; }
        count
    }
    public fn is_power_of_two(self) -> Bool {
        let n = self.to_int();
        n > 0 && bitand(n, n - 1) == 0
    }
    public fn checked_shl(self, shift: Int) -> Maybe<ISize> {
        if shift < 0 || shift >= 64 { None } else { Some(shl(self, shift as UInt32)) }
    }
    public fn checked_shr(self, shift: Int) -> Maybe<ISize> {
        if shift < 0 || shift >= 64 { None } else { Some(shr(self, shift as UInt32)) }
    }
    public fn checked_pow(self, exp: Int) -> Maybe<ISize> {
        if exp < 0 { None }
        else if exp == 0 { Some(1 as ISize) }
        else {
            let mut base = self;
            let mut e = exp;
            let mut result = 1 as ISize;
            let mut overflow = false;
            while e > 0 && !overflow {
                if bitand(e, 1) == 1 {
                    match result.checked_mul(base) {
                        Some(v) => { result = v; },
                        None => { overflow = true; },
                    };
                }
                e = e >> 1;
                if e > 0 && !overflow {
                    match base.checked_mul(base) {
                        Some(v) => { base = v; },
                        None => { overflow = true; },
                    };
                }
            }
            if overflow { None } else { Some(result) }
        }
    }
    public fn wrapping_shl(self, shift: Int) -> ISize { shl(self, (bitand(shift, 63)) as UInt32) }
    public fn wrapping_shr(self, shift: Int) -> ISize { shr(self, (bitand(shift, 63)) as UInt32) }
    public fn wrapping_div(self, rhs: ISize) -> ISize {
        if self.to_int() == -9223372036854775808 && rhs.to_int() == -1 { self } else { div(self, rhs) }
    }
    public fn wrapping_rem(self, rhs: ISize) -> ISize {
        if self.to_int() == -9223372036854775808 && rhs.to_int() == -1 { 0 as ISize } else { rem(self, rhs) }
    }
    public fn div_euclid(self, rhs: ISize) -> ISize {
        let q = self.to_int() / rhs.to_int();
        let r = self.to_int() % rhs.to_int();
        if r < 0 { if rhs.to_int() > 0 { (q - 1) as ISize } else { (q + 1) as ISize } }
        else { q as ISize }
    }
    public fn rem_euclid(self, rhs: ISize) -> ISize {
        let r = self.to_int() % rhs.to_int();
        if r < 0 { if rhs.to_int() > 0 { (r + rhs.to_int()) as ISize } else { (r - rhs.to_int()) as ISize } }
        else { r as ISize }
    }
    public fn saturating_pow(self, exp: Int) -> ISize {
        match self.checked_pow(exp) {
            Some(v) => v,
            None => { if self.to_int() < 0 && bitand(exp, 1) == 1 { -9223372036854775808 as ISize } else { 9223372036854775807 as ISize } },
        }
    }
    public fn overflowing_shl(self, shift: Int) -> (ISize, Bool) {
        (shl(self, (bitand(shift, 63)) as UInt32), shift < 0 || shift >= 64)
    }
    public fn overflowing_shr(self, shift: Int) -> (ISize, Bool) {
        (shr(self, (bitand(shift, 63)) as UInt32), shift < 0 || shift >= 64)
    }
    public fn midpoint(self, other: ISize) -> ISize {
        let a = self.to_int();
        let b = other.to_int();
        ((a >> 1) + (b >> 1) + bitand(bitand(a, b), 1)) as ISize
    }
    public fn to_ne_bytes(self) -> List<Byte> { to_le_bytes(self) }
    public fn from_ne_bytes(bytes: List<Byte>) -> ISize { from_le_bytes(bytes) }
}


