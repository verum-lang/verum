    public fn rem_euclid(self, rhs: USize) -> USize { rem(self, rhs) }
    public fn saturating_pow(self, exp: Int) -> USize {
        match self.checked_pow(exp) { Some(v) => v, None => 18446744073709551615 as USize }
    }
    public fn overflowing_shl(self, shift: Int) -> (USize, Bool) {
        (shl(self, (bitand(shift, 63)) as UInt32), shift < 0 || shift >= 64)
    }
    public fn overflowing_shr(self, shift: Int) -> (USize, Bool) {
        (shr(self, (bitand(shift, 63)) as UInt32), shift < 0 || shift >= 64)
    }
    public fn midpoint(self, other: USize) -> USize {
        let a = self.to_int();
        let b = other.to_int();
        ((a >> 1) + (b >> 1) + bitand(bitand(a, b), 1)) as USize
    }
    public fn to_ne_bytes(self) -> List<Byte> { to_le_bytes(self) }
    public fn from_ne_bytes(bytes: List<Byte>) -> USize { from_le_bytes(bytes) }
}


// =============================================================================
// Float32 - 32-bit IEEE 754 floating point
// =============================================================================

implement Float32 {
    public const MIN: Float32 = -3.40282347e+38;
    public const MAX: Float32 = 3.40282347e+38;
    public const MIN_POSITIVE: Float32 = 1.17549435e-38;
    public const EPSILON: Float32 = 1.1920929e-7;
    public const BITS: Int = 32;

    public fn infinity() -> Float32 { f32_infinity() }
    public fn neg_infinity() -> Float32 { f32_neg_infinity() }
    public fn nan() -> Float32 { f32_nan() }

    public fn is_nan(self) -> Bool { self != self }
    public fn is_infinite(self) -> Bool { self == Float32.infinity() || self == Float32.neg_infinity() }
    public fn is_finite(self) -> Bool { !self.is_nan() && !self.is_infinite() }

    public fn abs(self) -> Float32 { fabs(self) }
    public fn sqrt(self) -> Float32 { sqrt(self) }
    public fn floor(self) -> Float32 { floor(self) }
    public fn ceil(self) -> Float32 { ceil(self) }
    public fn round(self) -> Float32 { round(self) }
    public fn trunc(self) -> Float32 { trunc(self) }
    public fn cbrt(self) -> Float32 { cbrt(self) }
    public fn exp(self) -> Float32 { exp(self) }
    public fn exp2(self) -> Float32 { exp2(self) }
    public fn ln(self) -> Float32 { log(self) }
    public fn log2(self) -> Float32 { log2(self) }
    public fn log10(self) -> Float32 { log10(self) }
    public fn pow(self, exponent: Float32) -> Float32 { pow(self, exponent) }
    public fn sin(self) -> Float32 { sin(self) }
    public fn cos(self) -> Float32 { cos(self) }
    public fn tan(self) -> Float32 { tan(self) }
    public fn asin(self) -> Float32 { asin(self) }
    public fn acos(self) -> Float32 { acos(self) }
    public fn atan(self) -> Float32 { atan(self) }
    public fn atan2(self, other: Float32) -> Float32 { atan2(self, other) }
    public fn sinh(self) -> Float32 { sinh(self) }
    public fn cosh(self) -> Float32 { cosh(self) }
    public fn tanh(self) -> Float32 { tanh(self) }
    public fn min(self, other: Float32) -> Float32 { minnum(self, other) }
    public fn max(self, other: Float32) -> Float32 { maxnum(self, other) }
    public fn mul_add(self, a: Float32, b: Float32) -> Float32 { fma(self, a, b) }
    public fn hypot(self, other: Float32) -> Float32 { hypot(self, other) }

    public fn asinh(self) -> Float32 { asinh(self) }
    public fn acosh(self) -> Float32 { acosh(self) }
    public fn atanh(self) -> Float32 { atanh(self) }
    public fn copysign(self, sign: Float32) -> Float32 { copysign(self, sign) }
    public fn is_normal(self) -> Bool { self.is_finite() && !self.is_nan() && self.abs() >= Float32.MIN_POSITIVE }
    public fn is_positive(self) -> Bool { self > (0.0 as Float32) }
    public fn is_negative(self) -> Bool { self < (0.0 as Float32) }
    public fn is_zero(self) -> Bool { self == (0.0 as Float32) }
    public fn signum(self) -> Float32 {
        if self.is_nan() { Float32.nan() }
        else if self > (0.0 as Float32) { 1.0 as Float32 }
        else if self < (0.0 as Float32) { -1.0 as Float32 }
        else { 0.0 as Float32 }
    }
    public fn fract(self) -> Float32 { sub(self, trunc(self)) }
    public fn clamp(self, min_val: Float32, max_val: Float32) -> Float32 {
        if self < min_val { min_val }
        else if self > max_val { max_val }
        else { self }
    }
    public fn exp_m1(self) -> Float32 { expm1(self) }
    public fn ln_1p(self) -> Float32 { log1p(self) }
    public fn log_base(self, base: Float32) -> Float32 { div(log(self), log(base)) }
    public fn powi(self, exponent: Int) -> Float32 {
        let mut result = 1.0 as Float32;
        let mut base = self;
        let mut e = if exponent < 0 { 0 - exponent } else { exponent };
        while e > 0 {
            if e % 2 == 1 {
                result = mul(result, base);
            }
            base = mul(base, base);
            e = e / 2;
        }
        if exponent < 0 {
            div(1.0 as Float32, result)
        } else {
            result
        }
    }
    public fn sin_cos(self) -> (Float32, Float32) { (sin(self), cos(self)) }
    public fn to_degrees(self) -> Float32 { mul(self, 57.29577951308232 as Float32) }
    public fn to_radians(self) -> Float32 { mul(self, 0.017453292519943295 as Float32) }
    public fn to_int(self) -> Int { self as Int }

    public fn to_bits(self) -> UInt32 { f32_to_bits(self) }
    public fn from_bits(bits: UInt32) -> Float32 { f32_from_bits(bits) }

    public fn to_le_bytes(self) -> [Byte; 4] {
        let bits = f32_to_bits(self);
        to_le_bytes_4(bits)
    }
    public fn to_be_bytes(self) -> [Byte; 4] {
        let bits = f32_to_bits(self);
        to_be_bytes_4(bits)
    }
    public fn from_le_bytes(bytes: [Byte; 4]) -> Float32 {
        let bits = from_le_bytes_4(bytes);
        f32_from_bits(bits)
    }
    public fn from_be_bytes(bytes: [Byte; 4]) -> Float32 {
        let bits = from_be_bytes_4(bytes);
        f32_from_bits(bits)
    }
    public fn to_ne_bytes(self) -> [Byte; 4] { self.to_le_bytes() }
    public fn from_ne_bytes(bytes: [Byte; 4]) -> Float32 { Float32.from_le_bytes(bytes) }

    public fn to_float(self) -> Float { self as Float }

    /// Midpoint of two Float32 values, avoiding overflow.
    public fn midpoint(self, other: Float32) -> Float32 {
        let a: Float = self.to_float() * 0.5;
        let b: Float = other.to_float() * 0.5;
        (a + b) as Float32
    }

    /// Linear interpolation between self and other by factor t.
    public fn lerp(self, other: Float32, t: Float32) -> Float32 {
        let s: Float = self.to_float();
        let o: Float = other.to_float();
        let f: Float = t.to_float();
        let diff: Float = o - s;
        let scaled: Float = f * diff;
        (s + scaled) as Float32
    }

    /// Total comparison (orders NaN after all values).
    public fn total_cmp(self, other: Float32) -> Int {
        if self < other { -1 }
        else if self > other { 1 }
        else if self == other { 0 }
        else if other.is_nan() {
            if self.is_nan() { 0 } else { -1 }
        }
        else { 1 }
    }

    /// Reciprocal: 1.0 / self.
    public fn recip(self) -> Float32 {
        div(1.0 as Float32, self)
    }

    /// Check if subnormal (nonzero, finite, below MIN_POSITIVE).
    public fn is_subnormal(self) -> Bool {
        self.is_finite() && !self.is_zero() && !self.is_nan() && self.abs() < Float32.MIN_POSITIVE
    }

    /// Euclidean division.
    public fn div_euclid(self, rhs: Float32) -> Float32 {
        let q: Float = self.to_float() / rhs.to_float();
        let qt: Float = q.trunc();
        let r: Float = self.to_float() - qt * rhs.to_float();
        if r < 0.0 {
            if rhs.to_float() > 0.0 { (qt - 1.0) as Float32 } else { (qt + 1.0) as Float32 }
        } else {
            qt as Float32
        }
    }

    /// Euclidean remainder (always non-negative).
    public fn rem_euclid(self, rhs: Float32) -> Float32 {
        let sf: Float = self.to_float();
        let rf: Float = rhs.to_float();
        let r: Float = sf - (sf / rf).trunc() * rf;
        if r < 0.0 {
            let abs_rhs: Float = if rf < 0.0 { 0.0 - rf } else { rf };
            (r + abs_rhs) as Float32
        } else {
            r as Float32
        }
    }
}


// =============================================================================
// Float64 - 64-bit IEEE 754 floating point (alias for Float)
// =============================================================================

implement Float64 {
    public const MIN: Float64 = -1.7976931348623157e+308;
    public const MAX: Float64 = 1.7976931348623157e+308;
    public const MIN_POSITIVE: Float64 = 2.2250738585072014e-308;
    public const EPSILON: Float64 = 2.220446049250313e-16;
    public const BITS: Int = 64;

    public fn infinity() -> Float64 { 1.0 / 0.0 }
    public fn neg_infinity() -> Float64 { -1.0 / 0.0 }
    public fn nan() -> Float64 { 0.0 / 0.0 }

    public fn is_nan(self) -> Bool { self != self }
    public fn is_infinite(self) -> Bool { self == Float64.infinity() || self == Float64.neg_infinity() }
    public fn is_finite(self) -> Bool { !self.is_nan() && !self.is_infinite() }

    public fn abs(self) -> Float64 { if self < 0.0 { -self } else { self } }
    public fn sqrt(self) -> Float64 { sqrt(self) }
    public fn floor(self) -> Float64 { floor(self) }
    public fn ceil(self) -> Float64 { ceil(self) }
    public fn round(self) -> Float64 { round(self) }
    public fn trunc(self) -> Float64 { trunc(self) }
    public fn cbrt(self) -> Float64 { cbrt(self) }
    public fn exp(self) -> Float64 { exp(self) }
    public fn exp2(self) -> Float64 { exp2(self) }
    public fn ln(self) -> Float64 { log(self) }
    public fn log2(self) -> Float64 { log2(self) }
    public fn log10(self) -> Float64 { log10(self) }
    public fn pow(self, exponent: Float64) -> Float64 { pow(self, exponent) }
    public fn sin(self) -> Float64 { sin(self) }
    public fn cos(self) -> Float64 { cos(self) }
    public fn tan(self) -> Float64 { tan(self) }
    public fn asin(self) -> Float64 { asin(self) }
    public fn acos(self) -> Float64 { acos(self) }
    public fn atan(self) -> Float64 { atan(self) }
    public fn atan2(self, other: Float64) -> Float64 { atan2(self, other) }
    public fn sinh(self) -> Float64 { sinh(self) }
    public fn cosh(self) -> Float64 { cosh(self) }
    public fn tanh(self) -> Float64 { tanh(self) }
    public fn asinh(self) -> Float64 { asinh(self) }
    public fn acosh(self) -> Float64 { acosh(self) }
    public fn atanh(self) -> Float64 { atanh(self) }
    public fn min(self, other: Float64) -> Float64 { minnum(self, other) }
    public fn max(self, other: Float64) -> Float64 { maxnum(self, other) }
    public fn mul_add(self, a: Float64, b: Float64) -> Float64 { fma(self, a, b) }
    public fn hypot(self, other: Float64) -> Float64 { hypot(self, other) }
    public fn copysign(self, sign: Float64) -> Float64 { copysign(self, sign) }

    public fn is_normal(self) -> Bool { self.is_finite() && !self.is_nan() && self.abs() >= Float64.MIN_POSITIVE }
    public fn is_positive(self) -> Bool { self > (0.0 as Float64) }
    public fn is_negative(self) -> Bool { self < (0.0 as Float64) }
    public fn is_zero(self) -> Bool { self == (0.0 as Float64) }
    public fn signum(self) -> Float64 {
        if self.is_nan() { Float64.nan() }
        else if self > (0.0 as Float64) { 1.0 as Float64 }
        else if self < (0.0 as Float64) { -1.0 as Float64 }
        else { 0.0 as Float64 }
    }
    public fn fract(self) -> Float64 { sub(self, trunc(self)) }
    public fn clamp(self, min_val: Float64, max_val: Float64) -> Float64 {
        if self < min_val { min_val }
        else if self > max_val { max_val }
        else { self }
    }
    public fn exp_m1(self) -> Float64 { expm1(self) }
    public fn ln_1p(self) -> Float64 { log1p(self) }
    public fn log_base(self, base: Float64) -> Float64 { log(self) / log(base) }
    public fn powi(self, exponent: Int) -> Float64 {
        let mut result = 1.0 as Float64;
        let mut base = self;
        let mut e = if exponent < 0 { 0 - exponent } else { exponent };
        while e > 0 {
            if e % 2 == 1 {
                result = mul(result, base);
            }
            base = mul(base, base);
            e = e / 2;
        }
        if exponent < 0 {
            div(1.0 as Float64, result)
        } else {
            result
        }
    }
    public fn sin_cos(self) -> (Float64, Float64) { (sin(self), cos(self)) }
    public fn to_degrees(self) -> Float64 { mul(self, 57.29577951308232 as Float64) }
    public fn to_radians(self) -> Float64 { mul(self, 0.017453292519943295 as Float64) }
    public fn to_int(self) -> Int { self as Int }

    public fn to_bits(self) -> UInt64 { f64_to_bits(self) }
    public fn from_bits(bits: UInt64) -> Float64 { f64_from_bits(bits) }

    public fn to_le_bytes(self) -> [Byte; 8] {
        let bits = f64_to_bits(self);
        to_le_bytes_8(bits)
    }
    public fn to_be_bytes(self) -> [Byte; 8] {
        let bits = f64_to_bits(self);
        to_be_bytes_8(bits)
    }
    public fn from_le_bytes(bytes: [Byte; 8]) -> Float64 {
        let bits = from_le_bytes_8(bytes);
        f64_from_bits(bits)
    }
    public fn from_be_bytes(bytes: [Byte; 8]) -> Float64 {
        let bits = from_be_bytes_8(bytes);
        f64_from_bits(bits)
    }
    public fn to_ne_bytes(self) -> [Byte; 8] { self.to_le_bytes() }
    public fn from_ne_bytes(bytes: [Byte; 8]) -> Float64 { Float64.from_le_bytes(bytes) }

    /// Midpoint of two Float64 values, avoiding overflow.
    public fn midpoint(self, other: Float64) -> Float64 {
        let a: Float = (self as Float) * 0.5;
        let b: Float = (other as Float) * 0.5;
        (a + b) as Float64
    }

    /// Linear interpolation between self and other by factor t.
    public fn lerp(self, other: Float64, t: Float64) -> Float64 {
        let s: Float = self as Float;
        let o: Float = other as Float;
        let f: Float = t as Float;
        let diff: Float = o - s;
        let scaled: Float = f * diff;
        (s + scaled) as Float64
    }

    /// Total comparison (orders NaN after all values).
    public fn total_cmp(self, other: Float64) -> Int {
        if self < other { -1 }
        else if self > other { 1 }
        else if self == other { 0 }
        else if other.is_nan() {
            if self.is_nan() { 0 } else { -1 }
        }
        else { 1 }
    }

    /// Reciprocal: 1.0 / self.
    public fn recip(self) -> Float64 {
        div(1.0 as Float64, self)
    }

    /// Check if subnormal (nonzero, finite, below MIN_POSITIVE).
    public fn is_subnormal(self) -> Bool {
        self.is_finite() && !self.is_zero() && !self.is_nan() && self.abs() >= (0.0 as Float64) && self.abs() < Float64.MIN_POSITIVE
    }

    /// Euclidean division.
    public fn div_euclid(self, rhs: Float64) -> Float64 {
        let q: Float = (self as Float) / (rhs as Float);
        let qt: Float = q.trunc();
        let r: Float = (self as Float) - qt * (rhs as Float);
        if r < 0.0 {
            if (rhs as Float) > 0.0 { (qt - 1.0) as Float64 } else { (qt + 1.0) as Float64 }
        } else {
            qt as Float64
        }
    }

    /// Euclidean remainder (always non-negative).
    public fn rem_euclid(self, rhs: Float64) -> Float64 {
        let sf: Float = self as Float;
        let rf: Float = rhs as Float;
        let r: Float = sf - (sf / rf).trunc() * rf;
        if r < 0.0 {
            let abs_rhs: Float = if rf < 0.0 { 0.0 - rf } else { rf };
            (r + abs_rhs) as Float64
        } else {
            r as Float64
        }
    }
}

// =============================================================================
// Widening From Conversions for Sized Numeric Types
// =============================================================================
// Each target type has at most ONE From implementation to avoid disambiguation.
// Widening chain: Int8 -> Int16 -> Int32 -> Int64, UInt8 -> UInt16 -> UInt32 -> UInt64
// =============================================================================

implement From<Int8> for Int16 {
    public fn from(val: Int8) -> Int16 { val as Int16 }
}

implement From<Int16> for Int32 {
    public fn from(val: Int16) -> Int32 { val as Int32 }
}

implement From<Int32> for Int64 {
    public fn from(val: Int32) -> Int64 { val as Int64 }
}

implement From<UInt8> for UInt16 {
    public fn from(val: UInt8) -> UInt16 { val as UInt16 }
}

implement From<UInt16> for UInt32 {
    public fn from(val: UInt16) -> UInt32 { val as UInt32 }
}

implement From<UInt32> for UInt64 {
    public fn from(val: UInt32) -> UInt64 { val as UInt64 }
}

// =============================================================================
// Eq, Ord, Hash, Clone, Copy Protocol Implementations for Sized Numeric Types
// =============================================================================
// These are REQUIRED for protocol-based dispatch. The compiler must NOT
// hardcode knowledge of these types — explicit protocol implementations
// enable all generic code that bounds on Eq, Ord, Hash, Clone, or Copy.
// =============================================================================

// --- Int8 ---
implement Eq for Int8 {
    public fn eq(&self, other: &Int8) -> Bool { eq(*self, *other) }
}
implement Ord for Int8 {
    public fn cmp(&self, other: &Int8) -> Ordering {
        if *self < *other { Less }
        else if *self > *other { Greater }
        else { Equal }
    }
}
implement Hash for Int8 {
    public fn hash(&self, hasher: &mut Hasher) { hasher.write_int(*self as Int); }
}
implement Clone for Int8 {
    public fn clone(&self) -> Int8 { *self }
}
implement Copy for Int8 {}

