    public fn saturating_sub(self, rhs: Int8) -> Int8 { saturating_sub(self, rhs) }
    public fn saturating_mul(self, rhs: Int8) -> Int8 { saturating_mul(self, rhs) }
    public fn pow(self, exp: Int) -> Int8 {
        assert(exp >= 0);
        let mut result = 1 as Int8;
        let mut base = self;
        let mut e = exp;
        while e > 0 {
            if e % 2 == 1 { result = result * base; }
            base = base * base;
            e = e / 2;
        }
        result
