    public fn checked_sub(self, rhs: UInt32) -> Maybe<UInt32> { checked_sub(self, rhs) }
    public fn checked_mul(self, rhs: UInt32) -> Maybe<UInt32> { checked_mul(self, rhs) }
    public fn wrapping_add(self, rhs: UInt32) -> UInt32 { wrapping_add(self, rhs) }
    public fn wrapping_sub(self, rhs: UInt32) -> UInt32 { wrapping_sub(self, rhs) }
    public fn wrapping_mul(self, rhs: UInt32) -> UInt32 { wrapping_mul(self, rhs) }
    public fn saturating_add(self, rhs: UInt32) -> UInt32 { saturating_add(self, rhs) }
    public fn saturating_sub(self, rhs: UInt32) -> UInt32 { saturating_sub(self, rhs) }
    public fn saturating_mul(self, rhs: UInt32) -> UInt32 { saturating_mul(self, rhs) }
    public fn leading_zeros(self) -> Int { clz(self) }
    public fn trailing_zeros(self) -> Int { ctz(self) }
    public fn count_ones(self) -> Int { popcnt(self) }
    public fn count_zeros(self) -> Int { 32 - popcnt(self) }
    public fn rotate_left(self, n: Int) -> UInt32 { rotl(self, n) }
    public fn rotate_right(self, n: Int) -> UInt32 { rotr(self, n) }
    public fn swap_bytes(self) -> UInt32 { bswap(self) }
    public fn pow(self, exp: Int) -> UInt32 {
        assert(exp >= 0);
        let mut result = 1 as UInt32;
        let mut base = self;
        let mut e = exp;
        while e > 0 {
            if e % 2 == 1 { result = result * base; }
            base = base * base;
            e = e / 2;
        }
        result
    }
    public fn checked_div(self, rhs: UInt32) -> Maybe<UInt32> {
        if rhs == (0 as UInt32) { None } else { Some(self / rhs) }
    }
    public fn in_range(self, start: UInt32, end: UInt32) -> Bool { self >= start && self < end }
    public fn to_float(self) -> Float { self.to_int().to_float() }
    public fn to_int(self) -> Int { self as Int }
    public fn overflowing_add(self, rhs: UInt32) -> (UInt32, Bool) { overflowing_add(self, rhs) }
    public fn overflowing_sub(self, rhs: UInt32) -> (UInt32, Bool) { overflowing_sub(self, rhs) }
    public fn overflowing_mul(self, rhs: UInt32) -> (UInt32, Bool) { overflowing_mul(self, rhs) }
    public fn reverse_bits(self) -> UInt32 { bitreverse(self) }
    public fn to_binary(self) -> Text { self.to_int().to_binary() }
    public fn to_hex(self) -> Text { self.to_int().to_hex() }
    public fn to_octal(self) -> Text { self.to_int().to_octal() }
    public fn checked_rem(self, rhs: UInt32) -> Maybe<UInt32> {
        if rhs == (0 as UInt32) { None } else { Some(rem(self, rhs)) }
    }
    public fn wrapping_neg(self) -> UInt32 { wrapping_neg(self) }
    public fn abs_diff(self, other: UInt32) -> Int {
        let a = self.to_int();
        let b_val = other.to_int();
        if a >= b_val { a - b_val } else { b_val - a }
    }
    public fn ilog2(self) -> Int {
        assert(self.to_int() > 0);
        31 - self.leading_zeros()
    }
    public fn ilog10(self) -> Int {
        assert(self.to_int() > 0);
        let mut count = 0;
        let mut n = self.to_int();
        while n >= 10 { n = n / 10; count = count + 1; }
        count
    }
    public fn is_power_of_two(self) -> Bool {
        let n = self.to_int();
        n > 0 && bitand(n, n - 1) == 0
    }
    public fn next_power_of_two(self) -> UInt32 {
        let n = self.to_int();
        if n <= 1 { 1 as UInt32 }
        else if n.is_power_of_two() { self }
        else {
            let shift = n.ilog2() + 1;
            assert(shift < 32);
            (1 << shift) as UInt32
        }
    }
    public fn checked_shl(self, shift: Int) -> Maybe<UInt32> {
        if shift < 0 || shift >= 32 { None } else { Some(shl(self, shift as UInt32)) }
    }
    public fn checked_shr(self, shift: Int) -> Maybe<UInt32> {
        if shift < 0 || shift >= 32 { None } else { Some(shr(self, shift as UInt32)) }
    }
    public fn checked_pow(self, exp: Int) -> Maybe<UInt32> {
        if exp < 0 { None }
        else if exp == 0 { Some(1 as UInt32) }
        else {
            let mut base = self;
            let mut e = exp;
            let mut result = 1 as UInt32;
            let mut overflow = false;
            while e > 0 && !overflow {
                if bitand(e, 1) == 1 {
                    match result.checked_mul(base) {
                        Some(v) => { result = v; },
                        None => { overflow = true; },
                    };
                }
                e = e >> 1;
                if e > 0 && !overflow {
                    match base.checked_mul(base) {
                        Some(v) => { base = v; },
                        None => { overflow = true; },
                    };
                }
            }
            if overflow { None } else { Some(result) }
        }
    }
    public fn wrapping_shl(self, shift: Int) -> UInt32 { shl(self, (bitand(shift, 31)) as UInt32) }
    public fn wrapping_shr(self, shift: Int) -> UInt32 { shr(self, (bitand(shift, 31)) as UInt32) }
    public fn wrapping_div(self, rhs: UInt32) -> UInt32 { div(self, rhs) }
    public fn wrapping_rem(self, rhs: UInt32) -> UInt32 { rem(self, rhs) }
    public fn div_euclid(self, rhs: UInt32) -> UInt32 { div(self, rhs) }
    public fn rem_euclid(self, rhs: UInt32) -> UInt32 { rem(self, rhs) }
    public fn saturating_pow(self, exp: Int) -> UInt32 {
        match self.checked_pow(exp) { Some(v) => v, None => 4294967295 as UInt32 }
    }
    public fn overflowing_shl(self, shift: Int) -> (UInt32, Bool) {
        (shl(self, (bitand(shift, 31)) as UInt32), shift < 0 || shift >= 32)
    }
    public fn overflowing_shr(self, shift: Int) -> (UInt32, Bool) {
        (shr(self, (bitand(shift, 31)) as UInt32), shift < 0 || shift >= 32)
    }
    public fn midpoint(self, other: UInt32) -> UInt32 {
        let a = self.to_int();
        let b = other.to_int();
        ((a >> 1) + (b >> 1) + bitand(bitand(a, b), 1)) as UInt32
    }
    public fn to_ne_bytes(self) -> [Byte; 4] { to_le_bytes_4(self) }
    public fn from_ne_bytes(bytes: [Byte; 4]) -> UInt32 { from_le_bytes_4(bytes) }
}

// =============================================================================
// UInt16 - 16-bit unsigned integer
// =============================================================================

implement UInt16 {
    public const MIN: UInt16 = 0;
    public const MAX: UInt16 = 65535;
    public const BITS: Int = 16;

    public fn min(self, other: UInt16) -> UInt16 { intrinsic_min(self, other) }
    public fn max(self, other: UInt16) -> UInt16 { intrinsic_max(self, other) }
    public fn clamp(self, min_val: UInt16, max_val: UInt16) -> UInt16 { intrinsic_clamp(self, min_val, max_val) }

    public fn to_le_bytes(self) -> [Byte; 2] { to_le_bytes_2(self) }
    public fn to_be_bytes(self) -> [Byte; 2] { to_be_bytes_2(self) }
    public fn from_le_bytes(bytes: [Byte; 2]) -> UInt16 { from_le_bytes_2(bytes) }
    public fn from_be_bytes(bytes: [Byte; 2]) -> UInt16 { from_be_bytes_2(bytes) }

    public fn checked_add(self, rhs: UInt16) -> Maybe<UInt16> { checked_add(self, rhs) }
    public fn checked_sub(self, rhs: UInt16) -> Maybe<UInt16> { checked_sub(self, rhs) }
    public fn checked_mul(self, rhs: UInt16) -> Maybe<UInt16> { checked_mul(self, rhs) }
    public fn wrapping_add(self, rhs: UInt16) -> UInt16 { wrapping_add(self, rhs) }
    public fn wrapping_sub(self, rhs: UInt16) -> UInt16 { wrapping_sub(self, rhs) }
    public fn wrapping_mul(self, rhs: UInt16) -> UInt16 { wrapping_mul(self, rhs) }
    public fn saturating_add(self, rhs: UInt16) -> UInt16 { saturating_add(self, rhs) }
    public fn saturating_sub(self, rhs: UInt16) -> UInt16 { saturating_sub(self, rhs) }
    public fn saturating_mul(self, rhs: UInt16) -> UInt16 { saturating_mul(self, rhs) }
    public fn leading_zeros(self) -> Int { clz(self) }
    public fn trailing_zeros(self) -> Int { ctz(self) }
    public fn count_ones(self) -> Int { popcnt(self) }
    public fn count_zeros(self) -> Int { 16 - popcnt(self) }
    public fn rotate_left(self, n: Int) -> UInt16 { rotl(self, n) }
    public fn rotate_right(self, n: Int) -> UInt16 { rotr(self, n) }
    public fn swap_bytes(self) -> UInt16 { bswap(self) }
    public fn pow(self, exp: Int) -> UInt16 {
        assert(exp >= 0);
        let mut result = 1 as UInt16;
        let mut base = self;
        let mut e = exp;
        while e > 0 {
            if e % 2 == 1 { result = result * base; }
            base = base * base;
            e = e / 2;
        }
        result
    }
    public fn checked_div(self, rhs: UInt16) -> Maybe<UInt16> {
        if rhs == (0 as UInt16) { None } else { Some(self / rhs) }
    }
    public fn in_range(self, start: UInt16, end: UInt16) -> Bool { self >= start && self < end }
    public fn to_float(self) -> Float { self.to_int().to_float() }
    public fn to_int(self) -> Int { self as Int }
    public fn overflowing_add(self, rhs: UInt16) -> (UInt16, Bool) { overflowing_add(self, rhs) }
    public fn overflowing_sub(self, rhs: UInt16) -> (UInt16, Bool) { overflowing_sub(self, rhs) }
    public fn overflowing_mul(self, rhs: UInt16) -> (UInt16, Bool) { overflowing_mul(self, rhs) }
    public fn reverse_bits(self) -> UInt16 { bitreverse(self) }
    public fn to_binary(self) -> Text { self.to_int().to_binary() }
    public fn to_hex(self) -> Text { self.to_int().to_hex() }
    public fn to_octal(self) -> Text { self.to_int().to_octal() }
    public fn checked_rem(self, rhs: UInt16) -> Maybe<UInt16> {
        if rhs == (0 as UInt16) { None } else { Some(rem(self, rhs)) }
    }
    public fn wrapping_neg(self) -> UInt16 { wrapping_neg(self) }
    public fn abs_diff(self, other: UInt16) -> Int {
        let a = self.to_int();
        let b_val = other.to_int();
        if a >= b_val { a - b_val } else { b_val - a }
    }
    public fn ilog2(self) -> Int {
        assert(self.to_int() > 0);
        15 - self.leading_zeros()
    }
    public fn ilog10(self) -> Int {
        assert(self.to_int() > 0);
        let mut count = 0;
        let mut n = self.to_int();
        while n >= 10 { n = n / 10; count = count + 1; }
        count
    }
    public fn is_power_of_two(self) -> Bool {
        let n = self.to_int();
        n > 0 && bitand(n, n - 1) == 0
    }
    public fn next_power_of_two(self) -> UInt16 {
        let n = self.to_int();
        if n <= 1 { 1 as UInt16 }
        else if n.is_power_of_two() { self }
        else {
            let shift = n.ilog2() + 1;
            assert(shift < 16);
            (1 << shift) as UInt16
        }
    }
    public fn checked_shl(self, shift: Int) -> Maybe<UInt16> {
        if shift < 0 || shift >= 16 { None } else { Some(shl(self, shift as UInt32)) }
    }
    public fn checked_shr(self, shift: Int) -> Maybe<UInt16> {
        if shift < 0 || shift >= 16 { None } else { Some(shr(self, shift as UInt32)) }
    }
    public fn checked_pow(self, exp: Int) -> Maybe<UInt16> {
        if exp < 0 { None }
        else if exp == 0 { Some(1 as UInt16) }
        else {
            let mut base = self;
            let mut e = exp;
            let mut result = 1 as UInt16;
            let mut overflow = false;
            while e > 0 && !overflow {
                if bitand(e, 1) == 1 {
                    match result.checked_mul(base) {
                        Some(v) => { result = v; },
                        None => { overflow = true; },
                    };
                }
                e = e >> 1;
                if e > 0 && !overflow {
                    match base.checked_mul(base) {
                        Some(v) => { base = v; },
                        None => { overflow = true; },
                    };
                }
            }
            if overflow { None } else { Some(result) }
        }
    }
    public fn wrapping_shl(self, shift: Int) -> UInt16 { shl(self, (bitand(shift, 15)) as UInt32) }
    public fn wrapping_shr(self, shift: Int) -> UInt16 { shr(self, (bitand(shift, 15)) as UInt32) }
    public fn wrapping_div(self, rhs: UInt16) -> UInt16 { div(self, rhs) }
    public fn wrapping_rem(self, rhs: UInt16) -> UInt16 { rem(self, rhs) }
    public fn div_euclid(self, rhs: UInt16) -> UInt16 { div(self, rhs) }
    public fn rem_euclid(self, rhs: UInt16) -> UInt16 { rem(self, rhs) }
    public fn saturating_pow(self, exp: Int) -> UInt16 {
        match self.checked_pow(exp) { Some(v) => v, None => 65535 as UInt16 }
    }
    public fn overflowing_shl(self, shift: Int) -> (UInt16, Bool) {
        (shl(self, (bitand(shift, 15)) as UInt32), shift < 0 || shift >= 16)
    }
    public fn overflowing_shr(self, shift: Int) -> (UInt16, Bool) {
        (shr(self, (bitand(shift, 15)) as UInt32), shift < 0 || shift >= 16)
    }
    public fn midpoint(self, other: UInt16) -> UInt16 {
        let a = self.to_int();
        let b = other.to_int();
        ((a >> 1) + (b >> 1) + bitand(bitand(a, b), 1)) as UInt16
    }
    public fn to_ne_bytes(self) -> List<Byte> { to_le_bytes(self) }
    public fn from_ne_bytes(bytes: List<Byte>) -> UInt16 { from_le_bytes(bytes) }
}

// =============================================================================
// UInt8 - 8-bit unsigned integer (alias for Byte)
// =============================================================================
// Note: Byte is the canonical 8-bit unsigned type. UInt8 provides semantic naming.

implement UInt8 {
    public const MIN: UInt8 = 0;
    public const MAX: UInt8 = 255;
    public const BITS: Int = 8;

    public fn min(self, other: UInt8) -> UInt8 { intrinsic_min(self, other) }
    public fn max(self, other: UInt8) -> UInt8 { intrinsic_max(self, other) }
    public fn clamp(self, min_val: UInt8, max_val: UInt8) -> UInt8 { intrinsic_clamp(self, min_val, max_val) }

    public fn checked_add(self, rhs: UInt8) -> Maybe<UInt8> { checked_add(self, rhs) }
    public fn checked_sub(self, rhs: UInt8) -> Maybe<UInt8> { checked_sub(self, rhs) }
    public fn checked_mul(self, rhs: UInt8) -> Maybe<UInt8> { checked_mul(self, rhs) }
    public fn wrapping_add(self, rhs: UInt8) -> UInt8 { wrapping_add(self, rhs) }
    public fn wrapping_sub(self, rhs: UInt8) -> UInt8 { wrapping_sub(self, rhs) }
    public fn wrapping_mul(self, rhs: UInt8) -> UInt8 { wrapping_mul(self, rhs) }
    public fn saturating_add(self, rhs: UInt8) -> UInt8 { saturating_add(self, rhs) }
    public fn saturating_sub(self, rhs: UInt8) -> UInt8 { saturating_sub(self, rhs) }
    public fn saturating_mul(self, rhs: UInt8) -> UInt8 { saturating_mul(self, rhs) }
    public fn pow(self, exp: Int) -> UInt8 {
        assert(exp >= 0);
        let mut result = 1 as UInt8;
        let mut base = self;
        let mut e = exp;
        while e > 0 {
            if e % 2 == 1 { result = result * base; }
            base = base * base;
            e = e / 2;
        }
        result
    }
    public fn checked_div(self, rhs: UInt8) -> Maybe<UInt8> {
        if rhs == (0 as UInt8) { None } else { Some(self / rhs) }
    }
    public fn in_range(self, start: UInt8, end: UInt8) -> Bool { self >= start && self < end }
    public fn to_float(self) -> Float { self.to_int().to_float() }
    public fn to_int(self) -> Int { self as Int }
    public fn overflowing_add(self, rhs: UInt8) -> (UInt8, Bool) { overflowing_add(self, rhs) }
    public fn overflowing_sub(self, rhs: UInt8) -> (UInt8, Bool) { overflowing_sub(self, rhs) }
    public fn overflowing_mul(self, rhs: UInt8) -> (UInt8, Bool) { overflowing_mul(self, rhs) }
    public fn reverse_bits(self) -> UInt8 { bitreverse(self) }
    public fn leading_zeros(self) -> Int { clz(self) }
    public fn trailing_zeros(self) -> Int { ctz(self) }
    public fn count_ones(self) -> Int { popcnt(self) }
    public fn count_zeros(self) -> Int { 8 - popcnt(self) }
    public fn rotate_left(self, n: Int) -> UInt8 { rotl(self, n) }
    public fn rotate_right(self, n: Int) -> UInt8 { rotr(self, n) }
    public fn swap_bytes(self) -> UInt8 { bswap(self) }
    public fn to_le_bytes(self) -> List<Byte> { to_le_bytes(self) }
    public fn to_be_bytes(self) -> List<Byte> { to_be_bytes(self) }
    public fn from_le_bytes(bytes: List<Byte>) -> UInt8 { from_le_bytes(bytes) }
    public fn from_be_bytes(bytes: List<Byte>) -> UInt8 { from_be_bytes(bytes) }
    public fn to_binary(self) -> Text { self.to_int().to_binary() }
    public fn to_hex(self) -> Text { self.to_int().to_hex() }
    public fn to_octal(self) -> Text { self.to_int().to_octal() }
    public fn checked_rem(self, rhs: UInt8) -> Maybe<UInt8> {
        if rhs == (0 as UInt8) { None } else { Some(rem(self, rhs)) }
    }
    public fn wrapping_neg(self) -> UInt8 { wrapping_neg(self) }
    public fn abs_diff(self, other: UInt8) -> Int {
        let a = self.to_int();
        let b_val = other.to_int();
        if a >= b_val { a - b_val } else { b_val - a }
    }
    public fn ilog2(self) -> Int {
        assert(self.to_int() > 0);
        7 - self.leading_zeros()
    }
    public fn ilog10(self) -> Int {
        assert(self.to_int() > 0);
        let mut count = 0;
        let mut n = self.to_int();
        while n >= 10 { n = n / 10; count = count + 1; }
        count
    }
    public fn is_power_of_two(self) -> Bool {
        let n = self.to_int();
        n > 0 && bitand(n, n - 1) == 0
    }
    public fn next_power_of_two(self) -> UInt8 {
        let n = self.to_int();
        if n <= 1 { 1 as UInt8 }
        else if n.is_power_of_two() { self }
        else {
            let shift = n.ilog2() + 1;
            assert(shift < 8);
            (1 << shift) as UInt8
        }
    }
    public fn checked_shl(self, shift: Int) -> Maybe<UInt8> {
        if shift < 0 || shift >= 8 { None } else { Some(shl(self, shift as UInt32)) }
    }
    public fn checked_shr(self, shift: Int) -> Maybe<UInt8> {
        if shift < 0 || shift >= 8 { None } else { Some(shr(self, shift as UInt32)) }
    }
    public fn checked_pow(self, exp: Int) -> Maybe<UInt8> {
        if exp < 0 { None }
        else if exp == 0 { Some(1 as UInt8) }
        else {
            let mut base = self;
            let mut e = exp;
            let mut result = 1 as UInt8;
            let mut overflow = false;
            while e > 0 && !overflow {
                if bitand(e, 1) == 1 {
                    match result.checked_mul(base) {
                        Some(v) => { result = v; },
                        None => { overflow = true; },
                    };
                }
                e = e >> 1;
                if e > 0 && !overflow {
                    match base.checked_mul(base) {
                        Some(v) => { base = v; },
                        None => { overflow = true; },
                    };
                }
            }
            if overflow { None } else { Some(result) }
        }
    }
    public fn wrapping_shl(self, shift: Int) -> UInt8 { shl(self, (bitand(shift, 7)) as UInt32) }
    public fn wrapping_shr(self, shift: Int) -> UInt8 { shr(self, (bitand(shift, 7)) as UInt32) }
    public fn wrapping_div(self, rhs: UInt8) -> UInt8 { div(self, rhs) }
    public fn wrapping_rem(self, rhs: UInt8) -> UInt8 { rem(self, rhs) }
    public fn div_euclid(self, rhs: UInt8) -> UInt8 { div(self, rhs) }
    public fn rem_euclid(self, rhs: UInt8) -> UInt8 { rem(self, rhs) }
    public fn saturating_pow(self, exp: Int) -> UInt8 {
        match self.checked_pow(exp) { Some(v) => v, None => 255 as UInt8 }
    }
    public fn overflowing_shl(self, shift: Int) -> (UInt8, Bool) {
        (shl(self, (bitand(shift, 7)) as UInt32), shift < 0 || shift >= 8)
    }
    public fn overflowing_shr(self, shift: Int) -> (UInt8, Bool) {
        (shr(self, (bitand(shift, 7)) as UInt32), shift < 0 || shift >= 8)
    }
    public fn midpoint(self, other: UInt8) -> UInt8 {
        let a = self.to_int();
        let b = other.to_int();
        ((a >> 1) + (b >> 1) + bitand(bitand(a, b), 1)) as UInt8
    }
    public fn to_ne_bytes(self) -> List<Byte> { to_le_bytes(self) }
    public fn from_ne_bytes(bytes: List<Byte>) -> UInt8 { from_le_bytes(bytes) }
}

