    public fn from_be_bytes(bytes: List<Byte>) -> USize { from_be_bytes(bytes) }
    public fn to_binary(self) -> Text { self.to_int().to_binary() }
    public fn to_hex(self) -> Text { self.to_int().to_hex() }
    public fn to_octal(self) -> Text { self.to_int().to_octal() }
    public fn checked_rem(self, rhs: USize) -> Maybe<USize> {
        if rhs == (0 as USize) { None } else { Some(rem(self, rhs)) }
    }
    public fn wrapping_neg(self) -> USize { wrapping_neg(self) }
    public fn abs_diff(self, other: USize) -> Int {
        let a = self.to_int();
        let b_val = other.to_int();
        if a >= b_val { a - b_val } else { b_val - a }
    }
    public fn ilog2(self) -> Int {
        assert(self.to_int() > 0);
        63 - self.leading_zeros()
    }
    public fn ilog10(self) -> Int {
        assert(self.to_int() > 0);
        let mut count = 0;
        let mut n = self.to_int();
        while n >= 10 { n = n / 10; count = count + 1; }
        count
    }
    public fn is_power_of_two(self) -> Bool {
        let n = self.to_int();
        n > 0 && bitand(n, n - 1) == 0
    }
    public fn next_power_of_two(self) -> USize {
        let n = self.to_int();
        if n <= 1 { 1 as USize }
        else if n.is_power_of_two() { self }
