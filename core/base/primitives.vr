        else { r as Int64 }
    }
    public fn saturating_pow(self, exp: Int) -> Int64 {
        match self.checked_pow(exp) {
            Some(v) => v,
            None => { if self.to_int() < 0 && bitand(exp, 1) == 1 { -9223372036854775808 as Int64 } else { 9223372036854775807 as Int64 } },
        }
    }
    public fn overflowing_shl(self, shift: Int) -> (Int64, Bool) {
        (shl(self, (bitand(shift, 63)) as UInt32), shift < 0 || shift >= 64)
    }
    public fn overflowing_shr(self, shift: Int) -> (Int64, Bool) {
        (shr(self, (bitand(shift, 63)) as UInt32), shift < 0 || shift >= 64)
    }
    public fn midpoint(self, other: Int64) -> Int64 {
        let a = self.to_int();
        let b = other.to_int();
        ((a >> 1) + (b >> 1) + bitand(bitand(a, b), 1)) as Int64
    }
    public fn to_ne_bytes(self) -> List<Byte> { to_le_bytes(self) }
    public fn from_ne_bytes(bytes: List<Byte>) -> Int64 { from_le_bytes(bytes) }
}

// =============================================================================
// Int128 - 128-bit signed integer
// =============================================================================

implement Int128 {
    // -2^127
    public const MIN: Int128 = -170141183460469231731687303715884105728;
    // 2^127 - 1
    public const MAX: Int128 = 170141183460469231731687303715884105727;
    public const BITS: Int = 128;

    public fn to_le_bytes(self) -> [Byte; 16] { to_le_bytes(self) }
    public fn to_be_bytes(self) -> [Byte; 16] { to_be_bytes(self) }
    public fn from_le_bytes(bytes: [Byte; 16]) -> Int128 { from_le_bytes(bytes) }
    public fn from_be_bytes(bytes: [Byte; 16]) -> Int128 { from_be_bytes(bytes) }

    public fn abs(self) -> Int128 { abs_signed(self) }
    public fn signum(self) -> Int128 { signum(self) }
    public fn min(self, other: Int128) -> Int128 { intrinsic_min(self, other) }
    public fn max(self, other: Int128) -> Int128 { intrinsic_max(self, other) }
    public fn clamp(self, min_val: Int128, max_val: Int128) -> Int128 { intrinsic_clamp(self, min_val, max_val) }
    public fn checked_add(self, rhs: Int128) -> Maybe<Int128> { checked_add(self, rhs) }
    public fn checked_sub(self, rhs: Int128) -> Maybe<Int128> { checked_sub(self, rhs) }
    public fn checked_mul(self, rhs: Int128) -> Maybe<Int128> { checked_mul(self, rhs) }
    public fn wrapping_add(self, rhs: Int128) -> Int128 { wrapping_add(self, rhs) }
    public fn wrapping_sub(self, rhs: Int128) -> Int128 { wrapping_sub(self, rhs) }
    public fn saturating_add(self, rhs: Int128) -> Int128 { saturating_add(self, rhs) }
    public fn wrapping_mul(self, rhs: Int128) -> Int128 { wrapping_mul(self, rhs) }
    public fn saturating_sub(self, rhs: Int128) -> Int128 { saturating_sub(self, rhs) }
    public fn saturating_mul(self, rhs: Int128) -> Int128 { saturating_mul(self, rhs) }
    public fn leading_zeros(self) -> Int { clz(self) }
    public fn trailing_zeros(self) -> Int { ctz(self) }
    public fn count_ones(self) -> Int { popcnt(self) }
    public fn count_zeros(self) -> Int { 128 - popcnt(self) }
    public fn rotate_left(self, n: Int) -> Int128 { rotl(self, n) }
    public fn rotate_right(self, n: Int) -> Int128 { rotr(self, n) }
    public fn swap_bytes(self) -> Int128 { bswap(self) }
    public fn pow(self, exp: Int) -> Int128 {
        assert(exp >= 0);
        let mut result = 1 as Int128;
        let mut base = self;
        let mut e = exp;
        while e > 0 {
            if e % 2 == 1 { result = result * base; }
            base = base * base;
            e = e / 2;
        }
        result
    }
    public fn is_positive(self) -> Bool { self > (0 as Int128) }
    public fn is_negative(self) -> Bool { self < (0 as Int128) }
    public fn checked_div(self, rhs: Int128) -> Maybe<Int128> {
        if rhs == (0 as Int128) { None } else { Some(self / rhs) }
    }
    public fn in_range(self, start: Int128, end: Int128) -> Bool { self >= start && self < end }
    public fn to_float(self) -> Float { self.to_int().to_float() }
    public fn to_int(self) -> Int { self as Int }
    public fn overflowing_add(self, rhs: Int128) -> (Int128, Bool) { overflowing_add(self, rhs) }
    public fn overflowing_sub(self, rhs: Int128) -> (Int128, Bool) { overflowing_sub(self, rhs) }
    public fn overflowing_mul(self, rhs: Int128) -> (Int128, Bool) { overflowing_mul(self, rhs) }
    public fn reverse_bits(self) -> Int128 { bitreverse(self) }
    public fn to_binary(self) -> Text { self.to_int().to_binary() }
    public fn to_hex(self) -> Text { self.to_int().to_hex() }
    public fn to_octal(self) -> Text { self.to_int().to_octal() }
    public fn checked_rem(self, rhs: Int128) -> Maybe<Int128> {
        if rhs == (0 as Int128) { None } else { Some(rem(self, rhs)) }
    }
    public fn wrapping_neg(self) -> Int128 { wrapping_neg(self) }
    public fn checked_neg(self) -> Maybe<Int128> {
        let pair = overflowing_sub(0 as Int128, self);
        if pair.1 { None } else { Some(pair.0) }
    }
    public fn ilog2(self) -> Int {
        assert(self.to_int() > 0);
        127 - self.leading_zeros()
    }
    public fn is_power_of_two(self) -> Bool {
        let n = self.to_int();
        n > 0 && bitand(n, n - 1) == 0
    }
    public fn checked_shl(self, shift: Int) -> Maybe<Int128> {
        if shift < 0 || shift >= 128 { None } else { Some(shl(self, shift as UInt32)) }
    }
    public fn checked_shr(self, shift: Int) -> Maybe<Int128> {
        if shift < 0 || shift >= 128 { None } else { Some(shr(self, shift as UInt32)) }
    }
    public fn checked_pow(self, exp: Int) -> Maybe<Int128> {
        if exp < 0 { None }
        else if exp == 0 { Some(1 as Int128) }
        else {
            let mut base = self;
            let mut e = exp;
            let mut result = 1 as Int128;
            let mut overflow = false;
            while e > 0 && !overflow {
                if bitand(e, 1) == 1 {
                    match result.checked_mul(base) {
                        Some(v) => { result = v; },
                        None => { overflow = true; },
                    };
                }
                e = e >> 1;
                if e > 0 && !overflow {
                    match base.checked_mul(base) {
                        Some(v) => { base = v; },
                        None => { overflow = true; },
                    };
                }
            }
            if overflow { None } else { Some(result) }
        }
    }
    public fn wrapping_shl(self, shift: Int) -> Int128 { shl(self, (bitand(shift, 127)) as UInt32) }
    public fn wrapping_shr(self, shift: Int) -> Int128 { shr(self, (bitand(shift, 127)) as UInt32) }
    public fn wrapping_div(self, rhs: Int128) -> Int128 { div(self, rhs) }
    public fn wrapping_rem(self, rhs: Int128) -> Int128 { rem(self, rhs) }
    public fn div_euclid(self, rhs: Int128) -> Int128 { div(self, rhs) }
    public fn rem_euclid(self, rhs: Int128) -> Int128 { rem(self, rhs) }
    public fn saturating_pow(self, exp: Int) -> Int128 {
        match self.checked_pow(exp) { Some(v) => v, None => Int128.MAX }
    }
    public fn overflowing_shl(self, shift: Int) -> (Int128, Bool) {
        (shl(self, (bitand(shift, 127)) as UInt32), shift < 0 || shift >= 128)
    }
    public fn overflowing_shr(self, shift: Int) -> (Int128, Bool) {
        (shr(self, (bitand(shift, 127)) as UInt32), shift < 0 || shift >= 128)
    }
    public fn midpoint(self, other: Int128) -> Int128 {
        let a = self.to_int();
        let b = other.to_int();
        ((a >> 1) + (b >> 1) + bitand(bitand(a, b), 1)) as Int128
    }
    public fn to_ne_bytes(self) -> List<Byte> { to_le_bytes(self) }
    public fn from_ne_bytes(bytes: List<Byte>) -> Int128 { from_le_bytes(bytes) }
    public fn abs_diff(self, other: Int128) -> Int {
        let a = self.to_int();
        let b = other.to_int();
        if a >= b { a - b } else { b - a }
    }
    public fn ilog10(self) -> Int {
        assert(self.to_int() > 0);
        let mut n = self.to_int();
        let mut count = 0;
        while n >= 10 {
            n = n / 10;
            count = count + 1;
        }
        count
    }
}

// =============================================================================
// ISize / USize - Platform-dependent size types
// =============================================================================

implement ISize {
    // On 64-bit platforms (assumed)
    public const MIN: ISize = -9223372036854775808;
    public const MAX: ISize = 9223372036854775807;
    public const BITS: Int = 64;

    public fn abs(self) -> ISize { abs_signed(self) }
    public fn signum(self) -> ISize { signum(self) }
