    }
}
implement PartialOrd for Float32 {
    public fn partial_cmp(&self, other: &Float32) -> Maybe<Ordering> {
        if self.is_nan() || other.is_nan() {
            None
        } else if *self < *other {
            Some(Less)
        } else if *self > *other {
            Some(Greater)
        } else {
            Some(Equal)
        }
    }
}
implement Clone for Float32 {
    public fn clone(&self) -> Float32 { *self }
}
implement Copy for Float32 {}

// =============================================================================
// Float64 — Full Protocol Suite
// =============================================================================
// Float64 was previously missing nearly all protocols. These implementations
// bring it to parity with Float.
// =============================================================================

implement Add for Float64 {
    type Output = Float64;
    public fn add(self, rhs: Float64) -> Float64 { add(self, rhs) }
}

implement Sub for Float64 {
    type Output = Float64;
    public fn sub(self, rhs: Float64) -> Float64 { sub(self, rhs) }
}

implement Mul for Float64 {
    type Output = Float64;
    public fn mul(self, rhs: Float64) -> Float64 { mul(self, rhs) }
}

implement Div for Float64 {
    type Output = Float64;
    public fn div(self, rhs: Float64) -> Float64 { div(self, rhs) }
}

implement Rem for Float64 {
    type Output = Float64;
    public fn rem(self, rhs: Float64) -> Float64 { rem(self, rhs) }
}

implement Eq for Float64 {
    public fn eq(&self, other: &Float64) -> Bool {
        // Note: NaN != NaN by IEEE 754
        eq(*self, *other)
    }
}

implement PartialOrd for Float64 {
    public fn partial_cmp(&self, other: &Float64) -> Maybe<Ordering> {
        if self.is_nan() || other.is_nan() {
            None
        } else if *self < *other {
            Some(Less)
        } else if *self > *other {
            Some(Greater)
        } else {
            Some(Equal)
        }
    }
}

implement Clone for Float64 {
    public fn clone(&self) -> Float64 { *self }
}

implement Copy for Float64 {}

implement Default for Float64 {
    public fn default() -> Float64 { 0.0 as Float64 }
}

implement Debug for Float64 {
    public fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(&self.to_float().to_text())
    }
}

implement Display for Float64 {
    public fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(&self.to_float().to_text())
    }
}

implement Zero for Float64 {
    public fn zero() -> Float64 { 0.0 as Float64 }
    public fn is_zero(&self) -> Bool { *self == (0.0 as Float64) }
}

implement One for Float64 {
    public fn one() -> Float64 { 1.0 as Float64 }
    public fn is_one(&self) -> Bool { *self == (1.0 as Float64) }
}

// --- Display for Byte ---
implement Display for Byte {
    public fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(&(*self as Int).to_text())
    }
}

