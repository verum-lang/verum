// =============================================================================
// cli/manpage.vr — Groff/troff manpage emitter
// =============================================================================
// Layer: 5 (CLI)
// Dependencies: core, text, cli.spec
// Spec: internal/specs/cli-framework.md §8.2
// =============================================================================
//

// Emits a `.TH ... .SH ...` groff document compatible with `man(1)`.
// Output sections: NAME, SYNOPSIS, DESCRIPTION, OPTIONS, COMMANDS,
// EXAMPLES, ENVIRONMENT, EXIT STATUS, AUTHOR, SEE ALSO. Subcommands are
// rendered with their own subsections (`.SS`) so a single page can
// document a multi-level CLI (kubectl-style).
//
// Spec field correspondences:
//   CommandSpec.name        → .TH NAME 1
//   CommandSpec.about       → .SH NAME
//   CommandSpec.long_about  → .SH DESCRIPTION
//   ArgSpec / FlagSpec      → .SH OPTIONS (.TP for each)
//   subcommands             → .SH COMMANDS (.SS per subcommand)
//   examples                → .SH EXAMPLES
//   flags[].env_fallback    → .SH ENVIRONMENT
//   ParseErrorKind exit-codes → .SH EXIT STATUS
//

// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module manpage;

mount core.{Maybe, Result, List, Text, Int, Bool};
mount core.text.builder.TextBuilder;
mount core.cli.spec.{CommandSpec, ArgSpec, FlagSpec, Example};

// =============================================================================
// Manpage section number
// =============================================================================

public type Section is
    | UserCommands              // 1
    | SystemCalls               // 2
    | LibraryCalls              // 3
    | SpecialFiles              // 4
    | FileFormats               // 5
    | Games                     // 6
    | Misc                      // 7
    | SystemAdmin;              // 8

implement Section {
    public fn number(&self) -> Int {
        match self {
            Section.UserCommands => 1,
            Section.SystemCalls => 2,
            Section.LibraryCalls => 3,
            Section.SpecialFiles => 4,
            Section.FileFormats => 5,
            Section.Games => 6,
            Section.Misc => 7,
            Section.SystemAdmin => 8,
        }
    }
}

// =============================================================================
// Top-level emit
// =============================================================================

/// Render `cmd` as a groff manpage in section `section`. The result is
/// suitable for direct write to `<bin>.<n>` in a man-path directory.
public fn render(cmd: &CommandSpec, section: Section) -> Text {
    let mut b = TextBuilder.new();

    // .TH header
    b.push(".TH ");
    b.push(&cmd.name.to_uppercase());
    b.push(" ");
    b.push(&Text.from(f"{section.number()}"));
    match &cmd.version {
        Some(v) => { b.push(" \""); b.push(v); b.push("\""); },
        None => { b.push(" \"\""); },
    }
    b.push(" \"User Commands\"\n");

    write_name(&mut b, cmd);
    write_synopsis(&mut b, cmd);
    write_description(&mut b, cmd);
    if cmd.flags.len() > 0 || cmd.args.len() > 0 {
        write_options(&mut b, cmd);
    }
    if cmd.subcommands.len() > 0 {
        write_commands(&mut b, cmd);
    }
    if cmd.examples.len() > 0 {
        write_examples(&mut b, cmd);
    }
    if has_env_fallbacks(cmd) {
        write_environment(&mut b, cmd);
    }
    write_exit_status(&mut b);
    write_author(&mut b, cmd);
    b.build()
}

// =============================================================================
// Sections
// =============================================================================

fn write_name(b: &mut TextBuilder, cmd: &CommandSpec) {
    b.push(".SH NAME\n");
    b.push(&cmd.name);
    b.push(" \\- ");
    b.push(&cmd.about);
    b.push("\n");
}

fn write_synopsis(b: &mut TextBuilder, cmd: &CommandSpec) {
    b.push(".SH SYNOPSIS\n");
    b.push(".B ");
    b.push(&cmd.name);
    b.push("\n");
    if cmd.flags.len() > 0 {
        b.push("[\\fIOPTIONS\\fR] ");
    }
    let mut i: Int = 0;
    while i < cmd.args.len() {
        let a = &cmd.args[i];
        b.push("\\fI");
        match &a.placeholder {
            Some(p) => b.push(p),
            None => b.push(&a.name.to_uppercase()),
        }
        b.push("\\fR ");
        i = i + 1;
    }
    if cmd.subcommands.len() > 0 {
        b.push("\\fICOMMAND\\fR");
    }
    b.push("\n");
}

fn write_description(b: &mut TextBuilder, cmd: &CommandSpec) {
    b.push(".SH DESCRIPTION\n");
    match &cmd.long_about {
        Some(la) => { b.push(la); b.push("\n"); },
        None => { b.push(&cmd.about); b.push("\n"); },
    }
}

fn write_options(b: &mut TextBuilder, cmd: &CommandSpec) {
    b.push(".SH OPTIONS\n");

    let mut i: Int = 0;
    while i < cmd.flags.len() {
        let f = &cmd.flags[i];
        if f.hidden { i = i + 1; continue; }
        b.push(".TP\n");
        match f.short {
            Some(c) => {
                b.push("\\fB-");
                b.push(&Text.from(f"{c}"));
                b.push("\\fR, ");
            },
            None => {},
        }
        match &f.long {
            Some(l) => {
                b.push("\\fB--");
                b.push(l);
                b.push("\\fR");
            },
            None => {},
        }
        if !f.arity.is_switch() {
            b.push(" \\fI");
            match &f.placeholder {
                Some(p) => b.push(p),
                None => match &f.long {
                    Some(l) => b.push(&l.to_uppercase()),
                    None => b.push("VALUE"),
                },
            }
            b.push("\\fR");
        }
        b.push("\n");
        b.push(&f.help);
        b.push("\n");
        match &f.refinement {
            Some(r) => {
                b.push(".RS\n");
                b.push("Constraint: ");
                b.push(&r.expression);
                b.push(".\n.RE\n");
            },
            None => {},
        }
        i = i + 1;
    }

    let mut j: Int = 0;
    while j < cmd.args.len() {
        let a = &cmd.args[j];
        b.push(".TP\n\\fI");
        match &a.placeholder {
            Some(p) => b.push(p),
            None => b.push(&a.name.to_uppercase()),
        }
        b.push("\\fR\n");
        b.push(&a.help);
        b.push("\n");
        j = j + 1;
    }
}

fn write_commands(b: &mut TextBuilder, cmd: &CommandSpec) {
    b.push(".SH COMMANDS\n");
    let mut i: Int = 0;
    while i < cmd.subcommands.len() {
        let sc = &cmd.subcommands[i];
        if sc.hidden { i = i + 1; continue; }
        b.push(".SS ");
        b.push(&sc.name);
        b.push("\n");
        b.push(&sc.about);
        b.push("\n");
        i = i + 1;
    }
}

fn write_examples(b: &mut TextBuilder, cmd: &CommandSpec) {
    b.push(".SH EXAMPLES\n");
    let mut i: Int = 0;
    while i < cmd.examples.len() {
        let ex = &cmd.examples[i];
        b.push(".PP\n");
        b.push(&ex.description);
        b.push("\n.RS\n.EX\n");
        b.push(&ex.command);
        b.push("\n.EE\n.RE\n");
        i = i + 1;
    }
}

fn has_env_fallbacks(cmd: &CommandSpec) -> Bool {
    let mut i: Int = 0;
    while i < cmd.flags.len() {
        if cmd.flags[i].env_fallback.is_some() { return true; }
        i = i + 1;
    }
    let mut j: Int = 0;
    while j < cmd.args.len() {
        if cmd.args[j].env_fallback.is_some() { return true; }
        j = j + 1;
    }
    false
}

fn write_environment(b: &mut TextBuilder, cmd: &CommandSpec) {
    b.push(".SH ENVIRONMENT\n");
    let mut i: Int = 0;
    while i < cmd.flags.len() {
        match &cmd.flags[i].env_fallback {
            Some(env) => {
                b.push(".TP\n\\fB");
                b.push(env);
                b.push("\\fR\n");
                b.push("Fallback for \\fB--");
                match &cmd.flags[i].long {
                    Some(l) => b.push(l),
                    None => b.push("(this flag)"),
                }
                b.push("\\fR.\n");
            },
            None => {},
        }
        i = i + 1;
    }
}

fn write_exit_status(b: &mut TextBuilder) {
    b.push(".SH EXIT STATUS\n");
    b.push(".TP\n0\nSuccess.\n");
    b.push(".TP\n1\nGeneric error.\n");
    b.push(".TP\n2\nUsage error (invalid argv).\n");
    b.push(".TP\n65\nInvalid input data.\n");
    b.push(".TP\n77\nPermission denied.\n");
    b.push(".TP\n78\nConfiguration error.\n");
}

fn write_author(b: &mut TextBuilder, cmd: &CommandSpec) {
    match &cmd.author {
        Some(a) => {
            b.push(".SH AUTHOR\n");
            b.push(a);
            b.push("\n");
        },
        None => {},
    }
}
