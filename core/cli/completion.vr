// =============================================================================
// cli/completion.vr — Shell-completion script generators
// =============================================================================
// Layer: 5 (CLI)
// Dependencies: core, text, cli.spec
// Spec: internal/specs/cli-framework.md §8.3
// =============================================================================
//

// One source-of-truth → many shells. Each generator walks the same
// `CommandSpec` tree and emits a shell-specific completion script that
// covers: subcommands, long flags, short flags, value suggestions
// (Static / EnumValues / FilePath / DirectoryPath / Hostname / Dynamic).
//
// Static completion sources are emitted inline; Dynamic sources call back
// into the binary via `<bin> __complete <flag> <prefix>` — the runtime
// recognises this hidden subcommand and prints the candidate list.
//

// Phase 3 ships:
//   * bash         — bashcompletion v2-style
//   * zsh          — _arguments-based with descriptions
//   * fish         — `complete -c <bin>` directives
//   * powershell   — Register-ArgumentCompleter
//   * nushell      — extern + flag descriptors
//   * elvish       — edit:completion:arg-completer
//

// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module completion;

mount core.{Maybe, Result, List, Text, Char, Int, Bool};
mount core.text.builder.TextBuilder;
mount core.cli.spec.{
    CommandSpec, ArgSpec, FlagSpec, CompletionSource,
};

// =============================================================================
// Shell — target shell
// =============================================================================

public type Shell is
    | Bash
    | Zsh
    | Fish
    | PowerShell
    | Nushell
    | Elvish;

implement Shell {
    public fn name(&self) -> Text {
        match self {
            Shell.Bash => "bash".to_text(),
            Shell.Zsh => "zsh".to_text(),
            Shell.Fish => "fish".to_text(),
            Shell.PowerShell => "powershell".to_text(),
            Shell.Nushell => "nushell".to_text(),
            Shell.Elvish => "elvish".to_text(),
        }
    }
}

// =============================================================================
// Top-level dispatch
// =============================================================================

/// Render a shell-completion script for `cmd` targeting `shell`.
public fn render(cmd: &CommandSpec, shell: Shell) -> Text {
    match shell {
        Shell.Bash => render_bash(cmd),
        Shell.Zsh => render_zsh(cmd),
        Shell.Fish => render_fish(cmd),
        Shell.PowerShell => render_powershell(cmd),
        Shell.Nushell => render_nushell(cmd),
        Shell.Elvish => render_elvish(cmd),
    }
}

// =============================================================================
// bash
// =============================================================================

fn render_bash(cmd: &CommandSpec) -> Text {
    let bin = &cmd.name;
    let mut b = TextBuilder.new();
    b.push("# bash completion for ");
    b.push(bin);
    b.push("\n_");
    b.push(bin);
    b.push("() {\n");
    b.push("    local cur prev words cword\n");
    b.push("    _init_completion -n = || return\n\n");

    // Subcommand list
    b.push("    local subcommands=\"");
    let names = cmd.subcommand_names();
    let mut i: Int = 0;
    while i < names.len() {
        if i > 0 { b.push(" "); }
        b.push(&names[i]);
        i = i + 1;
    }
    b.push("\"\n");

    // Long-flag list
    b.push("    local longs=\"");
    let longs = cmd.long_names();
    let mut j: Int = 0;
    while j < longs.len() {
        if j > 0 { b.push(" "); }
        b.push("--");
        b.push(&longs[j]);
        j = j + 1;
    }
    b.push("\"\n\n");

    b.push("    case \"$cur\" in\n");
    b.push("        --*) COMPREPLY=( $(compgen -W \"$longs\" -- \"$cur\") );;\n");
    b.push("        *)   COMPREPLY=( $(compgen -W \"$subcommands\" -- \"$cur\") );;\n");
    b.push("    esac\n");
    b.push("}\n");
    b.push("complete -F _");
    b.push(bin);
    b.push(" ");
    b.push(bin);
    b.push("\n");
    b.build()
}

// =============================================================================
// zsh
// =============================================================================

fn render_zsh(cmd: &CommandSpec) -> Text {
    let bin = &cmd.name;
    let mut b = TextBuilder.new();
    b.push("#compdef ");
    b.push(bin);
    b.push("\n");
    b.push("_");
    b.push(bin);
    b.push("() {\n");
    b.push("    local -a flags subcommands\n");

    b.push("    flags=(\n");
    let mut i: Int = 0;
    while i < cmd.flags.len() {
        let f = &cmd.flags[i];
        match &f.long {
            Some(l) => {
                b.push("        '--");
                b.push(l);
                b.push("[");
                b.push(&f.help);
                b.push("]'\n");
            },
            None => {},
        }
        i = i + 1;
    }
    b.push("    )\n");

    b.push("    subcommands=(\n");
    let mut k: Int = 0;
    while k < cmd.subcommands.len() {
        let sc = &cmd.subcommands[k];
        b.push("        '");
        b.push(&sc.name);
        b.push(":");
        b.push(&sc.about);
        b.push("'\n");
        k = k + 1;
    }
    b.push("    )\n");

    b.push("    _arguments -C $flags '*::: := __");
    b.push(bin);
    b.push("_subcmd'\n");
    b.push("}\n_");
    b.push(bin);
    b.push("\n");
    b.build()
}

// =============================================================================
// fish
// =============================================================================

fn render_fish(cmd: &CommandSpec) -> Text {
    let bin = &cmd.name;
    let mut b = TextBuilder.new();
    b.push("# fish completion for ");
    b.push(bin);
    b.push("\n");

    // Subcommands
    let mut i: Int = 0;
    while i < cmd.subcommands.len() {
        let sc = &cmd.subcommands[i];
        b.push("complete -c ");
        b.push(bin);
        b.push(" -n '__fish_use_subcommand' -a '");
        b.push(&sc.name);
        b.push("' -d '");
        b.push(&sc.about);
        b.push("'\n");
        i = i + 1;
    }

    // Flags
    let mut j: Int = 0;
    while j < cmd.flags.len() {
        let f = &cmd.flags[j];
        b.push("complete -c ");
        b.push(bin);
        match f.short {
            Some(c) => { b.push(" -s "); b.push(&Text.from(f"{c}")); },
            None => {},
        }
        match &f.long {
            Some(l) => { b.push(" -l "); b.push(l); },
            None => {},
        }
        b.push(" -d '");
        b.push(&f.help);
        b.push("'");
        match &f.completion {
            CompletionSource.FilePath => b.push(" -F"),
            CompletionSource.DirectoryPath => b.push(" -F -a '(__fish_complete_directories)'"),
            CompletionSource.Hostname => b.push(" -a '(__fish_print_hostnames)'"),
            CompletionSource.EnumValues(vs) => {
                b.push(" -a '");
                let mut m: Int = 0;
                while m < vs.len() {
                    if m > 0 { b.push(" "); }
                    b.push(&vs[m]);
                    m = m + 1;
                }
                b.push("'");
            },
            CompletionSource.Static(vs) => {
                b.push(" -a '");
                let mut m: Int = 0;
                while m < vs.len() {
                    if m > 0 { b.push(" "); }
                    b.push(&vs[m]);
                    m = m + 1;
                }
                b.push("'");
            },
            _ => {},
        }
        b.push("\n");
        j = j + 1;
    }
    b.build()
}

// =============================================================================
// powershell
// =============================================================================

fn render_powershell(cmd: &CommandSpec) -> Text {
    let bin = &cmd.name;
    let mut b = TextBuilder.new();
    b.push("Register-ArgumentCompleter -Native -CommandName '");
    b.push(bin);
    b.push("' -ScriptBlock {\n");
    b.push("    param($wordToComplete, $commandAst, $cursorPosition)\n");
    b.push("    $candidates = @(\n");
    let names = cmd.subcommand_names();
    let mut i: Int = 0;
    while i < names.len() {
        b.push("        '");
        b.push(&names[i]);
        b.push("'\n");
        i = i + 1;
    }
    let longs = cmd.long_names();
    let mut j: Int = 0;
    while j < longs.len() {
        b.push("        '--");
        b.push(&longs[j]);
        b.push("'\n");
        j = j + 1;
    }
    b.push("    )\n");
    b.push("    $candidates | Where-Object { $_ -like \"$wordToComplete*\" } |\n");
    b.push("        ForEach-Object { [System.Management.Automation.CompletionResult]::new($_, $_, 'ParameterValue', $_) }\n");
    b.push("}\n");
    b.build()
}

// =============================================================================
// nushell
// =============================================================================

fn render_nushell(cmd: &CommandSpec) -> Text {
    let bin = &cmd.name;
    let mut b = TextBuilder.new();
    b.push("# nushell completion for ");
    b.push(bin);
    b.push("\nexport extern \"");
    b.push(bin);
    b.push("\" [\n");

    let mut i: Int = 0;
    while i < cmd.flags.len() {
        let f = &cmd.flags[i];
        match &f.long {
            Some(l) => {
                b.push("    --");
                b.push(l);
                b.push("\t# ");
                b.push(&f.help);
                b.push("\n");
            },
            None => {},
        }
        i = i + 1;
    }

    b.push("]\n");
    b.build()
}

// =============================================================================
// elvish
// =============================================================================

fn render_elvish(cmd: &CommandSpec) -> Text {
    let bin = &cmd.name;
    let mut b = TextBuilder.new();
    b.push("# elvish completion for ");
    b.push(bin);
    b.push("\nuse builtin\n");
    b.push("edit:completion:arg-completer[");
    b.push(bin);
    b.push("] = {|@words|\n");
    b.push("    var subcommands = [");
    let names = cmd.subcommand_names();
    let mut i: Int = 0;
    while i < names.len() {
        if i > 0 { b.push(" "); }
        b.push("'");
        b.push(&names[i]);
        b.push("'");
        i = i + 1;
    }
    b.push("]\n");
    b.push("    put $@subcommands\n");
    b.push("}\n");
    b.build()
}
