// =============================================================================
// core/database/postgres/async_copy.vr — async COPY FROM / COPY TO V0
// =============================================================================
// Layer: 3 (Database — postgres adapter)
// Spec: internal/specs/database.md §6.1.8 (async surface), §6.1.6 (COPY).
// =============================================================================
//
// Adds true streaming COPY to the async surface. The actor pattern
// from `async_connection.vr` is fundamentally request/response
// (one PgRequest → one oneshot reply). COPY is different — it
// streams arbitrarily many CopyData frames between the
// `Q "COPY ... FROM/TO ..."` and the trailing ReadyForQuery.
//
// Architecture — sub-actor takeover:
//
//   When the actor processes ReqCopyInOpen, it calls
//   `conn.start_copy_in_session(sql)` and acks the caller. Then it
//   ENTERS A SUB-LOOP reading from a per-COPY chunk-channel
//   (separate from the main mailbox) until the writer signals
//   Done or Cancel. While in the sub-loop the main mailbox is
//   paused — fine, the actor owns one wire and one writer must
//   finish before the next request can use it.
//
//   CopyOut is symmetric but the actor pushes chunks to the
//   caller's Receiver instead of pulling from a Sender. After
//   CopyDone the actor sends the row count via a completion
//   oneshot.
//
// Sync `copy_in_bytes` / `copy_out_bytes` (one-shot bulk) stay
// canonical and unchanged; this is opt-in true streaming.
//
// V0 surface:
//   * `copy_in_async(conn, copy_sql)` -> `AsyncCopyInWriter`
//        .write(bytes).await -> Result<(), DbError>
//        .finish().await       -> Result<row_count, DbError>
//        .cancel(reason).await -> Result<(), DbError>
//   * `copy_out_async(conn, copy_sql)` -> `AsyncCopyOutReader`
//        .read_chunk().await   -> Result<Maybe<List<Byte>>, …>
//        .finish().await       -> Result<row_count, DbError>
//
// Out of V0:
//   * Per-chunk MAX_RATE shaping.
//   * COPY BINARY format helpers (V0 surfaces raw bytes; caller
//     prepends the 11-byte signature + builds tuple framing).
// =============================================================================

@arch_module(
    exposes: [Capability.Read(ResourceTag.Database("*")), Capability.Write(ResourceTag.Database("*")), Capability.Persist(PersistenceMedium.DatabaseMedium("*")), Capability.Network(NetProtocol.Tcp, NetDirection.Bidirectional)],
    requires: [Capability.Exec(ExecTarget.Syscall(0)), Capability.Network(NetProtocol.Tcp, NetDirection.Bidirectional)],
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LCls,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.database.postgres.async_copy;

mount core.*;
mount base.{Result, Ok, Err, Text, Maybe, None, Some, Bool};
mount collections.List;
mount core.database.common.error.{
    DbError, AdapterId, AdPostgres, AdapterSpecific,
};
mount core.database.postgres.async_connection.{
    AsyncPgConnection, PgRequest, ReqCopyInOpen, ReqCopyOutOpen,
    CopyInChunk, CicBytes, CicDone, CicCancel,
};
mount core.async.channel.{
    Sender, Receiver, OneshotSender,
    bounded_channel, oneshot,
};

// =============================================================================
// Caller-side handles
// =============================================================================

/// Affine writer for COPY FROM. Send bytes via `write`; finish
/// with `finish` to commit (returns server's COPY row count) or
/// abort with `cancel` (server-side rollback). Drop without
/// either sends a best-effort cancel from the actor side once
/// the chunk channel closes.
public type affine AsyncCopyInWriter is {
    chunk_tx: Sender<CopyInChunk>,
    /// Per-writer metric counters. Cloneable Shared atomics —
    /// `metrics()` returns a CopyMetricsSnapshot at any time.
    metrics: core.database.common.copy_metrics.CopyMetrics,
    /// Optional caller-side cancellation. When triggered, the
    /// next `write` call short-circuits and emits a CicCancel
    /// to the actor (best-effort wire-cancel).
    token: Maybe<core.async.cancellation.CancellationToken>,
};

implement AsyncCopyInWriter {
    /// Snapshot the per-writer atomic counters. Cheap (4 atomic
    /// loads); safe to call from any task.
    public fn metrics(&self) -> core.database.common.copy_metrics.CopyMetricsSnapshot {
        self.metrics.snapshot()
    }

    public async fn write(&self, bytes: List<Byte>) -> Result<(), DbError> {
        // Cancellation gate — short-circuit if the caller
        // flipped the token.
        match &self.token {
            Some(t) => {
                if t.is_cancelled() {
                    self.metrics.record_cancellation();
                    let _ = self.chunk_tx.send_async(CicCancel {
                        reason: "cancellation token fired".clone(),
                        reply: oneshot<Result<(), DbError>>().0,
                    }).await;
                    return Err(cancelled_err("copy_in.write"));
                }
            }
            None => {}
        }
        let n = bytes.len() as Int;
        match self.chunk_tx.send_async(CicBytes(bytes)).await {
            Ok(())  => {
                self.metrics.record_chunk(n);
                Ok(())
            }
            Err(_)  => Err(actor_dropped("copy_in.write")),
        }
    }

    public async fn finish(self) -> Result<Int, DbError> {
        let (rs, rr) = oneshot();
        match self.chunk_tx.send_async(CicDone(rs)).await {
            Ok(())  => {}
            Err(_)  => { return Err(actor_dropped("copy_in.finish send")); }
        }
        match rr.await {
            Ok(r)  => r,
            Err(_) => Err(actor_dropped("copy_in.finish reply")),
        }
    }

    public async fn cancel(self, reason: &Text) -> Result<(), DbError> {
        self.metrics.record_cancellation();
        let (rs, rr) = oneshot();
        match self.chunk_tx.send_async(CicCancel { reason: reason.clone(), reply: rs }).await {
            Ok(())  => {}
            Err(_)  => { return Err(actor_dropped("copy_in.cancel send")); }
        }
        match rr.await {
            Ok(r)  => r,
            Err(_) => Err(actor_dropped("copy_in.cancel reply")),
        }
    }
}

/// Affine reader for COPY TO. Pull chunks via `read_chunk`; once
/// `Ok(None)` is observed, call `finish` to consume the stream
/// completion and surface the COPY row count.
public type affine AsyncCopyOutReader is {
    chunk_rx: Receiver<CopyOutEvent>,
    /// Set once the actor signals end-of-stream. Holds the
    /// row count or the wire-level failure.
    completion: Maybe<Result<Int, DbError>>,
    metrics: core.database.common.copy_metrics.CopyMetrics,
};

/// Internal — the chunk channel carries either a data frame or
/// the terminal completion event so the reader's API is
/// monotonic without a side oneshot.
public type CopyOutEvent is
      CoeBytes(List<Byte>)
    | CoeDone(Result<Int, DbError>);

implement AsyncCopyOutReader {
    /// Snapshot the per-reader counters. chunks_sent reflects the
    /// number of chunks delivered to the caller; bytes_sent is
    /// the cumulative payload bytes received.
    public fn metrics(&self) -> core.database.common.copy_metrics.CopyMetricsSnapshot {
        self.metrics.snapshot()
    }

    /// `Ok(Some(bytes))` for each CopyData frame; `Ok(None)`
    /// exactly once when the stream ends. Subsequent calls also
    /// return `Ok(None)`.
    public async fn read_chunk(&mut self) -> Result<Maybe<List<Byte>>, DbError> {
        match self.completion {
            Some(_) => { return Ok(None); }
            None    => {}
        }
        match self.chunk_rx.recv_fut().await {
            Some(CoeBytes(b)) => {
                self.metrics.record_chunk(b.len() as Int);
                Ok(Some(b))
            }
            Some(CoeDone(r)) => {
                self.completion = Some(r);
                Ok(None)
            }
            None => {
                // Channel closed without a CoeDone — actor died.
                let e = actor_dropped("copy_out.read_chunk");
                self.completion = Some(Err(e.clone()));
                Err(e)
            }
        }
    }

    /// After `Ok(None)` from `read_chunk`, drain the completion
    /// signal and return the row count or the terminal error.
    public async fn finish(mut self) -> Result<Int, DbError> {
        match self.completion {
            Some(r) => r,
            None    => {
                // Caller forgot to drain; do it now.
                loop {
                    match self.read_chunk().await {
                        Ok(Some(_)) => {}
                        Ok(None) => {
                            match self.completion {
                                Some(r) => { return r; }
                                None    => { return Err(actor_dropped("copy_out.finish")); }
                            }
                        }
                        Err(e) => { return Err(e); }
                    }
                }
            }
        }
    }
}

// =============================================================================
// Constructors
// =============================================================================

/// Open a streaming COPY FROM. The actor issues `copy_sql` and
/// drives the wire to `CopyInResponse` before this returns Ok;
/// the writer is then ready to `write` chunks.
///
/// `chunk_capacity` bounds in-flight chunks (back-pressures the
/// caller via `write`'s send_async future).
public async fn copy_in_async(
    conn: &AsyncPgConnection,
    copy_sql: &Text,
    chunk_capacity: Int,
) -> Result<AsyncCopyInWriter, DbError> {
    copy_in_async_with_token(conn, copy_sql, chunk_capacity, None).await
}

/// Sibling of `copy_in_async` that wires a caller-side
/// CancellationToken. The writer's `write` short-circuits with
/// `CANCELLED` when the token flips; the actor receives a
/// best-effort CicCancel so the wire returns to Ready.
public async fn copy_in_async_with_token(
    conn: &AsyncPgConnection,
    copy_sql: &Text,
    chunk_capacity: Int,
    token: Maybe<core.async.cancellation.CancellationToken>,
) -> Result<AsyncCopyInWriter, DbError> {
    let cap = if chunk_capacity < 1 { 1 } else { chunk_capacity };
    let (chunk_tx, chunk_rx) = bounded_channel<CopyInChunk>(cap);
    let (open_tx, open_rx) = oneshot<Result<(), DbError>>();

    match conn.tx_ref().send_async(ReqCopyInOpen {
        sql: copy_sql.clone(),
        chunk_rx: chunk_rx,
        ack: open_tx,
    }).await {
        Ok(())  => {}
        Err(_)  => { return Err(actor_dropped("copy_in_async send")); }
    }
    match open_rx.await {
        Ok(Ok(()))  => {}
        Ok(Err(e))  => { return Err(e); }
        Err(_)      => { return Err(actor_dropped("copy_in_async ack")); }
    }
    Ok(AsyncCopyInWriter {
        chunk_tx: chunk_tx,
        metrics: core.database.common.copy_metrics.CopyMetrics.new(),
        token: token,
    })
}

/// Open a streaming COPY TO. The actor issues `copy_sql` and
/// drives the wire to `CopyOutResponse` before this returns Ok;
/// the reader is then ready to `read_chunk`.
public async fn copy_out_async(
    conn: &AsyncPgConnection,
    copy_sql: &Text,
    chunk_capacity: Int,
) -> Result<AsyncCopyOutReader, DbError> {
    let cap = if chunk_capacity < 1 { 1 } else { chunk_capacity };
    let (chunk_tx, chunk_rx) = bounded_channel<CopyOutEvent>(cap);
    let (open_tx, open_rx) = oneshot<Result<(), DbError>>();

    match conn.tx_ref().send_async(ReqCopyOutOpen {
        sql: copy_sql.clone(),
        chunk_tx: chunk_tx,
        ack: open_tx,
    }).await {
        Ok(())  => {}
        Err(_)  => { return Err(actor_dropped("copy_out_async send")); }
    }
    match open_rx.await {
        Ok(Ok(()))  => {}
        Ok(Err(e))  => { return Err(e); }
        Err(_)      => { return Err(actor_dropped("copy_out_async ack")); }
    }
    Ok(AsyncCopyOutReader {
        chunk_rx: chunk_rx,
        completion: None,
        metrics: core.database.common.copy_metrics.CopyMetrics.new(),
    })
}

fn cancelled_err(what: &str) -> DbError {
    DbError.Adapter(AdapterSpecific {
        adapter: AdPostgres,
        code: "CANCELLED".clone(),
        message: f"async COPY cancelled at {what}",
        retryable: false,
    })
}

fn actor_dropped(what: &str) -> DbError {
    DbError.Adapter(AdapterSpecific {
        adapter: AdPostgres,
        code: "ACTOR_CLOSED".clone(),
        message: f"async PG actor unavailable during {what}",
        retryable: false,
    })
}
