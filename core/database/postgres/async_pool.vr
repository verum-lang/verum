// =============================================================================
// core/database/postgres/async_pool.vr — async connection pool
// =============================================================================
// Layer: 3 (Database — postgres adapter)
// Spec: internal/specs/database.md §6.1.8 (async surface), §4.3 (pool).
// =============================================================================
//
// Channel-based bounded pool over `AsyncPgConnection`. `acquire().await`
// pulls a connection from the available-mpsc; release pushes it back.
// Genuinely async — `acquire` Pending state yields to the executor;
// no thread blocks waiting for a slot.
//
//   * `min_size` connections are eagerly opened during `launch`.
//   * `max_size` caps the total connection count; lazy-grown
//     between min and max on demand when the available channel
//     is empty.
//   * Backpressure is implicit: when N callers contend for fewer
//     than N connections, late callers' futures stay Pending
//     until a release pushes back to the available channel.
//
// V0 scope: simple checkout/checkin model. The sync `PgPool` /
// `PooledConnection` health-state machine is more elaborate
// (drain / grace deadlines / arena reset). V1 mirrors those
// semantics here once async telemetry catches up.
// =============================================================================

@arch_module(
    exposes: [Capability.Read(ResourceTag.Database("*")), Capability.Write(ResourceTag.Database("*")), Capability.Persist(PersistenceMedium.DatabaseMedium("*")), Capability.Network(NetProtocol.Tcp, NetDirection.Bidirectional)],
    requires: [Capability.Exec(ExecTarget.Syscall(0)), Capability.Network(NetProtocol.Tcp, NetDirection.Bidirectional)],
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LCls,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.database.postgres.async_pool;

mount core.*;
mount base.{Result, Ok, Err, Text, Maybe, None, Some, Bool};
mount collections.List;
mount core.database.common.error.{
    DbError, AdapterId, AdPostgres, AdapterSpecific,
};
mount core.database.postgres.config.PgConfig;
mount core.database.postgres.async_connection.{
    AsyncPgConnection, connect as async_connect,
};
mount core.async.channel.{
    Sender, Receiver, bounded_channel,
};

// =============================================================================
// Config
// =============================================================================

public type AsyncPoolConfig is {
    min_size: Int,
    max_size: Int,
    /// Per-connection mailbox depth (passed straight into
    /// `AsyncPgConnection::connect`). Caps in-flight requests
    /// per connection; raises pipeline ceiling without raising
    /// connection count.
    mailbox_capacity: Int,
    /// SQL strings to prepare on every freshly-opened connection.
    /// Each string is passed through `conn.prepare(sql).await`;
    /// the actor's stmt cache (default cap 128) absorbs the
    /// resulting handle, so subsequent `prepare(same sql)` calls
    /// from any caller hit the cache and skip the wire round-
    /// trip + server-side slot allocation.
    ///
    /// Empty list (default) → no warmup. Errors during warmup
    /// fail the connection-open path; the slot reservation is
    /// rolled back so the pool stays consistent.
    prepare_on_open: List<Text>,
};

implement AsyncPoolConfig {
    public fn default() -> AsyncPoolConfig {
        AsyncPoolConfig {
            min_size: 2,
            max_size: 16,
            mailbox_capacity: 64,
            prepare_on_open: List.new(),
        }
    }

    public fn with_size(mut self, min: Int, max: Int) -> AsyncPoolConfig {
        self.min_size = min;
        self.max_size = max;
        self
    }

    public fn with_mailbox_capacity(mut self, c: Int) -> AsyncPoolConfig {
        self.mailbox_capacity = c;
        self
    }

    /// Replace the warmup SQL list. Each entry is sent through
    /// `conn.prepare(sql).await` on every freshly-opened
    /// connection; the actor cache makes subsequent prepares
    /// of the same SQL free.
    public fn with_prepare_on_open(mut self, sql_list: List<Text>) -> AsyncPoolConfig {
        self.prepare_on_open = sql_list;
        self
    }

    /// Append a single SQL string to the warmup list. Convenient
    /// for chained-builder construction.
    public fn add_warmup_sql(mut self, sql: Text) -> AsyncPoolConfig {
        self.prepare_on_open.push(sql);
        self
    }
}

// =============================================================================
// Pool
// =============================================================================

public type AsyncPgPool is {
    config: PgConfig,
    pool_cfg: AsyncPoolConfig,
    /// Channel-mediated availability — pop-to-acquire,
    /// push-to-release. Capacity == `max_size`.
    available_tx: Sender<AsyncPgConnection>,
    available_rx: Shared<sync.mutex.Mutex<Receiver<AsyncPgConnection>>>,
    /// Total currently-tracked connections (between 0 and
    /// `max_size`). `acquire` opens a fresh connection only if
    /// `current < max_size` AND the available channel is empty.
    current: Shared<AtomicInt>,
};

implement AsyncPgPool {
    /// Eagerly open `min_size` connections, hand the handles to
    /// the available-channel, return the pool. Errors if the
    /// first connection fails — assume a config/network problem
    /// the caller wants surfaced loud.
    public async fn launch(
        config: PgConfig,
        pool_cfg: AsyncPoolConfig,
    ) -> Result<AsyncPgPool, DbError> {
        let max = if pool_cfg.max_size < 1 { 1 } else { pool_cfg.max_size };
        let (tx, rx) = bounded_channel<AsyncPgConnection>(max);

        let mut opened: Int = 0;
        let mut i: Int = 0;
        while i < pool_cfg.min_size {
            let h = open_and_warm(&config, &pool_cfg).await?;
            match tx.send_async(h).await {
                Ok(())  => { opened = opened + 1; }
                Err(_)  => {
                    // Should never happen — channel cap == max_size,
                    // and we've opened ≤ min_size ≤ max_size.
                    return Err(pool_err("failed to seat freshly-opened connection"));
                }
            }
            i = i + 1;
        }

        Ok(AsyncPgPool {
            config: config,
            pool_cfg: pool_cfg,
            available_tx: tx,
            available_rx: Shared.new(sync.mutex.Mutex.new(rx)),
            current: Shared.new(AtomicInt.new(opened)),
        })
    }

    /// Pop a connection. If the available channel is empty AND
    /// `current < max_size`, lazy-open a fresh one. Otherwise
    /// awaits the next release.
    public async fn acquire(&self) -> Result<AsyncPgPoolGuard, DbError> {
        // Fast path — non-async try_recv before yielding.
        let mut guard = self.available_rx.lock().unwrap_or_else(|p| p.into_inner());
        match guard.try_recv() {
            Ok(h) => {
                drop(guard);
                return Ok(AsyncPgPoolGuard {
                    handle: Some(h),
                    available_tx: self.available_tx.clone(),
                });
            }
            Err(_) => {}
        }
        drop(guard);

        // Try to grow lazily.
        let cur = self.current.fetch_add(1, MemoryOrdering.AcqRel);
        if cur < self.pool_cfg.max_size {
            // We reserved a slot — open + warm a fresh one.
            match open_and_warm(&self.config, &self.pool_cfg).await {
                Ok(h) => {
                    return Ok(AsyncPgPoolGuard {
                        handle: Some(h),
                        available_tx: self.available_tx.clone(),
                    });
                }
                Err(e) => {
                    // Roll back the slot reservation so future
                    // acquires can retry.
                    let _ = self.current.fetch_sub(1, MemoryOrdering.AcqRel);
                    return Err(e);
                }
            }
        } else {
            // Overcommitted — undo the increment, await an
            // existing connection's release.
            let _ = self.current.fetch_sub(1, MemoryOrdering.AcqRel);
            // Async wait on the channel.
            let mut g2 = self.available_rx.lock().unwrap_or_else(|p| p.into_inner());
            let fut = g2.recv_fut();
            drop(g2);
            match fut.await {
                Some(h) => Ok(AsyncPgPoolGuard {
                    handle: Some(h),
                    available_tx: self.available_tx.clone(),
                }),
                None => Err(pool_err("available channel closed")),
            }
        }
    }

    /// Snapshot — number of tracked connections. Channel-`len`
    /// is not directly observable in V0; consumers wanting
    /// idle/in-use breakdown belong in the V1 telemetry pass.
    public fn tracked(&self) -> Int {
        self.current.load(MemoryOrdering.Acquire)
    }
}

// =============================================================================
// Guard — auto-release on drop
// =============================================================================

/// RAII guard that returns the wrapped `AsyncPgConnection` to the
/// pool when dropped. Marked affine so it can't be cloned: each
/// checkout is single-owner.
public type affine AsyncPgPoolGuard is {
    handle: Maybe<AsyncPgConnection>,
    available_tx: Sender<AsyncPgConnection>,
};

implement AsyncPgPoolGuard {
    public fn conn_ref(&self) -> &AsyncPgConnection {
        match &self.handle {
            Some(h) => h,
            None    => panic("AsyncPgPoolGuard: handle taken"),
        }
    }

    public fn conn(&self) -> AsyncPgConnection {
        match &self.handle {
            Some(h) => h.clone(),
            None    => panic("AsyncPgPoolGuard: handle taken"),
        }
    }

    /// Eager release. Cleaner than letting Drop run if the caller
    /// has more work after the connection is no longer needed.
    public async fn release(mut self) {
        match self.handle.take() {
            Some(h) => { let _ = self.available_tx.send_async(h).await; }
            None    => {}
        }
    }
}

implement Drop for AsyncPgPoolGuard {
    fn drop(&mut self) {
        // Non-blocking best-effort return. If the channel is full
        // (impossible — cap == max_size and we hold one slot
        // ourselves) the connection is dropped and the actor
        // shuts down; the pool's `current` counter stays high
        // until V1 adds reconciliation.
        match self.handle.take() {
            Some(h) => { let _ = self.available_tx.try_send(h); }
            None    => {}
        }
    }
}

// =============================================================================
// Helpers
// =============================================================================

fn pool_err(what: &str) -> DbError {
    DbError.Adapter(AdapterSpecific {
        adapter: AdPostgres,
        code: "ASYNC_POOL".clone(),
        message: f"async pool error: {what}",
        retryable: false,
    })
}

/// Open a fresh `AsyncPgConnection` and run the warmup hot-list
/// against it. The warmup primes the actor's stmt cache so
/// subsequent caller `prepare(same sql)` calls hit cache.
///
/// Errors during warmup propagate — the pool caller bears the
/// failure (slot reservation roll-back happens at the call
/// site). That keeps the pool consistent: a connection in the
/// available channel is always one that completed warmup.
async fn open_and_warm(
    config: &PgConfig,
    pool_cfg: &AsyncPoolConfig,
) -> Result<AsyncPgConnection, DbError> {
    let h = async_connect(config, pool_cfg.mailbox_capacity).await?;
    let mut i: Int = 0;
    while i < (pool_cfg.prepare_on_open.len() as Int) {
        match h.prepare(&pool_cfg.prepare_on_open[i]).await {
            Ok(_)  => {}
            Err(e) => {
                // Best-effort tear-down — the actor cleanup runs
                // on its own when every Sender drops.
                return Err(e);
            }
        }
        i = i + 1;
    }
    Ok(h)
}
