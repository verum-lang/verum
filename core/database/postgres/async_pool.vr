// =============================================================================
// core/database/postgres/async_pool.vr — async connection pool
// =============================================================================
// Layer: 3 (Database — postgres adapter)
// Spec: internal/specs/database.md §6.1.8 (async surface), §4.3 (pool).
// =============================================================================
//
// Channel-based bounded pool over `AsyncPgConnection`. `acquire().await`
// pulls a connection from the available-mpsc; release pushes it back.
// Genuinely async — `acquire` Pending state yields to the executor;
// no thread blocks waiting for a slot.
//
//   * `min_size` connections are eagerly opened during `launch`.
//   * `max_size` caps the total connection count; lazy-grown
//     between min and max on demand when the available channel
//     is empty.
//   * Backpressure is implicit: when N callers contend for fewer
//     than N connections, late callers' futures stay Pending
//     until a release pushes back to the available channel.
//
// V0 scope: simple checkout/checkin model. The sync `PgPool` /
// `PooledConnection` health-state machine is more elaborate
// (drain / grace deadlines / arena reset). V1 mirrors those
// semantics here once async telemetry catches up.
// =============================================================================

@arch_module(
    exposes: [Capability.Read(ResourceTag.Database("*")), Capability.Write(ResourceTag.Database("*")), Capability.Persist(PersistenceMedium.DatabaseMedium("*")), Capability.Network(NetProtocol.Tcp, NetDirection.Bidirectional)],
    requires: [Capability.Exec(ExecTarget.Syscall(0)), Capability.Network(NetProtocol.Tcp, NetDirection.Bidirectional)],
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LCls,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.database.postgres.async_pool;

mount core.*;
mount base.{Result, Ok, Err, Text, Maybe, None, Some, Bool};
mount collections.List;
mount core.database.common.error.{
    DbError, AdapterId, AdPostgres, AdapterSpecific,
};
mount core.database.postgres.config.PgConfig;
mount core.database.postgres.async_connection.{
    AsyncPgConnection, connect as async_connect,
};
mount core.async.channel.{
    Sender, Receiver, bounded_channel,
};

// =============================================================================
// Config
// =============================================================================

public type AsyncPoolConfig is {
    min_size: Int,
    max_size: Int,
    /// Per-connection mailbox depth (passed straight into
    /// `AsyncPgConnection::connect`). Caps in-flight requests
    /// per connection; raises pipeline ceiling without raising
    /// connection count.
    mailbox_capacity: Int,
    /// SQL strings to prepare on every freshly-opened connection.
    /// Each string is passed through `conn.prepare(sql).await`;
    /// the actor's stmt cache (default cap 128) absorbs the
    /// resulting handle, so subsequent `prepare(same sql)` calls
    /// from any caller hit the cache and skip the wire round-
    /// trip + server-side slot allocation.
    ///
    /// Empty list (default) → no warmup. Errors during warmup
    /// fail the connection-open path; the slot reservation is
    /// rolled back so the pool stays consistent.
    prepare_on_open: List<Text>,
};

implement AsyncPoolConfig {
    public fn default() -> AsyncPoolConfig {
        AsyncPoolConfig {
            min_size: 2,
            max_size: 16,
            mailbox_capacity: 64,
            prepare_on_open: List.new(),
        }
    }

    public fn with_size(mut self, min: Int, max: Int) -> AsyncPoolConfig {
        self.min_size = min;
        self.max_size = max;
        self
    }

    public fn with_mailbox_capacity(mut self, c: Int) -> AsyncPoolConfig {
        self.mailbox_capacity = c;
        self
    }

    /// Replace the warmup SQL list. Each entry is sent through
    /// `conn.prepare(sql).await` on every freshly-opened
    /// connection; the actor cache makes subsequent prepares
    /// of the same SQL free.
    public fn with_prepare_on_open(mut self, sql_list: List<Text>) -> AsyncPoolConfig {
        self.prepare_on_open = sql_list;
        self
    }

    /// Append a single SQL string to the warmup list. Convenient
    /// for chained-builder construction.
    public fn add_warmup_sql(mut self, sql: Text) -> AsyncPoolConfig {
        self.prepare_on_open.push(sql);
        self
    }
}

// =============================================================================
// Pool
// =============================================================================

public type AsyncPgPool is {
    config: PgConfig,
    pool_cfg: AsyncPoolConfig,
    /// Channel-mediated availability — pop-to-acquire,
    /// push-to-release. Capacity == `max_size`.
    available_tx: Sender<AsyncPgConnection>,
    available_rx: Shared<sync.mutex.Mutex<Receiver<AsyncPgConnection>>>,
    /// Total currently-tracked connections (between 0 and
    /// `max_size`). `acquire` opens a fresh connection only if
    /// `current < max_size` AND the available channel is empty.
    current: Shared<AtomicInt>,
};

implement AsyncPgPool {
    /// Eagerly open `min_size` connections, hand the handles to
    /// the available-channel, return the pool. Errors if the
    /// first connection fails — assume a config/network problem
    /// the caller wants surfaced loud.
    public async fn launch(
        config: PgConfig,
        pool_cfg: AsyncPoolConfig,
    ) -> Result<AsyncPgPool, DbError> {
        let max = if pool_cfg.max_size < 1 { 1 } else { pool_cfg.max_size };
        let (tx, rx) = bounded_channel<AsyncPgConnection>(max);

        let mut opened: Int = 0;
        let mut i: Int = 0;
        while i < pool_cfg.min_size {
            let h = open_and_warm(&config, &pool_cfg).await?;
            match tx.send_async(h).await {
                Ok(())  => { opened = opened + 1; }
                Err(_)  => {
                    // Should never happen — channel cap == max_size,
                    // and we've opened ≤ min_size ≤ max_size.
                    return Err(pool_err("failed to seat freshly-opened connection"));
                }
            }
            i = i + 1;
        }

        Ok(AsyncPgPool {
            config: config,
            pool_cfg: pool_cfg,
            available_tx: tx,
            available_rx: Shared.new(sync.mutex.Mutex.new(rx)),
            current: Shared.new(AtomicInt.new(opened)),
        })
    }

    /// Pop a connection. If the available channel is empty AND
    /// `current < max_size`, lazy-open a fresh one. Otherwise
    /// awaits the next release.
    public async fn acquire(&self) -> Result<AsyncPgPoolGuard, DbError> {
        // Fast path — non-async try_recv before yielding.
        let mut guard = self.available_rx.lock().unwrap_or_else(|p| p.into_inner());
        match guard.try_recv() {
            Ok(h) => {
                drop(guard);
                return Ok(AsyncPgPoolGuard {
                    handle: Some(h),
                    available_tx: self.available_tx.clone(),
                });
            }
            Err(_) => {}
        }
        drop(guard);

        // Try to grow lazily.
        let cur = self.current.fetch_add(1, MemoryOrdering.AcqRel);
        if cur < self.pool_cfg.max_size {
            // We reserved a slot — open + warm a fresh one.
            match open_and_warm(&self.config, &self.pool_cfg).await {
                Ok(h) => {
                    return Ok(AsyncPgPoolGuard {
                        handle: Some(h),
                        available_tx: self.available_tx.clone(),
                    });
                }
                Err(e) => {
                    // Roll back the slot reservation so future
                    // acquires can retry.
                    let _ = self.current.fetch_sub(1, MemoryOrdering.AcqRel);
                    return Err(e);
                }
            }
        } else {
            // Overcommitted — undo the increment, await an
            // existing connection's release.
            let _ = self.current.fetch_sub(1, MemoryOrdering.AcqRel);
            // Async wait on the channel.
            let mut g2 = self.available_rx.lock().unwrap_or_else(|p| p.into_inner());
            let fut = g2.recv_fut();
            drop(g2);
            match fut.await {
                Some(h) => Ok(AsyncPgPoolGuard {
                    handle: Some(h),
                    available_tx: self.available_tx.clone(),
                }),
                None => Err(pool_err("available channel closed")),
            }
        }
    }

    /// Snapshot — number of tracked connections. Channel-`len`
    /// is not directly observable in V0; consumers wanting
    /// idle/in-use breakdown belong in the V1 telemetry pass.
    public fn tracked(&self) -> Int {
        self.current.load(MemoryOrdering.Acquire)
    }
}

// =============================================================================
// Guard — auto-release on drop
// =============================================================================

/// RAII guard that returns the wrapped `AsyncPgConnection` to the
/// pool when dropped. Marked affine so it can't be cloned: each
/// checkout is single-owner.
public type affine AsyncPgPoolGuard is {
    handle: Maybe<AsyncPgConnection>,
    available_tx: Sender<AsyncPgConnection>,
};

implement AsyncPgPoolGuard {
    public fn conn_ref(&self) -> &AsyncPgConnection {
        match &self.handle {
            Some(h) => h,
            None    => panic("AsyncPgPoolGuard: handle taken"),
        }
    }

    public fn conn(&self) -> AsyncPgConnection {
        match &self.handle {
            Some(h) => h.clone(),
            None    => panic("AsyncPgPoolGuard: handle taken"),
        }
    }

    /// Eager release. Cleaner than letting Drop run if the caller
    /// has more work after the connection is no longer needed.
    public async fn release(mut self) {
        match self.handle.take() {
            Some(h) => { let _ = self.available_tx.send_async(h).await; }
            None    => {}
        }
    }

    // -------------------------------------------------------------------------
    // Ergonomic delegations — forward to the inner AsyncPgConnection so that
    // application code can call `pool.acquire().await?.execute(...)` without
    // an extra `.conn_ref()` hop.  These cover the parameter-less DML/DDL
    // statements; parameterised queries still go through the typed-database
    // wrapper (`AsyncTypedDatabase`) which speaks `prepare` + `execute_prepared`
    // in one call.
    // -------------------------------------------------------------------------

    /// Run a single statement that produces no rows; returns the
    /// `command_tag` from CommandComplete.  Forwards to
    /// `AsyncPgConnection.execute`.
    public async fn execute(&self, sql: &Text) -> Result<Text, DbError> {
        self.conn_ref().execute(sql).await
    }

    /// Run a single SELECT and stream its rows.  Forwards to
    /// `AsyncPgConnection.simple_query`.
    public async fn simple_query(&self, sql: &Text)
        -> Result<core.database.postgres.connection.PgSimpleQueryResult, DbError>
    {
        self.conn_ref().simple_query(sql).await
    }

    /// Async health-check — round-trips `SELECT 1`.  Forwards to
    /// `AsyncPgConnection.ping`.
    public async fn ping(&self) -> Result<(), DbError> {
        self.conn_ref().ping().await
    }

    /// Prepare a server-side statement.  Forwards to
    /// `AsyncPgConnection.prepare`.
    public async fn prepare(&self, sql: &Text)
        -> Result<core.database.postgres.async_connection.AsyncPgPreparedStatement, DbError>
    {
        self.conn_ref().prepare(sql).await
    }

    // -------------------------------------------------------------------------
    // Parameterised query API — typed-row results
    // -------------------------------------------------------------------------
    //
    // Prepares the statement, executes with bound params, decodes
    // rows into the `Row` façade for column-name-keyed access.
    //
    // Param encoding goes through `wire.typed.encode_params_for_bind`
    // which accepts `List<Maybe<TypedValue>>` and returns
    // `List<Maybe<List<Byte>>>` — the wire form `execute_prepared`
    // expects.  Callers either:
    //   - build the typed-param list manually via
    //     `core.database.common.types.typed_value_*` constructors, or
    //   - go through `AsyncTypedDatabase` which adds compile-time
    //     param encoders for tuple shapes.
    //
    // The `Row` façade wraps the per-row `(RowDescription, List<WireValue>)`
    // pair returned by `execute_prepared_typed`.  All results in this
    // path use binary wire format (the prepared-statement default).

    /// Execute a parameterised query and stream every row.
    /// Returns an empty `List<Row>` when no rows match.
    public async fn query(
        &self,
        sql:    &Text,
        params: List<Maybe<core.database.postgres.wire.typed.TypedValue>>,
    ) -> Result<List<core.database.postgres.row.Row>, DbError> {
        let conn = self.conn_ref();
        let stmt = conn.prepare(sql).await?;
        let result = conn.execute_prepared_typed(&stmt, params).await?;
        let _ = conn.close_prepared(stmt).await; // best-effort cleanup
        let row_desc = match result.row_description {
            Some(rd) => rd,
            None     => return Ok(List.new()),
        };
        let mut out: List<core.database.postgres.row.Row> = List.with_capacity(result.rows.len());
        let mut i: Int = 0;
        while i < result.rows.len() as Int {
            let typed_row = result.rows[i].clone();
            let wire_row  = typed_row_to_wire_values(&typed_row);
            out.push(core.database.postgres.row.Row.new(row_desc.clone(), wire_row));
            i = i + 1;
        }
        Ok(out)
    }

    /// Execute a parameterised query expecting exactly one row.
    /// Errors with `DbError.QueryFailed` when zero rows are returned.
    /// Use `query_one_opt` when zero rows is a valid outcome.
    public async fn query_one(
        &self,
        sql:    &Text,
        params: List<Maybe<core.database.postgres.wire.typed.TypedValue>>,
    ) -> Result<core.database.postgres.row.Row, DbError> {
        match self.query_one_opt(sql, params).await? {
            Some(r) => Ok(r),
            None => {
                // SQLSTATE `02000` = no_data (per ISO/IEC 9075-2 §22.1).
                let sql_state = core.database.common.error.SqlState.parse(&"02000".to_text())
                    .unwrap_or_else(|| core.database.common.error.SqlState { code: "02000".to_text() });
                Err(DbError.QueryFailed {
                    sql_state,
                    message:  "query_one: zero rows returned (expected exactly one)".to_text(),
                    position: None,
                })
            },
        }
    }

    /// Execute a parameterised query expecting at most one row.
    /// Returns `Ok(None)` when the result set is empty.
    public async fn query_one_opt(
        &self,
        sql:    &Text,
        params: List<Maybe<core.database.postgres.wire.typed.TypedValue>>,
    ) -> Result<Maybe<core.database.postgres.row.Row>, DbError> {
        let conn = self.conn_ref();
        let stmt = conn.prepare(sql).await?;
        let result = conn.execute_prepared_typed(&stmt, params).await?;
        let _ = conn.close_prepared(stmt).await;
        if result.rows.is_empty() {
            return Ok(None);
        }
        let row_desc = match result.row_description {
            Some(rd) => rd,
            None     => return Ok(None),
        };
        let wire_row = typed_row_to_wire_values(&result.rows[0]);
        Ok(Some(core.database.postgres.row.Row.new(row_desc, wire_row)))
    }

    /// Execute a parameterised statement with no result rows
    /// (INSERT/UPDATE/DELETE).  Returns the `command_tag`.
    public async fn execute_with_params(
        &self,
        sql:    &Text,
        params: List<Maybe<core.database.postgres.wire.typed.TypedValue>>,
    ) -> Result<Text, DbError> {
        let conn = self.conn_ref();
        let stmt = conn.prepare(sql).await?;
        let result = conn.execute_prepared_typed(&stmt, params).await?;
        let _ = conn.close_prepared(stmt).await;
        Ok(result.command_tag)
    }
}

// =============================================================================
// Helper — convert a typed-row's cells to TEXT-format WireValues.
//
// `execute_prepared_typed` returns rows as `List<List<TypedValue>>`
// where every cell is already in the post-decoded Verum-native form.
// The `Row` façade reads bytes; we project each `TypedValue` back to
// its canonical TEXT-format representation.  TEXT format is the
// universal lingua franca — every getter on the Row façade has a
// TEXT-decode branch — so this projection is faithful for every
// column type the façade covers (bool / int{2,4,8} / text-family /
// bytea / timestamp / timestamptz / text-array).  Unsupported types
// project to `WvNull` and surface as a normal getter-time error if
// the caller tries to read them.
// =============================================================================

fn typed_row_to_wire_values(
    row: &List<core.database.postgres.wire.typed.TypedValue>,
) -> List<core.database.common.types.WireValue> {
    let mut out: List<core.database.common.types.WireValue> = List.with_capacity(row.len());
    let mut i: Int = 0;
    while i < row.len() as Int {
        out.push(typed_value_to_wire_text(&row[i]));
        i = i + 1;
    }
    out
}

fn typed_value_to_wire_text(
    v: &core.database.postgres.wire.typed.TypedValue,
) -> core.database.common.types.WireValue {
    use core.database.postgres.wire.typed.{
        TvNull, TvBool, TvInt2, TvInt4, TvInt8, TvText, TvBytea,
        TvTimestamp, TvTimestamptz,
    };
    use core.database.common.types.{WireValue, WvNull as WvN, WvPresent, WfText};

    let bytes_opt: Maybe<List<Byte>> = match v {
        TvNull              => None,
        TvBool(b)           => Some(if *b { "t".as_bytes().to_list() } else { "f".as_bytes().to_list() }),
        TvInt2(n)           => Some(format_int_text(*n as Int)),
        TvInt4(n)           => Some(format_int_text(*n as Int)),
        TvInt8(n)           => Some(format_int_text(*n as Int)),
        TvText(s)           => Some(s.as_bytes().to_list()),
        TvBytea(b)          => Some(format_bytea_hex_text(b)),
        TvTimestamp(us)     => Some(format_pg_timestamp_text(*us, false)),
        TvTimestamptz(us)   => Some(format_pg_timestamp_text(*us, true)),
        _                   => None,
    };
    match bytes_opt {
        None    => WvN,
        Some(b) => WvPresent { bytes: b, format: WfText },
    }
}

fn format_int_text(n: Int) -> List<Byte> {
    f"{n}".as_bytes().to_list()
}

fn format_bytea_hex_text(b: &List<Byte>) -> List<Byte> {
    // Emit `\x<hex>` form — the postgres `bytea_output=hex` default
    // and what `Row.get_bytes` parses on the TEXT branch.
    let mut out: List<Byte> = List.with_capacity(2 + b.len() * 2);
    out.push(b'\\');
    out.push(b'x');
    let mut i: Int = 0;
    while i < b.len() as Int {
        let byte = b[i];
        out.push(hex_nibble_to_byte((byte >> 4) as Int));
        out.push(hex_nibble_to_byte((byte & 0x0f) as Int));
        i = i + 1;
    }
    out
}

fn hex_nibble_to_byte(n: Int) -> Byte {
    if n < 10 { (b'0' + n as Byte) }
    else      { (b'a' + (n - 10) as Byte) }
}

fn format_pg_timestamp_text(microseconds: Int, with_tz: Bool) -> List<Byte> {
    // Reproduce postgres' canonical TIMESTAMP[TZ] TEXT output
    // (`YYYY-MM-DD HH:MM:SS.ffffff[+00]`) so `Row.get_timestamp`'s
    // TEXT branch can parse it.  Inputs are microseconds since
    // 2000-01-01 00:00:00 (postgres epoch); we shift to Unix epoch
    // (1970-01-01) and delegate the calendar split to the time
    // library's RFC 3339 formatter.
    const POSTGRES_EPOCH_OFFSET_SEC: Int = 946_684_800;  // seconds between 1970-01-01 and 2000-01-01
    let unix_seconds = POSTGRES_EPOCH_OFFSET_SEC + (microseconds / 1_000_000);
    let nanos        = (microseconds % 1_000_000) * 1_000;
    let formatted    = core.time.rfc3339.format_utc_with_nanos(unix_seconds, nanos);
    // RFC 3339 form is `YYYY-MM-DDTHH:MM:SS.fffZ`.  For non-tz
    // timestamps the `Z` is meaningless but harmless — `Row`'s
    // normaliser strips it.  We keep RFC 3339 and let the caller's
    // `parse_rfc3339` round-trip cleanly.
    let _ = with_tz;
    formatted.as_bytes().to_list()
}

implement Drop for AsyncPgPoolGuard {
    fn drop(&mut self) {
        // Non-blocking best-effort return. If the channel is full
        // (impossible — cap == max_size and we hold one slot
        // ourselves) the connection is dropped and the actor
        // shuts down; the pool's `current` counter stays high
        // until V1 adds reconciliation.
        match self.handle.take() {
            Some(h) => { let _ = self.available_tx.try_send(h); }
            None    => {}
        }
    }
}

// =============================================================================
// Helpers
// =============================================================================

fn pool_err(what: &str) -> DbError {
    DbError.Adapter(AdapterSpecific {
        adapter: AdPostgres,
        code: "ASYNC_POOL".clone(),
        message: f"async pool error: {what}",
        retryable: false,
    })
}

/// Open a fresh `AsyncPgConnection` and run the warmup hot-list
/// against it. The warmup primes the actor's stmt cache so
/// subsequent caller `prepare(same sql)` calls hit cache.
///
/// Errors during warmup propagate — the pool caller bears the
/// failure (slot reservation roll-back happens at the call
/// site). That keeps the pool consistent: a connection in the
/// available channel is always one that completed warmup.
async fn open_and_warm(
    config: &PgConfig,
    pool_cfg: &AsyncPoolConfig,
) -> Result<AsyncPgConnection, DbError> {
    let h = async_connect(config, pool_cfg.mailbox_capacity).await?;
    let mut i: Int = 0;
    while i < (pool_cfg.prepare_on_open.len() as Int) {
        match h.prepare(&pool_cfg.prepare_on_open[i]).await {
            Ok(_)  => {}
            Err(e) => {
                // Best-effort tear-down — the actor cleanup runs
                // on its own when every Sender drops.
                return Err(e);
            }
        }
        i = i + 1;
    }
    Ok(h)
}
