// =============================================================================
// core/database/postgres/introspect.vr — Postgres SchemaSnapshot extractor
// =============================================================================
// Layer: 3 (Database — postgres adapter)
// Spec: internal/specs/database.md §5.3 (verum db:introspect)
// =============================================================================
//
// Drives a live PgConnection through `information_schema` + `pg_catalog`
// to populate `core.database.common.schema.SchemaSnapshot`. The full
// snapshot survives the round-trip (tables / columns / indexes /
// foreign keys) and can be rendered to schema.snap.vr for compile-
// time consumption by the sql# meta-fn.
//
// Source views:
//   * `information_schema.tables`        — table list (filter on
//                                          `table_type = 'BASE TABLE'`)
//   * `information_schema.columns`       — per-column metadata; the
//                                          `is_nullable`, `data_type`,
//                                          `column_default`, `udt_name`
//                                          fields drive ColumnSnap
//   * `information_schema.key_column_usage`
//                                        — PK column membership
//                                          (joined with table_constraints
//                                          where constraint_type = 'PRIMARY KEY')
//   * `pg_catalog.pg_indexes`            — index list including the
//                                          definition string; we parse
//                                          out columns + UNIQUE + WHERE
//   * `information_schema.referential_constraints`
//     + `information_schema.key_column_usage`
//                                        — FK columns + ON DELETE / ON UPDATE
//
// CHECK-constraint introspection (`information_schema.check_constraints`)
// is left for a follow-up because Postgres stores them post-AST-
// rewrite and round-tripping the text accurately requires more care.
// =============================================================================

module core.database.postgres.introspect;

mount core.*;
mount base.{Result, Ok, Err, Text, Maybe, None, Some};
mount collections.List;
mount core.database.common.error.{DbError, AdapterId};
mount core.database.common.schema.{
    SchemaSnapshot, TableSnap, ColumnSnap, IndexSnap, ForeignKeySnap,
};
mount core.database.common.types.{WireValue, WvNull, WvPresent};
mount core.database.postgres.connection.PgConnection;

/// Build a SchemaSnapshot off a live PgConnection. Schema scope is
/// the connection's `current_schema()` (typically "public"); pass an
/// explicit `scope_schema` to introspect a different namespace.
public fn introspect(conn: &mut PgConnection) -> Result<SchemaSnapshot, DbError> {
    introspect_schema(conn, &"public".clone())
}

public fn introspect_schema(conn: &mut PgConnection, schema: &Text) -> Result<SchemaSnapshot, DbError> {
    let mut snap = SchemaSnapshot.empty(AdPostgres);
    snap.default_schema = schema.clone();
    snap.server_version = match probe_version(conn) {
        Ok(v)  => v,
        Err(_) => "unknown".clone(),
    };

    let tables = list_tables(conn, schema)?;
    let mut i: Int = 0;
    while i < tables.len() as Int {
        let name = &tables[i];
        let table = build_table_snap(conn, schema, name)?;
        snap.add_table(table);
        i = i + 1;
    }
    Ok(snap)
}

// -----------------------------------------------------------------------------
// Probes
// -----------------------------------------------------------------------------

fn probe_version(conn: &mut PgConnection) -> Result<Text, DbError> {
    match conn.query_first(&"SHOW server_version".clone()) {
        Ok(opt) => match opt {
            Some(row) => {
                if (row.len() as Int) >= 1 {
                    Ok(value_to_text(&row[0]))
                } else { Ok("".clone()) }
            }
            None => Ok("".clone()),
        },
        Err(e) => Err(e),
    }
}

fn list_tables(conn: &mut PgConnection, schema: &Text) -> Result<List<Text>, DbError> {
    let mut sql: Text = "SELECT table_name FROM information_schema.tables WHERE table_schema = '".clone();
    sql.push_str(schema);
    sql.push_str(&"' AND table_type = 'BASE TABLE' ORDER BY table_name".clone());
    match conn.query_all(&sql) {
        Ok(rows) => {
            let mut out: List<Text> = List.new();
            let mut i: Int = 0;
            while i < rows.len() as Int {
                let r = &rows[i];
                if (r.len() as Int) >= 1 {
                    out.push(value_to_text(&r[0]));
                }
                i = i + 1;
            }
            Ok(out)
        }
        Err(e) => Err(e),
    }
}

fn build_table_snap(conn: &mut PgConnection, schema: &Text, name: &Text) -> Result<TableSnap, DbError> {
    let mut t = TableSnap.empty(schema.clone(), name.clone());
    let pk_cols = read_pk_columns(conn, schema, name)?;
    t.columns      = read_columns(conn, schema, name, &pk_cols)?;
    t.indexes      = read_indexes(conn, schema, name)?;
    t.foreign_keys = read_foreign_keys(conn, schema, name)?;
    Ok(t)
}

// -----------------------------------------------------------------------------
// Columns
// -----------------------------------------------------------------------------

fn read_columns(
    conn: &mut PgConnection,
    schema: &Text,
    table: &Text,
    pk_cols: &List<Text>,
) -> Result<List<ColumnSnap>, DbError> {
    let mut sql: Text = "SELECT column_name, data_type, is_nullable, column_default FROM information_schema.columns WHERE table_schema = '".clone();
    sql.push_str(schema);
    sql.push_str(&"' AND table_name = '".clone());
    sql.push_str(table);
    sql.push_str(&"' ORDER BY ordinal_position".clone());
    match conn.query_all(&sql) {
        Ok(rows) => {
            let mut out: List<ColumnSnap> = List.new();
            let mut i: Int = 0;
            while i < rows.len() as Int {
                let r = &rows[i];
                if (r.len() as Int) >= 4 {
                    let col_name = value_to_text(&r[0]);
                    let col_type = value_to_text(&r[1]);
                    let is_null  = value_to_text(&r[2]);
                    let default_text = value_to_text(&r[3]);
                    let nullable = is_null == "YES";
                    let default_expr = if default_text.len() == 0 { None } else { Some(default_text.clone()) };
                    let autoincrement = looks_serial(&default_text);
                    out.push(ColumnSnap {
                        name: col_name.clone(),
                        declared_type: col_type,
                        nullable: nullable,
                        pk: contains_text(pk_cols, &col_name),
                        unique: false,    // populated when we read indexes
                        autoincrement: autoincrement,
                        default_expr: default_expr,
                        refinement: None,
                        check_constraint: None,
                    });
                }
                i = i + 1;
            }
            Ok(out)
        }
        Err(e) => Err(e),
    }
}

fn looks_serial(default_text: &Text) -> Bool {
    // Postgres serial / identity: column default is `nextval('seq'::regclass)`
    // for SERIAL; identity columns appear via a different metadata path
    // we don't query here.
    text_contains(default_text, &"nextval".clone())
}

fn read_pk_columns(conn: &mut PgConnection, schema: &Text, table: &Text) -> Result<List<Text>, DbError> {
    let mut sql: Text = "SELECT kcu.column_name FROM information_schema.table_constraints tc JOIN information_schema.key_column_usage kcu ON tc.constraint_name = kcu.constraint_name AND tc.table_schema = kcu.table_schema AND tc.table_name = kcu.table_name WHERE tc.constraint_type = 'PRIMARY KEY' AND tc.table_schema = '".clone();
    sql.push_str(schema);
    sql.push_str(&"' AND tc.table_name = '".clone());
    sql.push_str(table);
    sql.push_str(&"' ORDER BY kcu.ordinal_position".clone());
    match conn.query_all(&sql) {
        Ok(rows) => {
            let mut out: List<Text> = List.new();
            let mut i: Int = 0;
            while i < rows.len() as Int {
                if (rows[i].len() as Int) >= 1 {
                    out.push(value_to_text(&rows[i][0]));
                }
                i = i + 1;
            }
            Ok(out)
        }
        Err(e) => Err(e),
    }
}

// -----------------------------------------------------------------------------
// Indexes
// -----------------------------------------------------------------------------

fn read_indexes(conn: &mut PgConnection, schema: &Text, table: &Text) -> Result<List<IndexSnap>, DbError> {
    let mut sql: Text = "SELECT indexname, indexdef FROM pg_indexes WHERE schemaname = '".clone();
    sql.push_str(schema);
    sql.push_str(&"' AND tablename = '".clone());
    sql.push_str(table);
    sql.push_str(&"' ORDER BY indexname".clone());
    match conn.query_all(&sql) {
        Ok(rows) => {
            let mut out: List<IndexSnap> = List.new();
            let mut i: Int = 0;
            while i < rows.len() as Int {
                let r = &rows[i];
                if (r.len() as Int) >= 2 {
                    let name = value_to_text(&r[0]);
                    let def  = value_to_text(&r[1]);
                    let cols = parse_index_cols(&def);
                    let unique = text_contains(&def, &"CREATE UNIQUE INDEX".clone());
                    let predicate = parse_index_where(&def);
                    out.push(IndexSnap {
                        name: name,
                        columns: cols,
                        predicate: predicate,
                        unique: unique,
                    });
                }
                i = i + 1;
            }
            Ok(out)
        }
        Err(e) => Err(e),
    }
}

fn parse_index_cols(def: &Text) -> List<Text> {
    // pg_indexes.indexdef is a CREATE INDEX statement; extract the
    // parenthesised column list. This is a quick parse — enough for
    // simple-column indexes; expression indexes reuse the function
    // text verbatim and round-trip as a single pseudo-column entry.
    let bytes = def.as_bytes();
    let mut depth: Int = 0;
    let mut start: Int = -1;
    let mut end: Int = -1;
    let mut i: Int = 0;
    while i < bytes.len() {
        let b = bytes[i];
        if b == (0x28 as Byte) {
            if depth == 0 { start = i + 1; }
            depth = depth + 1;
        } else if b == (0x29 as Byte) {
            depth = depth - 1;
            if depth == 0 { end = i; break; }
        }
        i = i + 1;
    }
    if start < 0 || end < 0 || end <= start {
        return List.new();
    }
    let mut col_buf: List<Byte> = List.new();
    let mut j = start;
    while j < end {
        col_buf.push(bytes[j]);
        j = j + 1;
    }
    let cols_text = Text.from_bytes(&col_buf).unwrap_or("".clone());
    split_by_comma_trim_quotes(&cols_text)
}

fn parse_index_where(def: &Text) -> Maybe<Text> {
    // CREATE INDEX ... WHERE ( predicate ) — find " WHERE " (case-
    // sensitive in the indexdef Postgres returns).
    let bytes = def.as_bytes();
    let needle = " WHERE ".as_bytes();
    let mut i: Int = 0;
    while i + needle.len() <= bytes.len() {
        let mut k: Int = 0;
        let mut hit = true;
        while k < needle.len() {
            if bytes[i + k] != needle[k] { hit = false; break; }
            k = k + 1;
        }
        if hit {
            let mut tail: List<Byte> = List.new();
            let mut j = i + needle.len();
            while j < bytes.len() {
                tail.push(bytes[j]);
                j = j + 1;
            }
            return Some(Text.from_bytes(&tail).unwrap_or("".clone()));
        }
        i = i + 1;
    }
    None
}

fn split_by_comma_trim_quotes(s: &Text) -> List<Text> {
    let bytes = s.as_bytes();
    let mut out: List<Text> = List.new();
    let mut start: Int = 0;
    let mut depth: Int = 0;
    let mut i: Int = 0;
    while i <= bytes.len() {
        let at_end = i == bytes.len();
        let b = if at_end { 0 as Byte } else { bytes[i] };
        if !at_end {
            if b == (0x28 as Byte) { depth = depth + 1; }
            else if b == (0x29 as Byte) { depth = depth - 1; }
        }
        let cut = at_end || (b == (0x2C as Byte) && depth == 0);
        if cut {
            let mut col: List<Byte> = List.new();
            let mut j = start;
            while j < i {
                col.push(bytes[j]);
                j = j + 1;
            }
            let raw = Text.from_bytes(&col).unwrap_or("".clone());
            out.push(trim_and_strip_quotes(&raw));
            start = i + 1;
        }
        i = i + 1;
    }
    out
}

fn trim_and_strip_quotes(s: &Text) -> Text {
    let bytes = s.as_bytes();
    let mut start: Int = 0;
    let mut end: Int = bytes.len() as Int;
    while start < end && (bytes[start] == 0x20 as Byte || bytes[start] == 0x09 as Byte) { start = start + 1; }
    while end > start && (bytes[end - 1] == 0x20 as Byte || bytes[end - 1] == 0x09 as Byte) { end = end - 1; }
    if end - start >= 2 && bytes[start] == 0x22 as Byte && bytes[end - 1] == 0x22 as Byte {
        start = start + 1;
        end = end - 1;
    }
    let mut out: List<Byte> = List.new();
    let mut k = start;
    while k < end { out.push(bytes[k]); k = k + 1; }
    Text.from_bytes(&out).unwrap_or("".clone())
}

// -----------------------------------------------------------------------------
// Foreign keys
// -----------------------------------------------------------------------------

fn read_foreign_keys(conn: &mut PgConnection, schema: &Text, table: &Text) -> Result<List<ForeignKeySnap>, DbError> {
    let mut sql: Text = "SELECT tc.constraint_name, kcu.column_name, ccu.table_name, ccu.column_name, rc.update_rule, rc.delete_rule FROM information_schema.table_constraints tc JOIN information_schema.key_column_usage kcu ON tc.constraint_name = kcu.constraint_name AND tc.table_schema = kcu.table_schema JOIN information_schema.referential_constraints rc ON tc.constraint_name = rc.constraint_name AND tc.table_schema = rc.constraint_schema JOIN information_schema.constraint_column_usage ccu ON rc.unique_constraint_name = ccu.constraint_name AND rc.unique_constraint_schema = ccu.constraint_schema WHERE tc.constraint_type = 'FOREIGN KEY' AND tc.table_schema = '".clone();
    sql.push_str(schema);
    sql.push_str(&"' AND tc.table_name = '".clone());
    sql.push_str(table);
    sql.push_str(&"' ORDER BY tc.constraint_name, kcu.ordinal_position".clone());
    match conn.query_all(&sql) {
        Ok(rows) => {
            let mut grouped: List<ForeignKeySnap> = List.new();
            let mut current_name: Text = "".clone();
            let mut i: Int = 0;
            while i < rows.len() as Int {
                let r = &rows[i];
                if (r.len() as Int) >= 6 {
                    let cname    = value_to_text(&r[0]);
                    let from_col = value_to_text(&r[1]);
                    let ref_tab  = value_to_text(&r[2]);
                    let to_col   = value_to_text(&r[3]);
                    let on_upd   = value_to_text(&r[4]);
                    let on_del   = value_to_text(&r[5]);
                    if cname != current_name {
                        grouped.push(ForeignKeySnap {
                            columns: List.new(),
                            referenced_table: ref_tab.clone(),
                            referenced_columns: List.new(),
                            on_delete: on_del.clone(),
                            on_update: on_upd.clone(),
                        });
                        current_name = cname;
                    }
                    let last = (grouped.len() as Int) - 1;
                    grouped[last].columns.push(from_col);
                    grouped[last].referenced_columns.push(to_col);
                }
                i = i + 1;
            }
            Ok(grouped)
        }
        Err(e) => Err(e),
    }
}

// -----------------------------------------------------------------------------
// WireValue → Text helpers (text-encoded rows from simple_query).
// -----------------------------------------------------------------------------

fn value_to_text(v: &WireValue) -> Text {
    match v {
        WvNull => "".clone(),
        WvPresent { bytes, .. } => Text.from_bytes(bytes).unwrap_or("".clone()),
    }
}

fn contains_text(haystack: &List<Text>, needle: &Text) -> Bool {
    let mut i: Int = 0;
    while i < haystack.len() as Int {
        if haystack[i] == *needle { return true; }
        i = i + 1;
    }
    false
}

fn text_contains(hay: &Text, needle: &Text) -> Bool {
    let h = hay.as_bytes();
    let n = needle.as_bytes();
    if n.len() > h.len() { return false; }
    let mut i: Int = 0;
    while i + n.len() <= h.len() {
        let mut k: Int = 0;
        let mut hit = true;
        while k < n.len() {
            if h[i + k] != n[k] { hit = false; break; }
            k = k + 1;
        }
        if hit { return true; }
        i = i + 1;
    }
    false
}
