module core.database.postgres.copy;

// =============================================================================
// postgres/copy.vr — bulk-streaming COPY FROM/TO
// =============================================================================
// Layer: 2-3
// Spec: database.md §6.1.6; postgresql.org §53.6 "COPY".
//
// COPY is the high-throughput bulk-ingest path on Postgres — 5-10×
// faster than `INSERT` even when pipelined, because the server skips
// per-row Parse/Bind round-trips and accepts a stream of pre-formatted
// rows.  The wire flow:
//
//     C → S : Query("COPY t (c1, c2) FROM STDIN [BINARY]")
//     S → C : CopyInResponse { format, column_formats }
//     C → S : CopyData { bytes: row_bytes }   * many *
//     C → S : CopyDone   |   C → S : CopyFail(reason)
//     S → C : CommandComplete { tag: "COPY N" }
//     S → C : ReadyForQuery
//
// COPY TO (server → client) is symmetric:
//
//     C → S : Query("COPY t (c) TO STDOUT [BINARY]")
//     S → C : CopyOutResponse { format, column_formats }
//     S → C : CopyData { bytes }   * many *
//     S → C : CopyDone
//     S → C : CommandComplete + ReadyForQuery
//
// v1 covers TEXT mode (newline-terminated rows, tab-separated columns
// per Postgres default).  Binary mode requires the 19-byte signature
// + 32-bit endian-marked field counts; deferred to v2.
// =============================================================================

mount core.*;
mount base.{Result, Ok, Err, Text, Maybe, None, Some};
mount collections.List;
mount core.database.common.error.{
    DbError, AdapterId, AdPostgres, AdapterSpecific,
};
mount core.database.postgres.connection.{PgConnection};

// -----------------------------------------------------------------------------
// CopyInBuilder — fluent assembly of a COPY FROM statement
// -----------------------------------------------------------------------------

/// Builder for a COPY FROM statement.  Renders the SQL and drives the
/// server's CopyInResponse / CopyData / CopyDone state machine.
public type CopyInBuilder is {
    table: Text,
    columns: List<Text>,
}

public fn copy_in(table: &Text) -> CopyInBuilder {
    CopyInBuilder { table: table.clone(), columns: List.new() }
}

implement CopyInBuilder {
    /// Restrict the COPY to a column subset.  Required when the
    /// caller's row layout doesn't match the table column order.
    public fn with_columns(mut self, cols: List<Text>) -> CopyInBuilder {
        self.columns = cols;
        self
    }

    /// Render the SQL — `COPY t (c1, c2) FROM STDIN`.  Internal use
    /// by `run`; exposed for tracing / dry-run.
    pub fn render_sql(&self) -> Text {
        let mut sql: Text = "COPY ".clone();
        sql.push_str(&self.table);
        if self.columns.len() > 0 {
            sql.push_str(&" (".clone());
            let mut i: Int = 0;
            while i < self.columns.len() {
                if i > 0 { sql.push_str(&", ".clone()); }
                sql.push_str(&self.columns[i]);
                i = i + 1;
            }
            sql.push_str(&")".clone());
        }
        sql.push_str(&" FROM STDIN".clone());
        sql
    }

    /// Drive the COPY FROM round-trip.  `rows` is a list of pre-
    /// formatted row strings (newline-terminated; tab-separated for
    /// the default text format).  Returns the server-reported COPY
    /// row count from the trailing CommandComplete.
    pub fn run(&self, conn: &mut PgConnection, rows: &List<Text>)
        -> Result<Int, DbError>
    {
        run_copy_in_text(conn, &self.render_sql(), rows)
    }

    /// Drive a COPY FROM where each row is *raw bytes* the caller
    /// has already formatted (e.g. for binary-mode COPY).  The
    /// caller is responsible for the wire-format invariant.
    pub fn run_bytes(&self, conn: &mut PgConnection, rows: &List<List<Byte>>)
        -> Result<Int, DbError>
    {
        run_copy_in_bytes(conn, &self.render_sql(), rows)
    }
}

// -----------------------------------------------------------------------------
// CopyOutBuilder — symmetrical for server-to-client streaming
// -----------------------------------------------------------------------------

public type CopyOutBuilder is {
    table: Text,
    columns: List<Text>,
}

public fn copy_out(table: &Text) -> CopyOutBuilder {
    CopyOutBuilder { table: table.clone(), columns: List.new() }
}

implement CopyOutBuilder {
    public fn with_columns(mut self, cols: List<Text>) -> CopyOutBuilder {
        self.columns = cols;
        self
    }

    pub fn render_sql(&self) -> Text {
        let mut sql: Text = "COPY ".clone();
        sql.push_str(&self.table);
        if self.columns.len() > 0 {
            sql.push_str(&" (".clone());
            let mut i: Int = 0;
            while i < self.columns.len() {
                if i > 0 { sql.push_str(&", ".clone()); }
                sql.push_str(&self.columns[i]);
                i = i + 1;
            }
            sql.push_str(&")".clone());
        }
        sql.push_str(&" TO STDOUT".clone());
        sql
    }

    /// Drive a COPY TO and collect every row's raw payload bytes.
    /// Each entry is one server-emitted CopyData chunk — for text
    /// mode that's typically one row, but the protocol allows
    /// arbitrary chunking and the caller should treat the
    /// concatenation as the canonical body.
    pub fn run(&self, conn: &mut PgConnection) -> Result<List<List<Byte>>, DbError> {
        run_copy_out(conn, &self.render_sql())
    }
}

// -----------------------------------------------------------------------------
// Internals — drive the wire round-trip
// -----------------------------------------------------------------------------

/// Internal: forward to PgConnection.copy_in_text_lines, which owns
/// the wire round-trip.
fn run_copy_in_text(
    conn: &mut PgConnection,
    sql: &Text,
    rows: &List<Text>,
) -> Result<Int, DbError> {
    conn.copy_in_text_lines(sql, rows)
}

fn run_copy_in_bytes(
    conn: &mut PgConnection,
    sql: &Text,
    rows: &List<List<Byte>>,
) -> Result<Int, DbError> {
    conn.copy_in_bytes(sql, rows)
}

fn run_copy_out(
    conn: &mut PgConnection,
    sql: &Text,
) -> Result<List<List<Byte>>, DbError> {
    conn.copy_out_bytes(sql)
}
