// =============================================================================
// core/database/postgres/wire/frontend.vr — frontend message builders
// =============================================================================
// Spec: postgresql.org/docs/16/protocol-message-formats.html
//
// Pure encoders — every function returns the wire bytes ready to be
// shipped to the socket. The closure-based `frame` helper takes care
// of length-self-adjustment, so every payload builder writes only
// the post-length body.
// =============================================================================

module core.database.postgres.wire.frontend;

mount core.*;
mount base.{Text, Maybe, None, Some};
mount collections.List;
mount core.database.common.types.WireBuf;
mount core.database.postgres.wire.frame.frame;
mount core.database.postgres.wire.frame.frame_untagged;
mount core.database.postgres.wire.types.{
    FE_QUERY, FE_PARSE, FE_BIND, FE_DESCRIBE, FE_EXECUTE, FE_FLUSH,
    FE_SYNC, FE_TERMINATE, FE_CLOSE, FE_PASSWORD,
    FE_COPY_DATA, FE_COPY_DONE, FE_COPY_FAIL,
    PROTO_V3_0,
};

// -----------------------------------------------------------------------------
// Startup message — untagged, length-prefixed.
// -----------------------------------------------------------------------------
//
// Body layout:
//   * 4-byte BE protocol version (PROTO_V3_0 = 196608)
//   * sequence of NUL-terminated `key`, NUL-terminated `value` pairs
//   * trailing NUL byte (empty key) terminates the parameter list
//
// Mandatory parameters: `user`. Optional: `database`, `application_name`,
// `client_encoding`, `replication`. Spindle defaults `client_encoding` to
// `UTF8` and `application_name` to `verum-spindle`.

public type StartupParams is {
    user: Text,
    database: Maybe<Text>,
    application_name: Text,
    client_encoding: Text,
    replication: Maybe<Text>,
};

implement StartupParams {
    public fn new(user: Text) -> StartupParams {
        StartupParams {
            user: user,
            database: None,
            application_name: "verum-spindle".clone(),
            client_encoding: "UTF8".clone(),
            replication: None,
        }
    }

    public fn with_database(self, db: Text) -> StartupParams {
        StartupParams { database: Some(db), .. self }
    }

    public fn with_application_name(self, name: Text) -> StartupParams {
        StartupParams { application_name: name, .. self }
    }

    public fn with_replication(self, replication: Text) -> StartupParams {
        StartupParams { replication: Some(replication), .. self }
    }
}

public fn startup(params: &StartupParams) -> List<Byte> {
    let user = params.user.clone();
    let app_name = params.application_name.clone();
    let client_enc = params.client_encoding.clone();
    let database = params.database.clone();
    let replication = params.replication.clone();
    frame_untagged(|buf: &mut WireBuf| {
        buf.put_i32_be(PROTO_V3_0);
        buf.put_cstr(&"user".clone());
        buf.put_cstr(&user);
        match database {
            Some(db) => {
                buf.put_cstr(&"database".clone());
                buf.put_cstr(&db);
            }
            None => {}
        }
        buf.put_cstr(&"application_name".clone());
        buf.put_cstr(&app_name);
        buf.put_cstr(&"client_encoding".clone());
        buf.put_cstr(&client_enc);
        match replication {
            Some(r) => {
                buf.put_cstr(&"replication".clone());
                buf.put_cstr(&r);
            }
            None => {}
        }
        // Empty key terminates the parameter list.
        buf.put_u8(0);
    })
}

// -----------------------------------------------------------------------------
// SSLRequest / CancelRequest — untagged, fixed payload.
// -----------------------------------------------------------------------------

/// Magic packet sent BEFORE the startup message to negotiate TLS. The
/// server replies with a single byte (`'S'` accept / `'N'` decline)
/// outside the normal frame stream.
public fn ssl_request() -> List<Byte> {
    frame_untagged(|buf: &mut WireBuf| {
        buf.put_i32_be(80877103);    // 0x04D2162F  (SSL request magic)
    })
}

/// Cancel a running query. Sent on a *separate* TCP connection using
/// the (process_id, secret_key) pair captured from the original
/// startup handshake's BackendKeyData.
public fn cancel_request(process_id: Int, secret_key: Int) -> List<Byte> {
    frame_untagged(|buf: &mut WireBuf| {
        buf.put_i32_be(80877102);    // 0x04D2162E  (CancelRequest magic)
        buf.put_i32_be(process_id);
        buf.put_i32_be(secret_key);
    })
}

// -----------------------------------------------------------------------------
// Simple Query (Q) — single SQL string, mode is "simple query"
// (no parameters, server may stream multiple result-sets back).
// -----------------------------------------------------------------------------

public fn simple_query(sql: &Text) -> List<Byte> {
    let s = sql.clone();
    frame(FE_QUERY, |buf: &mut WireBuf| {
        buf.put_cstr(&s);
    })
}

// -----------------------------------------------------------------------------
// Terminate (X) — orderly close. The server processes nothing after
// this; the connection is shut down at the TCP level next.
// -----------------------------------------------------------------------------

public fn terminate() -> List<Byte> {
    frame(FE_TERMINATE, |_buf: &mut WireBuf| {})
}

// -----------------------------------------------------------------------------
// Sync (S) — extended-protocol pipeline barrier. Forces a ReadyForQuery.
// -----------------------------------------------------------------------------

public fn sync() -> List<Byte> {
    frame(FE_SYNC, |_buf: &mut WireBuf| {})
}

// -----------------------------------------------------------------------------
// Flush (H) — extended-protocol "send the responses you've buffered".
// Useful when pipelining without inserting a Sync barrier.
// -----------------------------------------------------------------------------

public fn flush() -> List<Byte> {
    frame(FE_FLUSH, |_buf: &mut WireBuf| {})
}

// -----------------------------------------------------------------------------
// COPY frames — bulk-streaming protocol (database.md §6.1.6)
// -----------------------------------------------------------------------------
//
// After the server emits CopyInResponse, the client streams payload
// in `CopyData` frames followed by a single `CopyDone` (success) or
// `CopyFail` (abort with error message).  Each CopyData carries an
// arbitrary chunk; the server resyncs at row boundaries internally
// so the chunk size is purely a transport choice.

/// CopyData (`d`) — chunk of payload bytes during a COPY FROM stream.
/// Caller decides the chunk size; for TEXT-mode COPY each row should
/// land in its own frame (one trailing newline) for cleanest server
/// error reporting, but multiple rows per frame are accepted.
public fn copy_data(bytes: &[Byte]) -> List<Byte> {
    let owned = bytes_to_list(bytes);
    frame(FE_COPY_DATA, |buf: &mut WireBuf| {
        buf.put_bytes(owned.as_slice());
    })
}

/// CopyDone (`c`) — terminate a COPY FROM stream successfully.
/// Server then emits CommandComplete + ReadyForQuery.
public fn copy_done() -> List<Byte> {
    frame(FE_COPY_DONE, |_buf: &mut WireBuf| {})
}

/// CopyFail (`f`) — abort a COPY FROM stream with an error message.
/// `reason` is logged server-side and propagated to the client as
/// ErrorResponse.
public fn copy_fail(reason: &Text) -> List<Byte> {
    let s = reason.clone();
    frame(FE_COPY_FAIL, |buf: &mut WireBuf| {
        buf.put_cstr(&s);
    })
}

// -----------------------------------------------------------------------------
// PasswordMessage — also carries SCRAM client messages.
// -----------------------------------------------------------------------------

public fn password_message(payload: &[Byte]) -> List<Byte> {
    let owned = bytes_to_list(payload);
    frame(FE_PASSWORD, |buf: &mut WireBuf| {
        buf.put_bytes(owned.as_slice());
    })
}

/// SASL initial response: mechanism name + NUL + 4-byte BE length +
/// initial-response bytes (or `-1` for empty).
public fn sasl_initial_response(mechanism: &Text, initial_response: &[Byte]) -> List<Byte> {
    let mech = mechanism.clone();
    let body = bytes_to_list(initial_response);
    frame(FE_PASSWORD, |buf: &mut WireBuf| {
        buf.put_cstr(&mech);
        buf.put_i32_be(body.len() as Int);
        buf.put_bytes(body.as_slice());
    })
}

/// SASL response: subsequent client SCRAM messages after the initial.
public fn sasl_response(client_message: &[Byte]) -> List<Byte> {
    let body = bytes_to_list(client_message);
    frame(FE_PASSWORD, |buf: &mut WireBuf| {
        buf.put_bytes(body.as_slice());
    })
}

// -----------------------------------------------------------------------------
// Extended protocol — Parse / Bind / Describe / Execute / Close
// -----------------------------------------------------------------------------
//
// The extended-query path lets the client cache a parsed statement on
// the server (Parse), bind parameters by reference (Bind), describe
// the result-set shape (Describe), and run it (Execute). A Sync at
// the end of a chain forces the server to emit ReadyForQuery and
// flush its responses; pipelining runs many round-trips before that
// barrier.
//
// Naming convention for portal / statement names: Spindle uses the
// 16-hex-char `s<fingerprint_hex>` slot from `PreparedQuery::server_
// name()`; an empty Text means "use the unnamed default slot" and is
// only safe when no other request is in flight.

/// Parse — register a SQL string with the server under `name`. Pass
/// `param_oids` empty to let the server infer parameter types (it
/// will then send `ParameterDescription` after Sync).
public fn parse(name: &Text, sql: &Text, param_oids: &[Int]) -> List<Byte> {
    let n = name.clone();
    let q = sql.clone();
    let oids = ints_to_list(param_oids);
    frame(FE_PARSE, |buf: &mut WireBuf| {
        buf.put_cstr(&n);
        buf.put_cstr(&q);
        buf.put_u16_be(oids.len() as Int);
        let mut i = 0;
        while i < oids.len() as Int {
            buf.put_i32_be(oids[i]);
            i = i + 1;
        }
    })
}

/// Bind — bind values to a previously-parsed statement.
///   * `portal`   — destination portal name; "" = unnamed default
///   * `stmt_name` — source statement name; "" = unnamed default
///   * `param_formats` — per-parameter wire format (0 text, 1 binary).
///                       Pass an empty slice to default every param to
///                       text; pass length-1 to apply one format to
///                       all; pass length-N to vary per param.
///   * `params` — the parameter values; each entry is an
///                already-encoded byte slice or `None` for SQL NULL.
///   * `result_formats` — per-column result format. Same length-N
///                        rules as `param_formats`.
public fn bind(
    portal: &Text,
    stmt_name: &Text,
    param_formats: &[Int],
    params: &List<Maybe<List<Byte>>>,
    result_formats: &[Int],
) -> List<Byte> {
    let p = portal.clone();
    let s = stmt_name.clone();
    let pf = ints_to_list(param_formats);
    let rf = ints_to_list(result_formats);
    let owned_params = clone_params(params);
    frame(FE_BIND, |buf: &mut WireBuf| {
        buf.put_cstr(&p);
        buf.put_cstr(&s);
        // Param formats
        buf.put_u16_be(pf.len() as Int);
        let mut i = 0;
        while i < pf.len() as Int {
            buf.put_u16_be(pf[i]);
            i = i + 1;
        }
        // Param values
        buf.put_u16_be(owned_params.len() as Int);
        let mut k = 0;
        while k < owned_params.len() as Int {
            match &owned_params[k] {
                None    => { buf.put_i32_be(-1); }
                Some(v) => {
                    buf.put_i32_be(v.len() as Int);
                    buf.put_bytes(v.as_slice());
                }
            }
            k = k + 1;
        }
        // Result formats
        buf.put_u16_be(rf.len() as Int);
        let mut j = 0;
        while j < rf.len() as Int {
            buf.put_u16_be(rf[j]);
            j = j + 1;
        }
    })
}

/// Describe — kind 'S' (statement) or 'P' (portal).
public fn describe_statement(name: &Text) -> List<Byte> {
    let n = name.clone();
    frame(FE_DESCRIBE, |buf: &mut WireBuf| {
        buf.put_u8(0x53);     // 'S'
        buf.put_cstr(&n);
    })
}

public fn describe_portal(name: &Text) -> List<Byte> {
    let n = name.clone();
    frame(FE_DESCRIBE, |buf: &mut WireBuf| {
        buf.put_u8(0x50);     // 'P'
        buf.put_cstr(&n);
    })
}

/// Execute — run a portal until it produces `max_rows` rows (0 = all).
public fn execute(portal: &Text, max_rows: Int) -> List<Byte> {
    let p = portal.clone();
    frame(FE_EXECUTE, |buf: &mut WireBuf| {
        buf.put_cstr(&p);
        buf.put_i32_be(max_rows);
    })
}

/// Close — kind 'S' (statement) or 'P' (portal). Caller picks one
/// per the slot they want to release; the server emits CloseComplete.
public fn close_statement(name: &Text) -> List<Byte> {
    let n = name.clone();
    frame(FE_CLOSE, |buf: &mut WireBuf| {
        buf.put_u8(0x53);
        buf.put_cstr(&n);
    })
}

public fn close_portal(name: &Text) -> List<Byte> {
    let n = name.clone();
    frame(FE_CLOSE, |buf: &mut WireBuf| {
        buf.put_u8(0x50);
        buf.put_cstr(&n);
    })
}

// -----------------------------------------------------------------------------
// Helpers
// -----------------------------------------------------------------------------

fn ints_to_list(xs: &[Int]) -> List<Int> {
    let mut out: List<Int> = List.new();
    let mut i = 0;
    while i < xs.len() {
        out.push(xs[i]);
        i = i + 1;
    }
    out
}

fn clone_params(src: &List<Maybe<List<Byte>>>) -> List<Maybe<List<Byte>>> {
    let mut out: List<Maybe<List<Byte>>> = List.new();
    let mut i = 0;
    while i < src.len() as Int {
        match &src[i] {
            None    => out.push(None),
            Some(v) => out.push(Some(v.clone())),
        }
        i = i + 1;
    }
    out
}

fn bytes_to_list(buf: &[Byte]) -> List<Byte> {
    let mut out: List<Byte> = List.new();
    let mut i = 0;
    while i < buf.len() {
        out.push(buf[i]);
        i = i + 1;
    }
    out
}
