// =============================================================================
// core/database/postgres/wire/typed.vr — TypedValue ADT + codec dispatch
// =============================================================================
// Layer: 3 (Database — postgres adapter, wire layer)
// Spec: internal/specs/database.md §6.1.4 (binary codec register)
// =============================================================================
//
// The unified type-aware codec front-end. `core.database.postgres.wire.codec`
// (commit #6) lives below this layer and ships the per-type binary
// encoders / decoders (jsonb, range, array, inet, …). This module
// adds:
//
//   * `TypedValue` — sum type covering every Phase-2 and Phase-3
//     OID Spindle understands. One variant per scalar / composite
//     type the binary protocol distinguishes.
//
//   * Phase-2 codecs the codec.vr module hadn't shipped yet — bool,
//     int2/4/8, float4/8, text, bytea, uuid. Phase-3 specifics
//     (jsonb, ranges, arrays, inet, cidr) reuse codec.vr's existing
//     functions through TypedValue's `from_*` / `to_*` projections.
//
//   * `encode_typed(oid, &TypedValue, buf, arena)` — dispatch on the
//     declared OID. Used by extended-protocol Bind: caller passes the
//     param's PG OID + the corresponding TypedValue, the dispatch
//     emits binary wire bytes into the connection arena.
//
//   * `decode_typed(oid, &ArenaSlice) -> Result<TypedValue, DbError>`
//     — dispatch on the column's RowDescription OID. Used by
//     connection.vr's DataRow handler: each column's bytes flow
//     through the per-OID decoder into the typed result.
//
// Without this dispatch layer the per-type codecs in codec.vr are
// reachable only by name — hot-path callers had to pattern-match on
// OID themselves (or, worse, fall back to text protocol). With it,
// the extended-protocol adapter can do `encode_typed(param_oid,
// &param_val, ...)` for every parameter and `decode_typed(col_oid,
// &col_slice)` for every column without per-type pattern-matching
// at the call site.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.database.postgres.wire.typed;

mount core.*;
mount base.{Result, Ok, Err, Text, Maybe, None, Some};
mount collections.List;
mount core.intrinsics.runtime.mem_raw.{load_byte, store_byte};
mount core.database.common.error.{DbError, DecodeFault, EncodeFault};
mount core.database.common.arena.{SpindleArena};
mount core.database.common.types.{ArenaSlice, ArenaWireBuf};
mount core.database.postgres.wire.codec.{
    PG_TYPE_BOOL, PG_TYPE_BYTEA, PG_TYPE_INT2, PG_TYPE_INT4, PG_TYPE_INT8,
    PG_TYPE_FLOAT4, PG_TYPE_FLOAT8, PG_TYPE_TEXT, PG_TYPE_VARCHAR,
    PG_TYPE_BPCHAR, PG_TYPE_NAME, PG_TYPE_OID, PG_TYPE_UUID,
    PG_TYPE_JSON, PG_TYPE_JSONB, PG_TYPE_INET, PG_TYPE_CIDR,
    PG_TYPE_INT4RANGE, PG_TYPE_INT8RANGE, PG_TYPE_NUMRANGE,
    PG_TYPE_TSRANGE, PG_TYPE_TSTZRANGE, PG_TYPE_DATERANGE,
    PG_TYPE_DATE, PG_TYPE_TIME, PG_TYPE_TIMESTAMP, PG_TYPE_TIMESTAMPTZ,
    PG_TYPE_INTERVAL, PG_TYPE_RECORD, PG_TYPE_ANYARRAY,
    PgJsonb, PgRange, PgArrayHeader, PgInet,
    decode_jsonb, encode_jsonb, decode_range, encode_range,
    decode_array, encode_array_1d, decode_inet, encode_inet,
    PG_RANGE_FLAG_EMPTY, PG_RANGE_FLAG_LB_INC, PG_RANGE_FLAG_UB_INC,
    PG_RANGE_FLAG_LB_INF, PG_RANGE_FLAG_UB_INF,
    element_oid_for_array, range_element_oid,
    PgComposite, PgCompositeField,
    decode_composite as raw_decode_composite,
};

// =============================================================================
// TypedValue — sum type covering every supported PG OID.
// =============================================================================
//
// The variants keep variable-length payloads (text, bytea) as
// `List<Byte>` rather than ArenaSlice — a TypedValue is the
// boundary between wire-arena and application-owned data, so
// owning the bytes lets the value outlive the connection's
// per-query arena scope. Callers that want zero-copy reads at the
// wire layer keep using the lower-level functions in codec.vr
// directly.

public type TypedValue is
      // SQL NULL — distinct from "absence of value".
      TvNull
    | TvBool(Bool)
    | TvInt2(Int)               // i16
    | TvInt4(Int)               // i32
    | TvInt8(Int)               // i64
    | TvFloat4(Float)           // f32 (carried as Float; precision preserved on encode)
    | TvFloat8(Float)           // f64
    | TvText(Text)              // covers PG_TYPE_TEXT / VARCHAR / BPCHAR / NAME
    | TvBytea(List<Byte>)
    | TvUuid(List<Byte>)        // exactly 16 raw bytes
    | TvOid(Int)                // 32-bit unsigned, carried as Int
    | TvJson(Text)              // legacy text-json
    | TvJsonb(Text)             // version-byte stripped; raw JSON text
    | TvInet(TypedInet)
    | TvIntRange(TypedIntRange)
    | TvTextRange(TypedTextRange)    // covers tsrange/tstzrange/numrange string-form
    | TvArray(TypedArray)
    | TvDate(Int)               // days since 2000-01-01 (PG epoch)
    | TvTime(Int)               // microseconds since midnight
    | TvTimestamp(Int)          // microseconds since 2000-01-01 00:00:00 (naive)
    | TvTimestamptz(Int)        // microseconds since 2000-01-01 00:00:00 UTC
    | TvInterval(TypedInterval)
    /// Composite / record — anonymous (PG_TYPE_RECORD = 2249) OR
    /// any user-defined composite type. PG binary wire is
    /// SELF-DESCRIBING per field (each field carries its own
    /// type_oid), so the same encoder/decoder works for both
    /// flavours regardless of the outer OID.
    | TvComposite(TypedComposite);

public type TypedInet is {
    family: Int,                // 2 = IPv4, 3 = IPv6
    prefix_bits: Int,
    is_cidr: Bool,
    addr: List<Byte>,           // 4 or 16 bytes
};

public type TypedIntRange is {
    flags: Int,                 // PG_RANGE_FLAG_*
    lower: Maybe<Int>,
    upper: Maybe<Int>,
};

public type TypedTextRange is {
    flags: Int,
    lower: Maybe<Text>,
    upper: Maybe<Text>,
};

public type TypedArray is {
    element_oid: Int,
    /// Multi-dimensional layout flattened to row-major. A 1-D array
    /// has `dimensions = [N]` and `elements.len() = N`. NULL
    /// elements are `None`.
    dimensions: List<Int>,
    elements: List<Maybe<TypedValue>>,
};

public type TypedInterval is {
    months: Int,
    days: Int,
    microseconds: Int,
};

/// One field of a composite/record value. `type_oid` carries the
/// per-field PG OID (the wire is self-describing); `value` is
/// `None` for SQL NULL fields.
public type TypedField is {
    type_oid: Int,
    value: Maybe<TypedValue>,
};

/// Composite / record value. Field positions are significant
/// (matches the schema's column order); names are NOT carried in
/// V0 — callers using user-defined composite types pair positions
/// with their own schema-aware accessor.
public type TypedComposite is {
    fields: List<TypedField>,
};

implement TypedValue {
    public fn is_null(&self) -> Bool {
        match self { TvNull => true, _ => false }
    }

    /// Best-effort short type-name for diagnostics.
    public fn type_name(&self) -> Text {
        match self {
            TvNull         => "null".clone(),
            TvBool(_)      => "bool".clone(),
            TvInt2(_)      => "int2".clone(),
            TvInt4(_)      => "int4".clone(),
            TvInt8(_)      => "int8".clone(),
            TvFloat4(_)    => "float4".clone(),
            TvFloat8(_)    => "float8".clone(),
            TvText(_)      => "text".clone(),
            TvBytea(_)     => "bytea".clone(),
            TvUuid(_)      => "uuid".clone(),
            TvOid(_)       => "oid".clone(),
            TvJson(_)      => "json".clone(),
            TvJsonb(_)     => "jsonb".clone(),
            TvInet(_)      => "inet".clone(),
            TvIntRange(_)  => "intrange".clone(),
            TvTextRange(_) => "textrange".clone(),
            TvArray(_)     => "array".clone(),
            TvDate(_)      => "date".clone(),
            TvTime(_)      => "time".clone(),
            TvTimestamp(_) => "timestamp".clone(),
            TvTimestamptz(_)=> "timestamptz".clone(),
            TvInterval(_)  => "interval".clone(),
            TvComposite(_) => "composite".clone(),
        }
    }
}

// =============================================================================
// Phase-2 binary encoders — write into ArenaWireBuf.
// =============================================================================
//
// Wire layouts per PostgreSQL `src/backend/utils/adt/*_send.c`:
//
//   bool      — 1 byte: 0x00 = false, 0x01 = true
//   bytea     — opaque bytes, length is in the column header
//   int2/4/8  — big-endian
//   float4/8  — IEEE-754 big-endian
//   text/varchar/bpchar/name — UTF-8 bytes; length is in the column header
//   uuid      — 16 raw bytes (network order)
//   oid       — u32 big-endian
//   date      — i32 days since 2000-01-01
//   time      — i64 microseconds since midnight
//   timestamp / timestamptz — i64 microseconds since 2000-01-01
//   interval  — i64 microseconds || i32 days || i32 months (16 bytes total)

fn encode_bool(buf: &mut ArenaWireBuf, arena: &mut SpindleArena, v: Bool) -> Bool {
    buf.put_u8(arena, if v { 1 } else { 0 })
}

fn encode_int2(buf: &mut ArenaWireBuf, arena: &mut SpindleArena, v: Int) -> Bool {
    buf.put_u16_be(arena, v & 0xFFFF)
}

fn encode_int4(buf: &mut ArenaWireBuf, arena: &mut SpindleArena, v: Int) -> Bool {
    buf.put_i32_be(arena, v)
}

fn encode_int8(buf: &mut ArenaWireBuf, arena: &mut SpindleArena, v: Int) -> Bool {
    buf.put_i64_be(arena, v)
}

fn encode_float4(buf: &mut ArenaWireBuf, arena: &mut SpindleArena, v: Float) -> Bool {
    let bits = v.to_bits();
    // IEEE-754 single-precision is the low 32 bits of the f64 bit
    // representation only when the value rounds losslessly. For
    // safety, pre-round through f32 conversion: cast to Float32 then
    // back to bits.
    let f32 = v as Float32;
    let bits32 = f32.to_bits();
    buf.put_u32_be(arena, (bits32 as Int) & 0xFFFFFFFF)
}

fn encode_float8(buf: &mut ArenaWireBuf, arena: &mut SpindleArena, v: Float) -> Bool {
    let bits = v.to_bits();
    buf.put_u64_be(arena, bits as Int)
}

fn encode_text(buf: &mut ArenaWireBuf, arena: &mut SpindleArena, s: &Text) -> Bool {
    buf.put_bytes(arena, s.as_bytes())
}

fn encode_bytea(buf: &mut ArenaWireBuf, arena: &mut SpindleArena, b: &[Byte]) -> Bool {
    buf.put_bytes(arena, b)
}

fn encode_uuid(buf: &mut ArenaWireBuf, arena: &mut SpindleArena, b: &[Byte]) -> Bool {
    if (b.len() as Int) != 16 { return false; }
    buf.put_bytes(arena, b)
}

fn encode_oid(buf: &mut ArenaWireBuf, arena: &mut SpindleArena, oid: Int) -> Bool {
    buf.put_u32_be(arena, oid & 0xFFFFFFFF)
}

fn encode_date(buf: &mut ArenaWireBuf, arena: &mut SpindleArena, days: Int) -> Bool {
    buf.put_i32_be(arena, days)
}

fn encode_time(buf: &mut ArenaWireBuf, arena: &mut SpindleArena, micros: Int) -> Bool {
    buf.put_i64_be(arena, micros)
}

fn encode_timestamp(buf: &mut ArenaWireBuf, arena: &mut SpindleArena, micros: Int) -> Bool {
    buf.put_i64_be(arena, micros)
}

fn encode_interval(buf: &mut ArenaWireBuf, arena: &mut SpindleArena, iv: &TypedInterval) -> Bool {
    if !buf.put_i64_be(arena, iv.microseconds) { return false; }
    if !buf.put_i32_be(arena, iv.days)         { return false; }
    buf.put_i32_be(arena, iv.months)
}

// =============================================================================
// Phase-2 binary decoders — read from ArenaSlice.
// =============================================================================

fn decode_bool(s: &ArenaSlice) -> Result<Bool, DbError> {
    if s.len < 1 {
        return Err(decode_fault("bool: empty payload".clone()));
    }
    Ok((load_byte(s.ptr) & 0x01) != 0)
}

fn decode_int2(s: &ArenaSlice) -> Result<Int, DbError> {
    if s.len < 2 {
        return Err(decode_fault("int2: short payload".clone()));
    }
    let hi = load_byte(s.ptr)     & 0xFF;
    let lo = load_byte(s.ptr + 1) & 0xFF;
    let u = (hi << 8) | lo;
    if (u & 0x8000) != 0 {
        Ok(u | (-1 ^ 0xFFFF))
    } else {
        Ok(u)
    }
}

fn decode_int4(s: &ArenaSlice) -> Result<Int, DbError> {
    if s.len < 4 {
        return Err(decode_fault("int4: short payload".clone()));
    }
    let b0 = (load_byte(s.ptr)     & 0xFF) << 24;
    let b1 = (load_byte(s.ptr + 1) & 0xFF) << 16;
    let b2 = (load_byte(s.ptr + 2) & 0xFF) << 8;
    let b3 = (load_byte(s.ptr + 3) & 0xFF);
    let u = b0 | b1 | b2 | b3;
    if (u & 0x8000_0000) != 0 {
        Ok(u | (-1 ^ 0xFFFF_FFFF))
    } else {
        Ok(u)
    }
}

fn decode_int8(s: &ArenaSlice) -> Result<Int, DbError> {
    if s.len < 8 {
        return Err(decode_fault("int8: short payload".clone()));
    }
    let mut v: Int = 0;
    let mut i: Int = 0;
    while i < 8 {
        v = (v << 8) | (load_byte(s.ptr + i) & 0xFF);
        i = i + 1;
    }
    Ok(v)
}

fn decode_float4(s: &ArenaSlice) -> Result<Float, DbError> {
    let bits = decode_int4(s)? & 0xFFFFFFFF;
    let f32_val = Float32.from_bits(bits as UInt32);
    Ok(f32_val as Float)
}

fn decode_float8(s: &ArenaSlice) -> Result<Float, DbError> {
    let bits = decode_int8(s)?;
    Ok(Float.from_bits(bits as UInt64))
}

fn decode_text(s: &ArenaSlice, arena: &SpindleArena) -> Result<Text, DbError> {
    match s.to_owned(arena) {
        None       => Err(decode_fault("text: arena slice stale".clone())),
        Some(b)    => match Text.from_utf8(b) {
            Ok(t)  => Ok(t),
            Err(_) => Err(decode_fault("text: invalid UTF-8".clone())),
        }
    }
}

fn decode_bytea(s: &ArenaSlice, arena: &SpindleArena) -> Result<List<Byte>, DbError> {
    match s.to_owned(arena) {
        None    => Err(decode_fault("bytea: arena slice stale".clone())),
        Some(b) => Ok(b),
    }
}

fn decode_uuid(s: &ArenaSlice, arena: &SpindleArena) -> Result<List<Byte>, DbError> {
    if s.len != 16 {
        return Err(decode_fault(f"uuid: expected 16 bytes, got {s.len}"));
    }
    decode_bytea(s, arena)
}

fn decode_oid(s: &ArenaSlice) -> Result<Int, DbError> {
    if s.len < 4 {
        return Err(decode_fault("oid: short payload".clone()));
    }
    let b0 = (load_byte(s.ptr)     & 0xFF) << 24;
    let b1 = (load_byte(s.ptr + 1) & 0xFF) << 16;
    let b2 = (load_byte(s.ptr + 2) & 0xFF) << 8;
    let b3 = (load_byte(s.ptr + 3) & 0xFF);
    Ok(b0 | b1 | b2 | b3)
}

fn decode_date(s: &ArenaSlice) -> Result<Int, DbError> {
    decode_int4(s)
}

fn decode_time(s: &ArenaSlice) -> Result<Int, DbError> {
    decode_int8(s)
}

fn decode_timestamp(s: &ArenaSlice) -> Result<Int, DbError> {
    decode_int8(s)
}

fn decode_interval(s: &ArenaSlice) -> Result<TypedInterval, DbError> {
    if s.len < 16 {
        return Err(decode_fault("interval: short payload".clone()));
    }
    let micros = decode_int8(s)?;
    let days = {
        let mut sub: ArenaSlice = ArenaSlice {
            ptr: s.ptr + 8,
            len: 4,
            generation: s.generation,
        };
        decode_int4(&sub)?
    };
    let months = {
        let mut sub: ArenaSlice = ArenaSlice {
            ptr: s.ptr + 12,
            len: 4,
            generation: s.generation,
        };
        decode_int4(&sub)?
    };
    Ok(TypedInterval { months: months, days: days, microseconds: micros })
}

// =============================================================================
// Dispatch — encode_typed / decode_typed
// =============================================================================

/// Encode `value` according to the param's declared OID. Used by
/// extended-protocol Bind: every param has a known OID (from the
/// `Parse`'s `param_oids` array), and the dispatch picks the right
/// encoder.
///
/// SQL NULL is signalled OUT-OF-BAND by a `-1` length prefix in the
/// Bind frame; this function is called only for non-NULL params, so
/// `TvNull` is rejected with `EncodeFailed`. The Bind builder is
/// responsible for emitting the length prefix.
public fn encode_typed(
    oid: Int,
    value: &TypedValue,
    buf: &mut ArenaWireBuf,
    arena: &mut SpindleArena,
) -> Result<(), DbError> {
    // Reject NULL — caller must short-circuit via the length prefix.
    match value {
        TvNull => return Err(encode_fault("encode_typed called with TvNull".clone())),
        _      => {}
    }

    // OID dispatch. Each branch enforces the variant matches the
    // declared OID; mismatches surface as EncodeFailed with the
    // type name so the caller learns "you said int4 but supplied
    // text".
    let ok = if oid == PG_TYPE_BOOL {
        match value {
            TvBool(b) => encode_bool(buf, arena, *b),
            _ => return Err(encode_fault(f"oid bool, got {value.type_name()}")),
        }
    } else if oid == PG_TYPE_INT2 {
        match value {
            TvInt2(n) => encode_int2(buf, arena, *n),
            _ => return Err(encode_fault(f"oid int2, got {value.type_name()}")),
        }
    } else if oid == PG_TYPE_INT4 {
        match value {
            TvInt4(n) => encode_int4(buf, arena, *n),
            _ => return Err(encode_fault(f"oid int4, got {value.type_name()}")),
        }
    } else if oid == PG_TYPE_INT8 {
        match value {
            TvInt8(n) => encode_int8(buf, arena, *n),
            _ => return Err(encode_fault(f"oid int8, got {value.type_name()}")),
        }
    } else if oid == PG_TYPE_FLOAT4 {
        match value {
            TvFloat4(f) => encode_float4(buf, arena, *f),
            _ => return Err(encode_fault(f"oid float4, got {value.type_name()}")),
        }
    } else if oid == PG_TYPE_FLOAT8 {
        match value {
            TvFloat8(f) => encode_float8(buf, arena, *f),
            _ => return Err(encode_fault(f"oid float8, got {value.type_name()}")),
        }
    } else if oid == PG_TYPE_TEXT || oid == PG_TYPE_VARCHAR
           || oid == PG_TYPE_BPCHAR || oid == PG_TYPE_NAME {
        match value {
            TvText(s) => encode_text(buf, arena, s),
            _ => return Err(encode_fault(f"oid text, got {value.type_name()}")),
        }
    } else if oid == PG_TYPE_BYTEA {
        match value {
            TvBytea(b) => encode_bytea(buf, arena, b.as_slice()),
            _ => return Err(encode_fault(f"oid bytea, got {value.type_name()}")),
        }
    } else if oid == PG_TYPE_UUID {
        match value {
            TvUuid(b) => encode_uuid(buf, arena, b.as_slice()),
            _ => return Err(encode_fault(f"oid uuid, got {value.type_name()}")),
        }
    } else if oid == PG_TYPE_OID {
        match value {
            TvOid(n) => encode_oid(buf, arena, *n),
            _ => return Err(encode_fault(f"oid oid, got {value.type_name()}")),
        }
    } else if oid == PG_TYPE_DATE {
        match value {
            TvDate(d) => encode_date(buf, arena, *d),
            _ => return Err(encode_fault(f"oid date, got {value.type_name()}")),
        }
    } else if oid == PG_TYPE_TIME {
        match value {
            TvTime(t) => encode_time(buf, arena, *t),
            _ => return Err(encode_fault(f"oid time, got {value.type_name()}")),
        }
    } else if oid == PG_TYPE_TIMESTAMP {
        match value {
            TvTimestamp(t) => encode_timestamp(buf, arena, *t),
            _ => return Err(encode_fault(f"oid timestamp, got {value.type_name()}")),
        }
    } else if oid == PG_TYPE_TIMESTAMPTZ {
        match value {
            TvTimestamptz(t) => encode_timestamp(buf, arena, *t),
            _ => return Err(encode_fault(f"oid timestamptz, got {value.type_name()}")),
        }
    } else if oid == PG_TYPE_INTERVAL {
        match value {
            TvInterval(iv) => encode_interval(buf, arena, iv),
            _ => return Err(encode_fault(f"oid interval, got {value.type_name()}")),
        }
    } else if oid == PG_TYPE_JSON {
        match value {
            TvJson(s) => encode_text(buf, arena, s),
            _ => return Err(encode_fault(f"oid json, got {value.type_name()}")),
        }
    } else if oid == PG_TYPE_JSONB {
        match value {
            TvJsonb(s) => encode_jsonb(buf, arena, s),
            _ => return Err(encode_fault(f"oid jsonb, got {value.type_name()}")),
        }
    } else if range_element_oid(oid).is_some() {
        let elem_oid = range_element_oid(oid).unwrap();
        match value {
            TvIntRange(r) => encode_int_range(buf, arena, elem_oid, r)?,
            TvTextRange(r) => encode_text_range(buf, arena, elem_oid, r)?,
            _ => return Err(encode_fault(f"oid range, got {value.type_name()}")),
        }
    } else if element_oid_for_array(oid).is_some() {
        let elem_oid = element_oid_for_array(oid).unwrap();
        match value {
            TvArray(arr) => encode_typed_array(buf, arena, elem_oid, arr)?,
            _ => return Err(encode_fault(f"oid array, got {value.type_name()}")),
        }
    } else {
        // Catch-all: composite / record / user-defined composite.
        // The wire is self-describing per field, so we don't need
        // a pg_type registry for the outer OID — TvComposite +
        // any OID dispatches to encode_composite.
        match value {
            TvComposite(c) => encode_composite(buf, arena, c)?,
            _ => return Err(encode_fault(f"oid {oid}: no codec dispatch entry")),
        }
    };

    if !ok {
        return Err(encode_fault(f"oid {oid}: arena exhausted during encode"));
    }
    Ok(())
}

// =============================================================================
// Range encoders — typed wrappers over codec.encode_range
// =============================================================================

/// Encode a typed integer range (`int4range` / `int8range`).
/// Element-OID-aware: for `int4range` the bounds are 4-byte i32;
/// for `int8range` they're 8-byte i64. Returns `Bool` shape that
/// matches every other encoder so the dispatch dropthrough handles
/// arena-exhaustion uniformly.
fn encode_int_range(
    buf: &mut ArenaWireBuf,
    arena: &mut SpindleArena,
    elem_oid: Int,
    r: &TypedIntRange,
) -> Result<Bool, DbError> {
    if (r.flags & PG_RANGE_FLAG_EMPTY) != 0 {
        let ok = encode_range(buf, arena, r.flags, None, None);
        return Ok(ok);
    }
    // Encode each bound into temporary owned bytes so encode_range
    // can splice them into the wire layout.
    let lower_bytes: Maybe<List<Byte>> = match r.lower {
        Some(v) => Some(encode_int_to_bytes(elem_oid, v)?),
        None    => None,
    };
    let upper_bytes: Maybe<List<Byte>> = match r.upper {
        Some(v) => Some(encode_int_to_bytes(elem_oid, v)?),
        None    => None,
    };
    let lower_ref: Maybe<&[Byte]> = match &lower_bytes {
        Some(b) => Some(b.as_slice()),
        None    => None,
    };
    let upper_ref: Maybe<&[Byte]> = match &upper_bytes {
        Some(b) => Some(b.as_slice()),
        None    => None,
    };
    let ok = encode_range(buf, arena, r.flags, lower_ref, upper_ref);
    Ok(ok)
}

fn encode_int_to_bytes(elem_oid: Int, v: Int) -> Result<List<Byte>, DbError> {
    let mut out: List<Byte> = List.new();
    if elem_oid == PG_TYPE_INT4 {
        out.push(((v >> 24) & 0xFF) as Byte);
        out.push(((v >> 16) & 0xFF) as Byte);
        out.push(((v >> 8)  & 0xFF) as Byte);
        out.push((v & 0xFF) as Byte);
        Ok(out)
    } else if elem_oid == PG_TYPE_INT8 {
        out.push(((v >> 56) & 0xFF) as Byte);
        out.push(((v >> 48) & 0xFF) as Byte);
        out.push(((v >> 40) & 0xFF) as Byte);
        out.push(((v >> 32) & 0xFF) as Byte);
        out.push(((v >> 24) & 0xFF) as Byte);
        out.push(((v >> 16) & 0xFF) as Byte);
        out.push(((v >> 8)  & 0xFF) as Byte);
        out.push((v & 0xFF) as Byte);
        Ok(out)
    } else {
        Err(encode_fault(f"int_range: unsupported element oid {elem_oid}"))
    }
}

/// Encode a typed text range (`numrange` / `tsrange` / `tstzrange`
/// / `daterange` — every range whose element wire format is text-
/// dominated). The element is sent as the canonical PG textual
/// representation so the server's input parser can lift it back.
fn encode_text_range(
    buf: &mut ArenaWireBuf,
    arena: &mut SpindleArena,
    _elem_oid: Int,
    r: &TypedTextRange,
) -> Result<Bool, DbError> {
    if (r.flags & PG_RANGE_FLAG_EMPTY) != 0 {
        let ok = encode_range(buf, arena, r.flags, None, None);
        return Ok(ok);
    }
    let lower_bytes: Maybe<List<Byte>> = match &r.lower {
        Some(t) => {
            let raw = t.as_bytes();
            let mut owned: List<Byte> = List.with_capacity(raw.len() as Int);
            let mut i: Int = 0;
            while i < (raw.len() as Int) {
                owned.push(raw[i]);
                i = i + 1;
            }
            Some(owned)
        }
        None => None,
    };
    let upper_bytes: Maybe<List<Byte>> = match &r.upper {
        Some(t) => {
            let raw = t.as_bytes();
            let mut owned: List<Byte> = List.with_capacity(raw.len() as Int);
            let mut i: Int = 0;
            while i < (raw.len() as Int) {
                owned.push(raw[i]);
                i = i + 1;
            }
            Some(owned)
        }
        None => None,
    };
    let lower_ref: Maybe<&[Byte]> = match &lower_bytes {
        Some(b) => Some(b.as_slice()),
        None    => None,
    };
    let upper_ref: Maybe<&[Byte]> = match &upper_bytes {
        Some(b) => Some(b.as_slice()),
        None    => None,
    };
    let ok = encode_range(buf, arena, r.flags, lower_ref, upper_ref);
    Ok(ok)
}

// =============================================================================
// Array encoder — recursive over encode_typed
// =============================================================================

/// Encode a typed 1-D array. Each element is encoded into a
/// scratch `ArenaWireBuf` via `encode_typed`; the resulting bytes
/// are collected and handed to `encode_array_1d` along with the
/// element OID. Multi-dim arrays are out of V0.
fn encode_typed_array(
    buf: &mut ArenaWireBuf,
    arena: &mut SpindleArena,
    elem_oid: Int,
    arr: &TypedArray,
) -> Result<Bool, DbError> {
    // V0 — multi-dim arrays out of scope.
    if arr.dimensions.len() as Int > 1 {
        return Err(encode_fault(
            f"array: V0 supports 1-D only; got {arr.dimensions.len() as Int} dims"
        ));
    }
    // Element-by-element encode into temp byte buffers.
    let n = arr.elements.len() as Int;
    let mut owned_payloads: List<Maybe<List<Byte>>> = List.with_capacity(n);
    let mut i: Int = 0;
    while i < n {
        match &arr.elements[i] {
            None => { owned_payloads.push(None); }
            Some(v) => {
                // Snapshot arena, encode element, copy bytes out,
                // rewind. Same pattern as encode_params_for_bind.
                let scope = core.database.common.arena.ArenaScope.begin(
                    arena,
                    core.database.common.arena.ApQuery,
                );
                let mut sub = ArenaWireBuf.with_arena(arena, 32);
                match encode_typed(elem_oid, v, &mut sub, arena) {
                    Ok(_) => {
                        let slice = sub.as_slice();
                        let mut owned: List<Byte> = List.with_capacity(slice.len);
                        let mut k: Int = 0;
                        while k < slice.len {
                            owned.push(load_byte(slice.ptr + k) as Byte);
                            k = k + 1;
                        }
                        scope.discard(arena);
                        owned_payloads.push(Some(owned));
                    }
                    Err(e) => {
                        scope.discard(arena);
                        return Err(e);
                    }
                }
            }
        }
        i = i + 1;
    }
    // Build the &[Byte] vector encode_array_1d wants.
    let mut refs: List<Maybe<&[Byte]>> = List.with_capacity(n);
    let mut j: Int = 0;
    while j < n {
        match &owned_payloads[j] {
            None    => { refs.push(None); }
            Some(b) => { refs.push(Some(b.as_slice())); }
        }
        j = j + 1;
    }
    let ok = encode_array_1d(buf, arena, elem_oid, &refs);
    Ok(ok)
}

/// Decode a column value according to its declared OID. Used by
/// connection.vr's DataRow handler: each column has an OID from
/// the most recent RowDescription, and the dispatch picks the
/// right decoder.
///
/// `arena` is the connection arena the slice was carved from —
/// passed through so decoders that need to materialise owned
/// strings (text, bytea, uuid) can do `.to_owned`.
public fn decode_typed(
    oid: Int,
    slice: &ArenaSlice,
    arena: &SpindleArena,
) -> Result<TypedValue, DbError> {
    if oid == PG_TYPE_BOOL {
        Ok(TvBool(decode_bool(slice)?))
    } else if oid == PG_TYPE_INT2 {
        Ok(TvInt2(decode_int2(slice)?))
    } else if oid == PG_TYPE_INT4 {
        Ok(TvInt4(decode_int4(slice)?))
    } else if oid == PG_TYPE_INT8 {
        Ok(TvInt8(decode_int8(slice)?))
    } else if oid == PG_TYPE_FLOAT4 {
        Ok(TvFloat4(decode_float4(slice)?))
    } else if oid == PG_TYPE_FLOAT8 {
        Ok(TvFloat8(decode_float8(slice)?))
    } else if oid == PG_TYPE_TEXT || oid == PG_TYPE_VARCHAR
           || oid == PG_TYPE_BPCHAR || oid == PG_TYPE_NAME {
        Ok(TvText(decode_text(slice, arena)?))
    } else if oid == PG_TYPE_BYTEA {
        Ok(TvBytea(decode_bytea(slice, arena)?))
    } else if oid == PG_TYPE_UUID {
        Ok(TvUuid(decode_uuid(slice, arena)?))
    } else if oid == PG_TYPE_OID {
        Ok(TvOid(decode_oid(slice)?))
    } else if oid == PG_TYPE_DATE {
        Ok(TvDate(decode_date(slice)?))
    } else if oid == PG_TYPE_TIME {
        Ok(TvTime(decode_time(slice)?))
    } else if oid == PG_TYPE_TIMESTAMP {
        Ok(TvTimestamp(decode_timestamp(slice)?))
    } else if oid == PG_TYPE_TIMESTAMPTZ {
        Ok(TvTimestamptz(decode_timestamp(slice)?))
    } else if oid == PG_TYPE_INTERVAL {
        Ok(TvInterval(decode_interval(slice)?))
    } else if oid == PG_TYPE_JSON {
        Ok(TvJson(decode_text(slice, arena)?))
    } else if oid == PG_TYPE_JSONB {
        let pgj = decode_jsonb(slice)?;
        match pgj.into_canonical(arena) {
            Some(canonical) => Ok(TvJsonb(canonical.json_text)),
            None            => Err(decode_fault("jsonb: arena slice stale".clone())),
        }
    } else if range_element_oid(oid).is_some() {
        let elem_oid = range_element_oid(oid).unwrap();
        decode_range_typed(slice, arena, elem_oid)
    } else if element_oid_for_array(oid).is_some() {
        let elem_oid = element_oid_for_array(oid).unwrap();
        decode_array_typed(slice, arena, elem_oid)
    } else if oid == PG_TYPE_RECORD {
        // Anonymous record (OID 2249). User-defined composites
        // have allocated OIDs the caller knows from pg_type;
        // they should call decode_composite_at(slice, arena)
        // directly when they recognise their OID.
        decode_composite_at(slice, arena)
    } else {
        Err(decode_fault(f"oid {oid}: no decoder registered"))
    }
}

// =============================================================================
// Composite / record encoders + decoders
// =============================================================================
//
// PG binary composite wire (per src/backend/utils/adt/rowtypes.c
// `record_send`):
//
//   ncolumns:i32
//   per column:
//     type_oid:i32     — each field's OID (self-describing).
//     length:i32       — `-1` for SQL NULL.
//     bytes:[length]   — per-OID binary encoding.

fn encode_composite(
    buf: &mut ArenaWireBuf,
    arena: &mut SpindleArena,
    c: &TypedComposite,
) -> Result<Bool, DbError> {
    let n = c.fields.len() as Int;
    if !buf.put_i32_be(arena, n) { return Ok(false); }
    let mut i: Int = 0;
    while i < n {
        let f = &c.fields[i];
        if !buf.put_i32_be(arena, f.type_oid) { return Ok(false); }
        match &f.value {
            None => {
                if !buf.put_i32_be(arena, -1) { return Ok(false); }
            }
            Some(v) => {
                // Encode the field into a scratch arena buffer,
                // copy bytes out + rewind. Same pattern as
                // encode_typed_array / encode_params_for_bind.
                let scope = core.database.common.arena.ArenaScope.begin(
                    arena,
                    core.database.common.arena.ApQuery,
                );
                let mut sub = ArenaWireBuf.with_arena(arena, 32);
                match encode_typed(f.type_oid, v, &mut sub, arena) {
                    Ok(_) => {
                        let slice = sub.as_slice();
                        // Write length prefix then bytes.
                        if !buf.put_i32_be(arena, slice.len) {
                            scope.discard(arena);
                            return Ok(false);
                        }
                        let mut k: Int = 0;
                        while k < slice.len {
                            let b = (load_byte(slice.ptr + k) & 0xFF) as Int;
                            if !buf.put_u8(arena, b) {
                                scope.discard(arena);
                                return Ok(false);
                            }
                            k = k + 1;
                        }
                        scope.discard(arena);
                    }
                    Err(e) => {
                        scope.discard(arena);
                        return Err(e);
                    }
                }
            }
        }
        i = i + 1;
    }
    Ok(true)
}

/// Decode a composite/record value from `slice`. Public so callers
/// who know an "unknown" OID is actually a user-defined composite
/// can dispatch it directly.
///
/// Composes the wire-level `decode_composite` from `core.database.
/// postgres.wire.codec` (which handles the header + per-field length
/// validation) with the per-field `decode_typed` dispatch.  Single-
/// source-of-truth: any wire-format fix in `codec.vr` automatically
/// reaches this path.  V0 caps composites at 4096 columns (a
/// reasonable upper bound for typed-row use; raw `decode_composite`
/// has no such cap for callers who manage their own dispatch).
public fn decode_composite_at(
    slice: &ArenaSlice,
    arena: &SpindleArena,
) -> Result<TypedValue, DbError> {
    let raw = raw_decode_composite(slice)?;
    let ncols = raw.field_count();
    if ncols > 4096 {
        return Err(decode_fault(f"composite: ncolumns {ncols} out of range"));
    }
    let mut fields: List<TypedField> = List.with_capacity(ncols);
    let mut i: Int = 0;
    while i < ncols {
        let raw_field = &raw.fields[i];
        let typed_field = match &raw_field.value {
            None => TypedField { type_oid: raw_field.type_oid, value: None },
            Some(body) => {
                let v = decode_typed(raw_field.type_oid, body, arena)?;
                TypedField { type_oid: raw_field.type_oid, value: Some(v) }
            }
        };
        fields.push(typed_field);
        i = i + 1;
    }
    Ok(TvComposite(TypedComposite { fields: fields }))
}

// `slice_i32_be_or_err` and `subslice_or_err` were the inline wire-
// walking helpers that `decode_composite_at` previously used.  After
// the refactor that routes composite decoding through
// `core.database.postgres.wire.codec.decode_composite` (single-source-
// of-truth), both helpers are unused and have been removed.  If future
// composite-shaped wire types need inline parsing, prefer adding the
// helper to `codec.vr` so all dependents continue to share one
// implementation.

// =============================================================================
// Range decoder — typed wrapper
// =============================================================================

fn decode_range_typed(
    slice: &ArenaSlice,
    arena: &SpindleArena,
    elem_oid: Int,
) -> Result<TypedValue, DbError> {
    let r = decode_range(slice)?;
    if r.is_empty() {
        if elem_oid == PG_TYPE_INT4 || elem_oid == PG_TYPE_INT8 {
            return Ok(TvIntRange(TypedIntRange {
                flags: r.flags,
                lower: None,
                upper: None,
            }));
        }
        return Ok(TvTextRange(TypedTextRange {
            flags: r.flags,
            lower: None,
            upper: None,
        }));
    }
    if elem_oid == PG_TYPE_INT4 || elem_oid == PG_TYPE_INT8 {
        let lower: Maybe<Int> = match &r.lower {
            Some(b) => {
                let v = decode_typed(elem_oid, b, arena)?;
                Some(int_value_or_err(&v)?)
            }
            None => None,
        };
        let upper: Maybe<Int> = match &r.upper {
            Some(b) => {
                let v = decode_typed(elem_oid, b, arena)?;
                Some(int_value_or_err(&v)?)
            }
            None => None,
        };
        return Ok(TvIntRange(TypedIntRange {
            flags: r.flags,
            lower: lower,
            upper: upper,
        }));
    }
    // Text-dominated ranges (numrange / tsrange / tstzrange / daterange).
    let lower: Maybe<Text> = match &r.lower {
        Some(b) => {
            let s = read_arena_slice_to_text(b);
            Some(s)
        }
        None => None,
    };
    let upper: Maybe<Text> = match &r.upper {
        Some(b) => {
            let s = read_arena_slice_to_text(b);
            Some(s)
        }
        None => None,
    };
    Ok(TvTextRange(TypedTextRange {
        flags: r.flags,
        lower: lower,
        upper: upper,
    }))
}

fn int_value_or_err(v: &TypedValue) -> Result<Int, DbError> {
    match v {
        TvInt2(n) | TvInt4(n) | TvInt8(n) => Ok(*n),
        _ => Err(decode_fault("range: expected integer element".clone())),
    }
}

fn read_arena_slice_to_text(s: &ArenaSlice) -> Text {
    let mut out = "".clone();
    let mut i: Int = 0;
    while i < s.len {
        let b = (load_byte(s.ptr + i) & 0xFF) as Byte;
        out.push_byte(b);
        i = i + 1;
    }
    out
}

// =============================================================================
// Array decoder — typed wrapper
// =============================================================================

fn decode_array_typed(
    slice: &ArenaSlice,
    arena: &SpindleArena,
    elem_oid: Int,
) -> Result<TypedValue, DbError> {
    let (hdr, elements) = decode_array(slice)?;
    if hdr.ndim > 1 {
        return Err(decode_fault(
            f"array: V0 supports 1-D only; got {hdr.ndim} dims"
        ));
    }
    // Build dimensions list (V0 = 0 or 1 dim).
    let mut dims: List<Int> = List.new();
    if hdr.ndim == 1 && hdr.dimensions.len() > 0 {
        dims.push(hdr.dimensions[0].length);
    }
    // Decode each element through encode_typed.
    let mut decoded: List<Maybe<TypedValue>> = List.with_capacity(elements.len());
    let mut i: Int = 0;
    while i < (elements.len() as Int) {
        match &elements[i] {
            None    => { decoded.push(None); }
            Some(s) => {
                let v = decode_typed(elem_oid, s, arena)?;
                decoded.push(Some(v));
            }
        }
        i = i + 1;
    }
    Ok(TvArray(TypedArray {
        element_oid: elem_oid,
        dimensions: dims,
        elements: decoded,
    }))
}

// =============================================================================
// Heap-byte bridge — connection-side `WireValue.bytes: List<Byte>`
// adapter
// =============================================================================
//
// `decode_typed` operates on `ArenaSlice` for the zero-copy hot path.
// connection.vr's existing `WireValue` wraps `List<Byte>` (heap),
// because the simple-query / extended-query reply parser
// materialises each column's bytes into an owned list before
// passing them up. To bridge: copy the bytes into the connection
// arena, get back an ArenaSlice, dispatch normally. Per-column
// arena cost is the column's wire bytes; for typical scalar
// columns (4–16 bytes) this is a noise-level allocation.
//
// Once connection.vr is itself migrated to arena-borrowed
// `ArenaWireValue` / `ArenaSlice` (a follow-up cross-cutting refactor
// per spec §4.2), `decode_typed_from_bytes` becomes redundant — every
// caller can use `decode_typed` directly. Until then this bridge
// is the single point where the heap → arena hand-off happens.

/// Decode a column's heap-owned `List<Byte>` bytes through the typed
/// dispatch. Same OID lookup as `decode_typed`; the only difference
/// is the input shape.
public fn decode_typed_from_bytes(
    oid: Int,
    bytes: &[Byte],
    arena: &mut SpindleArena,
) -> Result<TypedValue, DbError> {
    let n = bytes.len() as Int;
    if n == 0 {
        // Empty payload — only `text` / `bytea` interpret this as
        // legitimately-empty; everything else expects at least one
        // length-defined byte. Defer to the per-OID decoder via an
        // empty arena slice so it can decide.
        let empty_slice = ArenaSlice {
            ptr: 0,
            len: 0,
            generation: arena.generation(),
        };
        return decode_typed(oid, &empty_slice, arena);
    }
    // Allocate into the arena — pure raw_alloc, no zero-init
    // needed (we overwrite every byte).
    let dst = arena.alloc_bytes(n);
    if dst == 0 {
        return Err(decode_fault("decode_typed_from_bytes: arena exhausted".clone()));
    }
    let mut i: Int = 0;
    while i < n {
        let _ = store_byte(dst + i, (bytes[i] as Int) & 0xFF);
        i = i + 1;
    }
    let slice = ArenaSlice {
        ptr: dst,
        len: n,
        generation: arena.generation(),
    };
    decode_typed(oid, &slice, arena)
}

/// Encode a list of typed parameters into wire-ready
/// `List<Maybe<List<Byte>>>` for direct consumption by
/// `core.database.postgres.wire.frontend.bind`.
///
/// `param_oids[i]` is the OID for `params[i]`; `params[i] = None`
/// represents SQL NULL (preserved as `None` in the output so the
/// bind builder's length-prefix-of-(-1) path fires).
///
/// Ownership: a fresh `List<Byte>` per param so the result outlives
/// any temporary arena. The internal encoding uses an
/// `ArenaWireBuf` for the bump-allocated hot path; the final bytes
/// are copied out before the function returns.
public fn encode_params_for_bind(
    param_oids: &[Int],
    params: &List<Maybe<TypedValue>>,
    arena: &mut SpindleArena,
) -> Result<List<Maybe<List<Byte>>>, DbError> {
    let n_oids = param_oids.len() as Int;
    let n_params = params.len() as Int;
    if n_oids != n_params {
        return Err(encode_fault(
            f"encode_params_for_bind: oids.len() = {n_oids}, params.len() = {n_params}"
        ));
    }
    let mut out: List<Maybe<List<Byte>>> = List.with_capacity(n_params);
    let mut i: Int = 0;
    while i < n_params {
        match &params[i] {
            None => out.push(None),
            Some(value) => {
                // Snapshot the arena before encoding — if encoding
                // succeeds we copy the bytes out and rewind so the
                // arena bump pointer doesn't grow per-call.
                let scope = core.database.common.arena.ArenaScope.begin(
                    arena,
                    core.database.common.arena.ApQuery,
                );
                let mut buf = ArenaWireBuf.with_arena(arena, 32);
                match encode_typed(param_oids[i], value, &mut buf, arena) {
                    Ok(_) => {
                        // Copy bytes out of the arena into a heap-
                        // owned List<Byte>.
                        let slice = buf.as_slice();
                        let mut owned: List<Byte> = List.with_capacity(slice.len);
                        let mut k: Int = 0;
                        while k < slice.len {
                            owned.push(load_byte(slice.ptr + k) as Byte);
                            k = k + 1;
                        }
                        scope.discard(arena);    // rewind arena
                        out.push(Some(owned));
                    }
                    Err(e) => {
                        scope.discard(arena);
                        return Err(e);
                    }
                }
            }
        }
        i = i + 1;
    }
    Ok(out)
}

// =============================================================================
// Error helpers — same shape as codec.vr's local `decode_fault` /
// `encode_fault` so the surface is consistent.
// =============================================================================

fn decode_fault(reason: Text) -> DbError {
    DbError.DecodeFailed {
        fault: DecodeFault {
            column_index: -1,
            column_name: "".clone(),
            expected_type: "".clone(),
            found_oid: -1,
            detail: reason,
        },
    }
}

fn encode_fault(reason: Text) -> DbError {
    DbError.EncodeFailed {
        fault: EncodeFault {
            param_index: -1,
            type_name: "".clone(),
            reason: reason,
        },
    }
}
