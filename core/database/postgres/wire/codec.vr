// =============================================================================
// core/database/postgres/wire/codec.vr — Postgres binary codec
// =============================================================================
// Layer: 3 (Database — postgres adapter, wire layer)
// Spec: internal/specs/database.md §6.1.4 (binary codec register),
//       §18.5 (canonical OID table), §18.10 (codec test vectors).
// =============================================================================
//
// The single source of truth for Postgres binary wire-format type
// codecs. Two responsibilities:
//
//   1. Canonical OID table (`PG_TYPE_*` constants) for every
//      type Spindle understands, plus the inverse `Spindle TypeOid
//      ↔ Postgres pg_type.oid` mapping used by the sql# meta-fn.
//
//   2. Per-type binary encoders / decoders. Phase-2 set (bool,
//      int2/4/8, float4/8, text, bytea, uuid, date/time/timestamp[tz],
//      interval) lives here. Phase-3 set added in this commit:
//      jsonb (and the deprecated json alias), the four canonical
//      range types (int4range, numrange, tsrange, tstzrange), and
//      the generic array<T> wire-format framer.
//
// Composite and tsvector types are deferred — both depend on
// follow-up work (composite needs the field-walker integrated with
// the row-type resolver). Documented as TODO and explicitly listed
// in the per-type "supported" predicate below so a sql# query that
// touches them produces a clean compile-time "unsupported" error
// rather than silent decode garbage.
//
// NUMERIC: V0 ships decode + integer-only encode (see
// `decode_numeric` / `encode_numeric_from_int` below).
// `PgNumeric.to_text` renders byte-identically to PG's text format.
// Full text→binary encoding for arbitrary-precision NUMERIC literals
// awaits `core.text.numeric.decimal` (V1); until then non-integer
// parameter binds route through FmtText.
//
// All codec functions take an `ArenaWireBuf` for encoding (so the
// hot path is bump-allocated out of the connection arena, no heap)
// and an `ArenaSlice` for decoding (the source bytes already live
// in the arena, so decoders just navigate an offset).
// =============================================================================

module core.database.postgres.wire.codec;

mount core.*;
mount base.{Result, Ok, Err, Text, Maybe, None, Some};
mount collections.List;
mount core.intrinsics.runtime.mem_raw.{load_byte, store_byte};
mount core.database.common.error.{DbError, DecodeFault, EncodeFault};
mount core.database.common.arena.{SpindleArena};
mount core.database.common.types.{
    ArenaSlice, ArenaWireBuf, ArenaWireValue, ArenaWireRow,
    AvNull, AvPresent, WireFormat, FmtBinary,
};
mount core.encoding.jsonb.{
    decode as jsonb_decode_canonical,
    encode as jsonb_encode_canonical,
    JsonbValue, JsonbError, JSONB_VERSION_1,
    JbeEmpty, JbeUnsupportedVersion, JbeBadUtf8,
};

// -----------------------------------------------------------------------------
// Canonical Postgres OID table (per src/include/catalog/pg_type.dat).
// -----------------------------------------------------------------------------
//
// Phase-2 set — every adapter MUST support these (Spec §6.1.4 phase 2):

public const PG_TYPE_BOOL:        Int = 16;
public const PG_TYPE_BYTEA:       Int = 17;
public const PG_TYPE_CHAR:        Int = 18;       // single-byte ASCII char
public const PG_TYPE_NAME:        Int = 19;
public const PG_TYPE_INT8:        Int = 20;
public const PG_TYPE_INT2:        Int = 21;
public const PG_TYPE_INT4:        Int = 23;
public const PG_TYPE_TEXT:        Int = 25;
public const PG_TYPE_OID:         Int = 26;
public const PG_TYPE_JSON:        Int = 114;       // legacy text-json
public const PG_TYPE_FLOAT4:      Int = 700;
public const PG_TYPE_FLOAT8:      Int = 701;
public const PG_TYPE_BPCHAR:      Int = 1042;     // CHAR(N)
public const PG_TYPE_VARCHAR:     Int = 1043;
public const PG_TYPE_DATE:        Int = 1082;
public const PG_TYPE_TIME:        Int = 1083;
public const PG_TYPE_TIMESTAMP:   Int = 1114;     // naive
public const PG_TYPE_TIMESTAMPTZ: Int = 1184;     // UTC
public const PG_TYPE_INTERVAL:    Int = 1186;
public const PG_TYPE_NUMERIC:     Int = 1700;
public const PG_TYPE_UUID:        Int = 2950;

// Phase-3 set — added in this commit:
public const PG_TYPE_JSONB:       Int = 3802;
public const PG_TYPE_TSVECTOR:    Int = 3614;
public const PG_TYPE_INET:        Int = 869;
public const PG_TYPE_CIDR:        Int = 650;

// Range types — element OIDs are the corresponding scalar types.
public const PG_TYPE_INT4RANGE:   Int = 3904;
public const PG_TYPE_NUMRANGE:    Int = 3906;
public const PG_TYPE_TSRANGE:     Int = 3908;
public const PG_TYPE_TSTZRANGE:   Int = 3910;
public const PG_TYPE_INT8RANGE:   Int = 3926;
public const PG_TYPE_DATERANGE:   Int = 3912;

// Generic array sentinel — actual array OIDs are per-element-type
// (e.g. int4[] is OID 1007, text[] is 1009). The dispatch table maps
// each scalar OID to its array OID via `array_oid_for_element`.
public const PG_TYPE_ANYARRAY:    Int = 2277;

// Composite / record (anonymous row).
public const PG_TYPE_RECORD:      Int = 2249;

// pgvector — runtime-resolved per-database OID (not a fixed system
// OID; the sql# meta-fn looks it up from `pg_type` once per schema
// snapshot).
public const PG_TYPE_VECTOR_DYNAMIC: Int = -1;

// -----------------------------------------------------------------------------
// Array-OID lookup — element OID → array OID for the supported set.
// -----------------------------------------------------------------------------

/// For every scalar OID Spindle supports, return the OID of the
/// corresponding array type, or `-1` if Postgres does not register
/// an array type for it (e.g. record[] is dynamic). The sql#
/// meta-fn uses this to decide whether `${some_list}` parameter
/// can fold to a single array bind or must be expanded to a tuple.
public fn array_oid_for_element(oid: Int) -> Int {
    if      oid == PG_TYPE_BOOL        { 1000 }
    else if oid == PG_TYPE_BYTEA       { 1001 }
    else if oid == PG_TYPE_CHAR        { 1002 }
    else if oid == PG_TYPE_NAME        { 1003 }
    else if oid == PG_TYPE_INT8        { 1016 }
    else if oid == PG_TYPE_INT2        { 1005 }
    else if oid == PG_TYPE_INT4        { 1007 }
    else if oid == PG_TYPE_TEXT        { 1009 }
    else if oid == PG_TYPE_OID         { 1028 }
    else if oid == PG_TYPE_JSON        { 199 }
    else if oid == PG_TYPE_FLOAT4      { 1021 }
    else if oid == PG_TYPE_FLOAT8      { 1022 }
    else if oid == PG_TYPE_BPCHAR      { 1014 }
    else if oid == PG_TYPE_VARCHAR     { 1015 }
    else if oid == PG_TYPE_DATE        { 1182 }
    else if oid == PG_TYPE_TIME        { 1183 }
    else if oid == PG_TYPE_TIMESTAMP   { 1115 }
    else if oid == PG_TYPE_TIMESTAMPTZ { 1185 }
    else if oid == PG_TYPE_INTERVAL    { 1187 }
    else if oid == PG_TYPE_NUMERIC     { 1231 }
    else if oid == PG_TYPE_UUID        { 2951 }
    else if oid == PG_TYPE_JSONB       { 3807 }
    else if oid == PG_TYPE_TSVECTOR    { 3643 }
    else if oid == PG_TYPE_INET        { 1041 }
    else if oid == PG_TYPE_CIDR        { 651 }
    else if oid == PG_TYPE_INT4RANGE   { 3905 }
    else if oid == PG_TYPE_NUMRANGE    { 3907 }
    else if oid == PG_TYPE_TSRANGE     { 3909 }
    else if oid == PG_TYPE_TSTZRANGE   { 3911 }
    else if oid == PG_TYPE_INT8RANGE   { 3927 }
    else if oid == PG_TYPE_DATERANGE   { 3913 }
    else { -1 }
}

/// Reverse of `array_oid_for_element` — given an array OID,
/// return the OID of its element type. `None` if the OID is not
/// a known array OID.
public fn element_oid_for_array(array_oid: Int) -> Maybe<Int> {
    if      array_oid == 1000 { Some(PG_TYPE_BOOL) }
    else if array_oid == 1001 { Some(PG_TYPE_BYTEA) }
    else if array_oid == 1002 { Some(PG_TYPE_CHAR) }
    else if array_oid == 1003 { Some(PG_TYPE_NAME) }
    else if array_oid == 1016 { Some(PG_TYPE_INT8) }
    else if array_oid == 1005 { Some(PG_TYPE_INT2) }
    else if array_oid == 1007 { Some(PG_TYPE_INT4) }
    else if array_oid == 1009 { Some(PG_TYPE_TEXT) }
    else if array_oid == 1028 { Some(PG_TYPE_OID) }
    else if array_oid == 199  { Some(PG_TYPE_JSON) }
    else if array_oid == 1021 { Some(PG_TYPE_FLOAT4) }
    else if array_oid == 1022 { Some(PG_TYPE_FLOAT8) }
    else if array_oid == 1014 { Some(PG_TYPE_BPCHAR) }
    else if array_oid == 1015 { Some(PG_TYPE_VARCHAR) }
    else if array_oid == 1182 { Some(PG_TYPE_DATE) }
    else if array_oid == 1183 { Some(PG_TYPE_TIME) }
    else if array_oid == 1115 { Some(PG_TYPE_TIMESTAMP) }
    else if array_oid == 1185 { Some(PG_TYPE_TIMESTAMPTZ) }
    else if array_oid == 1187 { Some(PG_TYPE_INTERVAL) }
    else if array_oid == 1231 { Some(PG_TYPE_NUMERIC) }
    else if array_oid == 2951 { Some(PG_TYPE_UUID) }
    else if array_oid == 3807 { Some(PG_TYPE_JSONB) }
    else if array_oid == 3643 { Some(PG_TYPE_TSVECTOR) }
    else if array_oid == 1041 { Some(PG_TYPE_INET) }
    else if array_oid == 651  { Some(PG_TYPE_CIDR) }
    else if array_oid == 3905 { Some(PG_TYPE_INT4RANGE) }
    else if array_oid == 3907 { Some(PG_TYPE_NUMRANGE) }
    else if array_oid == 3909 { Some(PG_TYPE_TSRANGE) }
    else if array_oid == 3911 { Some(PG_TYPE_TSTZRANGE) }
    else if array_oid == 3927 { Some(PG_TYPE_INT8RANGE) }
    else if array_oid == 3913 { Some(PG_TYPE_DATERANGE) }
    else { None }
}

/// Returns the element OID for a range type, or `None` if the
/// OID is not a known range. PG range types:
///   int4range  → int4    (3904 → 23)
///   int8range  → int8    (3926 → 20)
///   numrange   → numeric (3906 → 1700)
///   tsrange    → timestamp  (3908 → 1114)
///   tstzrange  → timestamptz (3910 → 1184)
///   daterange  → date    (3912 → 1082)
public fn range_element_oid(range_oid: Int) -> Maybe<Int> {
    if      range_oid == PG_TYPE_INT4RANGE  { Some(PG_TYPE_INT4) }
    else if range_oid == PG_TYPE_INT8RANGE  { Some(PG_TYPE_INT8) }
    else if range_oid == PG_TYPE_NUMRANGE   { Some(PG_TYPE_NUMERIC) }
    else if range_oid == PG_TYPE_TSRANGE    { Some(PG_TYPE_TIMESTAMP) }
    else if range_oid == PG_TYPE_TSTZRANGE  { Some(PG_TYPE_TIMESTAMPTZ) }
    else if range_oid == PG_TYPE_DATERANGE  { Some(PG_TYPE_DATE) }
    else { None }
}

/// Returns true if the given OID has a binary codec implementation
/// in this module. Used by sql# at compile time to reject unsupported
/// types with a precise error instead of letting them through to a
/// runtime decode failure.
public fn supports_binary(oid: Int) -> Bool {
    if      oid == PG_TYPE_BOOL        { true }
    else if oid == PG_TYPE_BYTEA       { true }
    else if oid == PG_TYPE_INT2        { true }
    else if oid == PG_TYPE_INT4        { true }
    else if oid == PG_TYPE_INT8        { true }
    else if oid == PG_TYPE_FLOAT4      { true }
    else if oid == PG_TYPE_FLOAT8      { true }
    else if oid == PG_TYPE_TEXT        { true }
    else if oid == PG_TYPE_VARCHAR     { true }
    else if oid == PG_TYPE_BPCHAR      { true }
    else if oid == PG_TYPE_NAME        { true }
    else if oid == PG_TYPE_OID         { true }
    else if oid == PG_TYPE_UUID        { true }
    else if oid == PG_TYPE_JSON        { true }
    else if oid == PG_TYPE_JSONB       { true }
    else if oid == PG_TYPE_INT4RANGE   { true }
    else if oid == PG_TYPE_INT8RANGE   { true }
    else if oid == PG_TYPE_NUMRANGE    { true }
    else if oid == PG_TYPE_TSRANGE     { true }
    else if oid == PG_TYPE_TSTZRANGE   { true }
    else if oid == PG_TYPE_DATERANGE   { true }
    else if oid == PG_TYPE_DATE        { true }
    else if oid == PG_TYPE_TIME        { true }
    else if oid == PG_TYPE_TIMESTAMP   { true }
    else if oid == PG_TYPE_TIMESTAMPTZ { true }
    else if oid == PG_TYPE_INTERVAL    { true }
    else if oid == PG_TYPE_INET        { true }
    else if oid == PG_TYPE_CIDR        { true }
    else if oid == PG_TYPE_NUMERIC     { true }
    // tsvector and composite remain on the deferred list.
    else { false }
}

// -----------------------------------------------------------------------------
// Decode error helpers.
// -----------------------------------------------------------------------------

fn decode_fault(reason: Text) -> DbError {
    DbError.DecodeFailed {
        fault: DecodeFault {
            column_index: -1,
            column_name: "".clone(),
            expected_type: "".clone(),
            found_oid: -1,
            detail: reason,
        },
    }
}

fn encode_fault(reason: Text) -> DbError {
    DbError.EncodeFailed {
        fault: EncodeFault {
            param_index: -1,
            type_name: "".clone(),
            reason: reason,
        },
    }
}

// -----------------------------------------------------------------------------
// Slice helpers — read big-endian primitives directly out of an
// ArenaSlice. The slice's `ptr` already lives in the connection
// arena; reads are pure pointer math.
// -----------------------------------------------------------------------------

/// Extract one byte at `off`. Returns `None` if `off` is past the
/// slice's end.
fn slice_byte(s: &ArenaSlice, off: Int) -> Maybe<Int> {
    if off < 0 || off >= s.len {
        None
    } else {
        Some(load_byte(s.ptr + off) & 0xFF)
    }
}

/// Read a 16-bit big-endian integer at `off`. Returns the value or
/// a decode fault if the slice is too short.
fn slice_u16_be(s: &ArenaSlice, off: Int) -> Result<Int, DbError> {
    if off < 0 || off + 2 > s.len {
        return Err(decode_fault("short read: u16 BE".clone()));
    }
    let hi = load_byte(s.ptr + off)     & 0xFF;
    let lo = load_byte(s.ptr + off + 1) & 0xFF;
    Ok((hi << 8) | lo)
}

/// Read a 32-bit big-endian integer (signed two's-complement).
fn slice_i32_be(s: &ArenaSlice, off: Int) -> Result<Int, DbError> {
    if off < 0 || off + 4 > s.len {
        return Err(decode_fault("short read: i32 BE".clone()));
    }
    let b0 = (load_byte(s.ptr + off)     & 0xFF) << 24;
    let b1 = (load_byte(s.ptr + off + 1) & 0xFF) << 16;
    let b2 = (load_byte(s.ptr + off + 2) & 0xFF) << 8;
    let b3 = (load_byte(s.ptr + off + 3) & 0xFF);
    let u = b0 | b1 | b2 | b3;
    if (u & 0x8000_0000) != 0 {
        Ok(u | (-1 ^ 0xFFFF_FFFF))    // sign-extend
    } else {
        Ok(u)
    }
}

/// Read a 64-bit big-endian integer.
fn slice_i64_be(s: &ArenaSlice, off: Int) -> Result<Int, DbError> {
    if off < 0 || off + 8 > s.len {
        return Err(decode_fault("short read: i64 BE".clone()));
    }
    let mut v: Int = 0;
    let mut i: Int = 0;
    while i < 8 {
        v = (v << 8) | (load_byte(s.ptr + off + i) & 0xFF);
        i = i + 1;
    }
    Ok(v)
}

/// Carve a sub-slice. Generation is inherited — invalidates with the
/// parent.
fn subslice(parent: &ArenaSlice, off: Int, len: Int) -> Result<ArenaSlice, DbError> {
    if off < 0 || len < 0 || off + len > parent.len {
        return Err(decode_fault("subslice out of range".clone()));
    }
    Ok(ArenaSlice {
        ptr: parent.ptr + off,
        len: len,
        generation: parent.generation,
    })
}

// -----------------------------------------------------------------------------
// JSONB — wire format = single version byte (0x01) || UTF-8 JSON text
// -----------------------------------------------------------------------------
//
// Wire layout is identical between Postgres and SQLite (and any other
// engine that ships JSONB v1). The canonical, format-agnostic
// implementation lives in `core.encoding.jsonb`; this section is the
// thin Postgres-arena adapter that:
//
//   * Reads the version byte directly through `slice_byte` (saves
//     a round-trip materialisation when only the byte is needed).
//   * Slices the body in-arena (no copy) for callers that don't
//     need the parsed text.
//   * Defers everything else — `core.encoding.jsonb.decode` /
//     `encode` — to the canonical module so a bug-fix in one place
//     reaches every adapter automatically.

/// Postgres JSONB column value with arena-borrowed body. Distinct
/// from `core.encoding.jsonb.JsonbValue` (which owns its `Text`)
/// because the wire-decode hot path hands out an `ArenaSlice` to
/// avoid a per-row allocation. `into_canonical` materialises the
/// owned form when the caller needs cross-arena lifetime.
public type PgJsonb is {
    /// Version byte from the wire — should always be 1 for current
    /// Postgres releases. Carried so future-version JSONBs surface
    /// at the API boundary instead of corrupting decoded text.
    version: Int,
    /// UTF-8 JSON text (unparsed). Sliced from the arena, no copy.
    text: ArenaSlice,
};

implement PgJsonb {
    /// Materialise the JSON payload into a heap-owned `JsonbValue`
    /// from `core.encoding.jsonb`. Pays one Text allocation; useful
    /// when the caller wants to outlive the connection arena or
    /// pass the document into a JSON parser that expects a `Text`.
    /// Returns `None` if the underlying arena slice is stale.
    public fn into_canonical(&self, arena: &SpindleArena) -> Maybe<JsonbValue> {
        match self.text.to_owned(arena) {
            None       => None,
            Some(body) => match Text.from_utf8(body) {
                Ok(t)  => Some(JsonbValue { version: self.version, json_text: t }),
                Err(_) => None,
            }
        }
    }
}

/// Decode a JSONB column from an arena-borrowed slice. Surfaces
/// version mismatches and short reads as structured `DbError`. The
/// version-byte gate matches `core.encoding.jsonb.decode` byte-for-
/// byte — both paths are required to reject the same set of
/// payloads.
public fn decode_jsonb(slice: &ArenaSlice) -> Result<PgJsonb, DbError> {
    let version = match slice_byte(slice, 0) {
        Some(v) => v,
        None    => return Err(decode_fault("jsonb: empty payload".clone())),
    };
    if version != JSONB_VERSION_1 {
        return Err(decode_fault(f"jsonb: unsupported version {version}"));
    }
    let body = subslice(slice, 1, slice.len - 1)?;
    Ok(PgJsonb { version: version, text: body })
}

/// Encode a JSON text payload as JSONB binary directly into the
/// arena buffer. Writes the version byte (0x01) followed by the
/// UTF-8 text. Returns false on arena exhaustion.
///
/// For the heap-allocated path — emit a `List<Byte>` rather than
/// writing into an arena — call `core.encoding.jsonb.encode`
/// instead. Both paths produce byte-identical output by
/// construction; the difference is purely the destination buffer.
public fn encode_jsonb(buf: &mut ArenaWireBuf, arena: &mut SpindleArena, json_text: &Text) -> Bool {
    if !buf.put_u8(arena, JSONB_VERSION_1) { return false; }
    buf.put_bytes(arena, json_text.as_bytes())
}

/// JSON (legacy) decode — pure UTF-8 text, no version prefix. The
/// caller treats it as a text-typed column for downstream use.
public fn decode_json(slice: &ArenaSlice) -> Result<ArenaSlice, DbError> {
    Ok(ArenaSlice { ptr: slice.ptr, len: slice.len, generation: slice.generation })
}

public fn encode_json(buf: &mut ArenaWireBuf, arena: &mut SpindleArena, json_text: &Text) -> Bool {
    buf.put_bytes(arena, json_text.as_bytes())
}

// -----------------------------------------------------------------------------
// Range types — wire format = flags byte || (lower_len i32 || lower
//                                            payload)? || (upper_len i32 ||
//                                            upper payload)?
// -----------------------------------------------------------------------------
//
// Reference: src/backend/utils/adt/rangetypes.c
//
// Flags byte (one of, OR'd):
//   0x01  EMPTY
//   0x02  LB_INC      (lower bound inclusive)
//   0x04  UB_INC      (upper bound inclusive)
//   0x08  LB_INF      (lower bound = -infinity, no payload follows)
//   0x10  UB_INF      (upper bound = +infinity, no payload follows)
//   0x20  LB_NULL     (legacy; not used by current Postgres)
//   0x40  UB_NULL     (legacy)
//   0x80  CONTAIN_EMPTY (hint for multirange; ignored at this layer)

public const PG_RANGE_FLAG_EMPTY:  Int = 0x01;
public const PG_RANGE_FLAG_LB_INC: Int = 0x02;
public const PG_RANGE_FLAG_UB_INC: Int = 0x04;
public const PG_RANGE_FLAG_LB_INF: Int = 0x08;
public const PG_RANGE_FLAG_UB_INF: Int = 0x10;

/// Decoded range as raw element slices. The element type is decoded
/// further by the per-element codec (caller-chosen via the dispatch
/// in `connection.vr` once the row resolver knows the column's
/// element OID).
public type PgRange is {
    flags: Int,
    /// `Some` if the lower bound exists (not -infinity, not empty).
    lower: Maybe<ArenaSlice>,
    /// `Some` if the upper bound exists.
    upper: Maybe<ArenaSlice>,
};

implement PgRange {
    public fn is_empty(&self)      -> Bool { (self.flags & PG_RANGE_FLAG_EMPTY) != 0 }
    public fn lower_inclusive(&self) -> Bool { (self.flags & PG_RANGE_FLAG_LB_INC) != 0 }
    public fn upper_inclusive(&self) -> Bool { (self.flags & PG_RANGE_FLAG_UB_INC) != 0 }
    public fn lower_unbounded(&self) -> Bool { (self.flags & PG_RANGE_FLAG_LB_INF) != 0 }
    public fn upper_unbounded(&self) -> Bool { (self.flags & PG_RANGE_FLAG_UB_INF) != 0 }
}

public fn decode_range(slice: &ArenaSlice) -> Result<PgRange, DbError> {
    let flags = match slice_byte(slice, 0) {
        Some(v) => v,
        None    => return Err(decode_fault("range: empty payload".clone())),
    };
    if (flags & PG_RANGE_FLAG_EMPTY) != 0 {
        return Ok(PgRange { flags: flags, lower: None, upper: None });
    }
    let mut off: Int = 1;
    let lower = if (flags & PG_RANGE_FLAG_LB_INF) == 0 {
        let len = slice_i32_be(slice, off)?;
        off = off + 4;
        let body = subslice(slice, off, len)?;
        off = off + len;
        Some(body)
    } else {
        None
    };
    let upper = if (flags & PG_RANGE_FLAG_UB_INF) == 0 {
        let len = slice_i32_be(slice, off)?;
        off = off + 4;
        let body = subslice(slice, off, len)?;
        off = off + len;
        Some(body)
    } else {
        None
    };
    Ok(PgRange { flags: flags, lower: lower, upper: upper })
}

/// Encode a range value. `lower_payload` / `upper_payload` are the
/// already-encoded element bytes (caller passes `None` to mean
/// "infinity"). The empty range — `flags & PG_RANGE_FLAG_EMPTY` —
/// is encoded as a single byte and ignores the payload arguments.
public fn encode_range(
    buf: &mut ArenaWireBuf,
    arena: &mut SpindleArena,
    flags: Int,
    lower_payload: Maybe<&[Byte]>,
    upper_payload: Maybe<&[Byte]>,
) -> Bool {
    if !buf.put_u8(arena, flags & 0xFF) { return false; }
    if (flags & PG_RANGE_FLAG_EMPTY) != 0 {
        return true;
    }
    if (flags & PG_RANGE_FLAG_LB_INF) == 0 {
        match lower_payload {
            None    => return false,    // contract violation — caller forgot
            Some(b) => {
                if !buf.put_i32_be(arena, b.len() as Int) { return false; }
                if !buf.put_bytes(arena, b)               { return false; }
            }
        }
    }
    if (flags & PG_RANGE_FLAG_UB_INF) == 0 {
        match upper_payload {
            None    => return false,
            Some(b) => {
                if !buf.put_i32_be(arena, b.len() as Int) { return false; }
                if !buf.put_bytes(arena, b)               { return false; }
            }
        }
    }
    true
}

// -----------------------------------------------------------------------------
// Array — multi-dimensional binary wire format.
// -----------------------------------------------------------------------------
//
// Reference: src/backend/utils/adt/arrayfuncs.c, function
// `array_send`. Wire layout:
//
//   i32  ndim                — number of dimensions (0..6)
//   i32  flags               — currently only bit 0 = "has nulls"
//   i32  element_oid         — repeated below; required even though
//                              sender already knows it
//   for each dim:
//     i32  length            — count of elements in the dimension
//     i32  lower_bound       — typically 1 (Postgres array indices
//                              are 1-based)
//   for each element (linearised in row-major order):
//     i32  payload_len       — -1 for SQL NULL
//     bytes payload[payload_len]
//
// Empty arrays (`{}`) are sent with `ndim = 0, flags = 0,
// element_oid = T, no dim-headers, no element bytes`.

public const PG_ARRAY_MAX_NDIM: Int = 6;

public type PgArrayDim is { length: Int, lower_bound: Int };

public type PgArrayHeader is {
    ndim: Int,
    has_nulls: Bool,
    element_oid: Int,
    dimensions: List<PgArrayDim>,
};

/// Decode the array header + element index. Returns the metadata
/// plus a `List<Maybe<ArenaSlice>>` whose entries are the per-
/// element payload slices in row-major order. A `None` entry means
/// SQL NULL.
public fn decode_array(slice: &ArenaSlice) -> Result<(PgArrayHeader, List<Maybe<ArenaSlice>>), DbError> {
    let ndim = slice_i32_be(slice, 0)?;
    if ndim < 0 || ndim > PG_ARRAY_MAX_NDIM {
        return Err(decode_fault(f"array: ndim {ndim} out of range"));
    }
    let flags = slice_i32_be(slice, 4)?;
    let element_oid = slice_i32_be(slice, 8)?;
    let mut off: Int = 12;
    let mut dims: List<PgArrayDim> = List.new();
    let mut total: Int = if ndim == 0 { 0 } else { 1 };
    let mut i: Int = 0;
    while i < ndim {
        let length = slice_i32_be(slice, off)?;
        let lo     = slice_i32_be(slice, off + 4)?;
        if length < 0 {
            return Err(decode_fault(f"array: dim {i} negative length"));
        }
        dims.push(PgArrayDim { length: length, lower_bound: lo });
        total = total * length;
        off = off + 8;
        i = i + 1;
    }
    let mut elements: List<Maybe<ArenaSlice>> = List.new();
    let mut k: Int = 0;
    while k < total {
        let payload_len = slice_i32_be(slice, off)?;
        off = off + 4;
        if payload_len < 0 {
            elements.push(None);
        } else {
            let body = subslice(slice, off, payload_len)?;
            elements.push(Some(body));
            off = off + payload_len;
        }
        k = k + 1;
    }
    let hdr = PgArrayHeader {
        ndim: ndim,
        has_nulls: (flags & 1) != 0,
        element_oid: element_oid,
        dimensions: dims,
    };
    Ok((hdr, elements))
}

/// Encode a one-dimensional array (the common case). `elements` is
/// the per-element payload, with `None` for SQL NULL. Multi-
/// dimensional encode is a follow-up — most application code only
/// produces 1-D arrays anyway.
public fn encode_array_1d(
    buf: &mut ArenaWireBuf,
    arena: &mut SpindleArena,
    element_oid: Int,
    elements: &List<Maybe<&[Byte]>>,
) -> Bool {
    let n = elements.len() as Int;
    let mut has_nulls: Bool = false;
    let mut i: Int = 0;
    while i < n {
        match &elements[i] {
            None    => { has_nulls = true; }
            Some(_) => {}
        }
        i = i + 1;
    }
    let flags = if has_nulls { 1 } else { 0 };
    // Empty array shortcut — ndim = 0.
    if n == 0 {
        if !buf.put_i32_be(arena, 0)            { return false; }
        if !buf.put_i32_be(arena, flags)        { return false; }
        if !buf.put_i32_be(arena, element_oid)  { return false; }
        return true;
    }
    if !buf.put_i32_be(arena, 1)            { return false; }   // ndim
    if !buf.put_i32_be(arena, flags)        { return false; }
    if !buf.put_i32_be(arena, element_oid)  { return false; }
    if !buf.put_i32_be(arena, n)            { return false; }   // length
    if !buf.put_i32_be(arena, 1)            { return false; }   // lower_bound = 1
    let mut k: Int = 0;
    while k < n {
        match &elements[k] {
            None => {
                if !buf.put_i32_be(arena, -1) { return false; }
            }
            Some(b) => {
                if !buf.put_i32_be(arena, b.len() as Int) { return false; }
                if !buf.put_bytes(arena, b)               { return false; }
            }
        }
        k = k + 1;
    }
    true
}

// -----------------------------------------------------------------------------
// inet / cidr — RFC 7822 binary wire layout.
// -----------------------------------------------------------------------------
//
// Reference: src/backend/utils/adt/network.c, `network_send`.
// Wire layout for both inet and cidr (the OID distinguishes them):
//
//   u8 family          — 2 = AF_INET, 3 = AF_INET6 (PG-internal codes,
//                        NOT the system AF_* macros)
//   u8 prefix_bits     — 0..32 for v4, 0..128 for v6
//   u8 is_cidr         — 1 = strict CIDR (host bits zeroed),
//                        0 = inet (no requirement)
//   u8 nb              — number of address bytes (4 or 16)
//   u8 addr[nb]        — network byte order

public const PG_INET_FAMILY_V4: Int = 2;
public const PG_INET_FAMILY_V6: Int = 3;

public type PgInet is {
    family: Int,
    prefix_bits: Int,
    is_cidr: Bool,
    addr: ArenaSlice,        // 4 or 16 bytes; preserves alignment via arena
};

public fn decode_inet(slice: &ArenaSlice) -> Result<PgInet, DbError> {
    let family = match slice_byte(slice, 0) {
        Some(v) => v,
        None    => return Err(decode_fault("inet: short header".clone())),
    };
    let prefix = match slice_byte(slice, 1) {
        Some(v) => v,
        None    => return Err(decode_fault("inet: missing prefix".clone())),
    };
    let is_cidr = match slice_byte(slice, 2) {
        Some(v) => v != 0,
        None    => return Err(decode_fault("inet: missing is_cidr".clone())),
    };
    let nb = match slice_byte(slice, 3) {
        Some(v) => v,
        None    => return Err(decode_fault("inet: missing nb".clone())),
    };
    let expected_nb = if family == PG_INET_FAMILY_V4 { 4 }
                      else if family == PG_INET_FAMILY_V6 { 16 }
                      else { return Err(decode_fault(f"inet: unknown family {family}")); };
    if nb != expected_nb {
        return Err(decode_fault(f"inet: family/nb mismatch (family={family}, nb={nb})"));
    }
    let addr = subslice(slice, 4, nb)?;
    Ok(PgInet {
        family: family,
        prefix_bits: prefix,
        is_cidr: is_cidr,
        addr: addr,
    })
}

public fn encode_inet(
    buf: &mut ArenaWireBuf,
    arena: &mut SpindleArena,
    family: Int,
    prefix_bits: Int,
    is_cidr: Bool,
    addr: &[Byte],
) -> Bool {
    if family != PG_INET_FAMILY_V4 && family != PG_INET_FAMILY_V6 { return false; }
    let nb = addr.len() as Int;
    if family == PG_INET_FAMILY_V4 && nb != 4  { return false; }
    if family == PG_INET_FAMILY_V6 && nb != 16 { return false; }
    if prefix_bits < 0 { return false; }
    if family == PG_INET_FAMILY_V4 && prefix_bits > 32  { return false; }
    if family == PG_INET_FAMILY_V6 && prefix_bits > 128 { return false; }
    if !buf.put_u8(arena, family)                     { return false; }
    if !buf.put_u8(arena, prefix_bits)                { return false; }
    if !buf.put_u8(arena, if is_cidr { 1 } else { 0 }){ return false; }
    if !buf.put_u8(arena, nb)                         { return false; }
    buf.put_bytes(arena, addr)
}

// -----------------------------------------------------------------------------
// NUMERIC (PG_TYPE_NUMERIC, oid 1700) — arbitrary-precision decimal.
// -----------------------------------------------------------------------------
//
// Wire layout (src/backend/utils/adt/numeric.c, struct NumericVar):
//
//   ndigits  i16   number of base-10000 digits
//   weight   i16   weight of most-significant digit (in base-10000)
//   sign     u16   0x0000=POS, 0x4000=NEG, 0xC000=NaN, 0xD000=+Inf,
//                  0xF000=-Inf
//   dscale   u16   display scale (decimal digits after the point)
//   digits   u16 × ndigits   each digit ∈ [0, 9999], MS first
//
// V0 surface — DECODE only:
//   * `decode_numeric(slice) -> Result<PgNumeric, DbError>` — header
//     + digit-array reader. Validates digit range + special-value sign
//     codes; rejects malformed payloads with a precise DbError.
//   * `PgNumeric.to_text(&self) -> Text` — render as decimal string
//     matching PG's text-format output. Produces:
//       - "NaN" / "Infinity" / "-Infinity" for special sign codes
//       - integer-only output when dscale == 0 (e.g. "12345")
//       - dscale-trailing-zero-padded fractional part (matches the
//         server's text representation byte-for-byte)
//
// ENCODE V0 (encode_numeric_from_int): emits the wire form for a
// signed-integer value, sufficient for parameter binding via
// integer-typed arguments. Full text→numeric encoding (parsing
// arbitrary decimal literals) is V1 — depends on `core.text.numeric.
// decimal` which doesn't exist yet. Until then, callers that need
// to bind a non-integer NUMERIC parameter route through PG's text
// format (FmtText) at the parameter-binding layer instead.

public const PG_NUMERIC_POS:  Int = 0x0000;
public const PG_NUMERIC_NEG:  Int = 0x4000;
public const PG_NUMERIC_NAN:  Int = 0xC000;
public const PG_NUMERIC_PINF: Int = 0xD000;
public const PG_NUMERIC_NINF: Int = 0xF000;

/// Postgres NUMERIC value as a base-10000 digit array.
///
/// Wire-format-faithful: preserves `weight` + `dscale` exactly so a
/// round-trip decode/encode produces byte-identical output. Arithmetic
/// on `PgNumeric` is intentionally NOT exposed at this layer — it
/// belongs in `core.text.numeric.decimal` (V1). Callers needing the
/// value for display use `to_text`; callers needing a Float fallback
/// can parse `to_text` via `Text.parse_float`.
public type PgNumeric is {
    /// Number of base-10000 digits in `digits` (0..=32767).
    ndigits: Int,
    /// Weight of the most-significant digit (in base-10000 units).
    /// E.g. weight=2 means digit_0 represents the 10^8 column.
    /// May be negative (e.g. 0.0001 → weight=-1).
    weight: Int,
    /// Sign code: PG_NUMERIC_{POS,NEG,NAN,PINF,NINF}.
    sign: Int,
    /// Display scale — number of decimal digits after the dot.
    /// Forced to 0 for special values (NaN/±Inf).
    dscale: Int,
    /// Base-10000 digits, most significant first.  Each digit ∈ [0, 9999].
    digits: List<Int>,
};

implement PgNumeric {
    public fn is_nan(&self)      -> Bool { self.sign == PG_NUMERIC_NAN  }
    public fn is_pos_inf(&self)  -> Bool { self.sign == PG_NUMERIC_PINF }
    public fn is_neg_inf(&self)  -> Bool { self.sign == PG_NUMERIC_NINF }
    public fn is_negative(&self) -> Bool { self.sign == PG_NUMERIC_NEG  }
    public fn is_zero(&self)     -> Bool {
        self.ndigits == 0 && (self.sign == PG_NUMERIC_POS || self.sign == PG_NUMERIC_NEG)
    }

    /// Render the value as a decimal string, byte-identical to PG's
    /// own text-format output. Special-case sign codes ⇒ "NaN" /
    /// "Infinity" / "-Infinity". Otherwise:
    ///   * Negative ⇒ leading '-'
    ///   * Integer part = digits 0..=weight (or "0" if weight < 0)
    ///   * Fractional part = `dscale` digits drawn from digits at
    ///     positions weight+1 onward, with leading zeros for missing
    ///     positions, trailing-zero-padded to `dscale` width.
    public fn to_text(&self) -> Text {
        if self.is_nan()     { return "NaN".clone(); }
        if self.is_pos_inf() { return "Infinity".clone(); }
        if self.is_neg_inf() { return "-Infinity".clone(); }

        // Zero: emit "0" or "0.000…0" depending on dscale.
        if self.is_zero() {
            if self.dscale <= 0 { return "0".clone(); }
            let mut s = "0.".clone();
            let mut k = 0;
            while k < self.dscale {
                s = s + "0";
                k = k + 1;
            }
            return s;
        }

        let mut out = "".clone();
        if self.is_negative() { out = out + "-"; }

        // ---- Integer part ----
        if self.weight < 0 {
            out = out + "0";
        } else {
            let mut d = 0;
            while d <= self.weight {
                let digit = if d < self.ndigits { self.digits[d] } else { 0 };
                if d == 0 {
                    // No leading zeros on the most-significant digit.
                    out = out + decimal4(digit, false);
                } else {
                    out = out + decimal4(digit, true);
                }
                d = d + 1;
            }
        }

        // ---- Fractional part ----
        if self.dscale <= 0 { return out; }
        out = out + ".";

        // Walk dscale positions; each position needs (dscale-pos)/4
        // digits drawn from `digits[weight+1 + (pos/4)]`. We render
        // 4 chars at a time, then trim/pad to exactly dscale chars.
        let frac_capacity_groups = (self.dscale + 3) / 4;
        let mut frac = "".clone();
        let mut g = 0;
        while g < frac_capacity_groups {
            let idx = self.weight + 1 + g;
            let digit = if idx >= 0 && idx < self.ndigits { self.digits[idx] } else { 0 };
            frac = frac + decimal4(digit, true);
            g = g + 1;
        }

        // Trim/pad frac to exactly dscale characters.
        let frac_len = frac.len();
        if frac_len >= self.dscale {
            out = out + frac.substring(0, self.dscale);
        } else {
            out = out + frac;
            let mut pad = self.dscale - frac_len;
            while pad > 0 {
                out = out + "0";
                pad = pad - 1;
            }
        }
        out
    }
}

/// Render a base-10000 digit (0..=9999) as decimal, optionally with
/// leading zeros to width 4 (used for non-leading positions).
fn decimal4(d: Int, pad: Bool) -> Text {
    let v = if d < 0 { 0 } else if d > 9999 { 9999 } else { d };
    if !pad {
        // Most-significant digit: no leading zeros.
        if v == 0       { return "0".clone(); }
        if v < 10       { return Text.from_int(v); }
        if v < 100      { return Text.from_int(v); }
        if v < 1000     { return Text.from_int(v); }
        Text.from_int(v)
    } else {
        // Non-leading: zero-pad to 4.
        let mut s = "".clone();
        if v < 1000 { s = s + "0"; }
        if v < 100  { s = s + "0"; }
        if v < 10   { s = s + "0"; }
        s + Text.from_int(v)
    }
}

/// Decode a NUMERIC binary payload from an arena-borrowed slice.
/// Validates header consistency (sign code in known set, digit count
/// matches payload length, individual digits in [0, 9999]); surfaces
/// malformed payloads as structured `DbError`. Special values (NaN /
/// ±Inf) carry zero digits per PG convention — callers MUST consult
/// `is_nan` / `is_pos_inf` / `is_neg_inf` before interpreting digits.
public fn decode_numeric(slice: &ArenaSlice) -> Result<PgNumeric, DbError> {
    if slice.len < 8 {
        return Err(decode_fault("numeric: short header (need 8 bytes)".clone()));
    }
    let ndigits = slice_i16_be(slice, 0)?;
    let weight  = slice_i16_be(slice, 2)?;
    let sign    = slice_u16_be(slice, 4)?;
    let dscale  = slice_u16_be(slice, 6)?;

    // Validate sign — must be one of the known codes.
    if sign != PG_NUMERIC_POS && sign != PG_NUMERIC_NEG
       && sign != PG_NUMERIC_NAN && sign != PG_NUMERIC_PINF
       && sign != PG_NUMERIC_NINF {
        return Err(decode_fault(f"numeric: unknown sign code 0x{sign}"));
    }

    // Special values carry zero digits.
    let is_special = sign == PG_NUMERIC_NAN || sign == PG_NUMERIC_PINF || sign == PG_NUMERIC_NINF;

    if ndigits < 0 {
        return Err(decode_fault(f"numeric: negative ndigits {ndigits}"));
    }
    if is_special && ndigits != 0 {
        return Err(decode_fault(f"numeric: special value with non-zero ndigits {ndigits}"));
    }

    // Payload bytes = 8 + ndigits * 2.
    let need = 8 + ndigits * 2;
    if slice.len < need {
        return Err(decode_fault(f"numeric: payload too short (have {slice.len}, need {need})"));
    }

    let mut digits: List<Int> = List.new();
    let mut i: Int = 0;
    while i < ndigits {
        let d = slice_u16_be(slice, 8 + i * 2)?;
        if d < 0 || d > 9999 {
            return Err(decode_fault(f"numeric: digit out of range [0,9999]: {d}"));
        }
        digits.push(d);
        i = i + 1;
    }

    Ok(PgNumeric {
        ndigits: ndigits,
        weight: weight,
        sign: sign,
        dscale: dscale,
        digits: digits,
    })
}

/// Read a 16-bit big-endian SIGNED integer at `off`.  Returns the
/// sign-extended value or a decode fault if the slice is too short.
fn slice_i16_be(s: &ArenaSlice, off: Int) -> Result<Int, DbError> {
    let raw = slice_u16_be(s, off)?;
    // Sign-extend from 16 bits.
    if raw >= 0x8000 { Ok(raw - 0x10000) } else { Ok(raw) }
}

/// Encode an i64 value as a NUMERIC binary payload. Builds the
/// minimal base-10000 digit representation, computes weight + dscale
/// (always 0 for an integer), writes the 8-byte header followed by
/// the digit array. Returns false on arena exhaustion.
///
/// V0 boundary: integer-only encode. For non-integer or arbitrary-
/// precision NUMERIC parameters, route through the text-format path
/// (FmtText) at the parameter-binding layer until `core.text.numeric.
/// decimal` exists (V1).
public fn encode_numeric_from_int(buf: &mut ArenaWireBuf, arena: &mut SpindleArena, value: Int) -> Bool {
    // Special-case zero: ndigits=0, weight=0, sign=POS, dscale=0.
    if value == 0 {
        if !buf.put_u16_be(arena, 0)              { return false; }   // ndigits
        if !buf.put_u16_be(arena, 0)              { return false; }   // weight
        if !buf.put_u16_be(arena, PG_NUMERIC_POS) { return false; }   // sign
        if !buf.put_u16_be(arena, 0)              { return false; }   // dscale
        return true;
    }

    let sign_code = if value < 0 { PG_NUMERIC_NEG } else { PG_NUMERIC_POS };
    let mut abs_v: Int = if value < 0 { -value } else { value };

    // Decompose abs_v into base-10000 digits, least significant first.
    let mut rev_digits: List<Int> = List.new();
    while abs_v > 0 {
        rev_digits.push(abs_v % 10000);
        abs_v = abs_v / 10000;
    }

    // Reverse to most-significant first.
    let mut digits: List<Int> = List.new();
    let mut i: Int = (rev_digits.len() as Int) - 1;
    while i >= 0 {
        digits.push(rev_digits[i]);
        i = i - 1;
    }

    let ndigits = digits.len() as Int;
    let weight = ndigits - 1;  // Most-significant digit's base-10000 weight.

    if !buf.put_u16_be(arena, ndigits)   { return false; }
    if !buf.put_u16_be(arena, weight)    { return false; }
    if !buf.put_u16_be(arena, sign_code) { return false; }
    if !buf.put_u16_be(arena, 0)         { return false; }  // dscale=0 for integer

    let mut k: Int = 0;
    while k < ndigits {
        if !buf.put_u16_be(arena, digits[k]) { return false; }
        k = k + 1;
    }
    true
}
