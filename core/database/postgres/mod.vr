// =============================================================================
// core/database/postgres/mod.vr — Spindle Postgres adapter (pure-Verum)
// =============================================================================
// Layer: 3 (Database — postgres adapter)
// Spec: internal/specs/database.md §6.1
// Codename: spindle (postgres back end)
// =============================================================================
//

// Pure-Verum Postgres v3 protocol implementation. No FFI to libpq.
//

//  wire.{frame,frontend,backend} — v3 message framing + taxonomy
//  auth.scram — SCRAM-SHA-256 client state machine
//  (md5 / password / trust modes are
//  compile-time-rejected per the spec)
//  error — Postgres ErrorResponse → DbError
//  config — PgConfig (host / port / user /
//  database / TLS mode / app_name)
//  connection — Startup handshake + simple-query
//  protocol over the wire layer
//

// The L4-L9 stack (extended protocol, pipelining, pool, NOTIFY,
// COPY, logical replication) lands incrementally — see T9.
// =============================================================================

@arch_module(
    exposes: [Capability.Read(ResourceTag.Database("*")), Capability.Write(ResourceTag.Database("*")), Capability.Persist(PersistenceMedium.DatabaseMedium("*")), Capability.Network(NetProtocol.Tcp, NetDirection.Bidirectional)],
    requires: [Capability.Exec(ExecTarget.Syscall(0)), Capability.Network(NetProtocol.Tcp, NetDirection.Bidirectional)],
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LCls,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.database.postgres;

public module pg_stream;
public module wire;
public module auth;
public module error;
public module config;
public module connection;
public module adapter;
public module stmt_cache;
public module extended;
public module pipeline;
public module notify;
public module pool;
public module typed_database;
public module introspect;
public module transaction;
public module copy;
public module replication;
public module pgoutput;
public module base_backup;
public module async_connection;
public module async_pool;
public module async_transaction;
public module async_typed_database;
public module async_copy;
public module async_replication;
public module async_base_backup;
public module async_pgoutput;
public module async_pgoutput_buffered;
public module async_pgoutput_typed;
public module async_listener;
public module composite_registry;
public module typed_row;
public module pg_stmt_cache;
public module pg_prepared_session;

