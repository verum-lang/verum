// =============================================================================
// core/database/postgres/mod.vr — Spindle Postgres adapter (pure-Verum)
// =============================================================================
// Layer: 3 (Database — postgres adapter)
// Spec: internal/specs/database.md §6.1
// Codename: spindle (postgres back end)
// =============================================================================
//
// Pure-Verum Postgres v3 protocol implementation. No FFI to libpq.
//
//   wire.{frame,frontend,backend}    — v3 message framing + taxonomy
//   auth.scram                       — SCRAM-SHA-256 client state machine
//                                      (md5 / password / trust modes are
//                                      compile-time-rejected per the spec)
//   error                            — Postgres ErrorResponse → DbError
//   config                           — PgConfig (host / port / user /
//                                      database / TLS mode / app_name)
//   connection                       — Startup handshake + simple-query
//                                      protocol over the wire layer
//
// The L4-L9 stack (extended protocol, pipelining, pool, NOTIFY,
// COPY, logical replication) lands incrementally — see T9.
// =============================================================================

module core.database.postgres;

public module wire;
public module auth;
public module error;
public module config;
public module connection;
public module adapter;
public module stmt_cache;
public module extended;
public module pool;
public module introspect;
public module transaction;
public module copy;

// Re-exports — keep the user-facing surface compact.
public mount .config.{
    PgConfig, PgTlsMode, PtmDisable, PtmVerifyFull,
};
public mount .connection.{
    PgConnection, PgConnState, SimpleQueryResult,
    PcsConnecting, PcsAuthenticating, PcsReady, PcsBusy, PcsClosed, PcsFailed,
    connect,
    cancel_running_query_at,
};
public mount .wire.backend.{NotificationResponse, CopyResponse, CopyFormat, CfText, CfBinary};
public mount .copy.{
    CopyInBuilder, CopyOutBuilder,
    copy_in, copy_out,
};
public mount .adapter.PgAdapter;
public mount .error.dberr_from_pg;
public mount .stmt_cache.{StmtCache, CacheEntry};
public mount .extended.{
    ExtendedQueryResult, PipelineEntry, PipelineBatch, ExtendedResultBuilder,
    build_parse_bind_execute, build_bind_execute,
};
public mount .pool.PgPool;
public mount .introspect.introspect as introspect_postgres;
public mount .transaction.{
    PgTransaction, PgTxKind, PgTxOpts, PgAccessMode, PgDeferrable,
    PgTkReadCommitted, PgTkRepeatableRead, PgTkSerializable,
    PgAmReadWrite, PgAmReadOnly,
    PgDfNone, PgDfDeferrable, PgDfNotDeferrable,
    pg_tx_opts_default,
    begin_tx, begin_tx_with,
    begin_tx_read_committed, begin_tx_serializable, begin_tx_read_only,
    commit_tx, rollback_tx,
    savepoint, release_savepoint, rollback_to_savepoint,
    with_transaction, with_transaction_serializable,
};
