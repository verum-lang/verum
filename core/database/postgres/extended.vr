// =============================================================================
// core/database/postgres/extended.vr — Extended-protocol query driver
// =============================================================================
// Spec: internal/specs/database.md §6.1, postgresql.org/docs/16/protocol-flow.html
//

// Extended protocol per Sync round:
//

//  client → Parse + Bind + Describe + Execute + Sync (one shot)
//  client → [Parse +] Bind + Execute + ... [+ Bind + Execute] + Sync (pipelined)
//  server ← ParseComplete + BindComplete + RowDescription +
//  DataRow* + CommandComplete + ReadyForQuery
//

// On a hit in `StmtCache` we skip Parse and emit only Bind + Execute
// + Sync. The Spindle pipelining model is implicit — `pipeline` lets
// the caller queue a batch of (sql, params) pairs and flushes them
// behind a single Sync at the end.
// =============================================================================

@arch_module(
    exposes: [Capability.Read(ResourceTag.Database("*")), Capability.Write(ResourceTag.Database("*")), Capability.Persist(PersistenceMedium.DatabaseMedium("*")), Capability.Network(NetProtocol.Tcp, NetDirection.Bidirectional)],
    requires: [Capability.Exec(ExecTarget.Syscall(0)), Capability.Network(NetProtocol.Tcp, NetDirection.Bidirectional)],
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LCls,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.database.postgres.extended;

mount core.*;
mount base.{Result, Ok, Err, Text, Maybe, None, Some};
mount collections.List;
mount core.database.common.error.{DbError, AdapterId, AdapterSpecific};
mount core.database.common.types.{WireValue, WvNull, WvPresent};
mount core.database.common.arena.SpindleArena;
mount core.database.postgres.wire.typed.{
    TypedValue, encode_params_for_bind, decode_typed_from_bytes,
};

mount core.database.postgres.wire.frontend.{
    parse, bind, describe_statement, execute, sync, close_statement,
};
mount core.database.postgres.wire.backend.{
    BackendMessage,
    BmRowDescription, BmDataRow, BmCommandComplete, BmEmptyQueryResponse,
    BmError, BmNotice, BmParseComplete, BmBindComplete, BmCloseComplete,
    BmNoData, BmPortalSuspend, BmReadyForQuery, BmParameterStatus, BmAuth,
    BmBackendKeyData, BmUnknown,
    RowDescription, DataRow, CommandComplete, Diagnostic, ColumnDesc,
    TxStatus,
    BackendMessageArena,
    BmaRowDescription, BmaDataRow, BmaCommandComplete, BmaEmptyQueryResponse,
    BmaError, BmaNotice, BmaParseComplete, BmaBindComplete, BmaCloseComplete,
    BmaNoData, BmaPortalSuspend, BmaReadyForQuery, BmaParameterStatus, BmaAuth,
    BmaBackendKeyData, BmaUnknown,
};
mount core.database.common.types.{ArenaWireRow};

// -----------------------------------------------------------------------------
// Public types — the result of one extended-protocol round-trip.
// -----------------------------------------------------------------------------

public type ExtendedQueryResult is {
    command_tag: Text,
    row_description: Maybe<RowDescription>,
    rows: List<List<WireValue>>,
};

public type PipelineEntry is {
    /// Pre-built Parse payload bytes — empty if the entry is a
    /// cache-hit re-bind.
    parse_bytes: List<Byte>,
    bind_bytes: List<Byte>,
    execute_bytes: List<Byte>,
};

public type PipelineBatch is {
    entries: List<PipelineEntry>,
    /// Trailing Sync — one per batch.
    sync_bytes: List<Byte>,
};

implement PipelineBatch {
    public fn new() -> PipelineBatch {
        PipelineBatch { entries: List.new(), sync_bytes: core.database.postgres.wire.frontend.sync() }
    }

    /// Append a Parse + Bind + Execute triple. Pass `parse_bytes` empty
    /// (List.new()) for a cache-hit re-bind.
    public fn push(
        &mut self,
        parse_bytes: List<Byte>,
        bind_bytes: List<Byte>,
        execute_bytes: List<Byte>,
    ) {
        self.entries.push(PipelineEntry {
            parse_bytes: parse_bytes,
            bind_bytes: bind_bytes,
            execute_bytes: execute_bytes,
        });
    }

    /// Flatten into a single byte buffer ready to be written to the
    /// connection in one syscall (Postgres allows this — server reads
    /// all messages up to the next Sync before responding).
    public fn flatten(&self) -> List<Byte> {
        let mut out: List<Byte> = List.new();
        let mut i: Int = 0;
        while i < self.entries.len() as Int {
            let e = &self.entries[i];
            append_all(&mut out, e.parse_bytes.as_slice());
            append_all(&mut out, e.bind_bytes.as_slice());
            append_all(&mut out, e.execute_bytes.as_slice());
            i = i + 1;
        }
        append_all(&mut out, self.sync_bytes.as_slice());
        out
    }

    public fn len(&self) -> Int { self.entries.len() as Int }
}

// -----------------------------------------------------------------------------
// Build helpers — assemble the bytes for one extended-protocol round.
// -----------------------------------------------------------------------------

/// Build the bytes to send for `execute_named` against an *uncached*
/// statement. Caller writes the whole buffer to the connection then
/// reads ParseComplete / BindComplete / [RowDescription] / DataRow* /
/// CommandComplete / ReadyForQuery.
public fn build_parse_bind_execute(
    stmt_name: &Text,
    sql: &Text,
    param_oids: &[Int],
    param_formats: &[Int],
    params: &List<Maybe<List<Byte>>>,
    result_formats: &[Int],
    portal: &Text,
    max_rows: Int,
) -> List<Byte> {
    // Fully-qualified — bare `parse` collides with 1-arg parse from
    // other modules under AOT lookup (task #11).
    let p = core.database.postgres.wire.frontend.parse(stmt_name, sql, param_oids);
    let b = core.database.postgres.wire.frontend.bind(portal, stmt_name, param_formats, params, result_formats);
    let e = core.database.postgres.wire.frontend.execute(portal, max_rows);
    let s = core.database.postgres.wire.frontend.sync();
    let mut out: List<Byte> = List.new();
    append_all(&mut out, p.as_slice());
    append_all(&mut out, b.as_slice());
    append_all(&mut out, e.as_slice());
    append_all(&mut out, s.as_slice());
    out
}

/// Cache-hit re-bind: skip Parse, emit only Bind + Execute + Sync.
public fn build_bind_execute(
    stmt_name: &Text,
    param_formats: &[Int],
    params: &List<Maybe<List<Byte>>>,
    result_formats: &[Int],
    portal: &Text,
    max_rows: Int,
) -> List<Byte> {
    let b = core.database.postgres.wire.frontend.bind(portal, stmt_name, param_formats, params, result_formats);
    let e = core.database.postgres.wire.frontend.execute(portal, max_rows);
    let s = core.database.postgres.wire.frontend.sync();
    let mut out: List<Byte> = List.new();
    append_all(&mut out, b.as_slice());
    append_all(&mut out, e.as_slice());
    append_all(&mut out, s.as_slice());
    out
}

// -----------------------------------------------------------------------------
// Reply consumer — turn a stream of BackendMessage into ExtendedQueryResult.
// -----------------------------------------------------------------------------

public type ExtendedResultBuilder is {
    rows: List<List<WireValue>>,
    row_desc: Maybe<RowDescription>,
    command_tag: Text,
    diagnostic: Maybe<Diagnostic>,
    finished: Bool,
};

implement ExtendedResultBuilder {
    public fn new() -> ExtendedResultBuilder {
        ExtendedResultBuilder {
            rows: List.new(),
            row_desc: None,
            command_tag: "".clone(),
            diagnostic: None,
            finished: false,
        }
    }

    /// Drive one backend message into the builder. Returns `true` when
    /// the round is complete (ReadyForQuery seen).
    public fn step(&mut self, msg: BackendMessage) -> Bool {
        match msg {
            BmParseComplete    => {}
            BmBindComplete     => {}
            BmCloseComplete    => {}
            BmNoData           => {}
            BmPortalSuspend    => {
                // Suspended mid-execute (max_rows reached). Caller has
                // to issue a fresh Execute to keep going; we report the
                // current set as a partial result.
                self.command_tag = "PORTAL_SUSPEND".clone();
            }
            BmRowDescription(rd) => { self.row_desc = Some(rd); }
            BmDataRow(dr)        => { self.rows.push(dr.values); }
            BmCommandComplete(cc) => {
                if self.command_tag.len() == 0 { self.command_tag = cc.tag; }
            }
            BmEmptyQueryResponse => {
                if self.command_tag.len() == 0 { self.command_tag = "EMPTY".clone(); }
            }
            BmError(d) => { self.diagnostic = Some(d); }
            BmNotice(_) => {}
            BmReadyForQuery(_) => { self.finished = true; }
            BmParameterStatus(_) => {}
            BmBackendKeyData(_) => {}
            BmAuth(_) => {}
            BmUnknown { .. } => {}
        }
        self.finished
    }

    /// Finalise. Returns Err(DbError) when the round contained an
    /// ErrorResponse; otherwise the populated result.
    public fn finish(self, error_translator: fn(Diagnostic) -> DbError)
        -> Result<ExtendedQueryResult, DbError>
    {
        match self.diagnostic {
            Some(d) => Err(error_translator(d)),
            None    => Ok(ExtendedQueryResult {
                command_tag: self.command_tag,
                row_description: self.row_desc,
                rows: self.rows,
            }),
        }
    }
}

// =============================================================================
// Arena-backed extended-query result + builder — spec §4.2 mirror
// =============================================================================
//
// Same finite-state shape as `ExtendedResultBuilder`, but `step`
// consumes `BackendMessageArena` so DataRow payloads stay zero-copy
// (slices into the connection arena). Lifetime contract identical
// to `simple_query_arena`: rows are valid until the next
// `arena.reset()`.

public type ExtendedQueryArenaResult is {
    command_tag: Text,
    row_description: Maybe<RowDescription>,
    rows: List<ArenaWireRow>,
};

public type ExtendedResultArenaBuilder is {
    rows: List<ArenaWireRow>,
    row_desc: Maybe<RowDescription>,
    command_tag: Text,
    diagnostic: Maybe<Diagnostic>,
    finished: Bool,
};

implement ExtendedResultArenaBuilder {
    public fn new() -> ExtendedResultArenaBuilder {
        ExtendedResultArenaBuilder {
            rows: List.new(),
            row_desc: None,
            command_tag: "".clone(),
            diagnostic: None,
            finished: false,
        }
    }

    /// Drive one arena-decoded backend message into the builder.
    /// Returns `true` once ReadyForQuery is observed.
    public fn step(&mut self, msg: BackendMessageArena) -> Bool {
        match msg {
            BmaParseComplete    => {}
            BmaBindComplete     => {}
            BmaCloseComplete    => {}
            BmaNoData           => {}
            BmaPortalSuspend    => {
                self.command_tag = "PORTAL_SUSPEND".clone();
            }
            BmaRowDescription(rd) => { self.row_desc = Some(rd); }
            BmaDataRow(arow)      => { self.rows.push(arow); }
            BmaCommandComplete(cc) => {
                if self.command_tag.len() == 0 { self.command_tag = cc.tag; }
            }
            BmaEmptyQueryResponse => {
                if self.command_tag.len() == 0 { self.command_tag = "EMPTY".clone(); }
            }
            BmaError(d) => { self.diagnostic = Some(d); }
            BmaNotice(_) => {}
            BmaReadyForQuery(_) => { self.finished = true; }
            BmaParameterStatus(_) => {}
            BmaBackendKeyData(_) => {}
            BmaAuth(_) => {}
            BmaUnknown { .. } => {}
        }
        self.finished
    }

    public fn finish(self, error_translator: fn(Diagnostic) -> DbError)
        -> Result<ExtendedQueryArenaResult, DbError>
    {
        match self.diagnostic {
            Some(d) => Err(error_translator(d)),
            None    => Ok(ExtendedQueryArenaResult {
                command_tag: self.command_tag,
                row_description: self.row_desc,
                rows: self.rows,
            }),
        }
    }
}

// -----------------------------------------------------------------------------
// Helpers
// -----------------------------------------------------------------------------

fn append_all(dst: &mut List<Byte>, src: &[Byte]) {
    let mut i = 0;
    while i < src.len() {
        dst.push(src[i]);
        i = i + 1;
    }
}

// =============================================================================
// Typed parameter / row helpers
// =============================================================================
//
// Front-door for callers that have a `List<Maybe<TypedValue>>` of
// params + the corresponding param-OID list (typically resolved
// from `Parse`'s `param_oids` or a `PreparedQuery<R, P>`'s
// declared shape). Wraps the bind-frame builder so the caller
// only sees typed values, never raw byte buffers.

/// Build the bind-frame bytes for a typed call. Encodes every
/// non-NULL param via the OID-dispatched binary encoder
/// (`encode_typed`), then composes the `Bind` packet with `binary`
/// param formats and `binary` result formats.
///
/// `arena` is borrowed for the duration of the encoding hot path —
/// each param is bump-allocated, copied out into a heap
/// `List<Byte>` the wire frame consumes, and the arena is rewound
/// before returning. Net per-call arena residency: zero past the
/// returned bytes.
public fn build_bind_typed(
    portal: &Text,
    stmt_name: &Text,
    param_oids: &[Int],
    params: &List<Maybe<TypedValue>>,
    arena: &mut SpindleArena,
) -> Result<List<Byte>, DbError> {
    let encoded_params = encode_params_for_bind(param_oids, params, arena)?;
    // Binary format for both params and results.
    let param_formats: List<Int> = {
        let mut v: List<Int> = List.with_capacity(1);
        v.push(1);             // 1 = binary, 0 = text
        v
    };
    let result_formats: List<Int> = {
        let mut v: List<Int> = List.with_capacity(1);
        v.push(1);
        v
    };
    Ok(core.database.postgres.wire.frontend.bind(
        portal,
        stmt_name,
        param_formats.as_slice(),
        &encoded_params,
        result_formats.as_slice(),
    ))
}

/// Decode a single `DataRow` payload (List<WireValue>) into typed
/// values using the column OIDs from the most-recent RowDescription.
/// Each non-NULL column flows through `decode_typed_from_bytes`;
/// NULL columns produce `None`.
///
/// `column_oids[i]` MUST correspond positionally to `row[i]`. The
/// arena is borrowed for staging — decoders that allocate (text /
/// bytea / uuid / jsonb materialisation) write through it.
public fn decode_typed_row(
    row: &List<WireValue>,
    column_oids: &[Int],
    arena: &mut SpindleArena,
) -> Result<List<Maybe<TypedValue>>, DbError> {
    let n_cols = column_oids.len() as Int;
    let n_vals = row.len() as Int;
    if n_cols != n_vals {
        return Err(DbError.DecodeFailed {
            fault: core.database.common.error.DecodeFault {
                column_index: -1,
                column_name: "".clone(),
                expected_type: "".clone(),
                found_oid: -1,
                detail: f"decode_typed_row: column_oids.len() = {n_cols}, row.len() = {n_vals}",
            },
        });
    }
    let mut out: List<Maybe<TypedValue>> = List.with_capacity(n_cols);
    let mut i: Int = 0;
    while i < n_cols {
        match &row[i] {
            WvNull => out.push(None),
            WvPresent { bytes, .. } => {
                let value = decode_typed_from_bytes(column_oids[i], bytes.as_slice(), arena)?;
                out.push(Some(value));
            }
        }
        i = i + 1;
    }
    Ok(out)
}

/// Convenience — decode every row in an `ExtendedQueryResult`'s
/// `rows` against the column OIDs from its `row_description`.
/// Returns a parallel `List<List<Maybe<TypedValue>>>`. Caller
/// supplies the arena (typically the connection's per-checkout
/// arena from `PooledConnection.arena_mut()`).
public fn decode_typed_result(
    result: &ExtendedQueryResult,
    arena: &mut SpindleArena,
) -> Result<List<List<Maybe<TypedValue>>>, DbError> {
    let oids: List<Int> = match &result.row_description {
        None => List.new(),
        Some(rd) => {
            let mut v: List<Int> = List.with_capacity(rd.fields.len() as Int);
            let mut i: Int = 0;
            while i < rd.fields.len() as Int {
                v.push(rd.fields[i].type_oid);
                i = i + 1;
            }
            v
        }
    };
    let mut out: List<List<Maybe<TypedValue>>> = List.with_capacity(result.rows.len() as Int);
    let mut k: Int = 0;
    while k < result.rows.len() as Int {
        let typed_row = decode_typed_row(&result.rows[k], oids.as_slice(), arena)?;
        out.push(typed_row);
        k = k + 1;
    }
    Ok(out)
}
