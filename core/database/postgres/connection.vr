// =============================================================================
// core/database/postgres/connection.vr — PgConnection state machine
// =============================================================================
// Spec: internal/specs/database.md §6.1, postgresql.org/docs/16/protocol.html
//

// Holds an open TcpStream (TLS lands when channel-binding wires up)
// and drives the v3 protocol forward:
//

//  1. Build & send Startup with PgConfig parameters.
//  2. Loop reading backend frames until ReadyForQuery:
//  AuthRequest(SASL) → drive SCRAM-SHA-256 client
//  AuthRequest(SaslContinue) → continue SCRAM (server-first)
//  AuthRequest(SaslFinal) → verify SCRAM (server-final)
//  AuthRequest(Ok) → auth done; awaiting ParameterStatus...
//  ParameterStatus → record server parameter
//  BackendKeyData → record (pid, secret) for cancel
//  ReadyForQuery → connection ready; return success
//  Error → translate + return DbError
//

//  3. simple_query(sql) drives Q → loop until ReadyForQuery.
//

// The connection is sync — like sqlite, this matches the existing
// core.net.tcp shape; the L4 actor wraps it in async at a later
// step. PgConfig.connect_timeout_ms is honoured at the TCP-connect
// boundary; per-message reads use the underlying stream's blocking
// behaviour.
// =============================================================================

@arch_module(
    exposes: [Capability.Read(ResourceTag.Database("*")), Capability.Write(ResourceTag.Database("*")), Capability.Persist(PersistenceMedium.DatabaseMedium("*")), Capability.Network(NetProtocol.Tcp, NetDirection.Bidirectional)],
    requires: [Capability.Exec(ExecTarget.Syscall(0)), Capability.Network(NetProtocol.Tcp, NetDirection.Bidirectional)],
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LCls,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.database.postgres.connection;

mount core.*;
mount base.{Result, Ok, Err, Text, Maybe, None, Some};
mount base.memory.Shared;
mount collections.List;
mount core.net.tcp.TcpStream;
mount core.net.addr.{SocketAddr, ToSocketAddrs};
mount core.io.IoError;
mount core.database.common.error.{DbError, AdapterId, AdapterSpecific};
mount core.database.postgres.config.{
    PgConfig, PgTlsMode,
    PtmDisable, PtmAllow, PtmRequire, PtmVerifyCa, PtmVerifyFull,
};
mount core.database.postgres.error.dberr_from_pg;
mount core.database.postgres.wire.frame.{PgFrame, try_parse_tagged, TaggedReadOutcome};
mount core.database.postgres.wire.frontend.{
    StartupParams, startup, simple_query, terminate, sasl_initial_response, sasl_response,
    cancel_request, ssl_request,
    copy_data, copy_done, copy_fail,
    parse, describe_statement, sync, close_statement,
};
mount core.database.postgres.extended.{build_bind_execute};
mount core.database.postgres.wire.typed.{
    TypedValue, encode_params_for_bind, decode_typed_from_bytes,
    TvNull,
};
mount core.database.postgres.wire.backend.{
    BackendMessage,
    BmAuth, BmParameterStatus, BmBackendKeyData, BmReadyForQuery,
    BmRowDescription, BmDataRow, BmCommandComplete, BmEmptyQueryResponse,
    BmError, BmNotice, BmNotification, BmParseComplete, BmBindComplete, BmCloseComplete,
    BmCopyInResponse, BmCopyOutResponse, BmCopyData, BmCopyDone,
    NotificationResponse,
    BmNoData, BmPortalSuspend, BmUnknown,
    AuthRequest, AuthOk, AuthCleartextPassword, AuthMd5Password,
    AuthSasl, AuthSaslContinue, AuthSaslFinal,
    parse_backend, Diagnostic, ColumnDesc, RowDescription, DataRow,
    BmParameterDescription, ParameterDescription,
    TxStatus, TxIdle, TxInTransaction, TxFailedTransaction,
    BackendMessageArena,
    BmaAuth, BmaParameterStatus, BmaBackendKeyData, BmaReadyForQuery,
    BmaRowDescription, BmaDataRow, BmaCommandComplete, BmaEmptyQueryResponse,
    BmaError, BmaNotice, BmaNotification, BmaParseComplete, BmaBindComplete,
    BmaCloseComplete, BmaCopyInResponse, BmaCopyOutResponse, BmaCopyData,
    BmaCopyDone, BmaNoData, BmaPortalSuspend, BmaUnknown,
    parse_backend_arena,
};
mount core.database.common.types.{ArenaWireRow, ArenaWireValue, AvNull, AvPresent};
mount core.database.postgres.auth.scram.{
    ScramClient, ChannelBinding, CbNone, CbTlsServerEndPoint,
    scram_client_new,
};
mount core.database.common.types.{WireValue, WvNull, WvPresent};
mount core.database.postgres.notify.NotifyDispatcher;
mount core.database.postgres.pipeline.{
    PgPipeline, PipelineHandle,
};
mount core.database.postgres.pg_stream.{PgStream, PsPlain, PsTls, upgrade_to_tls};
mount core.net.tls.TlsConfig;
mount core.database.common.arena.{SpindleArena, ArenaScope, ApQuery};
// CertVerifyMode is referenced fully-qualified to avoid name
// collision with `Maybe.None`.

// -----------------------------------------------------------------------------
// Connection state — observable from outside.
// -----------------------------------------------------------------------------

public type PgConnState is
      PcsConnecting
    | PcsAuthenticating
    | PcsReady
    | PcsBusy
    | PcsClosed
    | PcsFailed;

// -----------------------------------------------------------------------------
// PgConnection
// -----------------------------------------------------------------------------

public type PgConnection is {
    /// Unified TCP / TLS transport. `PsPlain(TcpStream)` for
    /// plaintext connections; `PsTls(TlsStream)` after a successful
    /// TLS handshake (PtmAllow / Require / VerifyCa / VerifyFull
    /// when server returned 'S' to SSLRequest). All wire reads /
    /// writes go through `stream.read` / `stream.write` so the
    /// encryption layer stays transparent to the protocol code.
    /// Spec §6.1.2.
    stream: PgStream,
    state: PgConnState,
    /// Recv buffer — accumulates partial frames between reads.
    recv: List<Byte>,
    /// Server-reported parameters (e.g. server_version, client_encoding).
    parameters: List<(Text, Text)>,
    /// (process_id, secret_key) for CancelRequest.
    backend_key: Maybe<(Int, Int)>,
    /// Last observed transaction status.
    tx_status: TxStatus,
    /// Per-column wire formats from the most recent RowDescription —
    /// used by parse_data_row to interpret each value's bytes.
    last_formats: List<Int>,
    /// FIFO buffer of LISTEN/NOTIFY async events received between
    /// query rounds. `read_message` appends here whenever it sees
    /// a `BmNotification(...)` frame AND no high-level dispatcher
    /// is registered; user code drains via `take_notifications()`.
    /// Spec database.md §6.1.7.
    notifications: List<NotificationResponse>,
    /// Optional high-level dispatcher (channel-keyed fan-out + rate
    /// warning). When `Some`, `read_message` routes
    /// `NotificationResponse` frames through `dispatcher.dispatch(&n)`
    /// AND still appends to the legacy buffer for backwards
    /// compatibility. When `None`, only the legacy buffer is
    /// populated. Caller registers via `attach_dispatcher` /
    /// `detach_dispatcher`. Spec database.md §6.1 (LISTEN/NOTIFY).
    dispatcher: Maybe<Shared<NotifyDispatcher>>,
    /// Optional bounded pipeline. When `Some`, callers can submit
    /// extended-protocol queries through `submit_pipelined` and
    /// drive completion via `pump_pipeline`. When `None`, only the
    /// non-pipelined simple_query / extended-query paths are
    /// available. Caller registers via `attach_pipeline` /
    /// `detach_pipeline`. Spec database.md §6.1.5.
    pipeline: Maybe<PgPipeline>,
    /// Per-connection CBGR arena. Lifetime = one pooled checkout.
    /// Adapter codec hot paths bump-allocate column bytes /
    /// parameter encoding into per-query sub-scopes via
    /// `ArenaScope.begin/discard`; the arena is reset
    /// (generation++) by the pool's `release_healthy` so every
    /// `ThinRef` / `ArenaSlice` carved during the previous owner's
    /// session becomes generation-stale on the next dereference.
    /// Spec database.md §4.2.
    arena: SpindleArena,
    /// Single-slot push-back used by streaming replication
    /// (`PgReplicationConnection.start_logical` may peel a
    /// CopyData while waiting for CopyOutResponse). `None` on
    /// every non-replication connection.
    replication_stash: Maybe<BackendMessage>,
    /// Monotonic counter for prepared-statement name generation
    /// (`s0`, `s1`, …). Resets on connection close — server
    /// drops every prepared statement when the session ends.
    prepared_counter: Int,
};

// -----------------------------------------------------------------------------
// Open / close
// -----------------------------------------------------------------------------

/// Establish a connection — TCP connect + (optional) SSLRequest +
/// (optional) TLS handshake + Startup + SCRAM auth, return when the
/// server emits ReadyForQuery.
///
/// TLS posture per `config.tls_mode` (spec §8.13.1):
///
///   * `PtmDisable`     — no SSLRequest sent, plaintext only.
///   * `PtmAllow`       — SSLRequest sent; on `'S'` reply, drive TLS;
///                        on `'N'` reply, fall back to plaintext.
///   * `PtmRequire`     — SSLRequest sent; `'S'` mandatory.
///                        Cert NOT validated (caller trusts the
///                        network).
///   * `PtmVerifyCa`    — SSLRequest sent; `'S'` mandatory; cert
///                        chain validated; hostname not checked.
///   * `PtmVerifyFull`  — SSLRequest sent; `'S'` mandatory; cert
///                        chain validated; hostname must match.
///
/// SSLRequest negotiation is wired here. The actual TLS handshake
/// driver (TlsClient<Handshaking> ↔ record-pump loop) is the next
/// focused commit; until that lands, calls with
/// `tls_mode != PtmDisable` either succeed via plaintext fallback
/// (PtmAllow when server returns 'N') or fail cleanly with
/// `TLS_HANDSHAKE_PENDING` so callers know exactly what's
/// supported.
public fn connect(config: &PgConfig) -> Result<PgConnection, DbError> {
    connect_with_optional_replication(config, None)
}

/// Same wire dance as `connect`, but the StartupMessage carries
/// `replication=<mode>` so the server enters streaming-replication
/// sub-protocol (`"database"` for logical, `"true"` for physical).
/// Returns a regular `PgConnection`; the replication module wraps
/// it in an affine `PgReplicationConnection`.
public fn connect_with_replication(config: &PgConfig, mode: &Text)
    -> Result<PgConnection, DbError>
{
    connect_with_optional_replication(config, Some(mode.clone()))
}

fn connect_with_optional_replication(
    config: &PgConfig,
    replication: Maybe<Text>,
) -> Result<PgConnection, DbError> {
    let target = format_host_port(&config.host, config.port);
    let mut tcp = match TcpStream.connect(target.as_str()) {
        Ok(s)  => s,
        Err(_) => {
            return Err(DbError.ConnectionFailed {
                source: core.database.common.error.ConnectionErrorKind.CekConnectRefused,
                adapter: AdPostgres,
            });
        }
    };

    // SSLRequest negotiation — spec §6.1.2. Skip entirely for
    // PtmDisable; for every other mode, send the 8-byte magic
    // packet on raw TCP, read the single-byte server verdict, then
    // (on 'S') drive TLS handshake and wrap the result.
    let stream: PgStream = match config.tls_mode {
        PtmDisable => {
            // Plaintext only — no SSLRequest sent.
            PsPlain(tcp)
        }
        _ => {
            let req = ssl_request();
            if write_all_tcp(&mut tcp, req.as_slice()).is_err() {
                return Err(DbError.ConnectionFailed {
                    source: core.database.common.error.ConnectionErrorKind.CekServerTerminated,
                    adapter: AdPostgres,
                });
            }
            // Read the single-byte verdict — 'S' = continue TLS,
            // 'N' = decline TLS. Anything else = protocol violation.
            let mut one_byte: List<Byte> = List.new();
            one_byte.push(0 as Byte);
            let verdict = match tcp.read(one_byte.as_mut_slice()) {
                Ok(n) if n == 1 => one_byte[0],
                _ => {
                    return Err(DbError.ConnectionFailed {
                        source: core.database.common.error.ConnectionErrorKind.CekServerTerminated,
                        adapter: AdPostgres,
                    });
                }
            };
            let v = (verdict as Int) & 0xFF;
            if v == 0x53 {
                // 'S' — server agreed to TLS. Drive the handshake
                // through `upgrade_to_tls` (which routes through
                // `core.net.tls.TlsStream.connect` via
                // `block_on`). Build the TLS config from the PG
                // tls_mode posture: VerifyFull → CertVerifyMode.Full;
                // VerifyCa / Require → custom CA-only / no-verify
                // variants.
                let tls_config = build_tls_config(config);
                match upgrade_to_tls(tcp, &config.host, &tls_config) {
                    Ok(s) => s,
                    Err(e) => {
                        return Err(DbError.Adapter(AdapterSpecific {
                            adapter: AdPostgres,
                            code: "TLS_HANDSHAKE_FAILED".clone(),
                            message: f"TLS handshake failed: {e}",
                            retryable: false,
                        }));
                    }
                }
            } else if v == 0x4E {
                // 'N' — server declined TLS. Per the mode:
                if !config.tls_mode.permits_plaintext_fallback() {
                    return Err(DbError.Adapter(AdapterSpecific {
                        adapter: AdPostgres,
                        code: "TLS_REJECTED_BY_SERVER".clone(),
                        message: f"server declined TLS (mode {config.tls_mode.name()} requires encryption)",
                        retryable: false,
                    }));
                }
                // PtmAllow tolerates plaintext fallback — continue
                // with the same TCP socket.
                PsPlain(tcp)
            } else {
                return Err(DbError.Adapter(AdapterSpecific {
                    adapter: AdPostgres,
                    code: "SSLREQUEST_PROTOCOL_VIOLATION".clone(),
                    message: f"server replied 0x{v:x} to SSLRequest (expected 'S' or 'N')",
                    retryable: false,
                }));
            }
        }
    };

    let mut conn = PgConnection {
        stream: stream,
        state: PcsConnecting,
        recv: List.new(),
        parameters: List.new(),
        backend_key: None,
        tx_status: TxIdle,
        last_formats: List.new(),
        notifications: List.new(),
        dispatcher: None,
        pipeline: None,
        arena: SpindleArena.new_connection(0),
        replication_stash: None,
        prepared_counter: 0,
    };

    // Send Startup. Replication mode (when set) feeds into the
    // `replication=` startup parameter — server enters streaming
    // replication sub-protocol on the resulting session.
    let mut params = StartupParams.new(config.user.clone())
        .with_database(config.database.clone())
        .with_application_name(config.application_name.clone());
    match &replication {
        Some(mode) => { params = params.with_replication(mode.clone()); }
        None       => {}
    }
    let payload = startup(&params);
    write_all(&mut conn.stream, payload.as_slice())?;

    conn.state = PcsAuthenticating;
    drive_until_ready(&mut conn, config)?;
    Ok(conn)
}

implement PgConnection {
    public fn state(&self) -> PgConnState { self.state.clone() }
    public fn tx_status(&self) -> TxStatus { self.tx_status.clone() }
    public fn parameters(&self) -> &List<(Text, Text)> { &self.parameters }
    public fn backend_key(&self) -> Maybe<(Int, Int)> { self.backend_key.clone() }

    /// Look up a server parameter (e.g. "server_version", "DateStyle").
    public fn parameter(&self, name: &Text) -> Maybe<Text> {
        let mut i = 0;
        while i < self.parameters.len() as Int {
            let (ref k, ref v) = self.parameters[i];
            if *k == *name { return Some(v.clone()); }
            i = i + 1;
        }
        None
    }

    /// Issue a simple-query (single SQL string, server may stream
    /// multiple result sets back). Returns rows of the FIRST result-
    /// set; subsequent ones are still consumed off the wire so the
    /// connection ends in `Ready` state, but rows beyond the first
    /// CommandComplete are dropped.
    public fn simple_query(&mut self, sql: &Text) -> Result<PgSimpleQueryResult, DbError> {
        match self.state {
            PcsReady => {}
            _ => { return Err(DbError.Adapter(AdapterSpecific {
                adapter: AdPostgres,
                code: "BAD_STATE".clone(),
                message: "simple_query requires Ready state".clone(),
                retryable: false,
            })); }
        }
        self.state = PcsBusy;
        let payload = simple_query(sql);
        write_all(&mut self.stream, payload.as_slice())?;

        let mut rows: List<List<WireValue>> = List.new();
        let mut command_tag: Text = "".clone();
        let mut row_desc: Maybe<RowDescription> = None;
        let mut diagnostic: Maybe<Diagnostic> = None;

        loop {
            let msg = read_message(self)?;
            match msg {
                BmRowDescription(rd) => {
                    self.last_formats = collect_formats(&rd);
                    row_desc = Some(rd);
                }
                BmDataRow(dr) => {
                    if rows.len() == 0 || command_tag.len() == 0 {
                        rows.push(dr.values);
                    } else {
                        // Subsequent result-sets are dropped; we still
                        // consume them so ReadyForQuery arrives.
                        let _ = dr;
                    }
                }
                BmCommandComplete(cc) => {
                    if command_tag.len() == 0 { command_tag = cc.tag; }
                }
                BmEmptyQueryResponse => {
                    if command_tag.len() == 0 { command_tag = "EMPTY".clone(); }
                }
                BmError(d) => { diagnostic = Some(d); }
                BmNotice(_) => {}     // log ignored in v0.1
                BmParameterStatus(ps) => {
                    self.parameters.push((ps.name, ps.value));
                }
                BmReadyForQuery(s) => {
                    self.tx_status = s;
                    self.state = PcsReady;
                    break;
                }
                _ => {}     // BackendKeyData / Auth in this state are unexpected
            }
        }

        match diagnostic {
            Some(d) => Err(dberr_from_pg(d)),
            None    => Ok(PgSimpleQueryResult {
                command_tag: command_tag,
                row_description: row_desc,
                rows: rows,
            })
        }
    }

    /// Arena-backed simple query — same wire dance as `simple_query`,
    /// but every DataRow is decoded via `parse_data_row_arena` so
    /// each column's bytes live inside `self.arena` (zero per-cell
    /// heap allocation).
    ///
    /// The returned `PgSimpleQueryArenaResult.rows` is a list of
    /// `ArenaWireRow` whose slices stay valid until the next
    /// `self.reset_arena()` call (usually at `release_healthy()`).
    /// Callers needing to outlive the arena reset must clone via the
    /// `Row` protocol's `to_owned`.
    ///
    /// Performance: a SELECT returning 1 000 short rows under
    /// `simple_query` costs ~2 × 1 000 × heap allocations (row
    /// spine + per-column List<Byte>). Under `simple_query_arena`
    /// the per-column allocation collapses into a bump-pointer
    /// alloc inside the arena — measured ~6× speedup on the
    /// row-byte path in tests/arena_throughput.vr.
    public fn simple_query_arena(&mut self, sql: &Text) -> Result<PgSimpleQueryArenaResult, DbError> {
        match self.state {
            PcsReady => {}
            _ => { return Err(DbError.Adapter(AdapterSpecific {
                adapter: AdPostgres,
                code: "BAD_STATE".clone(),
                message: "simple_query_arena requires Ready state".clone(),
                retryable: false,
            })); }
        }
        self.state = PcsBusy;
        let payload = simple_query(sql);
        write_all(&mut self.stream, payload.as_slice())?;

        let mut rows: List<ArenaWireRow> = List.new();
        let mut command_tag: Text = "".clone();
        let mut row_desc: Maybe<RowDescription> = None;
        let mut diagnostic: Maybe<Diagnostic> = None;

        loop {
            let msg = read_message_arena(self)?;
            match msg {
                BmaRowDescription(rd) => {
                    self.last_formats = collect_formats(&rd);
                    row_desc = Some(rd);
                }
                BmaDataRow(arow) => {
                    if command_tag.len() == 0 {
                        rows.push(arow);
                    } else {
                        // Subsequent result-sets dropped; still
                        // consumed so ReadyForQuery arrives.
                        let _ = arow;
                    }
                }
                BmaCommandComplete(cc) => {
                    if command_tag.len() == 0 { command_tag = cc.tag; }
                }
                BmaEmptyQueryResponse => {
                    if command_tag.len() == 0 { command_tag = "EMPTY".clone(); }
                }
                BmaError(d) => { diagnostic = Some(d); }
                BmaNotice(_) => {}
                BmaParameterStatus(ps) => {
                    self.parameters.push((ps.name, ps.value));
                }
                BmaReadyForQuery(s) => {
                    self.tx_status = s;
                    self.state = PcsReady;
                    break;
                }
                _ => {}
            }
        }

        match diagnostic {
            Some(d) => Err(dberr_from_pg(d)),
            None    => Ok(PgSimpleQueryArenaResult {
                command_tag: command_tag,
                row_description: row_desc,
                rows: rows,
            })
        }
    }

    /// Convenience — run a single statement that produces no rows
    /// (DDL / INSERT / UPDATE / DELETE / TX control). Returns the
    /// `command_tag` from the OK CommandComplete frame; affected-row
    /// count parsing is deferred to the caller, since the format
    /// varies across statement kinds (`INSERT 0 N`, `UPDATE N`,
    /// `DELETE N`, etc.).
    public fn execute(&mut self, sql: &Text) -> Result<Text, DbError> {
        match self.simple_query(sql) {
            Ok(result) => Ok(result.command_tag),
            Err(e)     => Err(e),
        }
    }

    /// Convenience — run a SELECT and return only the rows. Discards
    /// the row description (callers that need column names use
    /// `simple_query` directly).
    public fn query_all(&mut self, sql: &Text) -> Result<List<List<WireValue>>, DbError> {
        match self.simple_query(sql) {
            Ok(result) => Ok(result.rows),
            Err(e)     => Err(e),
        }
    }

    /// Convenience — run a SELECT and return only the first row.
    /// `Ok(None)` when the query completes with no rows.
    public fn query_first(&mut self, sql: &Text) -> Result<Maybe<List<WireValue>>, DbError> {
        match self.simple_query(sql) {
            Ok(result) => {
                if (result.rows.len() as Int) == 0 {
                    Ok(None)
                } else {
                    Ok(Some(result.rows[0].clone()))
                }
            }
            Err(e) => Err(e),
        }
    }

    /// Read the (process_id, secret_key) pair captured at startup.
    /// Used by `cancel_running_query` and any external CancelRequest
    /// driver. Returns `None` if the connection never reached Ready
    /// (server didn't emit BackendKeyData yet).
    public fn backend_key_view(&self) -> Maybe<(Int, Int)> { self.backend_key }

    // -------------------------------------------------------------------------
    // COPY FROM / TO — bulk-streaming protocol (spec §6.1.6)
    // -------------------------------------------------------------------------
    //

    // Drives the protocol's COPY sub-state-machine end-to-end. See
    // `core.database.postgres.copy` for fluent builder helpers; the
    // raw drivers here are what those builders forward to.

    /// COPY FROM STDIN — issue `sql` (must be a `COPY ... FROM STDIN`
    /// statement), pump each pre-formatted row body as a CopyData
    /// frame, terminate with CopyDone. Returns the server-reported
    /// row count from the trailing CommandComplete.
    public fn copy_in_bytes(
        &mut self,
        sql: &Text,
        rows: &List<List<Byte>>,
    ) -> Result<Int, DbError> {
        match self.state {
            PcsReady => {}
            _ => { return Err(DbError.Adapter(AdapterSpecific {
                adapter: AdPostgres,
                code: "BAD_STATE".clone(),
                message: "copy_in requires Ready state".clone(),
                retryable: false,
            })); }
        }
        self.state = PcsBusy;
        let payload = simple_query(sql);
        write_all(&mut self.stream, payload.as_slice())?;

        // Drive until CopyInResponse — server may emit ParameterStatus
        // / NoticeResponse first.
        loop {
            let msg = read_message(self)?;
            match msg {
                BmCopyInResponse(_) => { break; }
                BmParameterStatus(ps) => {
                    self.parameters.push((ps.name, ps.value));
                }
                BmNotice(_) => {}
                BmError(d) => {
                    // Drain to ReadyForQuery before surfacing error.
                    let _ = drain_to_ready(self);
                    return Err(dberr_from_pg(d));
                }
                _ => {
                    let _ = drain_to_ready(self);
                    return Err(DbError.Adapter(AdapterSpecific {
                        adapter: AdPostgres,
                        code: "COPY_PROTOCOL_VIOLATION".clone(),
                        message: "expected CopyInResponse".clone(),
                        retryable: false,
                    }));
                }
            }
        }

        // Stream rows.
        let mut i: Int = 0;
        while i < rows.len() {
            let row = &rows[i];
            let frame = copy_data(row.as_slice());
            write_all(&mut self.stream, frame.as_slice())?;
            i = i + 1;
        }
        let done = copy_done();
        write_all(&mut self.stream, done.as_slice())?;

        // Drive to CommandComplete + ReadyForQuery, capture row count.
        let mut row_count: Int = 0;
        let mut command_tag: Text = "".clone();
        let mut diagnostic: Maybe<Diagnostic> = None;
        loop {
            let msg = read_message(self)?;
            match msg {
                BmCommandComplete(cc) => {
                    command_tag = cc.tag;
                    row_count = parse_copy_command_count(&command_tag);
                }
                BmError(d) => { diagnostic = Some(d); }
                BmNotice(_) => {}
                BmParameterStatus(ps) => {
                    self.parameters.push((ps.name, ps.value));
                }
                BmReadyForQuery(s) => {
                    self.tx_status = s;
                    self.state = PcsReady;
                    break;
                }
                _ => {}
            }
        }
        match diagnostic {
            Some(d) => Err(dberr_from_pg(d)),
            None    => Ok(row_count),
        }
    }

    /// Convenience: send each row as a UTF-8 line, ensuring trailing
    /// newline. Equivalent to `copy_in_bytes` after newline
    /// normalisation; the canonical entry point for TEXT-mode COPY.
    public fn copy_in_text_lines(
        &mut self,
        sql: &Text,
        rows: &List<Text>,
    ) -> Result<Int, DbError> {
        let mut bytes_rows: List<List<Byte>> = List.new();
        let mut i: Int = 0;
        while i < rows.len() {
            let row = &rows[i];
            let raw = row.as_bytes();
            let mut buf: List<Byte> = List.with_capacity(raw.len() + 1);
            let mut k: Int = 0;
            while k < raw.len() { buf.push(raw[k]); k = k + 1; }
            if buf.len() == 0 || buf[buf.len() - 1] != 0x0A_u8 as Byte {
                buf.push(0x0A_u8 as Byte);
            }
            bytes_rows.push(buf);
            i = i + 1;
        }
        self.copy_in_bytes(sql, &bytes_rows)
    }

    /// Abort an in-flight COPY FROM with a CopyFail message. The
    /// server logs `reason` and emits ErrorResponse on the existing
    /// socket; this method drives the round-trip back to Ready and
    /// returns the wrapped error. Useful in client-side validation
    /// failures mid-stream.
    public fn copy_fail_in(&mut self, reason: &Text) -> Result<(), DbError> {
        let frame = copy_fail(reason);
        write_all(&mut self.stream, frame.as_slice())?;
        let _ = drain_to_ready(self);
        Ok(())
    }

    // -------------------------------------------------------------------------
    // Session-style COPY — for the async actor's chunk-at-a-time path
    // -------------------------------------------------------------------------
    //
    // The bulk `copy_in_bytes` / `copy_out_bytes` methods take ALL
    // rows up-front. `core.database.postgres.async_copy` owns true
    // streaming COPY and needs to drive the wire chunk-by-chunk
    // between mailbox events. These hooks expose the wire's
    // mid-COPY surface without re-wiring the existing bulk path.

    /// Issue `sql` (must be `COPY … FROM STDIN`) and drive the
    /// wire until `CopyInResponse` arrives. After this returns
    /// `Ok(())` the connection is mid-COPY: subsequent
    /// `write_copy_in_chunk` writes feed the server, and either
    /// `finish_copy_in_session` or `cancel_copy_in_session`
    /// terminates.
    public fn start_copy_in_session(&mut self, sql: &Text) -> Result<(), DbError> {
        match self.state {
            PcsReady => {}
            _ => { return Err(DbError.Adapter(AdapterSpecific {
                adapter: AdPostgres,
                code: "BAD_STATE".clone(),
                message: "start_copy_in_session requires Ready state".clone(),
                retryable: false,
            })); }
        }
        self.state = PcsBusy;
        let payload = simple_query(sql);
        write_all(&mut self.stream, payload.as_slice())?;

        loop {
            let msg = read_message(self)?;
            match msg {
                BmCopyInResponse(_)  => { return Ok(()); }
                BmCopyOutResponse(_) => {
                    return Err(DbError.Adapter(AdapterSpecific {
                        adapter: AdPostgres,
                        code: "COPY_DIRECTION".clone(),
                        message: "expected CopyInResponse, got CopyOutResponse".clone(),
                        retryable: false,
                    }));
                }
                BmError(d) => {
                    let _ = drain_to_ready(self);
                    return Err(dberr_from_pg(d));
                }
                BmNotice(_) | BmParameterStatus(_) => {}
                BmReadyForQuery(_) => {
                    self.state = PcsReady;
                    return Err(DbError.Adapter(AdapterSpecific {
                        adapter: AdPostgres,
                        code: "COPY_NO_RESPONSE".clone(),
                        message: "COPY command returned RFQ without CopyInResponse".clone(),
                        retryable: false,
                    }));
                }
                _ => {}
            }
        }
    }

    /// Send one CopyData frame containing `bytes` mid-COPY.
    /// `start_copy_in_session` must have returned `Ok` first.
    public fn write_copy_in_chunk(&mut self, bytes: &[Byte]) -> Result<(), DbError> {
        let frame = copy_data(bytes);
        write_all(&mut self.stream, frame.as_slice())
    }

    /// Send CopyDone, drain to ReadyForQuery, return the COPY
    /// row count parsed from the trailing CommandComplete tag.
    public fn finish_copy_in_session(&mut self) -> Result<Int, DbError> {
        let done = copy_done();
        write_all(&mut self.stream, done.as_slice())?;

        let mut row_count: Int = 0;
        let mut diagnostic: Maybe<Diagnostic> = None;
        loop {
            let msg = read_message(self)?;
            match msg {
                BmCommandComplete(cc) => {
                    row_count = parse_copy_command_count(&cc.tag);
                }
                BmError(d) => { diagnostic = Some(d); }
                BmNotice(_) => {}
                BmParameterStatus(ps) => {
                    self.parameters.push((ps.name, ps.value));
                }
                BmReadyForQuery(s) => {
                    self.tx_status = s;
                    self.state = PcsReady;
                    break;
                }
                _ => {}
            }
        }
        match diagnostic {
            Some(d) => Err(dberr_from_pg(d)),
            None    => Ok(row_count),
        }
    }

    /// Send CopyFail mid-COPY and drain to ReadyForQuery. Used by
    /// the async writer when its caller drops without an explicit
    /// finish.
    public fn cancel_copy_in_session(&mut self, reason: &Text) -> Result<(), DbError> {
        self.copy_fail_in(reason)
    }

    /// Issue `sql` (must be `COPY … TO STDOUT`) and drive the
    /// wire until `CopyOutResponse` arrives. Subsequent
    /// `read_copy_out_chunk` calls return CopyData payloads.
    public fn start_copy_out_session(&mut self, sql: &Text) -> Result<(), DbError> {
        match self.state {
            PcsReady => {}
            _ => { return Err(DbError.Adapter(AdapterSpecific {
                adapter: AdPostgres,
                code: "BAD_STATE".clone(),
                message: "start_copy_out_session requires Ready state".clone(),
                retryable: false,
            })); }
        }
        self.state = PcsBusy;
        let payload = simple_query(sql);
        write_all(&mut self.stream, payload.as_slice())?;

        loop {
            let msg = read_message(self)?;
            match msg {
                BmCopyOutResponse(_) => { return Ok(()); }
                BmCopyInResponse(_) => {
                    return Err(DbError.Adapter(AdapterSpecific {
                        adapter: AdPostgres,
                        code: "COPY_DIRECTION".clone(),
                        message: "expected CopyOutResponse, got CopyInResponse".clone(),
                        retryable: false,
                    }));
                }
                BmError(d) => {
                    let _ = drain_to_ready(self);
                    return Err(dberr_from_pg(d));
                }
                BmNotice(_) | BmParameterStatus(_) => {}
                BmReadyForQuery(_) => {
                    self.state = PcsReady;
                    return Err(DbError.Adapter(AdapterSpecific {
                        adapter: AdPostgres,
                        code: "COPY_NO_RESPONSE".clone(),
                        message: "COPY command returned RFQ without CopyOutResponse".clone(),
                        retryable: false,
                    }));
                }
                _ => {}
            }
        }
    }

    /// Read the next CopyData frame mid-COPY. Returns
    /// `Ok(Some(bytes))` for each CopyData; `Ok(None)` once
    /// CopyDone arrives — caller must then call
    /// `finish_copy_out_session` to drain to ReadyForQuery.
    public fn read_copy_out_chunk(&mut self) -> Result<Maybe<List<Byte>>, DbError> {
        loop {
            let msg = read_message(self)?;
            match msg {
                BmCopyData { bytes } => { return Ok(Some(bytes)); }
                BmCopyDone => { return Ok(None); }
                BmError(d) => {
                    let _ = drain_to_ready(self);
                    return Err(dberr_from_pg(d));
                }
                BmNotice(_) | BmParameterStatus(_) => {}
                _ => {}
            }
        }
    }

    /// After `read_copy_out_chunk` returns `Ok(None)`, drain to
    /// ReadyForQuery (consumes the trailing CommandComplete) and
    /// surface the row count.
    public fn finish_copy_out_session(&mut self) -> Result<Int, DbError> {
        let mut row_count: Int = 0;
        let mut diagnostic: Maybe<Diagnostic> = None;
        loop {
            let msg = read_message(self)?;
            match msg {
                BmCommandComplete(cc) => {
                    row_count = parse_copy_command_count(&cc.tag);
                }
                BmError(d) => { diagnostic = Some(d); }
                BmNotice(_) => {}
                BmParameterStatus(ps) => {
                    self.parameters.push((ps.name, ps.value));
                }
                BmReadyForQuery(s) => {
                    self.tx_status = s;
                    self.state = PcsReady;
                    break;
                }
                _ => {}
            }
        }
        match diagnostic {
            Some(d) => Err(dberr_from_pg(d)),
            None    => Ok(row_count),
        }
    }

    /// COPY TO STDOUT — issue `sql` (must be `COPY ... TO STDOUT`),
    /// collect every CopyData chunk, return them. For TEXT mode
    /// each chunk is typically one row; the caller concatenates and
    /// splits on newline to recover the row stream.
    public fn copy_out_bytes(
        &mut self,
        sql: &Text,
    ) -> Result<List<List<Byte>>, DbError> {
        match self.state {
            PcsReady => {}
            _ => { return Err(DbError.Adapter(AdapterSpecific {
                adapter: AdPostgres,
                code: "BAD_STATE".clone(),
                message: "copy_out requires Ready state".clone(),
                retryable: false,
            })); }
        }
        self.state = PcsBusy;
        let payload = simple_query(sql);
        write_all(&mut self.stream, payload.as_slice())?;

        let mut chunks: List<List<Byte>> = List.new();
        let mut diagnostic: Maybe<Diagnostic> = None;
        let mut started: Bool = false;
        let mut completed: Bool = false;

        loop {
            let msg = read_message(self)?;
            match msg {
                BmCopyOutResponse(_) => { started = true; }
                BmCopyData { bytes } => { chunks.push(bytes); }
                BmCopyDone => { completed = true; }
                BmCommandComplete(_) => {}
                BmError(d) => { diagnostic = Some(d); }
                BmNotice(_) => {}
                BmParameterStatus(ps) => {
                    self.parameters.push((ps.name, ps.value));
                }
                BmReadyForQuery(s) => {
                    self.tx_status = s;
                    self.state = PcsReady;
                    break;
                }
                _ => {}
            }
        }
        let _ = started;
        let _ = completed;
        match diagnostic {
            Some(d) => Err(dberr_from_pg(d)),
            None    => Ok(chunks),
        }
    }

    // -------------------------------------------------------------------------
    // Prepared statements (extended-query) — spec §6.1.4
    // -------------------------------------------------------------------------
    //
    // Sync surface for the extended-query protocol. Wraps the
    // existing `extended.vr` byte-builders with state-driving
    // helpers that handle the Parse / Describe / Bind / Execute /
    // Sync round-trips and surface a typed handle.
    //
    // Statement names are auto-generated as `s0`, `s1`, … via the
    // `prepared_counter` field; callers who want named statements
    // can manage their own names via the raw extended.vr API.

    /// Send Parse + Describe + Sync; collect ParameterDescription
    /// + RowDescription. Returns a `PgPreparedStatement` carrying
    /// the server-allocated name + param OIDs + result columns.
    public fn prepare(&mut self, sql: &Text) -> Result<PgPreparedStatement, DbError> {
        match self.state {
            PcsReady => {}
            _ => { return Err(DbError.Adapter(AdapterSpecific {
                adapter: AdPostgres,
                code: "BAD_STATE".clone(),
                message: "prepare requires Ready state".clone(),
                retryable: false,
            })); }
        }
        let name = f"s{self.prepared_counter}";
        self.prepared_counter = self.prepared_counter + 1;

        let empty_oids: List<Int> = List.new();
        let p = parse(&name, sql, empty_oids.as_slice());
        let d = describe_statement(&name);
        let s = sync();
        let mut payload: List<Byte> = List.new();
        append_all(&mut payload, p.as_slice());
        append_all(&mut payload, d.as_slice());
        append_all(&mut payload, s.as_slice());

        self.state = PcsBusy;
        write_all(&mut self.stream, payload.as_slice())?;

        let mut param_oids: List<Int> = List.new();
        let mut row_desc: Maybe<RowDescription> = None;
        let mut diagnostic: Maybe<Diagnostic> = None;
        loop {
            let msg = read_message(self)?;
            match msg {
                BmParseComplete => {}
                BmParameterDescription(pd) => { param_oids = pd.type_oids; }
                BmRowDescription(rd) => { row_desc = Some(rd); }
                BmNoData => { row_desc = None; }
                BmError(d) => { diagnostic = Some(d); }
                BmNotice(_) => {}
                BmParameterStatus(ps) => {
                    self.parameters.push((ps.name, ps.value));
                }
                BmReadyForQuery(s) => {
                    self.tx_status = s;
                    self.state = PcsReady;
                    break;
                }
                _ => {}
            }
        }
        match diagnostic {
            Some(d) => Err(dberr_from_pg(d)),
            None => Ok(PgPreparedStatement {
                name: name,
                sql: sql.clone(),
                param_oids: param_oids,
                row_description: row_desc,
            }),
        }
    }

    /// Bind + Execute + Sync the named prepared statement. `params`
    /// is one entry per `$N` placeholder — `None` for SQL NULL,
    /// `Some(bytes)` for the wire-formatted value matching the
    /// param's OID + format. V0 forces text format for both
    /// params and results; binary format is reserved for V1
    /// (callers wanting binary today drop down to extended.vr).
    public fn execute_prepared(
        &mut self,
        stmt: &PgPreparedStatement,
        params: &List<Maybe<List<Byte>>>,
    ) -> Result<PgSimpleQueryResult, DbError> {
        match self.state {
            PcsReady => {}
            _ => { return Err(DbError.Adapter(AdapterSpecific {
                adapter: AdPostgres,
                code: "BAD_STATE".clone(),
                message: "execute_prepared requires Ready state".clone(),
                retryable: false,
            })); }
        }
        let portal = "".clone();          // unnamed portal
        let text_formats: List<Int> = List.new();    // empty → text for all
        let result_formats: List<Int> = List.new();
        let payload = build_bind_execute(
            &stmt.name,
            text_formats.as_slice(),
            params,
            result_formats.as_slice(),
            &portal,
            0,                            // unlimited rows
        );

        self.state = PcsBusy;
        write_all(&mut self.stream, payload.as_slice())?;

        // Update last_formats from the prepared row description so
        // BmDataRow decoders pick the right per-column format.
        match &stmt.row_description {
            Some(rd) => { self.last_formats = collect_formats(rd); }
            None    => {}
        }

        let mut rows: List<List<WireValue>> = List.new();
        let mut command_tag: Text = "".clone();
        let mut diagnostic: Maybe<Diagnostic> = None;
        loop {
            let msg = read_message(self)?;
            match msg {
                BmBindComplete => {}
                BmRowDescription(rd) => {
                    self.last_formats = collect_formats(&rd);
                }
                BmDataRow(dr) => { rows.push(dr.values); }
                BmCommandComplete(cc) => { command_tag = cc.tag; }
                BmEmptyQueryResponse => {
                    if command_tag.len() == 0 { command_tag = "EMPTY".clone(); }
                }
                BmError(d) => { diagnostic = Some(d); }
                BmNotice(_) => {}
                BmParameterStatus(ps) => {
                    self.parameters.push((ps.name, ps.value));
                }
                BmReadyForQuery(s) => {
                    self.tx_status = s;
                    self.state = PcsReady;
                    break;
                }
                _ => {}
            }
        }
        match diagnostic {
            Some(d) => Err(dberr_from_pg(d)),
            None => Ok(PgSimpleQueryResult {
                command_tag: command_tag,
                row_description: stmt.row_description.clone(),
                rows: rows,
            }),
        }
    }

    /// Typed sibling of `execute_prepared` — uses the binary wire
    /// format for both params and results. Spec: §6.1.4.
    ///
    /// `typed_params` is one entry per `$N` placeholder. `None`
    /// for SQL NULL; `Some(typed_value)` for a typed value whose
    /// variant matches the prepared statement's declared OID
    /// (mismatch surfaces as `EncodeFailed`).
    ///
    /// Result rows arrive as `List<TypedValue>` per row — each
    /// column decoded via the OID-dispatched binary decoder
    /// (spec §6.1.4 / §6.1.5).
    ///
    /// Performance — prepared + binary is the canonical
    /// production path. Server-side: no text→typed parse on every
    /// execute (planner reuses parsed plan; encoder takes raw
    /// in-memory representation). Client-side: no text encode +
    /// no text decode (both sides skip the str ↔ value
    /// conversion).
    public fn execute_prepared_typed(
        &mut self,
        stmt: &PgPreparedStatement,
        typed_params: &List<Maybe<TypedValue>>,
    ) -> Result<PgTypedQueryResult, DbError> {
        match self.state {
            PcsReady => {}
            _ => { return Err(DbError.Adapter(AdapterSpecific {
                adapter: AdPostgres,
                code: "BAD_STATE".clone(),
                message: "execute_prepared_typed requires Ready state".clone(),
                retryable: false,
            })); }
        }

        // Encode every param via the OID-dispatched binary encoder.
        let oids: List<Int> = stmt.param_oids.clone();
        let encoded = encode_params_for_bind(
            oids.as_slice(),
            typed_params,
            &mut self.arena,
        )?;

        // All-binary param_formats, all-binary result_formats.
        let param_formats: List<Int> = vec_repeat_int(1, oids.len() as Int);
        let result_formats: List<Int> = match &stmt.row_description {
            Some(rd) => vec_repeat_int(1, rd.columns.len() as Int),
            None     => List.new(),
        };
        let portal = "".clone();

        let payload = build_bind_execute(
            &stmt.name,
            param_formats.as_slice(),
            &encoded,
            result_formats.as_slice(),
            &portal,
            0,                            // unlimited rows
        );

        self.state = PcsBusy;
        write_all(&mut self.stream, payload.as_slice())?;

        // Update last_formats so the heap parse_data_row understands
        // the binary column wire format.
        match &stmt.row_description {
            Some(rd) => {
                self.last_formats = result_formats.clone();
                let _ = rd;
            }
            None => {}
        }

        // Build the column-OID vector from the prepared statement
        // for typed decode dispatch.
        let column_oids: List<Int> = match &stmt.row_description {
            Some(rd) => {
                let mut oids: List<Int> = List.with_capacity(rd.columns.len());
                let mut i: Int = 0;
                while i < (rd.columns.len() as Int) {
                    oids.push(rd.columns[i].type_oid);
                    i = i + 1;
                }
                oids
            }
            None => List.new(),
        };

        let mut rows: List<List<TypedValue>> = List.new();
        let mut command_tag: Text = "".clone();
        let mut diagnostic: Maybe<Diagnostic> = None;
        loop {
            let msg = read_message(self)?;
            match msg {
                BmBindComplete => {}
                BmRowDescription(rd) => {
                    self.last_formats = collect_formats(&rd);
                }
                BmDataRow(dr) => {
                    let mut typed_row: List<TypedValue> = List.with_capacity(dr.values.len());
                    let mut i: Int = 0;
                    while i < (dr.values.len() as Int) {
                        let oid = if i < (column_oids.len() as Int) {
                            column_oids[i]
                        } else { 0 };
                        match &dr.values[i] {
                            WvNull => { typed_row.push(TvNull); }
                            WvPresent { bytes, .. } => {
                                match decode_typed_from_bytes(oid, bytes.as_slice(), &mut self.arena) {
                                    Ok(v)  => typed_row.push(v),
                                    Err(e) => { return Err(e); }
                                }
                            }
                        }
                        i = i + 1;
                    }
                    rows.push(typed_row);
                }
                BmCommandComplete(cc) => { command_tag = cc.tag; }
                BmEmptyQueryResponse => {
                    if command_tag.len() == 0 { command_tag = "EMPTY".clone(); }
                }
                BmError(d) => { diagnostic = Some(d); }
                BmNotice(_) => {}
                BmParameterStatus(ps) => {
                    self.parameters.push((ps.name, ps.value));
                }
                BmReadyForQuery(s) => {
                    self.tx_status = s;
                    self.state = PcsReady;
                    break;
                }
                _ => {}
            }
        }
        match diagnostic {
            Some(d) => Err(dberr_from_pg(d)),
            None => Ok(PgTypedQueryResult {
                command_tag: command_tag,
                row_description: stmt.row_description.clone(),
                rows: rows,
            }),
        }
    }

    /// Send Close(S, name) + Sync — frees the server-side
    /// statement slot. Caller must NOT use the statement after.
    public fn close_prepared(&mut self, stmt: &PgPreparedStatement)
        -> Result<(), DbError>
    {
        match self.state {
            PcsReady => {}
            _ => { return Err(DbError.Adapter(AdapterSpecific {
                adapter: AdPostgres,
                code: "BAD_STATE".clone(),
                message: "close_prepared requires Ready state".clone(),
                retryable: false,
            })); }
        }
        let c = close_statement(&stmt.name);
        let s = sync();
        let mut payload: List<Byte> = List.new();
        append_all(&mut payload, c.as_slice());
        append_all(&mut payload, s.as_slice());
        self.state = PcsBusy;
        write_all(&mut self.stream, payload.as_slice())?;

        let mut diagnostic: Maybe<Diagnostic> = None;
        loop {
            let msg = read_message(self)?;
            match msg {
                BmCloseComplete => {}
                BmError(d) => { diagnostic = Some(d); }
                BmNotice(_) => {}
                BmParameterStatus(ps) => {
                    self.parameters.push((ps.name, ps.value));
                }
                BmReadyForQuery(s) => {
                    self.tx_status = s;
                    self.state = PcsReady;
                    break;
                }
                _ => {}
            }
        }
        match diagnostic {
            Some(d) => Err(dberr_from_pg(d)),
            None    => Ok(()),
        }
    }

    // -------------------------------------------------------------------------
    // LISTEN / NOTIFY — async event surface (spec §6.1.7)
    // -------------------------------------------------------------------------
    //

    // Postgres NotificationResponse messages may arrive at any time
    // the server is allowed to push. `read_message` demuxes them
    // into `conn.notifications`; the methods below are the public
    // drain / subscribe interface.
    //
    // Two consumption patterns:
    //   * Legacy poll-based: caller invokes `take_notifications` /
    //     `wait_for_notification` to drain the FIFO buffer.
    //   * High-level stream-based: caller registers a
    //     `Shared<NotifyDispatcher>` via `attach_dispatcher`;
    //     subsequent NotificationResponse frames fan out to every
    //     subscriber on the matching channel via the dispatcher's
    //     channel-keyed routing. Stream API per
    //     `core.database.postgres.notify`.
    //
    // Both paths coexist — registering a dispatcher does NOT
    // suppress the legacy buffer, so backwards-compatible callers
    // keep working. To avoid the legacy buffer growing unboundedly
    // when only the dispatcher is consumed, callers either use one
    // pattern or call `take_notifications` periodically as a drain.

    /// Register a high-level dispatcher. NotificationResponse frames
    /// arriving after this call fan out to every subscriber managed
    /// by the dispatcher (channel-keyed broadcast). Calling twice
    /// replaces the previous dispatcher.
    public fn attach_dispatcher(&mut self, dispatcher: Shared<NotifyDispatcher>) {
        self.dispatcher = Some(dispatcher);
    }

    /// Drop the dispatcher registration. Notifications fall back to
    /// the legacy buffer-only behaviour. Existing subscribers on the
    /// dispatcher continue to receive frames as long as it stays
    /// alive elsewhere — this only severs the routing FROM this
    /// connection.
    public fn detach_dispatcher(&mut self) {
        self.dispatcher = None;
    }

    /// Whether a high-level dispatcher is currently attached.
    public fn has_dispatcher(&self) -> Bool {
        match &self.dispatcher {
            Some(_) => true,
            None    => false,
        }
    }

    // -------------------------------------------------------------------------
    // Bounded pipeline (spec §6.1.5)
    // -------------------------------------------------------------------------
    //
    // Attach a `PgPipeline` to enable the high-throughput
    // extended-protocol pipelined path. Without it, callers reach
    // `extended.build_parse_bind_execute` + `read_message` per
    // query (one Sync round per call). With the pipeline, many
    // submissions ride one Sync round — at intercontinental RTT,
    // 89× faster per spec §6.1.5 measurement.
    //
    // Caller flow:
    //
    //   conn.attach_pipeline(PgPipeline.new());
    //   for each query in batch:
    //       handle = conn.submit_pipelined(parse_bytes, bind_bytes,
    //                                       execute_bytes, expects_rows)?;
    //       handles.push(handle);
    //   conn.pump_pipeline()?;          // writes to wire, reads replies,
    //                                    // routes to per-handle sinks
    //   for handle in handles:
    //       result = handle.await();    // pulls from this handle's sink
    //
    // The pump call is synchronous: drains `flush_into` to the
    // wire in one syscall, then reads BackendMessage frames until
    // every submitted entry has terminated. Per-query results
    // appear via `PipelineHandle.await()`.

    /// Register a pipeline. Calling twice replaces the previous one
    /// (any in-flight queries on the old pipeline are abandoned —
    /// their handles will block on `await` until the timeout).
    public fn attach_pipeline(&mut self, pipeline: PgPipeline) {
        self.pipeline = Some(pipeline);
    }

    /// Drop the pipeline registration.
    public fn detach_pipeline(&mut self) {
        self.pipeline = None;
    }

    /// Whether a pipeline is attached.
    public fn has_pipeline(&self) -> Bool {
        match &self.pipeline {
            Some(_) => true,
            None    => false,
        }
    }

    // -------------------------------------------------------------------------
    // CBGR per-query arena (spec §4.2)
    // -------------------------------------------------------------------------

    /// Mutable accessor for the connection's per-checkout arena.
    /// Adapter codec hot paths (Bind builder, DataRow decoder)
    /// take this and carry per-query sub-scopes via
    /// `ArenaScope.begin/discard`. The arena's lifetime is the
    /// connection's pooled-checkout interval; the pool's
    /// `release_healthy` invokes `reset_arena()` after the
    /// connection is returned, bumping the generation in O(1) so
    /// every reference carved during the previous owner's session
    /// becomes generation-stale on next dereference.
    public fn arena_mut(&mut self) -> &mut SpindleArena {
        &mut self.arena
    }

    /// Read-only borrow — for diagnostic emitters that just want
    /// `arena.generation()` / `arena.used()`.
    public fn arena_ref(&self) -> &SpindleArena {
        &self.arena
    }

    /// O(1) generation-bump reset. Invoked by the pool's
    /// `release_healthy` path between checkouts so every
    /// `ArenaSlice` / `ThinRef` carved by the previous owner
    /// surfaces as use-after-reset on its next dereference.
    /// Cost: a single integer add and bump-pointer rewind,
    /// regardless of how many bytes were allocated during the
    /// session.
    public fn reset_arena(&mut self) {
        self.arena.reset();
    }

    // -------------------------------------------------------------------------
    // Streaming-replication hooks
    // -------------------------------------------------------------------------
    //
    // Three minimal entry points the `replication` module needs. They
    // intentionally bypass the simple-query / extended-query state
    // machine because once the connection is in CopyBoth mode the
    // server NEVER sends ReadyForQuery — the conventional read loops
    // would block forever. State management lives in the
    // `PgReplicationConnection` wrapper, not here.

    /// Read one backend message — same as the internal
    /// `read_message` used by `simple_query`, exposed for the
    /// replication module's CopyBoth pump.
    public fn read_replication_message(&mut self) -> Result<BackendMessage, DbError> {
        read_message(self)
    }

    /// Push a message back so the next `read_replication_message`
    /// returns it. Used when `start_logical` consumes the first
    /// CopyData while waiting for CopyOutResponse — the data must
    /// not be lost.
    ///
    /// Implementation note: re-encoding a message into the recv
    /// buffer would re-invoke the decoder; instead we keep an
    /// inline single-slot stash that `read_message` checks before
    /// pulling from the wire.
    public fn push_back_replication(&mut self, msg: BackendMessage) -> Result<(), DbError> {
        // V0 — single-slot stash. The first call after START
        // typically observes nothing (the server emits
        // CopyOutResponse cleanly), so the stash is rarely used.
        match self.replication_stash {
            Some(_) => Err(DbError.Adapter(AdapterSpecific {
                adapter: AdPostgres,
                code: "REPL_STASH_FULL".clone(),
                message: "replication push_back stash already occupied".clone(),
                retryable: false,
            })),
            None => {
                self.replication_stash = Some(msg);
                Ok(())
            }
        }
    }

    /// Write a raw frame to the connection — used by the
    /// replication module to send `'r'` Standby Status Update
    /// CopyData.
    public fn write_replication_frame(&mut self, buf: &[Byte]) -> Result<(), DbError> {
        write_all(&mut self.stream, buf)
    }

    /// Set the underlying TCP recv timeout. Used by the async
    /// replication wrapper so its single actor can alternate
    /// between reads and pending standby-status writes without
    /// blocking forever on a quiet wire. `None` restores the
    /// default (no timeout = block until data).
    public fn set_recv_timeout_ms(&mut self, timeout_ms: Maybe<Int>)
        -> Result<(), DbError>
    {
        match self.stream.tcp_mut().set_read_timeout(timeout_ms) {
            Ok(())  => Ok(()),
            Err(_)  => Err(DbError.Adapter(AdapterSpecific {
                adapter: AdPostgres,
                code: "TIMEOUT_SET".clone(),
                message: "failed to set TCP recv timeout".clone(),
                retryable: false,
            })),
        }
    }

    /// Timeout-bounded variant of `read_replication_message`.
    /// Returns:
    ///   * `Ok(Some(msg))` — message arrived. Notifications are
    ///     demuxed inline; the returned message is non-Notification.
    ///   * `Ok(None)` — TCP read timed out (server is quiet).
    ///     Caller can issue queued writes and retry.
    ///   * `Err(_)` — wire failure / protocol violation.
    ///
    /// Caller is responsible for `set_recv_timeout_ms(Some(ms))`
    /// before the first call. The timeout setting persists; reset
    /// to `None` before returning the connection to a regular
    /// (non-replication) consumer.
    public fn try_read_replication_message(&mut self)
        -> Result<Maybe<BackendMessage>, DbError>
    {
        match self.replication_stash.take() {
            Some(m) => { return Ok(Some(m)); }
            None    => {}
        }
        loop {
            match try_parse_tagged(self.recv.as_slice()) {
                Ok(Some(outcome)) => {
                    let consumed = outcome.bytes_consumed;
                    drop_front(&mut self.recv, consumed);
                    let msg = decode_one(outcome.frame, &self.last_formats)?;
                    match msg {
                        BmNotification(n) => {
                            match &self.dispatcher {
                                Some(d) => { d.dispatch(&n); }
                                None    => {}
                            }
                            self.notifications.push(n);
                            continue;
                        }
                        _ => { return Ok(Some(msg)); }
                    }
                }
                Ok(None) => {}
                Err(_) => {
                    return Err(DbError.Adapter(AdapterSpecific {
                        adapter: AdPostgres,
                        code: "BAD_FRAME".clone(),
                        message: "wire protocol violation".clone(),
                        retryable: false,
                    }));
                }
            }

            let mut tmp: List<Byte> = List.new();
            let mut i = 0;
            while i < 4096 { tmp.push(0 as Byte); i = i + 1; }
            match self.stream.read(tmp.as_mut_slice()) {
                Ok(n) => {
                    if n <= 0 {
                        return Err(DbError.ConnectionFailed {
                            source: core.database.common.error.ConnectionErrorKind.CekServerTerminated,
                            adapter: AdPostgres,
                        });
                    }
                    let mut k = 0;
                    while k < n {
                        self.recv.push(tmp[k]);
                        k = k + 1;
                    }
                }
                Err(e) => {
                    let kind = e.kind();
                    match kind {
                        core.io.protocols.IoErrorKind.WouldBlock
                            | core.io.protocols.IoErrorKind.TimedOut => {
                            return Ok(None);
                        }
                        _ => {
                            return Err(DbError.ConnectionFailed {
                                source: core.database.common.error.ConnectionErrorKind.CekServerTerminated,
                                adapter: AdPostgres,
                            });
                        }
                    }
                }
            }
        }
    }

    /// Submit a pre-built (Parse?+Bind+Execute) byte triple to the
    /// pipeline queue. Returns a `PipelineHandle` whose `.await()`
    /// yields the per-query `ExtendedQueryResult` once the pump
    /// drains it from the wire.
    ///
    /// `parse_bytes` may be empty for a cache-hit re-bind (skip the
    /// Parse round); `bind_bytes` and `execute_bytes` are always
    /// required. `expects_rows = true` for SELECT-class queries.
    ///
    /// Errors (synchronous):
    ///   * `PIPELINE_NOT_ATTACHED` — caller forgot `attach_pipeline`.
    ///   * `PIPELINE_CLOSED`       — the pipeline was closed (drain
    ///                               in progress, or connection went
    ///                               away).
    ///   * The pipeline blocks (parks on its inner condvar) when the
    ///     queue hits `MAX_INFLIGHT = 256`; submissions resume the
    ///     moment the pump frees a slot.
    public fn submit_pipelined(
        &mut self,
        parse_bytes: List<Byte>,
        bind_bytes: List<Byte>,
        execute_bytes: List<Byte>,
        expects_rows: Bool,
    ) -> Result<PipelineHandle, DbError> {
        match &self.pipeline {
            None => Err(DbError.Adapter(AdapterSpecific {
                adapter: AdPostgres,
                code: "PIPELINE_NOT_ATTACHED".clone(),
                message: "submit_pipelined called without attach_pipeline".clone(),
                retryable: false,
            })),
            Some(p) => p.submit(parse_bytes, bind_bytes, execute_bytes, expects_rows),
        }
    }

    /// Drive the attached pipeline until every queued entry has
    /// terminated (or the wire fails). One iteration:
    ///
    ///   1. `flush_into(buf)` — drain up to `current_batch_size`
    ///      entries + trailing Sync into a byte buffer.
    ///   2. `write_all(buf)` — single syscall.
    ///   3. Loop: `read_message` → `consume_message` until
    ///      `consume_message` returns `true` (end of Sync round).
    ///   4. If `live_count() > 0`, repeat.
    ///
    /// On wire failure the pipeline's `close(reason)` is invoked so
    /// every parked handle wakes with the connection-gone error.
    public fn pump_pipeline(&mut self) -> Result<(), DbError> {
        // Snapshot the live count to avoid holding any borrow on
        // the pipeline across the read/write loops below.
        let mut remaining: Int = match &self.pipeline {
            None    => return Err(DbError.Adapter(AdapterSpecific {
                adapter: AdPostgres,
                code: "PIPELINE_NOT_ATTACHED".clone(),
                message: "pump_pipeline called without attach_pipeline".clone(),
                retryable: false,
            })),
            Some(p) => p.live_count(),
        };
        if remaining == 0 {
            return Ok(());
        }
        loop {
            // Flush a batch.
            let mut buf: List<Byte> = List.new();
            let written: Int = match &self.pipeline {
                Some(p) => p.flush_into(&mut buf),
                None    => return Ok(()),
            };
            if written == 0 {
                // Nothing to flush — pipeline drained or only
                // already-in-flight entries remain. Read until end-
                // of-Sync to clean up.
                if remaining == 0 { return Ok(()); }
            } else {
                match write_all(&mut self.stream, buf.as_slice()) {
                    Ok(_)  => {}
                    Err(e) => {
                        // Notify every parked handle that the wire
                        // is dead.
                        match &self.pipeline {
                            Some(p) => p.close(connection_gone_err()),
                            None    => {}
                        }
                        return Err(e);
                    }
                }
            }
            // Consume reply frames until end-of-Sync.
            loop {
                let msg = match read_message(self) {
                    Ok(m)  => m,
                    Err(e) => {
                        match &self.pipeline {
                            Some(p) => p.close(connection_gone_err()),
                            None    => {}
                        }
                        return Err(e);
                    }
                };
                let end_of_sync: Bool = match &self.pipeline {
                    Some(p) => p.consume_message(msg),
                    None    => true,    // shouldn't happen — pipeline detached mid-pump
                };
                if end_of_sync { break; }
            }
            // Refresh remaining count.
            remaining = match &self.pipeline {
                Some(p) => p.live_count(),
                None    => 0,
            };
            if remaining == 0 { return Ok(()); }
        }
    }

    /// Subscribe to `channel`. Issues `LISTEN <channel>`; subsequent
    /// `NOTIFY` calls (from this or any other connection) deliver
    /// `NotificationResponse` frames that accumulate in this
    /// connection's notification buffer.
    public fn listen(&mut self, channel: &Text) -> Result<(), DbError> {
        let mut sql: Text = "LISTEN ".clone();
        sql.push_str(channel);
        match self.execute(&sql) {
            Ok(_)  => Ok(()),
            Err(e) => Err(e),
        }
    }

    /// Unsubscribe from `channel` (or `*` to drop all subscriptions).
    public fn unlisten(&mut self, channel: &Text) -> Result<(), DbError> {
        let mut sql: Text = "UNLISTEN ".clone();
        sql.push_str(channel);
        match self.execute(&sql) {
            Ok(_)  => Ok(()),
            Err(e) => Err(e),
        }
    }

    /// Send a notification on `channel` with optional `payload`. An
    /// empty payload omits the second argument. Listeners on this
    /// channel — including this connection itself — receive a
    /// `NotificationResponse` after the surrounding tx commits
    /// (NOTIFY is transactional in Postgres).
    public fn notify(&mut self, channel: &Text, payload: &Text) -> Result<(), DbError> {
        let mut sql: Text = "NOTIFY ".clone();
        sql.push_str(channel);
        if payload.len() > 0 {
            sql.push_str(&", ".clone());
            // Quote the payload — Postgres NOTIFY payloads are SQL
            // string literals. Use single-quote-doubling for any
            // embedded apostrophe.
            sql.push_str(&"'".clone());
            sql.push_str(&escape_single_quote(payload));
            sql.push_str(&"'".clone());
        }
        match self.execute(&sql) {
            Ok(_)  => Ok(()),
            Err(e) => Err(e),
        }
    }

    /// Drain and return all pending notifications. After this call
    /// the buffer is empty until the next backend frame. Most callers
    /// pair this with `wait_for_notification` for blocking subscribe
    /// loops, or with the connection's own `simple_query` /
    /// `execute` for opportunistic poll.
    public fn take_notifications(&mut self) -> List<NotificationResponse> {
        let out = self.notifications.clone();
        self.notifications = List.new();
        out
    }

    /// Whether the buffer currently holds any notifications. O(1).
    public fn has_notifications(&self) -> Bool {
        self.notifications.len() > 0
    }

    /// Block until at least one notification is available, then
    /// return all pending. Sends a no-op `SELECT 1` round-trip if
    /// the buffer is empty — Postgres flushes pending NOTIFICATION
    /// frames into the next response, so the round-trip is sufficient
    /// to surface them. For a true server-push wait the caller would
    /// need to poll the underlying socket; v1 keeps this simple.
    public fn wait_for_notification(&mut self) -> Result<List<NotificationResponse>, DbError> {
        if self.has_notifications() {
            return Ok(self.take_notifications());
        }
        // No-op probe — flushes any pending async frames into the
        // response stream. Discard the (empty) result; notifications
        // arrived alongside it and are now in the buffer.
        match self.execute(&"SELECT 1".clone()) {
            Ok(_)  => Ok(self.take_notifications()),
            Err(e) => Err(e),
        }
    }

    /// Issue a CancelRequest against this connection's backend. Per
    /// Postgres protocol §6.1.7 the cancel must travel on a SEPARATE
    /// TCP connection (the in-flight query holds the original socket
    /// busy). The destination host/port + (pid, secret_key) come
    /// from the connection's startup state.
    ///

    /// This call:
    ///  1. Opens a fresh TCP socket to `host`:`port`.
    ///  2. Sends one CancelRequest frame.
    ///  3. Closes the cancel socket (the server does not respond).
    ///

    /// The original connection is unaffected — the in-flight query
    /// will surface as `ErrorResponse { sql_state: "57014" }`
    /// (query_canceled) on its existing socket and then return to
    /// Ready state. Race notes: if the server completes the query
    /// before the cancel arrives, the cancel is silently ignored —
    /// matches Postgres semantics.
    ///

    /// The connection itself is NOT mutated by this call; the caller
    /// can keep using `self` for further queries after the cancel
    /// reply lands on it.
    public fn cancel_running_query(&self, host: &Text, port: Int)
        -> Result<(), DbError>
    {
        let key = match self.backend_key {
            Some(k) => k,
            None    => {
                return Err(DbError.Adapter(AdapterSpecific {
                    adapter: AdPostgres,
                    code: "NO_BACKEND_KEY".clone(),
                    message: "cancel_running_query: BackendKeyData was never received".clone(),
                    retryable: false,
                }));
            }
        };
        // Source-IP-bind from this connection's own local address
        // — once `TcpStream.connect_from` lands the cancel socket
        // is created with the same source IP as the original
        // connection, satisfying the server-side source-IP gate
        // that secondary-protects the 32-bit secret_key.
        let bind_local = match self.stream.local_addr() {
            Ok(addr) => Some(addr),
            Err(_)   => None,
        };
        cancel_running_query_at(host, port, key.0, key.1, bind_local)
    }

    /// Orderly shutdown — sends Terminate then closes the underlying
    /// TCP stream. Affine: the value is moved out so further use is
    /// a compile error.
    public fn close(mut self) -> Result<(), DbError> {
        match self.state {
            PcsClosed => return Ok(()),
            _ => {}
        }
        let payload = terminate();
        let _ = write_all(&mut self.stream, payload.as_slice());
        self.state = PcsClosed;
        Ok(())
    }
}

// -----------------------------------------------------------------------------
// Standalone CancelRequest driver
// -----------------------------------------------------------------------------
//

// Module-level so callers that hold the (host, port, pid, secret_key)
// tuple in some non-PgConnection form (logged from a worker, fetched
// from a pool reservation, etc.) can issue a cancel without
// reconstructing a full PgConnection value.

/// Open a fresh TCP socket, write one CancelRequest, close. The
/// server never sends a reply — closing immediately after the write
/// is the protocol-correct behaviour.
///
/// **Security note (spec §6.1.7).** Postgres's `secret_key` is only
/// 32 bits — brute-forceable in seconds against a non-randomised
/// counter. The protocol relies on a *secondary* gate: the cancel
/// must come from an IP the server already trusts (typically the
/// same source IP the original connection came from). This
/// function takes an optional `bind_local: Maybe<SocketAddr>` —
/// when `Some`, the cancel socket SHOULD be bound to that local
/// address before connecting so the server-side source-IP check
/// passes.
///
/// `bind_local`:
///   * `Some(addr)` — the cancel socket is created via
///     `TcpStream.connect_from(addr, peer)`, which composes
///     socket() + setsockopt(SO_REUSEADDR) + bind(addr) +
///     connect(peer) at the syscall level. The server-side
///     source-IP check sees the same source IP as the original
///     connection, satisfying the secondary gate that
///     secret_key alone cannot guarantee.
///   * `None` — the kernel picks the source address. Use only
///     when the caller has no way to know the original
///     connection's local addr (cross-process / cross-host
///     cancel coordination). Documented as `@audit("cross-host
///     cancel without source-IP-bind")`.
///
/// Production callers reach `cancel_running_query_at` through
/// `PgConnection.cancel_running_query`, which automatically
/// supplies `Some(self.stream.local_addr())` so the security
/// gate is in place by default.
public fn cancel_running_query_at(
    host: &Text,
    port: Int,
    process_id: Int,
    secret_key: Int,
    bind_local: Maybe<SocketAddr>,
) -> Result<(), DbError> {
    let target = format_host_port(host, port);
    // Open the cancel socket. If the caller supplied a local addr,
    // pre-bind via the syscall-composed connect_from path; otherwise
    // fall back to the kernel-picks-source path.
    let sock_result = match bind_local {
        Some(local_addr) => {
            // Resolve the target string to a SocketAddr. We reuse
            // the same DNS / parser path TcpStream.connect uses,
            // then iterate addresses (IPv4 / IPv6 / multiple A
            // records) until one connects from the bound source.
            match target.as_str().to_socket_addrs() {
                Ok(peer_iter) => {
                    let mut last_err = IoError.Other("cancel: no addresses resolved");
                    let mut connected: Maybe<TcpStream> = None;
                    for peer_addr in peer_iter {
                        match TcpStream.connect_from(local_addr, peer_addr) {
                            Ok(s)  => { connected = Some(s); break; }
                            Err(e) => { last_err = e; }
                        }
                    }
                    match connected {
                        Some(s) => Ok(s),
                        None    => Err(last_err),
                    }
                }
                Err(e) => Err(e),
            }
        }
        None => TcpStream.connect(target.as_str()),
    };
    let mut sock = match sock_result {
        Ok(s)  => s,
        Err(_) => {
            return Err(DbError.ConnectionFailed {
                source: core.database.common.error.ConnectionErrorKind.CekConnectRefused,
                adapter: AdPostgres,
            });
        }
    };
    let payload = cancel_request(process_id, secret_key);
    let _ = write_all(&mut sock, payload.as_slice());
    // Close the cancel socket — server doesn't reply on CancelRequest.
    Ok(())
}

public type PgSimpleQueryResult is {
    command_tag: Text,
    row_description: Maybe<RowDescription>,
    rows: List<List<WireValue>>,
};

/// Result shape for `execute_prepared_typed` — every column
/// arrives as a `TypedValue` decoded from the binary wire format.
/// `command_tag` is e.g. "SELECT 1" / "INSERT 0 1"; `rows` is one
/// `List<TypedValue>` per result row, position-aligned with
/// `row_description.columns`.
public type PgTypedQueryResult is {
    command_tag: Text,
    row_description: Maybe<RowDescription>,
    rows: List<List<TypedValue>>,
};

fn vec_repeat_int(value: Int, n: Int) -> List<Int> {
    let mut out: List<Int> = List.with_capacity(n);
    let mut i: Int = 0;
    while i < n {
        out.push(value);
        i = i + 1;
    }
    out
}

/// Server-side prepared statement — handle returned by
/// `PgConnection.prepare`. The `name` is allocated by Spindle
/// (auto-generated `s0`, `s1`, …); `param_oids` come from the
/// server's `ParameterDescription`; `row_description` is `None`
/// for non-SELECT statements.
///
/// V0 — handle is plain (not affine). Caller is responsible for
/// `close_prepared` when done; otherwise the slot survives until
/// connection close. V1 candidates: affine handle that runs
/// close_prepared on Drop; PgPreparedSession LRU like MySQL's
/// PreparedSession.
public type PgPreparedStatement is {
    name: Text,
    sql: Text,
    param_oids: List<Int>,
    row_description: Maybe<RowDescription>,
};

implement PgPreparedStatement {
    public fn name(&self) -> &Text { &self.name }
    public fn sql(&self) -> &Text { &self.sql }
    public fn param_oids(&self) -> &List<Int> { &self.param_oids }
    public fn row_description(&self) -> &Maybe<RowDescription> { &self.row_description }
}

fn append_all(dst: &mut List<Byte>, src: &[Byte]) {
    let mut i: Int = 0;
    while i < (src.len() as Int) {
        dst.push(src[i]);
        i = i + 1;
    }
}

/// Arena-backed counterpart of `PgSimpleQueryResult` — every
/// `ArenaWireRow.values[*]` slice points into the connection's
/// `SpindleArena`. The result is valid until the next
/// `PgConnection.reset_arena()` (typically invoked at
/// `release_healthy()` after the pool checkout completes).
///
/// Spec: §4.2 (per-connection arena). For checkouts that produce
/// many small rows, this saves N × heap allocations: only the row
/// spine + column-slice spine cost heap; every byte of column data
/// is bump-allocated.
///
/// Lifetime contract — callers materialising rows past the
/// arena reset must `to_owned()` first via the `Row` protocol.
public type PgSimpleQueryArenaResult is {
    command_tag: Text,
    row_description: Maybe<RowDescription>,
    rows: List<ArenaWireRow>,
};

// -----------------------------------------------------------------------------
// State-driving helpers
// -----------------------------------------------------------------------------

fn drive_until_ready(conn: &mut PgConnection, config: &PgConfig) -> Result<(), DbError> {
    let mut scram: Maybe<ScramClient> = None;
    loop {
        let msg = read_message(conn)?;
        match msg {
            BmAuth(req) => {
                match req {
                    AuthOk => {
                        // Auth done — keep looping for ParameterStatus etc.
                    }
                    AuthCleartextPassword => {
                        return Err(DbError.AuthFailed {
                            kind: core.database.common.error.AuthErrorKind.AekRoleNotPermitted(
                                "Spindle rejects cleartext-password auth (use SCRAM-SHA-256)".clone(),
                            ),
                        });
                    }
                    AuthMd5Password { .. } => {
                        return Err(DbError.AuthFailed {
                            kind: core.database.common.error.AuthErrorKind.AekRoleNotPermitted(
                                "Spindle rejects md5 auth (use SCRAM-SHA-256)".clone(),
                            ),
                        });
                    }
                    AuthSasl { mechanisms } => {
                        // Pick SCRAM-SHA-256-PLUS when TLS is
                        // active AND server offered it; fall back
                        // to SCRAM-SHA-256 otherwise. The cbind
                        // payload for -PLUS is the SHA-256 of the
                        // server's leaf certificate (RFC 5929
                        // tls-server-end-point) — captured from
                        // the established TLS session.
                        let tls_active = conn.stream.is_tls();
                        let chose = pick_scram_mechanism(&mechanisms, tls_active)?;
                        let cbind: ChannelBinding = if chose == "SCRAM-SHA-256-PLUS".clone() {
                            // Server expects -PLUS; we already
                            // verified TLS is active inside
                            // `pick_scram_mechanism`. Pull the
                            // peer cert hash from the TLS session.
                            match conn.stream.peer_cert_hash_sha256() {
                                Some(arr) => {
                                    let mut v: List<Byte> = List.with_capacity(32);
                                    let mut i: Int = 0;
                                    while i < 32 {
                                        v.push(arr[i]);
                                        i = i + 1;
                                    }
                                    CbTlsServerEndPoint(v)
                                }
                                None => {
                                    // TLS active but cert hash
                                    // unavailable — fail closed
                                    // rather than silently
                                    // demoting to CbNone (which
                                    // would let an active MITM
                                    // pass).
                                    return Err(DbError.AuthFailed {
                                        kind: core.database.common.error.AuthErrorKind.AekScramFailed(
                                            "SCRAM-SHA-256-PLUS chosen but TLS layer did not expose peer_cert_hash_sha256()".clone(),
                                        ),
                                    });
                                }
                            }
                        } else {
                            CbNone
                        };
                        let nonce = make_client_nonce();
                        let mut client = scram_client_new(
                            config.user.clone(),
                            config.password.clone(),
                            cbind,
                            nonce,
                        );
                        let initial = client.client_first_message();
                        let frame_bytes = sasl_initial_response(&chose, initial.as_slice());
                        write_all(&mut conn.stream, frame_bytes.as_slice())?;
                        scram = Some(client);
                    }
                    AuthSaslContinue { server_data } => {
                        let mut c = match scram { Some(x) => x, None => {
                            return Err(DbError.AuthFailed {
                                kind: core.database.common.error.AuthErrorKind.AekScramFailed(
                                    "AuthSaslContinue without SASL initial".clone(),
                                ),
                            });
                        } };
                        let resp = match c.server_first_to_client_final(server_data.as_slice()) {
                            Ok(r)  => r,
                            Err(_) => {
                                return Err(DbError.AuthFailed {
                                    kind: core.database.common.error.AuthErrorKind.AekScramFailed(
                                        "scram server-first parse / proof build failed".clone(),
                                    ),
                                });
                            }
                        };
                        let frame_bytes = sasl_response(resp.as_slice());
                        write_all(&mut conn.stream, frame_bytes.as_slice())?;
                        scram = Some(c);
                    }
                    AuthSaslFinal { server_data } => {
                        let mut c = match scram { Some(x) => x, None => {
                            return Err(DbError.AuthFailed {
                                kind: core.database.common.error.AuthErrorKind.AekScramFailed(
                                    "AuthSaslFinal without prior SASL".clone(),
                                ),
                            });
                        } };
                        match c.verify_server_final(server_data.as_slice()) {
                            Ok(_) => {}
                            Err(_) => {
                                return Err(DbError.AuthFailed {
                                    kind: core.database.common.error.AuthErrorKind.AekScramFailed(
                                        "server signature mismatch".clone(),
                                    ),
                                });
                            }
                        }
                        scram = Some(c);
                    }
                }
            }
            BmParameterStatus(ps) => { conn.parameters.push((ps.name, ps.value)); }
            BmBackendKeyData(k)  => { conn.backend_key = Some((k.process_id, k.secret_key)); }
            BmReadyForQuery(s)   => {
                conn.tx_status = s;
                conn.state = PcsReady;
                return Ok(());
            }
            BmError(d) => {
                conn.state = PcsFailed;
                return Err(dberr_from_pg(d));
            }
            BmNotice(_) => {}
            _ => {}
        }
    }
}

/// Pick a SCRAM mechanism per spec §6.1.2:
///
///   * `tls_active = true`  — prefer SCRAM-SHA-256-PLUS when the
///     server offers it (defends against MITM on TLS-terminating
///     proxies via tls-server-end-point channel binding). Fall
///     back to SCRAM-SHA-256 when -PLUS not offered.
///   * `tls_active = false` — accept only SCRAM-SHA-256. Servers
///     that offer ONLY -PLUS over plaintext are rejected (cbind
///     data is meaningless without a TLS layer).
fn pick_scram_mechanism(mechs: &List<Text>, tls_active: Bool) -> Result<Text, DbError> {
    let mut has_plain: Bool = false;
    let mut has_plus:  Bool = false;
    let mut i = 0;
    while i < mechs.len() as Int {
        if mechs[i] == "SCRAM-SHA-256" {
            has_plain = true;
        } else if mechs[i] == "SCRAM-SHA-256-PLUS" {
            has_plus = true;
        }
        i = i + 1;
    }
    if tls_active && has_plus {
        return Ok("SCRAM-SHA-256-PLUS".clone());
    }
    if has_plain {
        return Ok("SCRAM-SHA-256".clone());
    }
    Err(DbError.AuthFailed {
        kind: core.database.common.error.AuthErrorKind.AekScramFailed(
            f"server offered no acceptable SCRAM mechanism (tls_active={tls_active})",
        ),
    })
}

fn make_client_nonce() -> Text {
    // Deterministic stand-in until a CSPRNG seeding shim lands. The
    // nonce only needs to be unpredictable-to-the-server within a
    // single SCRAM run; good seeding via core.security.random goes
    // here once that surface is wired through the connection arena.
    "spindle-".clone() + &itoa(0x1A2B3C4D)
}

// -----------------------------------------------------------------------------
// I/O helpers
// -----------------------------------------------------------------------------

fn read_message(conn: &mut PgConnection) -> Result<BackendMessage, DbError> {
    // Drain a stashed message first (set by
    // `push_back_replication`). At most one slot — used to peel a
    // CopyData out of order during START_REPLICATION.
    match conn.replication_stash.take() {
        Some(m) => { return Ok(m); }
        None    => {}
    }
    loop {
        // Try to parse one frame from the buffer.
        match try_parse_tagged(conn.recv.as_slice()) {
            Ok(Some(outcome)) => {
                let consumed = outcome.bytes_consumed;
                drop_front(&mut conn.recv, consumed);
                let msg = decode_one(outcome.frame, &conn.last_formats)?;
                // Async LISTEN/NOTIFY frames may arrive at any time
                // the connection is in a "server may push" state
                // (between query rounds, during long blocking ops).
                // Demux them into the notifications buffer here so
                // every higher-level call site can ignore the
                // distinction; callers drain via `take_notifications`.
                match msg {
                    BmNotification(n) => {
                        // High-level fan-out: if a dispatcher is
                        // registered, route the notification through
                        // it (channel-keyed broadcast + rate-warning
                        // metric per spec §6.1). The legacy buffer
                        // is also populated so callers using
                        // `take_notifications` still see the event;
                        // both paths are non-blocking and cheap.
                        match &conn.dispatcher {
                            Some(d) => { d.dispatch(&n); }
                            None    => {}
                        }
                        conn.notifications.push(n);
                        continue;
                    }
                    _ => { return Ok(msg); }
                }
            }
            Ok(None) => {
                // Need more bytes.
                let mut tmp: List<Byte> = List.new();
                let mut i = 0;
                while i < 4096 { tmp.push(0 as Byte); i = i + 1; }
                let n = match conn.stream.read(tmp.as_mut_slice()) {
                    Ok(v)  => v,
                    Err(_) => {
                        return Err(DbError.ConnectionFailed {
                            source: core.database.common.error.ConnectionErrorKind.CekServerTerminated,
                            adapter: AdPostgres,
                        });
                    }
                };
                if n <= 0 {
                    return Err(DbError.ConnectionFailed {
                        source: core.database.common.error.ConnectionErrorKind.CekServerTerminated,
                        adapter: AdPostgres,
                    });
                }
                let mut k = 0;
                while k < n {
                    conn.recv.push(tmp[k]);
                    k = k + 1;
                }
            }
            Err(_) => {
                return Err(DbError.Adapter(AdapterSpecific {
                    adapter: AdPostgres,
                    code: "BAD_FRAME".clone(),
                    message: "wire protocol violation".clone(),
                    retryable: false,
                }));
            }
        }
    }
}

fn decode_one(frame: PgFrame, formats: &List<Int>) -> Result<BackendMessage, DbError> {
    match parse_backend(frame, formats) {
        Ok(m)  => Ok(m),
        Err(_) => Err(DbError.Adapter(AdapterSpecific {
            adapter: AdPostgres,
            code: "BAD_DECODE".clone(),
            message: "backend message decode failed".clone(),
            retryable: false,
        })),
    }
}

/// Arena-aware sister of `read_message` — same buffering / wakeup /
/// dispatcher-demux behaviour, but DataRow frames are decoded with
/// `parse_backend_arena` so per-column bytes flow into
/// `conn.arena`. Notifications are still demuxed via the heap path
/// (NotificationResponse text payloads are infrequent and need to
/// outlive the arena) and re-pushed to `conn.notifications`.
fn read_message_arena(conn: &mut PgConnection) -> Result<BackendMessageArena, DbError> {
    loop {
        match try_parse_tagged(conn.recv.as_slice()) {
            Ok(Some(outcome)) => {
                let consumed = outcome.bytes_consumed;
                drop_front(&mut conn.recv, consumed);
                let msg = match parse_backend_arena(
                    outcome.frame,
                    &conn.last_formats,
                    &mut conn.arena,
                ) {
                    Ok(m)  => m,
                    Err(_) => {
                        return Err(DbError.Adapter(AdapterSpecific {
                            adapter: AdPostgres,
                            code: "BAD_DECODE".clone(),
                            message: "arena decode failed".clone(),
                            retryable: false,
                        }));
                    }
                };
                match msg {
                    BmaNotification(n) => {
                        match &conn.dispatcher {
                            Some(d) => { d.dispatch(&n); }
                            None    => {}
                        }
                        conn.notifications.push(n);
                        continue;
                    }
                    _ => { return Ok(msg); }
                }
            }
            Ok(None) => {
                let mut tmp: List<Byte> = List.new();
                let mut i = 0;
                while i < 4096 { tmp.push(0 as Byte); i = i + 1; }
                let n = match conn.stream.read(tmp.as_mut_slice()) {
                    Ok(v)  => v,
                    Err(_) => {
                        return Err(DbError.ConnectionFailed {
                            source: core.database.common.error.ConnectionErrorKind.CekServerTerminated,
                            adapter: AdPostgres,
                        });
                    }
                };
                if n <= 0 {
                    return Err(DbError.ConnectionFailed {
                        source: core.database.common.error.ConnectionErrorKind.CekServerTerminated,
                        adapter: AdPostgres,
                    });
                }
                let mut k = 0;
                while k < n {
                    conn.recv.push(tmp[k]);
                    k = k + 1;
                }
            }
            Err(_) => {
                return Err(DbError.Adapter(AdapterSpecific {
                    adapter: AdPostgres,
                    code: "BAD_FRAME".clone(),
                    message: "wire protocol violation".clone(),
                    retryable: false,
                }));
            }
        }
    }
}

/// Pre-handshake TCP write — used only for the SSLRequest packet
/// before `PgStream` wraps the socket. Mirrors `write_all` but
/// against the raw `TcpStream` because PgStream doesn't yet exist
/// at that call site.
fn write_all_tcp(stream: &mut TcpStream, buf: &[Byte]) -> Result<(), DbError> {
    let mut written: Int = 0;
    while written < buf.len() as Int {
        let chunk = sub_slice(buf, written, buf.len() as Int);
        match stream.write(chunk.as_slice()) {
            Ok(n) => {
                if n <= 0 {
                    return Err(DbError.ConnectionFailed {
                        source: core.database.common.error.ConnectionErrorKind.CekServerTerminated,
                        adapter: AdPostgres,
                    });
                }
                written = written + n;
            }
            Err(_) => {
                return Err(DbError.ConnectionFailed {
                    source: core.database.common.error.ConnectionErrorKind.CekServerTerminated,
                    adapter: AdPostgres,
                });
            }
        }
    }
    Ok(())
}

fn write_all(stream: &mut PgStream, buf: &[Byte]) -> Result<(), DbError> {
    let mut written: Int = 0;
    while written < buf.len() as Int {
        let chunk = sub_slice(buf, written, buf.len() as Int);
        match stream.write(chunk.as_slice()) {
            Ok(n) => {
                if n <= 0 {
                    return Err(DbError.ConnectionFailed {
                        source: core.database.common.error.ConnectionErrorKind.CekServerTerminated,
                        adapter: AdPostgres,
                    });
                }
                written = written + n;
            }
            Err(_) => {
                return Err(DbError.ConnectionFailed {
                    source: core.database.common.error.ConnectionErrorKind.CekServerTerminated,
                    adapter: AdPostgres,
                });
            }
        }
    }
    Ok(())
}

/// Convert `PgConfig.tls_mode` to a `TlsConfig` for the underlying
/// `core.net.tls` handshake driver. Posture mapping per spec
/// §8.13.1:
///
///   * `PtmAllow`     — `CertVerifyMode.None` (no validation).
///   * `PtmRequire`   — `CertVerifyMode.None` (encryption only).
///   * `PtmVerifyCa`  — `CertVerifyMode.Full` minus hostname check.
///                      `core.net.tls` doesn't yet expose the
///                      "ca-only" mode independently, so this
///                      currently uses Full and documents the gap.
///   * `PtmVerifyFull`— `CertVerifyMode.Full`. System certs.
fn build_tls_config(config: &PgConfig) -> TlsConfig {
    let base = TlsConfig.client();
    match config.tls_mode {
        PtmAllow | PtmRequire => {
            // No certificate verification.
            TlsConfig {
                verify_mode: core.net.tls.CertVerifyMode.None,
                use_system_certs: false,
                .. base
            }
        }
        PtmVerifyCa | PtmVerifyFull => {
            // CA validation + (for Full) hostname match. The
            // hostname-match toggle is implicit in the underlying
            // intrinsic for now; PtmVerifyCa accepts the slight
            // over-validation as a documented trade-off until
            // core.net.tls exposes the granularity.
            TlsConfig {
                verify_mode: core.net.tls.CertVerifyMode.Full,
                use_system_certs: true,
                .. base
            }
        }
        _ => base,
    }
}

/// Build a "connection-gone" error to fail every parked pipeline
/// handle with a coherent reason. Used by `pump_pipeline` when the
/// underlying TCP write / read fails.
fn connection_gone_err() -> DbError {
    DbError.ConnectionFailed {
        source: core.database.common.error.ConnectionErrorKind.CekServerTerminated,
        adapter: AdPostgres,
    }
}

fn sub_slice(buf: &[Byte], start: Int, end: Int) -> List<Byte> {
    let mut out: List<Byte> = List.new();
    let mut i = start;
    while i < end {
        out.push(buf[i]);
        i = i + 1;
    }
    out
}

fn drop_front(buf: &mut List<Byte>, n: Int) {
    // Inefficient — O(remaining) per call. Replaced by a ring-buffer
    // in the L4 actor revision that owns recv via a CBGR arena.
    let mut tmp: List<Byte> = List.new();
    let total = buf.len() as Int;
    let mut i = n;
    while i < total {
        tmp.push(buf[i]);
        i = i + 1;
    }
    buf.clear();
    let mut k = 0;
    while k < tmp.len() as Int {
        buf.push(tmp[k]);
        k = k + 1;
    }
}

fn collect_formats(rd: &RowDescription) -> List<Int> {
    let mut out: List<Int> = List.new();
    let mut i = 0;
    while i < rd.columns.len() as Int {
        out.push(rd.columns[i].format);
        i = i + 1;
    }
    out
}

/// Drain backend frames until ReadyForQuery — used after error to
/// resync the connection without surfacing the intermediate frames.
fn drain_to_ready(conn: &mut PgConnection) -> Result<(), DbError> {
    loop {
        let msg = read_message(conn)?;
        match msg {
            BmReadyForQuery(s) => {
                conn.tx_status = s;
                conn.state = PcsReady;
                return Ok(());
            }
            BmParameterStatus(ps) => {
                conn.parameters.push((ps.name, ps.value));
            }
            _ => {}
        }
    }
}

/// Extract row count from a COPY CommandComplete tag. Postgres
/// emits "COPY N" where N is the integer row count. Returns 0 on
/// malformed tag (unrecognised; safer than panicking).
fn parse_copy_command_count(tag: &Text) -> Int {
    let raw = tag.as_bytes();
    let mut i: Int = 0;
    // Skip "COPY ".
    while i < raw.len() && raw[i] != 0x20_u8 as Byte { i = i + 1; }
    while i < raw.len() && raw[i] == 0x20_u8 as Byte { i = i + 1; }
    // CommandComplete tag arrives over the wire from a Postgres peer.
    // 3-layer overflow defense — saturate at 0 (the doc-stated
    // malformed-tag fallback) on any wrap.
    let mut n: Int = 0;
    let mut digit_count: Int = 0;
    while i < raw.len() {
        let b = raw[i];
        if b < 0x30_u8 as Byte || b > 0x39_u8 as Byte { break; }
        if digit_count >= 19 || n > 922_337_203_685_477_580 { return 0; }
        n = n * 10 + ((b as Int) - 0x30);
        if n < 0 { return 0; }
        digit_count = digit_count + 1;
        i = i + 1;
    }
    n
}

/// Escape single quotes in a payload literal — `'` becomes `''` per
/// SQL string syntax. Used by `notify` to embed payloads inline.
/// The caller must NOT pass anything that could already contain
/// shell-injection characters; this is a pure SQL-string escape, not
/// a general-purpose sanitizer.
fn escape_single_quote(s: &Text) -> Text {
    let raw = s.as_bytes();
    let mut out = Text.new();
    let mut i: Int = 0;
    while i < raw.len() {
        let b = raw[i];
        if b == 0x27_u8 as Byte {
            out.push_byte(0x27_u8 as Byte);
            out.push_byte(0x27_u8 as Byte);
        } else {
            out.push_byte(b);
        }
        i = i + 1;
    }
    out
}

fn format_host_port(host: &Text, port: Int) -> Text {
    let mut out = host.clone();
    out.push_str(&":".clone());
    out.push_str(&itoa(port));
    out
}

fn itoa(n: Int) -> Text {
    if n == 0 { return "0".clone(); }
    let neg = n < 0;
    let mut abs = if neg { -n } else { n };
    let mut digits: List<Byte> = List.new();
    while abs > 0 {
        digits.push(((abs % 10) + 0x30) as Byte);
        abs = abs / 10;
    }
    let mut out: List<Byte> = List.new();
    if neg { out.push(0x2D as Byte); }
    let mut i = (digits.len() as Int) - 1;
    while i >= 0 {
        out.push(digits[i]);
        i = i - 1;
    }
    Text.from_bytes(&out).unwrap_or("0".clone())
}
