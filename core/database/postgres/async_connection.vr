// =============================================================================
// core/database/postgres/async_connection.vr — async wrapper over sync wire
// =============================================================================
// Layer: 3 (Database — postgres adapter)
// Spec: internal/specs/database.md §6.1.8 (async surface).
// =============================================================================
//
// Design — actor-per-connection pattern (matches `tokio_postgres`'s
// internal model). The sync `PgConnection` stays canonical and
// unchanged; an async wrapper is layered on top via:
//
//   1. A `spawn_blocking` task that takes ownership of one
//      `PgConnection` and runs a blocking request loop. Blocking
//      I/O on the dedicated blocking-pool thread is correct
//      (`spawn_blocking`'s pool exists exactly for this).
//
//   2. A bounded mpsc channel of `PgRequest` enum values from the
//      caller(s) into the actor.
//
//   3. Each request carries a oneshot `reply` channel. The actor
//      dispatches the request synchronously, sends the response
//      back, and loops. The caller awaits the oneshot —
//      genuinely yielding to the executor while the actor works.
//
// Pre-this module the only PG surface was sync (`conn.simple_query`
// blocks the calling thread). Production handlers serving 10K
// concurrent queries cannot afford 10K blocked threads. The actor
// pattern caps blocked threads at `(connection_count)` while
// caller fan-out runs entirely on the async executor.
//
// V0 surface — covers the canonical operations used by every
// AsyncDatabase consumer:
//
//   * `simple_query(sql)`  → `Future<Result<PgSimpleQueryResult, …>>`
//   * `execute(sql)`       → `Future<Result<Text, …>>` (command_tag)
//   * `ping()`             → `Future<Result<(), …>>`
//   * `close()`            → `Future<Result<(), …>>` (terminates actor,
//                            joins, closes the wire cleanly)
//
// Out of V0 (each follow-up):
//   * `prepare` / `execute_prepared` (PG extended-query is
//     scaffolded; needs PgRequest::Prepare + Execute variants).
//   * Pipeline (sync `PgPipeline` keeps being the only path).
//   * Replication / COPY / NOTIFY (each its own sub-protocol —
//     async dispatch loop differs and gets its own actor tier).
//
// Lifetime — `AsyncPgConnection` is reference-counted via the
// `Sender` clone. Closing one handle does NOT shut down the
// actor; only `close()` (or all senders dropping) tears the
// session down.
// =============================================================================

@arch_module(
    exposes: [Capability.Read(ResourceTag.Database("*")), Capability.Write(ResourceTag.Database("*")), Capability.Persist(PersistenceMedium.DatabaseMedium("*")), Capability.Network(NetProtocol.Tcp, NetDirection.Bidirectional)],
    requires: [Capability.Exec(ExecTarget.Syscall(0)), Capability.Network(NetProtocol.Tcp, NetDirection.Bidirectional)],
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LCls,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.database.postgres.async_connection;

mount core.*;
mount base.{Result, Ok, Err, Text, Maybe, None, Some, Bool};
mount collections.List;
mount core.database.common.error.{
    DbError, AdapterId, AdPostgres, AdapterSpecific,
};
mount core.database.postgres.connection.{
    PgConnection, PgSimpleQueryResult, PgPreparedStatement,
    connect as sync_connect,
};
mount core.database.postgres.config.PgConfig;
mount core.database.postgres.pg_stmt_cache.{
    PgStmtCache, fingerprint as pg_stmt_fingerprint,
};
mount core.async.channel.{
    Sender, Receiver, OneshotSender, OneshotReceiver,
    bounded_channel, oneshot,
};
mount core.async.task.{spawn_blocking, JoinHandle};

// =============================================================================
// Request / response ADTs
// =============================================================================

/// One unit of work the actor will run synchronously on its owned
/// `PgConnection`. New variants are additive — keep the existing
/// reply types stable so older async clients keep working.
public type PgRequest is
      ReqSimpleQuery {
        sql: Text,
        reply: OneshotSender<Result<PgSimpleQueryResult, DbError>>,
    }
    | ReqExecute {
        sql: Text,
        reply: OneshotSender<Result<Text, DbError>>,
    }
    | ReqPing {
        reply: OneshotSender<Result<(), DbError>>,
    }
    /// Begin transaction with rendered options SQL fragment (the
    /// caller-side wrapper computes `opts.render_sql()` before
    /// sending; the actor doesn't know about PgTxOpts).
    | ReqBeginTx {
        begin_sql: Text,
        reply: OneshotSender<Result<(), DbError>>,
    }
    | ReqCommitTx {
        reply: OneshotSender<Result<(), DbError>>,
    }
    | ReqRollbackTx {
        reply: OneshotSender<Result<(), DbError>>,
    }
    | ReqSavepoint {
        name: Text,
        reply: OneshotSender<Result<(), DbError>>,
    }
    | ReqReleaseSavepoint {
        name: Text,
        reply: OneshotSender<Result<(), DbError>>,
    }
    | ReqRollbackToSavepoint {
        name: Text,
        reply: OneshotSender<Result<(), DbError>>,
    }
    /// Open a streaming COPY FROM session. Actor takes over the
    /// wire, acks via `ack`, then drives a sub-loop reading from
    /// `chunk_rx` until Done/Cancel.
    | ReqCopyInOpen {
        sql: Text,
        chunk_rx: Receiver<CopyInChunk>,
        ack: OneshotSender<Result<(), DbError>>,
    }
    /// Open a streaming COPY TO session. Actor acks via `ack`,
    /// then pushes every CopyData payload to `chunk_tx` until
    /// CopyDone, then drains to RFQ and sends a final
    /// `CoeDone(Result<row_count, …>)` event.
    | ReqCopyOutOpen {
        sql: Text,
        chunk_tx: Sender<core.database.postgres.async_copy.CopyOutEvent>,
        ack: OneshotSender<Result<(), DbError>>,
    }
    /// Prepare a server-side statement. Reply carries the
    /// `PgPreparedStatement` handle (server-allocated name + param
    /// OIDs + result columns).
    | ReqPrepare {
        sql: Text,
        reply: OneshotSender<Result<PgPreparedStatement, DbError>>,
    }
    /// Execute a previously-prepared statement with bound params.
    | ReqExecutePrepared {
        stmt: PgPreparedStatement,
        params: List<Maybe<List<Byte>>>,
        reply: OneshotSender<Result<PgSimpleQueryResult, DbError>>,
    }
    /// Typed sibling — binary-format params + result columns;
    /// reply carries decoded TypedValues.
    | ReqExecutePreparedTyped {
        stmt: PgPreparedStatement,
        typed_params: List<Maybe<core.database.postgres.wire.typed.TypedValue>>,
        reply: OneshotSender<Result<core.database.postgres.connection.PgTypedQueryResult, DbError>>,
    }
    /// Free the server-side slot for a prepared statement.
    | ReqClosePrepared {
        stmt: PgPreparedStatement,
        reply: OneshotSender<Result<(), DbError>>,
    }
    | ReqShutdown {
        reply: OneshotSender<Result<(), DbError>>,
    };

/// Per-chunk write event the COPY-IN sub-loop pulls from its
/// dedicated channel. `CicDone` carries the completion oneshot so
/// the writer's `finish()` future is awoken with the row count.
public type CopyInChunk is
      CicBytes(List<Byte>)
    | CicDone(OneshotSender<Result<Int, DbError>>)
    | CicCancel { reason: Text, reply: OneshotSender<Result<(), DbError>> };

// =============================================================================
// Public handle
// =============================================================================

/// Caller-side handle. Cheaply cloneable — every clone shares the
/// same actor / underlying connection. Concurrent calls from
/// different clones serialise inside the actor (one connection,
/// one wire — same as sync PG).
public type AsyncPgConnection is {
    tx: Sender<PgRequest>,
    /// Join handle for the actor task — kept so `close()` can
    /// await the actor's clean shutdown after dispatching
    /// `ReqShutdown`.
    join: Shared<sync.mutex.Mutex<Maybe<JoinHandle<()>>>>,
    /// Cached server endpoint for issuing CancelRequest from a
    /// fresh socket without round-tripping through the busy
    /// actor. Captured once at connect time.
    cancel_host: Text,
    cancel_port: Int,
    /// (process_id, secret_key) from the server's BackendKeyData
    /// frame during handshake. `None` if the server didn't send
    /// it — cancel_running_query will refuse with an explicit
    /// error.
    backend_key: Maybe<(Int, Int)>,
};

/// Async wrapper over the sync `PgPreparedStatement`. Holds the
/// server-allocated name + descriptor so the actor can dispatch
/// execute/close requests by value. V0 — handle is plain (not
/// affine); caller MUST call `close_prepared` to free the slot
/// before the connection actor shuts down or the slot leaks
/// until session close.
public type AsyncPgPreparedStatement is {
    inner: PgPreparedStatement,
};

implement AsyncPgPreparedStatement {
    public fn inner(&self) -> &PgPreparedStatement { &self.inner }
    public fn name(&self) -> &Text { self.inner.name() }
    public fn sql(&self) -> &Text { self.inner.sql() }
    public fn param_oids(&self) -> &List<Int> { self.inner.param_oids() }
}

implement AsyncPgConnection {
    public fn clone(&self) -> AsyncPgConnection {
        AsyncPgConnection {
            tx: self.tx.clone(),
            join: self.join.clone(),
            cancel_host: self.cancel_host.clone(),
            cancel_port: self.cancel_port,
            backend_key: self.backend_key.clone(),
        }
    }

    /// Cached BackendKeyData (process_id, secret_key) the server
    /// sent during handshake. Required input to CancelRequest.
    public fn backend_key(&self) -> Maybe<(Int, Int)> {
        self.backend_key.clone()
    }

    /// Issue a CancelRequest packet to the server asking it to
    /// abort the current query on this connection. Opens a
    /// FRESH TCP socket (CancelRequest spec — must NOT reuse
    /// the busy session socket); fires from a spawn_blocking
    /// task so it never round-trips through the actor.
    ///
    /// Best-effort — server may have already finished the query
    /// (returns Ok in that case; the cancel was a no-op).
    /// Returns an error if BackendKeyData wasn't captured during
    /// handshake.
    public async fn cancel_running_query(&self) -> Result<(), DbError> {
        self.cancel_running_query_with_local_bind(None).await
    }

    /// Sibling that pre-binds the cancel socket's source IP via
    /// `TcpStream.connect_from`. Required by spec §8.13.10 in
    /// hostile-network deployments where the server's pg_hba
    /// drops connections from any source other than the
    /// originally-trusted IP.
    public async fn cancel_running_query_with_local_bind(
        &self,
        bind_local: Maybe<core.net.tcp.SocketAddr>,
    ) -> Result<(), DbError> {
        let key = match self.backend_key {
            Some(k) => k,
            None => {
                return Err(DbError.Adapter(AdapterSpecific {
                    adapter: AdPostgres,
                    code: "CANCEL_NO_KEY".clone(),
                    message: "BackendKeyData not captured during handshake — cancel impossible".clone(),
                    retryable: false,
                }));
            }
        };
        let host = self.cancel_host.clone();
        let port = self.cancel_port;
        let pid = key.0;
        let secret = key.1;
        let jh = spawn_blocking(move || -> Result<(), DbError> {
            core.database.postgres.connection.cancel_running_query_at(
                &host, port, pid, secret, bind_local,
            )
        });
        match jh.join().await {
            Ok(r)  => r,
            Err(_) => Err(actor_dropped("cancel: blocking-pool join")),
        }
    }

    /// Wire a CancellationToken — when it flips, automatically
    /// fire `cancel_running_query()` so the SERVER-side query
    /// terminates without caller intervention. Spawns a one-shot
    /// background watcher task that awaits `token.cancelled()`.
    ///
    /// The watcher exits naturally when the token fires; if the
    /// connection closes first, the cancel becomes a no-op
    /// (CancelRequest against a dead session is silently
    /// ignored by PG).
    ///
    /// Multiple tokens may be attached — each spawns its own
    /// watcher; ANY one firing triggers the cancel.
    public fn attach_cancellation_token(
        &self,
        token: core.async.cancellation.CancellationToken,
    ) {
        let conn_clone = self.clone();
        let _ = core.async.task.spawn(async move {
            let _ = token.cancelled().await;
            let _ = conn_clone.cancel_running_query().await;
        });
    }

    /// Borrow the request channel for layered modules
    /// (`async_transaction`, `async_typed_database`) that build
    /// their own `PgRequest` variants and need to dispatch them
    /// on the same actor. Adapter-private — typed callers should
    /// stay on the high-level `simple_query` / `execute` /
    /// `begin_tx_async` entry points.
    public fn tx_ref(&self) -> &Sender<PgRequest> {
        &self.tx
    }

    /// Drive `simple_query` on the actor's owned connection. The
    /// returned future yields to the executor while the actor's
    /// blocking-pool thread runs the wire round-trip.
    public async fn simple_query(&self, sql: &Text)
        -> Result<PgSimpleQueryResult, DbError>
    {
        let (rs, rr) = oneshot();
        match self.tx.send_async(ReqSimpleQuery {
            sql: sql.clone(),
            reply: rs,
        }).await {
            Ok(())  => {}
            Err(_)  => { return Err(actor_dropped("simple_query")); }
        }
        match rr.await {
            Ok(r)  => r,
            Err(_) => Err(actor_dropped("simple_query reply")),
        }
    }

    /// Run a single statement that produces no rows; returns the
    /// `command_tag` from CommandComplete.
    public async fn execute(&self, sql: &Text) -> Result<Text, DbError> {
        let (rs, rr) = oneshot();
        match self.tx.send_async(ReqExecute {
            sql: sql.clone(),
            reply: rs,
        }).await {
            Ok(())  => {}
            Err(_)  => { return Err(actor_dropped("execute")); }
        }
        match rr.await {
            Ok(r)  => r,
            Err(_) => Err(actor_dropped("execute reply")),
        }
    }

    /// Async health-check — issues `simple_query("SELECT 1")` on
    /// the actor and reports the round-trip success.
    public async fn ping(&self) -> Result<(), DbError> {
        let (rs, rr) = oneshot();
        match self.tx.send_async(ReqPing { reply: rs }).await {
            Ok(())  => {}
            Err(_)  => { return Err(actor_dropped("ping")); }
        }
        match rr.await {
            Ok(r)  => r,
            Err(_) => Err(actor_dropped("ping reply")),
        }
    }

    /// Prepare a server-side statement. Returns a handle the
    /// caller passes to `execute_prepared` / `close_prepared`.
    /// Server-side slot is auto-named (`s0`, `s1`, …) and lives
    /// until `close_prepared` or actor shutdown.
    public async fn prepare(&self, sql: &Text)
        -> Result<AsyncPgPreparedStatement, DbError>
    {
        let (rs, rr) = oneshot();
        match self.tx.send_async(ReqPrepare {
            sql: sql.clone(),
            reply: rs,
        }).await {
            Ok(()) => {}
            Err(_) => { return Err(actor_dropped("prepare")); }
        }
        match rr.await {
            Ok(Ok(stmt)) => Ok(AsyncPgPreparedStatement {
                inner: stmt,
            }),
            Ok(Err(e))   => Err(e),
            Err(_)       => Err(actor_dropped("prepare reply")),
        }
    }

    /// Execute a previously-prepared statement with bound params.
    /// `params` is one entry per `$N` placeholder; `None` for
    /// SQL NULL, `Some(bytes)` for the wire-formatted value.
    public async fn execute_prepared(
        &self,
        stmt: &AsyncPgPreparedStatement,
        params: List<Maybe<List<Byte>>>,
    ) -> Result<PgSimpleQueryResult, DbError> {
        let (rs, rr) = oneshot();
        match self.tx.send_async(ReqExecutePrepared {
            stmt: stmt.inner.clone(),
            params: params,
            reply: rs,
        }).await {
            Ok(()) => {}
            Err(_) => { return Err(actor_dropped("execute_prepared")); }
        }
        match rr.await {
            Ok(r)  => r,
            Err(_) => Err(actor_dropped("execute_prepared reply")),
        }
    }

    /// Typed sibling of `execute_prepared` — binary-format params
    /// + result columns. Returns `PgTypedQueryResult` whose rows
    /// are decoded `List<TypedValue>` per column.
    public async fn execute_prepared_typed(
        &self,
        stmt: &AsyncPgPreparedStatement,
        typed_params: List<Maybe<core.database.postgres.wire.typed.TypedValue>>,
    ) -> Result<core.database.postgres.connection.PgTypedQueryResult, DbError> {
        let (rs, rr) = oneshot();
        match self.tx.send_async(ReqExecutePreparedTyped {
            stmt: stmt.inner.clone(),
            typed_params: typed_params,
            reply: rs,
        }).await {
            Ok(()) => {}
            Err(_) => { return Err(actor_dropped("execute_prepared_typed")); }
        }
        match rr.await {
            Ok(r)  => r,
            Err(_) => Err(actor_dropped("execute_prepared_typed reply")),
        }
    }

    /// Free the server-side slot for the prepared statement.
    public async fn close_prepared(&self, stmt: AsyncPgPreparedStatement)
        -> Result<(), DbError>
    {
        let (rs, rr) = oneshot();
        match self.tx.send_async(ReqClosePrepared {
            stmt: stmt.inner,
            reply: rs,
        }).await {
            Ok(()) => {}
            Err(_) => { return Err(actor_dropped("close_prepared")); }
        }
        match rr.await {
            Ok(r)  => r,
            Err(_) => Err(actor_dropped("close_prepared reply")),
        }
    }

    /// Tear down the actor cleanly — sends `ReqShutdown`, awaits
    /// the actor's `Terminate` reply, then joins the actor task.
    /// Subsequent calls on any clone fail with
    /// `ACTOR_CLOSED`.
    public async fn close(&self) -> Result<(), DbError> {
        let (rs, rr) = oneshot();
        match self.tx.send_async(ReqShutdown { reply: rs }).await {
            Ok(())  => {}
            Err(_)  => { return Err(actor_dropped("close")); }
        }
        let _ = rr.await;     // clean response
        // Take the JoinHandle and await it (best-effort — actor
        // may have already exited).
        let mut guard = self.join.lock().unwrap_or_else(|p| p.into_inner());
        match guard.take() {
            Some(jh) => { let _ = jh.join().await; }
            None     => {}
        }
        Ok(())
    }
}

// =============================================================================
// Constructor — connect + spawn actor
// =============================================================================

/// Establish a sync `PgConnection`, hand it to a `spawn_blocking`
/// actor task, return the caller-side handle.
///
/// `mailbox_capacity` bounds how many requests can sit in-flight
/// before `simple_query`/`execute` start to backpressure the
/// caller (their `send_async` future stays Pending until a slot
/// frees). 64 is a sane default for handler-fan-out workloads.
public async fn connect(
    cfg: &PgConfig,
    mailbox_capacity: Int,
) -> Result<AsyncPgConnection, DbError> {
    // Connection setup is itself a sync call; offload to a
    // blocking pool thread so the caller doesn't block.
    let cfg_owned = cfg.clone();
    let conn_jh = spawn_blocking(move || -> Result<PgConnection, DbError> {
        sync_connect(&cfg_owned)
    });
    let conn = match conn_jh.join().await {
        Ok(r)  => r?,
        Err(_) => { return Err(actor_dropped("connect: blocking-pool join")); }
    };

    // Snapshot connect endpoint + BackendKeyData BEFORE handing
    // the conn to the actor — once the actor owns it, we can no
    // longer read from the sync handle.
    let cancel_host = cfg.host.clone();
    let cancel_port = cfg.port;
    let backend_key = conn.backend_key();

    let cap = if mailbox_capacity < 1 { 1 } else { mailbox_capacity };
    let (tx, rx) = bounded_channel<PgRequest>(cap);

    let join = spawn_blocking(move || -> () {
        run_actor(conn, rx);
    });

    Ok(AsyncPgConnection {
        tx: tx,
        join: Shared.new(sync.mutex.Mutex.new(Some(join))),
        cancel_host: cancel_host,
        cancel_port: cancel_port,
        backend_key: backend_key,
    })
}

// =============================================================================
// Actor body — sync loop on the blocking pool
// =============================================================================

/// Owns the `PgConnection` for its lifetime. Pulls requests from
/// the mailbox synchronously (futex-block per `Receiver.recv`),
/// dispatches one at a time, sends the response back. Exits on
/// `ReqShutdown` or when the mailbox drops (every `Sender` gone).
///
/// Carries an actor-local `PgStmtCache` (default cap 128) so
/// `prepare(sql)` becomes idempotent: identical SQL returns the
/// same `PgPreparedStatement` handle and avoids the wire round-
/// trip + server-side slot allocation. Eviction (LRU) issues
/// `Close S name` on the wire so server-side state stays bounded.
fn run_actor(mut conn: PgConnection, mut rx: Receiver<PgRequest>) {
    let mut cache = PgStmtCache.new();
    loop {
        let req = match rx.recv() {
            Some(r) => r,
            None    => {
                // Every sender dropped — shut down. Best-effort
                // drain of cached statements before disposing the
                // socket, mirroring the explicit `ReqShutdown` path.
                let drained = cache.drain();
                let mut k: Int = 0;
                while k < (drained.len() as Int) {
                    let _ = conn.close_prepared(&drained[k]);
                    k = k + 1;
                }
                break;
            }
        };
        match req {
            ReqSimpleQuery { sql, reply } => {
                let r = conn.simple_query(&sql);
                let _ = reply.send(r);
            }
            ReqExecute { sql, reply } => {
                let r = conn.execute(&sql);
                let _ = reply.send(r);
            }
            ReqPing { reply } => {
                let r = match conn.simple_query(&"SELECT 1".clone()) {
                    Ok(_)  => Ok(()),
                    Err(e) => Err(e),
                };
                let _ = reply.send(r);
            }
            ReqBeginTx { begin_sql, reply } => {
                let r = match conn.execute(&begin_sql) {
                    Ok(_)  => Ok(()),
                    Err(e) => Err(e),
                };
                let _ = reply.send(r);
            }
            ReqCommitTx { reply } => {
                let r = match conn.execute(&"COMMIT".clone()) {
                    Ok(_)  => Ok(()),
                    Err(e) => Err(e),
                };
                let _ = reply.send(r);
            }
            ReqRollbackTx { reply } => {
                let r = match conn.execute(&"ROLLBACK".clone()) {
                    Ok(_)  => Ok(()),
                    Err(e) => Err(e),
                };
                let _ = reply.send(r);
            }
            ReqSavepoint { name, reply } => {
                let sql = f"SAVEPOINT {name}";
                let r = match conn.execute(&sql) {
                    Ok(_)  => Ok(()),
                    Err(e) => Err(e),
                };
                let _ = reply.send(r);
            }
            ReqReleaseSavepoint { name, reply } => {
                let sql = f"RELEASE SAVEPOINT {name}";
                let r = match conn.execute(&sql) {
                    Ok(_)  => Ok(()),
                    Err(e) => Err(e),
                };
                let _ = reply.send(r);
            }
            ReqRollbackToSavepoint { name, reply } => {
                let sql = f"ROLLBACK TO SAVEPOINT {name}";
                let r = match conn.execute(&sql) {
                    Ok(_)  => Ok(()),
                    Err(e) => Err(e),
                };
                let _ = reply.send(r);
            }
            ReqCopyInOpen { sql, chunk_rx, ack } => {
                run_copy_in_subloop(&mut conn, &sql, chunk_rx, ack);
            }
            ReqCopyOutOpen { sql, chunk_tx, ack } => {
                run_copy_out_subloop(&mut conn, &sql, chunk_tx, ack);
            }
            ReqPrepare { sql, reply } => {
                let fp = pg_stmt_fingerprint(&sql);
                let r = match cache.lookup(fp) {
                    Some(cached) => Ok(cached),
                    None => {
                        match conn.prepare(&sql) {
                            Ok(stmt) => {
                                let evicted = cache.insert(fp, clone_prepared(&stmt));
                                match evicted {
                                    Some(e) => { let _ = conn.close_prepared(&e); }
                                    None    => {}
                                }
                                Ok(stmt)
                            }
                            Err(e) => Err(e),
                        }
                    }
                };
                let _ = reply.send(r);
            }
            ReqExecutePrepared { stmt, params, reply } => {
                let r = conn.execute_prepared(&stmt, &params);
                let _ = reply.send(r);
            }
            ReqExecutePreparedTyped { stmt, typed_params, reply } => {
                let r = conn.execute_prepared_typed(&stmt, &typed_params);
                let _ = reply.send(r);
            }
            ReqClosePrepared { stmt, reply } => {
                // Drop the cache slot so a subsequent `prepare(same sql)`
                // re-prepares cleanly. Wire-level Close still goes
                // through.
                let fp = pg_stmt_fingerprint(&stmt.sql);
                let _ = cache.invalidate(fp);
                let r = conn.close_prepared(&stmt);
                let _ = reply.send(r);
            }
            ReqShutdown { reply } => {
                // Drain the cache + close every cached statement on
                // the wire BEFORE closing the connection. Reduces
                // server-side statement-count on graceful shutdown
                // and plays nicely with pgbouncer-style proxies.
                let drained = cache.drain();
                let mut k: Int = 0;
                while k < (drained.len() as Int) {
                    let _ = conn.close_prepared(&drained[k]);
                    k = k + 1;
                }
                // Clean wire shutdown — best-effort.
                let r = conn.close();
                let _ = reply.send(r);
                break;
            }
        }
    }
}

// =============================================================================
// COPY IN sub-loop
// =============================================================================

fn run_copy_in_subloop(
    conn: &mut PgConnection,
    sql: &Text,
    mut chunk_rx: Receiver<CopyInChunk>,
    ack: OneshotSender<Result<(), DbError>>,
) {
    match conn.start_copy_in_session(sql) {
        Ok(())  => { let _ = ack.send(Ok(())); }
        Err(e)  => {
            let _ = ack.send(Err(e));
            return;
        }
    }

    loop {
        let chunk = match chunk_rx.recv() {
            Some(c) => c,
            None    => {
                // Channel closed without an explicit Done/Cancel —
                // writer dropped. Best-effort cancel on the wire.
                let _ = conn.cancel_copy_in_session(&"writer dropped".clone());
                return;
            }
        };
        match chunk {
            CicBytes(b) => {
                match conn.write_copy_in_chunk(b.as_slice()) {
                    Ok(())  => {}
                    Err(_)  => {
                        // Wire failed mid-write — try to drain.
                        let _ = conn.cancel_copy_in_session(&"write failed".clone());
                        return;
                    }
                }
            }
            CicDone(reply) => {
                let r = conn.finish_copy_in_session();
                let _ = reply.send(r);
                return;
            }
            CicCancel { reason, reply } => {
                let r = conn.cancel_copy_in_session(&reason);
                let _ = reply.send(r);
                return;
            }
        }
    }
}

// =============================================================================
// COPY OUT sub-loop
// =============================================================================

fn run_copy_out_subloop(
    conn: &mut PgConnection,
    sql: &Text,
    chunk_tx: Sender<core.database.postgres.async_copy.CopyOutEvent>,
    ack: OneshotSender<Result<(), DbError>>,
) {
    match conn.start_copy_out_session(sql) {
        Ok(())  => { let _ = ack.send(Ok(())); }
        Err(e)  => {
            let _ = ack.send(Err(e));
            return;
        }
    }

    loop {
        match conn.read_copy_out_chunk() {
            Ok(Some(bytes)) => {
                let _ = chunk_tx.send(
                    core.database.postgres.async_copy.CoeBytes(bytes),
                );
            }
            Ok(None) => {
                // CopyDone observed — drain to RFQ for the row count.
                let r = conn.finish_copy_out_session();
                let _ = chunk_tx.send(
                    core.database.postgres.async_copy.CoeDone(r),
                );
                return;
            }
            Err(e) => {
                let _ = chunk_tx.send(
                    core.database.postgres.async_copy.CoeDone(Err(e)),
                );
                return;
            }
        }
    }
}

// =============================================================================
// Helpers
// =============================================================================

fn actor_dropped(what: &str) -> DbError {
    DbError.Adapter(AdapterSpecific {
        adapter: AdPostgres,
        code: "ACTOR_CLOSED".clone(),
        message: f"async PG actor unavailable during {what}",
        retryable: false,
    })
}

/// Clone a `PgPreparedStatement` for the actor's stmt-cache flow.
/// `name` / `sql` / `param_oids` / `row_description` clone cheaply
/// (the heavy bits are heap-shared via the underlying List/Text
/// reference-counting).
fn clone_prepared(s: &PgPreparedStatement) -> PgPreparedStatement {
    PgPreparedStatement {
        name: s.name.clone(),
        sql: s.sql.clone(),
        param_oids: s.param_oids.clone(),
        row_description: s.row_description.clone(),
    }
}
