// =============================================================================
// database/postgres/migrations/mod.vr — Postgres migration adapter entry-point
// =============================================================================
// Layer: 2 (Database — Postgres adapter)
// =============================================================================
//
// Postgres-specific facade over the universal migration subsystem
// (`core/database/common/migrations/`). Re-exports the universal
// types + the Postgres `MigrationStore` impl so callers can:
//
// ```verum
// use core.database.postgres.migrations.*;
//
// let conn = postgres.connect(&config).await?;
// let mut store = store_new(conn, store_config_default());
// let plan = build(vec![
//     migration_new(1, "init".to_text(), CREATE_USERS_SQL.to_text()),
// ])?;
// let runner = runner_new(RmStrict);
// let report = runner.execute(&plan, &mut store, now_ns()).await?;
// ```
//
// **Postgres-specific concerns operationalised here:**
//   * `pg_advisory_lock(<key>)` for concurrent-safety
//   * Transactional DDL when `config.transactional == true`
//   * Postgres-canonical column types (BIGINT / TEXT / TIMESTAMPTZ)
//   * `ON CONFLICT (version) DO UPDATE` for idempotent upsert
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1"),
    declarations: ShapeDeclarations {
        purpose: Some(Purpose {
            role: "Postgres facade for migration subsystem — store + universal re-exports",
            k_min: CveThresholdK.FullWitness,
            v_min: CveThresholdV.TypecheckPlusTests,
            e_min: CveThresholdE.StructurallyReady,
        }),
        substrate:      Some(CognitiveSubstrate.AnalyticDecompositional),
        anchoring:      Some(FormalAnchoring.CurryHowardLawvere),
        e_sense:        Some(ExecutabilitySense.StructuralReadiness),
        self_reference: None,
    },
)
module core.database.postgres.migrations;

// Postgres-specific store
public mount core.database.postgres.migrations.store.{
    PostgresMigrationStore, store_new,
};

// Universal types — re-exported for ergonomic use
public mount core.database.common.migrations.{
    Migration, MigrationStatus,
    MsPending, MsApplied, MsRolledBack, MsFailed,
    migration_new, status_name,
    JournalEntry, MigrationJournal, journal_new, checksum_for_sql,
    MigrationPlan, MigrationPlanError,
    PeDuplicateVersion, PeUnknownDependency, PeCycle,
    build,
    MigrationRunner, RunMode, RunDecision, RunReport,
    RmDryRun, RmStrict, RmContinueOnDrift,
    RdSkip, RdApply, RdSkipDrift, RdAbortDrift,
    runner_new, run_mode_name, decision_kind_name,
    MigrationStore, MigrationStoreConfig, store_config_default,
};
