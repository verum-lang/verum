// =============================================================================
// core/database/mysql/wire/backend.vr — server-packet decoders
// =============================================================================
// Spec: dev.mysql.com/doc/dev/mysql-server/latest/page_protocol_basic_packets.html
//
// Decodes the basic server packet types (Initial Handshake, OK / EOF /
// ERR, AuthSwitchRequest, AuthMoreData) plus ColumnDefinition41.
// All decoders propagate `FrameError` from `wire/frame.vr`; the
// connection layer maps that into the unified `core.database.common.
// error.DbError` once at the API boundary.
// =============================================================================

module core.database.mysql.wire.backend;

mount core.*;
mount base.{Result, Ok, Err, Text, Maybe, None, Some};
mount collections.List;
mount core.database.mysql.wire.frame.{
    FrameError, FeShort, FeBadLength, FeInvalidUtf8,
    decode_lei, read_u8, read_u16_le, read_u32_le, read_cstr, read_bytes,
    read_lenenc_string, LkNull,
};
mount core.database.mysql.wire.types.{
    PKT_OK, PKT_EOF, PKT_ERROR, PKT_AUTH_SW, PKT_AUTH_MORE,
    CSHA2_FAST_AUTH_DONE, CSHA2_FULL_AUTH_NEEDED,
    CAP_PROTOCOL_41, CAP_PLUGIN_AUTH, CAP_PLUGIN_AUTH_LENENC,
    CAP_DEPRECATE_EOF, CAP_SECURE_CONNECTION,
};

// -----------------------------------------------------------------------------
// Initial Handshake (server → client, very first packet)
// -----------------------------------------------------------------------------

public type InitialHandshake is {
    protocol_version: Int,
    server_version: Text,
    connection_id: Int,
    auth_plugin_data: List<Byte>,
    capabilities: Int,
    character_set: Int,
    status_flags: Int,
    auth_plugin_name: Text,
};

public fn parse_initial_handshake(payload: &[Byte]) -> Result<InitialHandshake, FrameError> {
    let mut off: Int = 0;
    let proto = read_u8(payload, off)?;
    off = off + 1;
    if proto != 10 {
        return Err(FeBadLength { len: proto });
    }
    let (server_ver, used) = read_cstr(payload, off)?;
    off = off + used;
    let conn_id = read_u32_le(payload, off)?;
    off = off + 4;
    let scramble = read_bytes(payload, off, 8)?;
    off = off + 8;
    off = off + 1;     // filler 0x00
    let caps_lo = read_u16_le(payload, off)?;
    off = off + 2;
    let charset = read_u8(payload, off)?;
    off = off + 1;
    let status = read_u16_le(payload, off)?;
    off = off + 2;
    let caps_hi = read_u16_le(payload, off)?;
    off = off + 2;
    let caps = caps_lo | (caps_hi << 16);
    let auth_data_len = if (caps & CAP_PLUGIN_AUTH) != 0 {
        let v = read_u8(payload, off)?;
        off = off + 1;
        v
    } else {
        off = off + 1;
        0
    };
    off = off + 10;     // reserved
    let part2_len = if auth_data_len >= 21 { auth_data_len - 8 } else { 13 };
    let part2 = read_bytes(payload, off, part2_len)?;
    off = off + part2_len;

    // Concatenate scramble (drop trailing NUL byte from part2).
    let mut full: List<Byte> = List.new();
    let mut i = 0;
    while i < scramble.len() as Int {
        full.push(scramble[i]);
        i = i + 1;
    }
    let part2_end = if (part2.len() as Int) > 0 { (part2.len() as Int) - 1 } else { 0 };
    let mut k = 0;
    while k < part2_end {
        full.push(part2[k]);
        k = k + 1;
    }

    let mut plugin_name: Text = "".clone();
    if (caps & CAP_PLUGIN_AUTH) != 0 {
        let (s, _) = read_cstr(payload, off)?;
        plugin_name = s;
    }

    Ok(InitialHandshake {
        protocol_version: proto,
        server_version: server_ver,
        connection_id: conn_id,
        auth_plugin_data: full,
        capabilities: caps,
        character_set: charset,
        status_flags: status,
        auth_plugin_name: plugin_name,
    })
}

// -----------------------------------------------------------------------------
// OK packet
// -----------------------------------------------------------------------------

public type OkPacket is {
    affected_rows: Int,
    last_insert_id: Int,
    status_flags: Int,
    warnings: Int,
    info: Text,
};

public fn parse_ok(payload: &[Byte], capabilities: Int) -> Result<OkPacket, FrameError> {
    if (payload.len() as Int) < 1 {
        return Err(FeShort { wanted: 1, available: 0 });
    }
    if payload[0] != PKT_OK {
        return Err(FeBadLength { len: payload[0] as Int });
    }
    let mut off: Int = 1;
    let (affected, _, used) = decode_lei(payload, off)?;
    off = off + used;
    let (last_id, _, used2) = decode_lei(payload, off)?;
    off = off + used2;
    let mut status: Int = 0;
    let mut warnings: Int = 0;
    if (capabilities & CAP_PROTOCOL_41) != 0 {
        status = read_u16_le(payload, off)?;
        off = off + 2;
        warnings = read_u16_le(payload, off)?;
        off = off + 2;
    }
    let mut info_bytes: List<Byte> = List.new();
    let mut i = off;
    while i < payload.len() as Int {
        info_bytes.push(payload[i]);
        i = i + 1;
    }
    let info = match Text.from_bytes(&info_bytes) {
        Ok(t)  => t,
        Err(_) => "".clone(),
    };
    Ok(OkPacket {
        affected_rows: affected,
        last_insert_id: last_id,
        status_flags: status,
        warnings: warnings,
        info: info,
    })
}

// -----------------------------------------------------------------------------
// ERR packet
// -----------------------------------------------------------------------------

public type ErrPacket is {
    code: Int,
    sql_state: Text,
    message: Text,
};

public fn parse_err(payload: &[Byte], capabilities: Int) -> Result<ErrPacket, FrameError> {
    if (payload.len() as Int) < 3 {
        return Err(FeShort { wanted: 3, available: payload.len() as Int });
    }
    if payload[0] != PKT_ERROR {
        return Err(FeBadLength { len: payload[0] as Int });
    }
    let code = read_u16_le(payload, 1)?;
    let mut off: Int = 3;
    let mut sql_state: Text = "".clone();
    if (capabilities & CAP_PROTOCOL_41) != 0 {
        off = off + 1;     // '#' marker
        let bytes = read_bytes(payload, off, 5)?;
        match Text.from_bytes(&bytes) {
            Ok(t)  => { sql_state = t; }
            Err(_) => {}
        }
        off = off + 5;
    }
    let mut msg_bytes: List<Byte> = List.new();
    let mut i = off;
    while i < payload.len() as Int {
        msg_bytes.push(payload[i]);
        i = i + 1;
    }
    let message = match Text.from_bytes(&msg_bytes) {
        Ok(t)  => t,
        Err(_) => "".clone(),
    };
    Ok(ErrPacket { code: code, sql_state: sql_state, message: message })
}

// -----------------------------------------------------------------------------
// AuthSwitchRequest / AuthMoreData
// -----------------------------------------------------------------------------

public type AuthSwitch is {
    plugin_name: Text,
    auth_data: List<Byte>,
};

public fn parse_auth_switch(payload: &[Byte]) -> Result<AuthSwitch, FrameError> {
    if (payload.len() as Int) < 1 || payload[0] != PKT_AUTH_SW {
        return Err(FeBadLength { len: 0 });
    }
    let (name, used) = read_cstr(payload, 1)?;
    let mut data: List<Byte> = List.new();
    let mut i = 1 + used;
    while i < payload.len() as Int {
        data.push(payload[i]);
        i = i + 1;
    }
    if data.len() > 0 && data[(data.len() as Int) - 1] == 0 {
        let _ = data.pop();
    }
    Ok(AuthSwitch { plugin_name: name, auth_data: data })
}

public type AuthMore is { data: List<Byte> };

public fn parse_auth_more(payload: &[Byte]) -> Result<AuthMore, FrameError> {
    if (payload.len() as Int) < 1 || payload[0] != PKT_AUTH_MORE {
        return Err(FeBadLength { len: 0 });
    }
    let mut data: List<Byte> = List.new();
    let mut i = 1;
    while i < payload.len() as Int {
        data.push(payload[i]);
        i = i + 1;
    }
    Ok(AuthMore { data: data })
}

// -----------------------------------------------------------------------------
// ColumnDefinition41
// -----------------------------------------------------------------------------

public type ColumnDef is {
    schema: Text,
    table: Text,
    org_table: Text,
    name: Text,
    org_name: Text,
    character_set: Int,
    column_length: Int,
    column_type: Int,
    flags: Int,
    decimals: Int,
};

public fn parse_column_def(payload: &[Byte]) -> Result<ColumnDef, FrameError> {
    let mut off: Int = 0;
    let (_, u0) = read_lenenc_string(payload, off)?;     off = off + u0;
    let (schema_b,  u1) = read_lenenc_string(payload, off)?; off = off + u1;
    let (table_b,   u2) = read_lenenc_string(payload, off)?; off = off + u2;
    let (otable_b,  u3) = read_lenenc_string(payload, off)?; off = off + u3;
    let (name_b,    u4) = read_lenenc_string(payload, off)?; off = off + u4;
    let (oname_b,   u5) = read_lenenc_string(payload, off)?; off = off + u5;

    // length-encoded fixed-length fields wrapper byte (always 0x0c)
    let (_, _, u6) = decode_lei(payload, off)?;          off = off + u6;
    let charset = read_u16_le(payload, off)?;            off = off + 2;
    let col_len = read_u32_le(payload, off)?;            off = off + 4;
    let col_type = read_u8(payload, off)?;               off = off + 1;
    let flags = read_u16_le(payload, off)?;              off = off + 2;
    let dec = read_u8(payload, off)?;                    off = off + 1;

    Ok(ColumnDef {
        schema:    bytes_to_text(&schema_b),
        table:     bytes_to_text(&table_b),
        org_table: bytes_to_text(&otable_b),
        name:      bytes_to_text(&name_b),
        org_name:  bytes_to_text(&oname_b),
        character_set: charset,
        column_length: col_len,
        column_type: col_type,
        flags: flags,
        decimals: dec,
    })
}

fn bytes_to_text(o: &Maybe<List<Byte>>) -> Text {
    match o {
        None    => "".clone(),
        Some(v) => match Text.from_bytes(v) { Ok(t) => t, Err(_) => "".clone() },
    }
}

// -----------------------------------------------------------------------------
// First-byte dispatcher.
// -----------------------------------------------------------------------------

public type ServerPacketKind is
      SkOk
    | SkError
    | SkEof
    | SkAuthSwitch
    | SkAuthMore
    | SkLocalInfile
    | SkData;

public fn classify(payload: &[Byte], capabilities: Int) -> ServerPacketKind {
    if payload.len() == 0 { return SkData; }
    let b = payload[0];
    if b == PKT_ERROR { return SkError; }
    if b == PKT_OK && (payload.len() as Int) >= 7 {
        return SkOk;
    }
    if b == PKT_EOF && (payload.len() as Int) < 9 {
        return SkEof;
    }
    if b == PKT_AUTH_SW {
        if (payload.len() as Int) > 5 {
            return SkAuthSwitch;
        }
        return SkEof;
    }
    if b == PKT_AUTH_MORE { return SkAuthMore; }
    if b == (0xFB as Byte) { return SkLocalInfile; }
    SkData
}
