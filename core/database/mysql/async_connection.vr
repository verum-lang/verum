// =============================================================================
// core/database/mysql/async_connection.vr — async wrapper over sync MySQL wire
// =============================================================================
// Layer: 3 (Database — mysql adapter)
// Spec: internal/specs/database.md §6.3.6 (async surface).
// =============================================================================
//
// Mirror of `core/database/postgres/async_connection.vr` against
// the MySQL wire. Same actor-per-connection pattern: each
// `MysqlConnection` runs on a dedicated `spawn_blocking` task; the
// caller-side `AsyncMysqlConnection` is an mpsc Sender + actor
// JoinHandle.
//
// Sync MysqlConnection canonical / unchanged. All blocking I/O
// stays on the dedicated blocking-pool thread; the async executor
// is never blocked.
//
// V0 surface — covers the canonical operations used by every
// AsyncMysqlDatabase consumer:
//   * `simple_query(sql)` → Future<Result<MySimpleQueryResult, …>>
//   * `execute(sql)`      → Future<Result<Int, …>>  (affected_rows)
//   * `ping()`            → Future<Result<(), …>>
//   * `close()`           → Future<Result<(), …>>
//
// Out of V0 (each follow-up):
//   * Prepared statements (PreparedSession lives caller-side; an
//     async wrapper needs a per-actor cache).
//   * MySQL X protocol (separate sub-protocol, separate actor).
//   * Multi-statement results.
// =============================================================================

@arch_module(
    exposes: [Capability.Read(ResourceTag.Database("*")), Capability.Write(ResourceTag.Database("*")), Capability.Persist(PersistenceMedium.DatabaseMedium("*")), Capability.Network(NetProtocol.Tcp, NetDirection.Bidirectional)],
    requires: [Capability.Exec(ExecTarget.Syscall(0)), Capability.Network(NetProtocol.Tcp, NetDirection.Bidirectional)],
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LCls,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.database.mysql.async_connection;

mount core.*;
mount base.{Result, Ok, Err, Text, Maybe, None, Some, Bool};
mount collections.List;
mount core.database.common.error.{
    DbError, AdapterId, AdMysql, AdapterSpecific,
};
mount core.database.mysql.connection.{
    MysqlConnection, MySimpleQueryResult,
    MysqlPreparedStatement, MysqlPreparedResult,
    connect as sync_connect,
};
mount core.database.mysql.wire.frontend.StmtParam;
mount core.database.mysql.config.MysqlConfig;
mount core.async.channel.{
    Sender, Receiver, OneshotSender,
    bounded_channel, oneshot,
};
mount core.async.task.{spawn_blocking, JoinHandle};

// =============================================================================
// Request enum
// =============================================================================

public type MysqlRequest is
      MyReqSimpleQuery {
        sql: Text,
        reply: OneshotSender<Result<MySimpleQueryResult, DbError>>,
    }
    | MyReqExecute {
        sql: Text,
        reply: OneshotSender<Result<Int, DbError>>,
    }
    /// Multi-statement COM_QUERY — `;`-separated SQL where each
    /// statement returns one result-set. Reply carries the list
    /// in declaration order; ERR mid-batch terminates the entire
    /// batch and the prior results are surfaced via the Err
    /// path's structured-source-info trail.
    | MyReqMultiQuery {
        sql: Text,
        reply: OneshotSender<Result<List<MySimpleQueryResult>, DbError>>,
    }
    | MyReqPing {
        reply: OneshotSender<Result<(), DbError>>,
    }
    | MyReqBeginTx {
        begin_sql: Text,
        reply: OneshotSender<Result<(), DbError>>,
    }
    | MyReqCommitTx {
        reply: OneshotSender<Result<(), DbError>>,
    }
    | MyReqRollbackTx {
        reply: OneshotSender<Result<(), DbError>>,
    }
    | MyReqSavepoint {
        name: Text,
        reply: OneshotSender<Result<(), DbError>>,
    }
    | MyReqReleaseSavepoint {
        name: Text,
        reply: OneshotSender<Result<(), DbError>>,
    }
    | MyReqRollbackToSavepoint {
        name: Text,
        reply: OneshotSender<Result<(), DbError>>,
    }
    /// Open a streaming LOAD DATA LOCAL INFILE session. Actor
    /// takes over the wire, acks via `ack`, then drives a sub-loop
    /// reading from `chunk_rx` until Done/Cancel — same pattern
    /// as PG's ReqCopyInOpen.
    | MyReqLoadDataLocalOpen {
        sql: Text,
        chunk_rx: Receiver<LoadDataChunk>,
        ack: OneshotSender<Result<(), DbError>>,
    }
    /// COM_STMT_PREPARE — server-side prepared statement.
    /// Reply carries the handle (statement_id + param/column
    /// metadata). Caller passes via execute_prepared.
    | MyReqPrepare {
        sql: Text,
        reply: OneshotSender<Result<MysqlPreparedStatement, DbError>>,
    }
    /// COM_STMT_EXECUTE.
    | MyReqExecutePrepared {
        stmt: MysqlPreparedStatement,
        params: List<StmtParam>,
        reply: OneshotSender<Result<MysqlPreparedResult, DbError>>,
    }
    /// COM_STMT_CLOSE — frees the server-side statement_id.
    | MyReqClosePrepared {
        stmt: MysqlPreparedStatement,
        reply: OneshotSender<Result<(), DbError>>,
    }
    | MyReqShutdown {
        reply: OneshotSender<Result<(), DbError>>,
    };

/// Per-chunk write event the LOAD-DATA sub-loop pulls from its
/// dedicated channel. `LdcDone` carries a oneshot the writer's
/// `finish()` future awaits — replies with the OK packet's
/// affected_rows count.
public type LoadDataChunk is
      LdcBytes(List<Byte>)
    | LdcDone(OneshotSender<Result<Int, DbError>>)
    | LdcCancel { reason: Text, reply: OneshotSender<Result<(), DbError>> };

// =============================================================================
// Public handle
// =============================================================================

public type AsyncMysqlConnection is {
    tx: Sender<MysqlRequest>,
    join: Shared<sync.mutex.Mutex<Maybe<JoinHandle<()>>>>,
    /// MySQL thread-id (server's `connection_id` from initial
    /// handshake). Required input to `KILL QUERY <id>`. Captured
    /// once at connect time so cancel doesn't round-trip the
    /// busy actor.
    connection_id: Int,
    /// Cached MysqlConfig — the side-cancel session re-opens
    /// against the same server using these credentials.
    /// `KILL QUERY` only works when the killer is the same user
    /// (or has PROCESS privilege); using the same cfg keeps
    /// it inside MySQL's same-user gate without any extra
    /// privilege.
    cancel_cfg: MysqlConfig,
};

implement AsyncMysqlConnection {
    public fn clone(&self) -> AsyncMysqlConnection {
        AsyncMysqlConnection {
            tx: self.tx.clone(),
            join: self.join.clone(),
            connection_id: self.connection_id,
            cancel_cfg: self.cancel_cfg.clone(),
        }
    }

    public fn tx_ref(&self) -> &Sender<MysqlRequest> { &self.tx }

    /// Cached MySQL connection_id (thread id). Required input
    /// to KILL QUERY. Returns 0 when the handshake didn't
    /// populate it (extremely rare — pre-3.21 servers).
    public fn connection_id(&self) -> Int { self.connection_id }

    /// Issue `KILL QUERY <connection_id>` from a fresh side
    /// connection to abort the current statement on the actor's
    /// connection. Best-effort — server may have already
    /// finished the query.
    ///
    /// Bypasses the actor entirely: spawn_blocking opens a fresh
    /// sync MysqlConnection using the cached cfg, sends the
    /// KILL command, closes. The actor's connection stays
    /// blocked on its current read, but the server-side query
    /// terminates with ER_QUERY_INTERRUPTED so the actor's
    /// recv_packet returns with that error.
    public async fn cancel_running_query(&self) -> Result<(), DbError> {
        if self.connection_id == 0 {
            return Err(DbError.Adapter(AdapterSpecific {
                adapter: AdMysql,
                code: "CANCEL_NO_CONN_ID".clone(),
                message: "connection_id absent — handshake didn't populate".clone(),
                retryable: false,
            }));
        }
        self.fire_kill(false).await
    }

    /// Issue bare `KILL <connection_id>` — terminates the entire
    /// session, not just the running statement. Use sparingly:
    /// the actor's wire dies + every subsequent request fails
    /// with ACTOR_CLOSED.
    public async fn cancel_session(&self) -> Result<(), DbError> {
        if self.connection_id == 0 {
            return Err(DbError.Adapter(AdapterSpecific {
                adapter: AdMysql,
                code: "CANCEL_NO_CONN_ID".clone(),
                message: "connection_id absent — handshake didn't populate".clone(),
                retryable: false,
            }));
        }
        self.fire_kill(true).await
    }

    async fn fire_kill(&self, full_session: Bool) -> Result<(), DbError> {
        let cfg = self.cancel_cfg.clone();
        let conn_id = self.connection_id;
        let jh = spawn_blocking(move || -> Result<(), DbError> {
            let mut side = sync_connect(&cfg)?;
            let sql = if full_session {
                f"KILL {conn_id}"
            } else {
                f"KILL QUERY {conn_id}"
            };
            let r = side.simple_query(&sql);
            let _ = side.close();
            match r {
                Ok(_)  => Ok(()),
                Err(e) => Err(e),
            }
        });
        match jh.join().await {
            Ok(r)  => r,
            Err(_) => Err(actor_dropped("cancel: blocking-pool join")),
        }
    }

    /// Wire a CancellationToken — when it flips, automatically
    /// fire `cancel_running_query()` so the SERVER-side query
    /// terminates without caller intervention. Spawns a one-shot
    /// background watcher task that awaits `token.cancelled()`.
    ///
    /// The watcher exits naturally when the token fires; if the
    /// connection closes first, the cancel becomes a no-op
    /// (KILL QUERY against a missing thread id silently ignored).
    ///
    /// Multiple tokens may be attached — each spawns its own
    /// watcher; ANY one firing triggers the cancel.
    public fn attach_cancellation_token(
        &self,
        token: core.async.cancellation.CancellationToken,
    ) {
        let conn_clone = self.clone();
        let _ = core.async.task.spawn(async move {
            let _ = token.cancelled().await;
            let _ = conn_clone.cancel_running_query().await;
        });
    }

    public async fn simple_query(&self, sql: &Text)
        -> Result<MySimpleQueryResult, DbError>
    {
        let (rs, rr) = oneshot();
        match self.tx.send_async(MyReqSimpleQuery {
            sql: sql.clone(),
            reply: rs,
        }).await {
            Ok(()) => {}
            Err(_) => { return Err(actor_dropped("simple_query")); }
        }
        match rr.await {
            Ok(r)  => r,
            Err(_) => Err(actor_dropped("simple_query reply")),
        }
    }

    public async fn execute(&self, sql: &Text) -> Result<Int, DbError> {
        let (rs, rr) = oneshot();
        match self.tx.send_async(MyReqExecute {
            sql: sql.clone(),
            reply: rs,
        }).await {
            Ok(()) => {}
            Err(_) => { return Err(actor_dropped("execute")); }
        }
        match rr.await {
            Ok(r)  => r,
            Err(_) => Err(actor_dropped("execute reply")),
        }
    }

    /// Multi-statement COM_QUERY — `;`-separated SQL where each
    /// statement returns one result-set. Reply carries the list
    /// in declaration order. Mirror of sync MysqlConnection
    /// .multi_query.
    public async fn multi_query(&self, sql: &Text)
        -> Result<List<MySimpleQueryResult>, DbError>
    {
        let (rs, rr) = oneshot();
        match self.tx.send_async(MyReqMultiQuery {
            sql: sql.clone(),
            reply: rs,
        }).await {
            Ok(()) => {}
            Err(_) => { return Err(actor_dropped("multi_query")); }
        }
        match rr.await {
            Ok(r)  => r,
            Err(_) => Err(actor_dropped("multi_query reply")),
        }
    }

    public async fn ping(&self) -> Result<(), DbError> {
        let (rs, rr) = oneshot();
        match self.tx.send_async(MyReqPing { reply: rs }).await {
            Ok(()) => {}
            Err(_) => { return Err(actor_dropped("ping")); }
        }
        match rr.await {
            Ok(r)  => r,
            Err(_) => Err(actor_dropped("ping reply")),
        }
    }

    public async fn close(&self) -> Result<(), DbError> {
        let (rs, rr) = oneshot();
        match self.tx.send_async(MyReqShutdown { reply: rs }).await {
            Ok(()) => {}
            Err(_) => { return Err(actor_dropped("close")); }
        }
        let _ = rr.await;
        let mut guard = self.join.lock().unwrap_or_else(|p| p.into_inner());
        match guard.take() {
            Some(jh) => { let _ = jh.join().await; }
            None     => {}
        }
        Ok(())
    }

    /// COM_STMT_PREPARE — server-side prepared statement.
    /// Returns a handle that's valid for the lifetime of this
    /// connection; caller MUST `close_prepared` to release the
    /// server-side slot before the connection ends.
    public async fn prepare(&self, sql: &Text)
        -> Result<AsyncMysqlPreparedStatement, DbError>
    {
        let (rs, rr) = oneshot();
        match self.tx.send_async(MyReqPrepare {
            sql: sql.clone(),
            reply: rs,
        }).await {
            Ok(()) => {}
            Err(_) => { return Err(actor_dropped("prepare")); }
        }
        match rr.await {
            Ok(Ok(stmt)) => Ok(AsyncMysqlPreparedStatement { inner: stmt }),
            Ok(Err(e))   => Err(e),
            Err(_)       => Err(actor_dropped("prepare reply")),
        }
    }

    /// COM_STMT_EXECUTE — bind params + run. Returns the
    /// binary-protocol payload (rows + affected_rows).
    public async fn execute_prepared(
        &self,
        stmt: &AsyncMysqlPreparedStatement,
        params: List<StmtParam>,
    ) -> Result<MysqlPreparedResult, DbError> {
        let (rs, rr) = oneshot();
        match self.tx.send_async(MyReqExecutePrepared {
            stmt: stmt.inner.clone(),
            params: params,
            reply: rs,
        }).await {
            Ok(()) => {}
            Err(_) => { return Err(actor_dropped("execute_prepared")); }
        }
        match rr.await {
            Ok(r)  => r,
            Err(_) => Err(actor_dropped("execute_prepared reply")),
        }
    }

    /// COM_STMT_CLOSE — frees the server-side slot.
    public async fn close_prepared(&self, stmt: AsyncMysqlPreparedStatement)
        -> Result<(), DbError>
    {
        let (rs, rr) = oneshot();
        match self.tx.send_async(MyReqClosePrepared {
            stmt: stmt.inner,
            reply: rs,
        }).await {
            Ok(()) => {}
            Err(_) => { return Err(actor_dropped("close_prepared")); }
        }
        match rr.await {
            Ok(r)  => r,
            Err(_) => Err(actor_dropped("close_prepared reply")),
        }
    }
}

// =============================================================================
// Async prepared-statement handle
// =============================================================================

/// Async wrapper over the sync MysqlPreparedStatement. Holds the
/// server-allocated statement_id + descriptor so the actor can
/// dispatch execute/close requests by value. Plain (not affine)
/// — caller MUST call `close_prepared` to free the slot.
public type AsyncMysqlPreparedStatement is {
    inner: MysqlPreparedStatement,
};

implement AsyncMysqlPreparedStatement {
    public fn inner(&self) -> &MysqlPreparedStatement { &self.inner }
    public fn statement_id(&self) -> Int { self.inner.statement_id }
    public fn num_params(&self) -> Int { self.inner.num_params }
    public fn num_columns(&self) -> Int { self.inner.num_columns }
}

// =============================================================================
// Constructor
// =============================================================================

public async fn connect(
    cfg: &MysqlConfig,
    mailbox_capacity: Int,
) -> Result<AsyncMysqlConnection, DbError> {
    let cfg_owned = cfg.clone();
    let cancel_cfg = cfg.clone();
    let conn_jh = spawn_blocking(move || -> Result<MysqlConnection, DbError> {
        sync_connect(&cfg_owned)
    });
    let conn = match conn_jh.join().await {
        Ok(r)  => r?,
        Err(_) => { return Err(actor_dropped("connect: blocking-pool join")); }
    };

    // Snapshot connection_id BEFORE handing the conn to the
    // actor — once the actor owns it, we can no longer read
    // from the sync handle.
    let connection_id = conn.connection_id();

    let cap = if mailbox_capacity < 1 { 1 } else { mailbox_capacity };
    let (tx, rx) = bounded_channel::<MysqlRequest>(cap);

    let join = spawn_blocking(move || -> () {
        run_actor(conn, rx);
    });

    Ok(AsyncMysqlConnection {
        tx: tx,
        join: Shared.new(sync.mutex.Mutex.new(Some(join))),
        connection_id: connection_id,
        cancel_cfg: cancel_cfg,
    })
}

// =============================================================================
// Actor body
// =============================================================================

fn run_actor(mut conn: MysqlConnection, mut rx: Receiver<MysqlRequest>) {
    loop {
        let req = match rx.recv() {
            Some(r) => r,
            None    => { break; }
        };
        match req {
            MyReqSimpleQuery { sql, reply } => {
                let r = conn.simple_query(&sql);
                let _ = reply.send(r);
            }
            MyReqExecute { sql, reply } => {
                let r = conn.execute(&sql);
                let _ = reply.send(r);
            }
            MyReqMultiQuery { sql, reply } => {
                let r = conn.multi_query(&sql);
                let _ = reply.send(r);
            }
            MyReqPing { reply } => {
                let r = conn.ping();
                let _ = reply.send(r);
            }
            MyReqBeginTx { begin_sql, reply } => {
                let r = match conn.execute(&begin_sql) {
                    Ok(_)  => Ok(()),
                    Err(e) => Err(e),
                };
                let _ = reply.send(r);
            }
            MyReqCommitTx { reply } => {
                let r = match conn.execute(&"COMMIT".clone()) {
                    Ok(_)  => Ok(()),
                    Err(e) => Err(e),
                };
                let _ = reply.send(r);
            }
            MyReqRollbackTx { reply } => {
                let r = match conn.execute(&"ROLLBACK".clone()) {
                    Ok(_)  => Ok(()),
                    Err(e) => Err(e),
                };
                let _ = reply.send(r);
            }
            MyReqSavepoint { name, reply } => {
                let sql = f"SAVEPOINT {name}";
                let r = match conn.execute(&sql) {
                    Ok(_)  => Ok(()),
                    Err(e) => Err(e),
                };
                let _ = reply.send(r);
            }
            MyReqReleaseSavepoint { name, reply } => {
                let sql = f"RELEASE SAVEPOINT {name}";
                let r = match conn.execute(&sql) {
                    Ok(_)  => Ok(()),
                    Err(e) => Err(e),
                };
                let _ = reply.send(r);
            }
            MyReqRollbackToSavepoint { name, reply } => {
                let sql = f"ROLLBACK TO SAVEPOINT {name}";
                let r = match conn.execute(&sql) {
                    Ok(_)  => Ok(()),
                    Err(e) => Err(e),
                };
                let _ = reply.send(r);
            }
            MyReqLoadDataLocalOpen { sql, chunk_rx, ack } => {
                run_load_data_subloop(&mut conn, &sql, chunk_rx, ack);
            }
            MyReqPrepare { sql, reply } => {
                let r = conn.prepare(&sql);
                let _ = reply.send(r);
            }
            MyReqExecutePrepared { stmt, params, reply } => {
                let r = conn.execute_prepared(&stmt, &params);
                let _ = reply.send(r);
            }
            MyReqClosePrepared { stmt, reply } => {
                let r = conn.close_prepared(&stmt);
                let _ = reply.send(r);
            }
            MyReqShutdown { reply } => {
                let r = conn.close();
                let _ = reply.send(r);
                break;
            }
        }
    }
}

// =============================================================================
// LOAD DATA LOCAL INFILE sub-loop
// =============================================================================

fn run_load_data_subloop(
    conn: &mut MysqlConnection,
    sql: &Text,
    mut chunk_rx: Receiver<LoadDataChunk>,
    ack: OneshotSender<Result<(), DbError>>,
) {
    match conn.start_load_data_local_session(sql) {
        Ok(())  => { let _ = ack.send(Ok(())); }
        Err(e)  => {
            let _ = ack.send(Err(e));
            return;
        }
    }

    loop {
        let chunk = match chunk_rx.recv() {
            Some(c) => c,
            None    => {
                // Writer dropped without explicit Done/Cancel —
                // best-effort cancel on the wire.
                let _ = conn.cancel_load_data_local_session(&"writer dropped".clone());
                return;
            }
        };
        match chunk {
            LdcBytes(b) => {
                match conn.write_load_data_chunk(b.as_slice()) {
                    Ok(())  => {}
                    Err(_)  => {
                        let _ = conn.cancel_load_data_local_session(&"write failed".clone());
                        return;
                    }
                }
            }
            LdcDone(reply) => {
                let r = conn.finish_load_data_local_session();
                let _ = reply.send(r);
                return;
            }
            LdcCancel { reason, reply } => {
                let r = conn.cancel_load_data_local_session(&reason);
                let _ = reply.send(r);
                return;
            }
        }
    }
}

fn actor_dropped(what: &str) -> DbError {
    DbError.Adapter(AdapterSpecific {
        adapter: AdMysql,
        code: "ACTOR_CLOSED".clone(),
        message: f"async MySQL actor unavailable during {what}",
        retryable: false,
    })
}
