// =============================================================================
// core/database/mysql/typed_prepared.vr — typed prepared-result decoder
// =============================================================================
// Layer: 3 (Database — mysql adapter)
// Spec: internal/specs/database.md §6.3.4 (binary protocol prepared cache).
// =============================================================================
//
// MysqlPreparedResult.rows surface as raw binary-protocol bytes
// (`List<List<Maybe<List<Byte>>>>`). Per cell the bytes encode
// the column's value per its `field_type` from
// MysqlPreparedStatement.column_types. Production consumers want
// decoded `RowValue` per cell + the typed-row composition the
// binlog decoder already provides.
//
// V0 — reuse the existing per-column decoder:
//
//   binlog_rows.vr's `decode_value_for_type(buf, off, &meta)` is
//   the canonical MySQL binary-protocol per-column decoder. It's
//   used by the binlog ROW pump AND now by this module. Both
//   produce payloads in the same wire format (per-field-type
//   byte + per-type encoding); the ColumnMeta-based dispatch
//   works for either source.
//
// V0 surface:
//   * typed_prepared_row(row, column_types) →
//        Result<List<RowValue>, DbError>
//     Walks the raw cell bytes paired with column_types,
//     synthesises a minimal ColumnMeta per cell, decodes via
//     decode_value_for_type. None cells → RvNull.
//
//   * typed_prepared_rows(result, stmt) →
//        Result<List<List<RowValue>>, DbError>
//     Convenience that lifts every row in a result against the
//     statement's column_types.
//
// MysqlTypedRow (existing) lifts each List<RowValue> into a
// typed Verum value (Int / Text / tuple / Maybe<T>) — same shape
// as PG's TypedRow. So end-to-end: prepare → execute_prepared →
// typed_prepared_rows → rows_typed_my<R>.
//
// OUT of V0:
//   * Typed PARAMS via TypedValue (current uses raw StmtParam —
//     adapter caller-side maps TypedValue→StmtParam).
//   * Per-column ColumnMeta extension carrying optional metadata
//     (TABLE_MAP-style ENUM_STR_VALUE / SIGNEDNESS) — prepared
//     statements don't ship that block; consumers use prepared
//     for known schemas where ENUM/SET semantics are caller
//     knowledge.
// =============================================================================

@arch_module(
    exposes: [Capability.Read(ResourceTag.Database("*"))],
    requires: [],
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LCls,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.database.mysql.typed_prepared;

mount core.*;
mount base.{Result, Ok, Err, Text, Maybe, None, Some, Bool};
mount collections.List;
mount core.database.common.error.{
    DbError, AdapterId, AdMysql, AdapterSpecific,
};
mount core.database.mysql.connection.{
    MysqlPreparedStatement, MysqlPreparedResult,
};
mount core.database.mysql.binlog_rows.{
    ColumnMeta, RowValue, RvNull,
    decode_value_for_type,
};

// =============================================================================
// typed_prepared_row — single-row decoder
// =============================================================================

/// Decode one prepared-statement row's raw cell bytes against
/// the per-column field_type list (typically
/// MysqlPreparedStatement.column_types). Position-aligned with
/// `row`; arity mismatch surfaces as a structured error.
///
/// `None` cells → RvNull (server marked NULL via the binary
/// protocol's NULL-bitmap). Present cells decode via the
/// canonical MySQL binary-protocol per-column decoder shared
/// with the binlog ROW pump.
public fn typed_prepared_row(
    row: &List<Maybe<List<Byte>>>,
    column_types: &List<Int>,
) -> Result<List<RowValue>, DbError> {
    let n = row.len() as Int;
    let m = column_types.len() as Int;
    if n != m {
        return Err(DbError.Adapter(AdapterSpecific {
            adapter: AdMysql,
            code: "PREPARED_ROW_ARITY".clone(),
            message: f"typed_prepared_row: row has {n} cells, column_types {m}",
            retryable: false,
        }));
    }
    let mut out: List<RowValue> = List.with_capacity(n);
    let mut i: Int = 0;
    while i < n {
        match &row[i] {
            None => { out.push(RvNull); }
            Some(bytes) => {
                // Synthesise a minimal ColumnMeta. metadata=0 is
                // safe — the prepared-row decoder doesn't carry
                // VARCHAR-max-length / decimal precision info on
                // the wire (those live in MyColumnDef which the
                // caller can inspect separately if needed).
                let meta = ColumnMeta {
                    column_type: column_types[i],
                    metadata: 0,
                    nullable: true,
                    unsigned: false,
                    string_values: List.new(),
                };
                let (v, _adv) = decode_value_for_type(bytes.as_slice(), 0, &meta)?;
                out.push(v);
            }
        }
        i = i + 1;
    }
    Ok(out)
}

/// Convenience — lift every row in a `MysqlPreparedResult`
/// against the statement's `column_types`. Errors short-circuit
/// on first failing row.
public fn typed_prepared_rows(
    result: &MysqlPreparedResult,
    stmt: &MysqlPreparedStatement,
) -> Result<List<List<RowValue>>, DbError> {
    let mut out: List<List<RowValue>> = List.with_capacity(result.rows.len());
    let mut i: Int = 0;
    while i < (result.rows.len() as Int) {
        let r = typed_prepared_row(&result.rows[i], &stmt.column_types);
        match r {
            Ok(v)  => { out.push(v); }
            Err(e) => {
                return Err(DbError.Adapter(AdapterSpecific {
                    adapter: AdMysql,
                    code: "PREPARED_ROWS_DECODE".clone(),
                    message: f"row {i}: {e}",
                    retryable: false,
                }));
            }
        }
        i = i + 1;
    }
    Ok(out)
}
