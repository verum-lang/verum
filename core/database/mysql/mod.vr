// =============================================================================
// core/database/mysql/mod.vr — Spindle MySQL adapter (pure-Verum)
// =============================================================================
// Layer: 3 (Database — mysql adapter)
// Spec: internal/specs/database.md §6.3
// =============================================================================
//
// Pure-Verum MySQL 8.0 binary protocol implementation. No FFI to
// libmysqlclient.
//
//   wire.{frame,frontend,backend,types}    — packet framing + taxonomies
//   auth.caching_sha2                      — caching_sha2_password (8.0+ default)
//   error                                  — MySQL error → DbError
//   config                                 — MysqlConfig
//   connection                             — handshake + COM_QUERY
//   adapter                                — Spindle vendor identity
// =============================================================================

module core.database.mysql;

public module wire;
public module auth;
public module error;
public module config;
public module connection;
public module adapter;
public module pool;
public module introspect;
public module transaction;

public mount .config.{
    MysqlConfig, MysqlTlsMode, MtmDisable, MtmRequired,
};
public mount .connection.{
    MysqlConnection, MysqlConnState, MySimpleQueryResult,
    MysqlTextValue, MtvNull, MtvBytes,
    MysqlPreparedStatement, MysqlPreparedResult,
    McsConnecting, McsAuthenticating, McsReady, McsBusy, McsClosed, McsFailed,
    connect,
};
public mount .wire.frontend.{
    StmtParam, SpNull, SpTinyInt, SpShort, SpLong, SpLongLong,
    SpDouble, SpFloat, SpString, SpBlob,
    param_null, param_int, param_text, param_blob, param_double,
};
public mount .adapter.MysqlAdapter;
public mount .error.dberr_from_mysql;
public mount .pool.MysqlPool;
public mount .introspect.introspect as introspect_mysql;
public mount .transaction.{
    MysqlTransaction, MyTxKind, MyTxOpts, MyAccessMode,
    MyTkRepeatableRead, MyTkReadCommitted, MyTkReadUncommitted, MyTkSerializable,
    MyAmReadWrite, MyAmReadOnly,
    my_tx_opts_default,
    begin_tx, begin_tx_with,
    begin_tx_serializable, begin_tx_read_only,
    commit_tx, rollback_tx,
    savepoint, release_savepoint, rollback_to_savepoint,
    with_transaction, with_transaction_serializable,
};
