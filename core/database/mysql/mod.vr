// =============================================================================
// core/database/mysql/mod.vr — Spindle MySQL adapter (pure-Verum)
// =============================================================================
// Layer: 3 (Database — mysql adapter)
// Spec: internal/specs/database.md §6.3
// =============================================================================
//

// Pure-Verum MySQL 8.0 binary protocol implementation. No FFI to
// libmysqlclient.
//

//  wire.{frame,frontend,backend,types} — packet framing + taxonomies
//  auth.caching_sha2 — caching_sha2_password (8.0+ default)
//  error — MySQL error → DbError
//  config — MysqlConfig
//  connection — handshake + COM_QUERY
//  adapter — Spindle vendor identity
// =============================================================================

@arch_module(
    exposes: [Capability.Read(ResourceTag.Database("*")), Capability.Write(ResourceTag.Database("*")), Capability.Persist(PersistenceMedium.DatabaseMedium("*")), Capability.Network(NetProtocol.Tcp, NetDirection.Bidirectional)],
    requires: [Capability.Exec(ExecTarget.Syscall(0)), Capability.Network(NetProtocol.Tcp, NetDirection.Bidirectional)],
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LCls,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.database.mysql;

public module mysql_stream;
public module wire;
public module auth;
public module error;
public module config;
public module connection;
public module stmt_cache;
public module prepared;
public module adapter;
public module pool;
public module typed_database;
public module introspect;
public module transaction;
public module async_connection;
public module async_pool;
public module async_transaction;
public module async_typed_database;
public module binlog;
public module binlog_rows;
public module async_binlog;
public module async_binlog_consumer;
public module typed_row;
public module json_binary;
public module async_load_data;
public module wkb_decoder;
public module async_prepared_session;
public module typed_prepared;
public module gtid;
public module load_data_csv;

public mount .config.{
    MysqlConfig, MysqlTlsMode,
    MtmDisable, MtmPreferred, MtmRequired, MtmVerifyCa, MtmVerifyIdentity,
};
public mount .mysql_stream.{MysqlStream, MsPlain, MsTls};
public mount .connection.{
    MysqlConnection, MysqlConnState, MySimpleQueryResult,
    MysqlTextValue, MtvNull, MtvBytes,
    MysqlPreparedStatement, MysqlPreparedResult,
    McsConnecting, McsAuthenticating, McsReady, McsBusy, McsClosed, McsFailed,
    connect,
};
public mount .wire.frontend.{
    StmtParam, SpNull, SpTinyInt, SpShort, SpLong, SpLongLong,
    SpDouble, SpFloat, SpString, SpBlob,
    param_null, param_int, param_text, param_blob, param_double,
};
public mount .stmt_cache.{
    MysqlStmtCache, MysqlStmtCacheMetrics, MyCacheEntry,
    DEFAULT_MYSQL_STMT_CACHE_CAP, fingerprint as stmt_fingerprint,
};
public mount .prepared.{
    PreparedSession, MY_ER_UNKNOWN_STMT_HANDLER,
};
public mount .typed_database.{
    MysqlTxScope,
    mysql_database_from_pool, mysql_admin_database_from_pool,
    mysql_readonly_database_from_pool,
};
public mount .adapter.MysqlAdapter;
public mount .error.dberr_from_mysql;
public mount .pool.MysqlPool;
public mount .introspect.introspect as introspect_mysql;
public mount .transaction.{
    MysqlTransaction, MyTxKind, MyTxOpts, MyAccessMode,
    MyTkRepeatableRead, MyTkReadCommitted, MyTkReadUncommitted, MyTkSerializable,
    MyAmReadWrite, MyAmReadOnly,
    my_tx_opts_default,
    begin_tx, begin_tx_with,
    begin_tx_serializable, begin_tx_read_only,
    commit_tx, rollback_tx,
    savepoint, release_savepoint, rollback_to_savepoint,
    with_transaction, with_transaction_serializable,
};
public mount .async_connection.{
    AsyncMysqlConnection, AsyncMysqlPreparedStatement,
    connect as async_mysql_connect,
};
public mount .async_prepared_session.{
    AsyncMysqlPreparedSession,
    MY_ER_UNKNOWN_STMT_HANDLER as ASYNC_MY_ER_UNKNOWN_STMT_HANDLER,
};
public mount .typed_prepared.{
    typed_prepared_row, typed_prepared_rows,
};
public mount .gtid.{
    GnoInterval, GnoIntervalSet, GtidSet,
    parse_gtid_set, format_gtid_set,
    encode_wire as encode_gtid_wire,
    decode_wire as decode_gtid_wire,
};
public mount .load_data_csv.{
    LoadDataCsvConfig,
    format_row as format_csv_row,
    format_rows as format_csv_rows,
};
public mount .binlog_rows.decode_value_for_type as decode_mysql_binary_value;
public mount .async_pool.{
    AsyncMysqlPool, AsyncMysqlPoolConfig, AsyncMysqlPoolGuard,
};
public mount .async_transaction.{
    AsyncMysqlTransaction,
    begin_tx_async as mysql_begin_tx_async,
    begin_tx_with_async as mysql_begin_tx_with_async,
    begin_tx_serializable_async as mysql_begin_tx_serializable_async,
    begin_tx_read_only_async as mysql_begin_tx_read_only_async,
    commit_tx_async as mysql_commit_tx_async,
    rollback_tx_async as mysql_rollback_tx_async,
    savepoint_async as mysql_savepoint_async,
    release_savepoint_async as mysql_release_savepoint_async,
    rollback_to_savepoint_async as mysql_rollback_to_savepoint_async,
};
public mount .async_typed_database.{
    AsyncMysqlTxScope,
    async_mysql_database_from_pool,
    async_mysql_admin_database_from_pool,
    async_mysql_readonly_database_from_pool,
};
public mount .binlog.{
    BinlogConfig, BinlogChecksum, BcNone, BcCrc32,
    BinlogStartFrom, BfFilePosition, BfGtidSet,
    RegisterSlaveInfo,
    BinlogStream, BinlogEventHeader,
    BinlogEvent, BeQuery, BeXid, BeRotate, BeFormatDescription,
    BeGtid, BeHeartbeat, BeOther,
    BeTableMap, BeWriteRows, BeUpdateRows, BeDeleteRows,
    QueryEventBody, RotateEventBody, FormatDescriptionBody,
    GtidEventBody,
    connect_binlog,
    BINLOG_DUMP_NON_BLOCK, BINLOG_THROUGH_GTID,
    ET_QUERY, ET_XID, ET_ROTATE, ET_FORMAT_DESCRIPTION,
    ET_GTID, ET_ANONYMOUS_GTID, ET_HEARTBEAT,
    ET_TABLE_MAP, ET_WRITE_ROWS_V2, ET_UPDATE_ROWS_V2, ET_DELETE_ROWS_V2,
    ET_PARTIAL_UPDATE_ROWS_V2,
};
public mount .binlog_rows.{
    TableMapEvent, ColumnMeta, TableMapCache,
    RowEventKind, RkWrite, RkUpdate, RkDelete, RkPartialUpdate,
    JsonDiff, JsonDiffOp, JdoReplace, JdoInsert, JdoRemove,
    decode_json_diff,
    RowsEvent, RowValue,
    RvNull, RvInt, RvUInt, RvFloat, RvText, RvBytes,
    RvDateTime, RvDate, RvTime, RvRaw,
    DecodedRow, DecodedRows, DrSimple, DrPairs,
    decode_with_table_map,
    COL_TYPE_TINY, COL_TYPE_SHORT, COL_TYPE_LONG, COL_TYPE_LONGLONG,
    COL_TYPE_FLOAT, COL_TYPE_DOUBLE, COL_TYPE_VARCHAR, COL_TYPE_BLOB,
    COL_TYPE_TIMESTAMP, COL_TYPE_DATETIME, COL_TYPE_NEWDECIMAL,
    COL_TYPE_JSON, COL_TYPE_NULL,
    COL_TYPE_ENUM, COL_TYPE_SET, COL_TYPE_GEOMETRY,
    TM_META_SIGNEDNESS, TM_META_DEFAULT_CHARSET, TM_META_COLUMN_CHARSET,
    TM_META_COLUMN_NAME, TM_META_SET_STR_VALUE, TM_META_ENUM_STR_VALUE,
    TM_META_GEOMETRY_TYPE, TM_META_SIMPLE_PRIMARY_KEY,
    TM_META_PRIMARY_KEY_WITH_PREFIX,
    TM_META_ENUM_AND_SET_DEFAULT_CHARSET, TM_META_ENUM_AND_SET_COLUMN_CHARSET,
    TM_META_COLUMN_VISIBILITY,
};
public mount .async_binlog.{
    AsyncMysqlBinlogStream, MysqlBinlogActorEvent,
    MbaEvent, MbaTerminated, MbaClosed,
    connect_binlog_async,
    DEFAULT_EVENT_CAPACITY,
};
public mount .async_binlog_consumer.{
    AsyncMysqlBinlogConsumer, BinlogChange,
    BcTableMap, BcRowsDecoded, BcRowsRaw, BcOther,
    BcTerminated as BinlogChangeTerminated,
    BcClosed as BinlogChangeClosed,
    attach_table_map_cache,
};
public mount .typed_row.{
    MysqlTypedRow, rows_typed_my,
};
public mount .json_binary.{
    decode_json_binary,
    JT_SMALL_OBJECT, JT_LARGE_OBJECT, JT_SMALL_ARRAY, JT_LARGE_ARRAY,
    JT_LITERAL, JT_INT16, JT_UINT16, JT_INT32, JT_UINT32,
    JT_INT64, JT_UINT64, JT_DOUBLE, JT_UTF8_STRING, JT_OPAQUE,
};
public mount .async_load_data.{
    AsyncMysqlInfileWriter,
    load_data_local_async,
    load_data_local_async_with_token,
};
public mount .wkb_decoder.{
    decode_wkb, decode_ewkb, decode_geometry_with_srid,
    WKB_POINT, WKB_LINE_STRING, WKB_POLYGON,
    WKB_MULTI_POINT, WKB_MULTI_LINE_STRING, WKB_MULTI_POLYGON,
    WKB_GEOMETRY_COLLECTION,
    WKB_BO_BIG_ENDIAN, WKB_BO_LITTLE_ENDIAN,
    EWKB_FLAG_Z, EWKB_FLAG_M, EWKB_FLAG_SRID, EWKB_BASE_TYPE_MASK,
    ISO_WKB_Z_OFFSET, ISO_WKB_M_OFFSET, ISO_WKB_ZM_OFFSET,
};
