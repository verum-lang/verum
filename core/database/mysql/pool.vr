// =============================================================================
// core/database/mysql/pool.vr — MysqlPool: ConnectionPool<MysqlConnection>
// =============================================================================
// Layer: 3 (Database — mysql adapter)
// Spec: internal/specs/database.md §4.3
//
// Thin vendor binding over `core.database.common.pool_impl.ConnectionPool<C>`.
// =============================================================================

module core.database.mysql.pool;

mount core.*;
mount base.{Result, Ok, Err, Text, Maybe, None, Some};
mount core.database.common.error.{DbError, AdapterId};
mount core.database.common.pool_impl.{
    ConnectionPool, PoolConfig, PooledConnection, PoolStatsSnapshot,
    ReleaseKind, Healthy, Discard,
};
mount core.database.mysql.connection.MysqlConnection;
mount core.database.mysql.config.MysqlConfig;
mount core.database.mysql.connection.connect as mysql_connect;

public type MysqlPool is {
    inner: ConnectionPool<MysqlConnection>,
    config: MysqlConfig,
}

implement MysqlPool {
    public fn launch(mysql_cfg: MysqlConfig, pool_cfg: PoolConfig) -> Result<MysqlPool, DbError> {
        let cfg_for_factory = mysql_cfg.clone();
        let factory = || -> Result<MysqlConnection, DbError> {
            mysql_connect(&cfg_for_factory)
        };
        match ConnectionPool.launch(pool_cfg, factory) {
            Ok(p)  => Ok(MysqlPool { inner: p, config: mysql_cfg }),
            Err(e) => Err(e),
        }
    }

    public fn acquire(&self) -> Result<PooledConnection<MysqlConnection>, DbError> {
        self.inner.acquire()
    }

    public fn drain(&self, deadline_ms: Int) -> Result<(), DbError> {
        self.inner.drain(deadline_ms)
    }

    public fn stats(&self) -> PoolStatsSnapshot { self.inner.stats() }

    public fn config(&self) -> &MysqlConfig { &self.config }
}
