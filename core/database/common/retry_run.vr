// =============================================================================
// core/database/common/retry_run.vr — run_with_retry combinator
// =============================================================================
// Layer: 3 (Database — common surface)
// Spec: internal/specs/database.md §5.5
// =============================================================================
//
// `run_with_retry<R>(policy, body)` is the canonical retry path for
// idempotent database operations. The body closure produces a fresh
// `Result<R, DbError>` on each attempt; we look at
// `err.is_retryable()` and either retry with full-jitter exponential
// backoff or surface the error to the caller.
//
// Determinism. The PRNG state lives inside `RetryPolicy.seed` —
// `seed == 0` draws from a process-default LCG, anything non-zero
// gives reproducible attempt scheduling for DST tests. The actual
// jitter math is in `RetryPolicy::jittered_delay_ms` so this module
// stays free of timing logic.
//
// The body is a `fn() -> Result<R, DbError>` rather than `fn(&mut Tx)`
// because the transaction handle is `affine` and must be re-acquired
// on each attempt. The caller's body closes over the connection /
// pool and re-begins inside.
// =============================================================================

module core.database.common.retry_run;

mount core.*;
mount base.{Result, Ok, Err, Text, Maybe, Some, None};
mount async.timer.sleep_ms;
mount core.database.common.error.DbError;
mount core.database.common.retry.{RetryPolicy, RetryAttemptInfo};

// -----------------------------------------------------------------------------
// Internal — initialise the per-call PRNG state from the policy.
// -----------------------------------------------------------------------------
//
// Centralised so the three retry variants below share one canonical
// seed initialiser.  An earlier revision had three copies of the
// `seed == 0 ? default : seed` decision drifting independently.

/// Default-seed constant used when `policy.seed == 0`.  Fixed value
/// makes the no-explicit-seed path deterministic across runs (good
/// for replay-able tests); for real-world jitter the caller passes
/// a non-zero seed (e.g. wall-clock micros).
const RETRY_DEFAULT_SEED: Int = 0x1A2B3C4D5E6F7080;

fn init_prng_state(policy: &RetryPolicy) -> Int {
    if policy.seed == 0 { RETRY_DEFAULT_SEED } else { policy.seed }
}

// -----------------------------------------------------------------------------
// Decision helper — given the policy + current attempt + error,
// decide whether to retry and how long to wait.  Sharing this
// across sync / async / inspect variants keeps the rules single-
// sourced; behaviour-changing tweaks land in one place.
// -----------------------------------------------------------------------------

type RetryDecision is
      RdSurface(DbError)              // give up; surface to caller
    | RdRetry { delay_ms: Int };      // sleep then retry

fn decide_retry(
    policy: &RetryPolicy,
    attempt: Int,
    err: DbError,
    prng_state: &mut Int,
) -> RetryDecision {
    if attempt >= policy.max_attempts { return RdSurface(err); }
    if !err.is_retryable()             { return RdSurface(err); }
    let delay = policy.jittered_delay_ms(attempt, prng_state);
    RdRetry { delay_ms: delay }
}

// -----------------------------------------------------------------------------
// Synchronous variant — for SQLite (and any other adapter exposing a
// sync `Connection` shape).
// -----------------------------------------------------------------------------

/// Run `body` against the configured policy, retrying on retryable
/// errors with full-jitter exponential backoff.  Returns the first
/// `Ok(R)` or the final `Err(DbError)` after the budget is spent.
///
/// The body is expected to be idempotent — the framework does not
/// enforce this at the type level (database.md §5.5 documents the
/// `Idempotent` marker as informational), but the retry semantics
/// only make sense for operations that can be re-run safely.
public fn run_with_retry_sync<R, F: fn() -> Result<R, DbError>>(
    policy: RetryPolicy,
    body: F,
) -> Result<R, DbError> {
    let mut prng_state: Int = init_prng_state(&policy);
    let mut attempt: Int = 0;
    loop {
        match body() {
            Ok(value) => { return Ok(value); }
            Err(e) => {
                attempt = attempt + 1;
                match decide_retry(&policy, attempt, e, &mut prng_state) {
                    RdSurface(final_err) => { return Err(final_err); }
                    RdRetry { delay_ms } => {
                        if delay_ms > 0 { let _ = sleep_ms(delay_ms); }
                    }
                }
            }
        }
    }
}

// -----------------------------------------------------------------------------
// Async variant — for postgres / mysql.
// -----------------------------------------------------------------------------

/// Async equivalent — the body produces an awaitable `Future<Result<R,
/// DbError>>`.  Same retry rules; the inter-attempt sleep is awaited
/// instead of blocking.
public async fn run_with_retry<R, F: fn() -> Result<R, DbError>>(
    policy: RetryPolicy,
    body: F,
) -> Result<R, DbError> {
    let mut prng_state: Int = init_prng_state(&policy);
    let mut attempt: Int = 0;
    loop {
        match body() {
            Ok(value) => { return Ok(value); }
            Err(e) => {
                attempt = attempt + 1;
                match decide_retry(&policy, attempt, e, &mut prng_state) {
                    RdSurface(final_err) => { return Err(final_err); }
                    RdRetry { delay_ms } => {
                        if delay_ms > 0 { let _ = sleep_ms(delay_ms).await; }
                    }
                }
            }
        }
    }
}

// -----------------------------------------------------------------------------
// Attempt observability — emit per-attempt records when the caller
// supplies an inspector closure (DST tests + tracing spans use this).
// -----------------------------------------------------------------------------

/// Like `run_with_retry_sync` but threads each attempt's
/// `RetryAttemptInfo` through `inspector` before sleeping.  Useful
/// for metrics labels and DST replay diagnostics.
public fn run_with_retry_inspect_sync<R, F: fn() -> Result<R, DbError>, G: fn(RetryAttemptInfo) -> ()>(
    policy: RetryPolicy,
    body: F,
    inspector: G,
) -> Result<R, DbError> {
    let mut prng_state: Int = init_prng_state(&policy);
    let mut attempt: Int = 0;
    loop {
        match body() {
            Ok(value) => { return Ok(value); }
            Err(e) => {
                attempt = attempt + 1;
                let msg = e.message();
                match decide_retry(&policy, attempt, e, &mut prng_state) {
                    RdSurface(final_err) => { return Err(final_err); }
                    RdRetry { delay_ms } => {
                        inspector(RetryAttemptInfo {
                            attempt: attempt,
                            last_error: msg,
                            next_delay_ms: delay_ms,
                        });
                        if delay_ms > 0 { let _ = sleep_ms(delay_ms); }
                    }
                }
            }
        }
    }
}

/// Async variant of the inspect-able runner.  Same shape, awaited
/// sleep — used by Postgres and MySQL handlers that want OTel-span-
/// per-attempt observability.
public async fn run_with_retry_inspect<R, F: fn() -> Result<R, DbError>, G: fn(RetryAttemptInfo) -> ()>(
    policy: RetryPolicy,
    body: F,
    inspector: G,
) -> Result<R, DbError> {
    let mut prng_state: Int = init_prng_state(&policy);
    let mut attempt: Int = 0;
    loop {
        match body() {
            Ok(value) => { return Ok(value); }
            Err(e) => {
                attempt = attempt + 1;
                let msg = e.message();
                match decide_retry(&policy, attempt, e, &mut prng_state) {
                    RdSurface(final_err) => { return Err(final_err); }
                    RdRetry { delay_ms } => {
                        inspector(RetryAttemptInfo {
                            attempt: attempt,
                            last_error: msg,
                            next_delay_ms: delay_ms,
                        });
                        if delay_ms > 0 { let _ = sleep_ms(delay_ms).await; }
                    }
                }
            }
        }
    }
}
