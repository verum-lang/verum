// =============================================================================
// core/database/common/error.vr — Spindle DbError taxonomy
// =============================================================================
// Layer: 3 (Database — common error surface)
// Spec: internal/specs/database.md §5.6
// =============================================================================
//

// One error type for every adapter. Vendor-specific codes are carried
// through `Adapter(AdapterError)`, but classifiers (`is_retryable`,
// `is_constraint_violation`, `category`) work portably so a single
// `run_with_retry` combinator covers Postgres SQLSTATE 40001, MySQL
// 1213, and SQLite SQLITE_BUSY without per-vendor branching at the
// call site.
//

// `IntoResponse` wires Weft → DbError automatically: a handler that
// uses [Database] gets `?` propagation to a 4xx/5xx response with the
// right status and never leaks server-internal SQL text to clients.
// =============================================================================

@arch_module(
    exposes: [Capability.Read(ResourceTag.Database("*")), Capability.Write(ResourceTag.Database("*"))],
    requires: [],
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LCls,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.database.common.error;

mount core.*;
mount base.{Result, Ok, Err, Text, Maybe, None, Some};

// -----------------------------------------------------------------------------
// AdapterId — which vendor produced the error / wire frame.
// -----------------------------------------------------------------------------

/// Vendor tag carried by every Spindle wire frame. Used by `Params.encode`
/// to choose the right OID dictionary, by `DbError` to format adapter-
/// specific messages, and by metrics to label samples.
public type AdapterId is
      AdPostgres
    | AdSqlite
    | AdMysql;

implement AdapterId {
    public fn name(&self) -> Text {
        match self {
            AdPostgres => "postgres",
            AdSqlite   => "sqlite",
            AdMysql    => "mysql",
        }
    }
}

// -----------------------------------------------------------------------------
// SqlState — five-character SQLSTATE codes (SQL-92).
// -----------------------------------------------------------------------------

/// Five-character SQLSTATE code as the standard defines it. Postgres
/// emits these natively; MySQL maps server errno → SQLSTATE in the
/// adapter; SQLite synthesises a small subset.
///

/// The code is held as a `Text` (5 ASCII chars) rather than a packed
/// integer because every operator from now on (display, log, retry
/// policy lookup) reads it as text. The 5-char invariant is enforced
/// at construction.
public type SqlState is { code: Text };

implement SqlState {
    /// Construct after validating the 5-character ASCII shape. Returns
    /// `None` on malformed input — never panics.
    public fn parse(s: &Text) -> Maybe<SqlState> {
        if s.len() != 5 {
            return None;
        }
        let bytes = s.as_bytes();
        let mut i = 0;
        while i < 5 {
            let b = bytes[i] as Int;
            // SQLSTATE is digits + uppercase ASCII letters only.
            let is_digit = b >= 0x30 && b <= 0x39;
            let is_upper = b >= 0x41 && b <= 0x5A;
            if !(is_digit || is_upper) {
                return None;
            }
            i = i + 1;
        }
        Some(SqlState { code: s.clone() })
    }

    public fn code(&self) -> &Text { &self.code }

    /// SQLSTATE class is the first two characters: 23 = integrity, 40 =
    /// transaction rollback, 08 = connection exception, etc.
    public fn class(&self) -> Text {
        let bytes = self.code.as_bytes();
        let mut out: Text = "".clone();
        out.push(bytes[0] as Char);
        out.push(bytes[1] as Char);
        out
    }

    /// Retryable per database.md §5.5: 40xxx (rollback / serialization),
    /// 08xxx (connection failure). Per-adapter overlays may expand this
    /// — see `Adapter.is_retryable`.
    public fn is_retryable(&self) -> Bool {
        let cls = self.class();
        cls == "40" || cls == "08"
    }

    /// Constraint violations: 23xxx (integrity), 22xxx (data exception).
    public fn is_integrity(&self) -> Bool {
        let cls = self.class();
        cls == "23" || cls == "22"
    }

    /// More specific subclass detection — every SQLSTATE 23* code that
    /// Spindle can map to a typed `ConstraintKind`. Returns
    /// `CkOther` for unrecognised 23* codes (forward-compat with new
    /// SQLSTATE codes Postgres / MySQL may add).
    public fn integrity_kind(&self) -> Maybe<ConstraintKind> {
        if !self.is_integrity() { return None; }
        let c = self.code.as_str();
        // SQLSTATE 23xxx subclasses — see PostgreSQL Appendix A.
        if      c == "23502" { Some(CkNotNull) }
        else if c == "23503" { Some(CkForeignKey) }
        else if c == "23505" { Some(CkUnique) }
        else if c == "23514" { Some(CkCheck) }
        else if c == "23001" { Some(CkRestrictViolation) }
        else if c == "23000" { Some(CkOther) }
        else if self.class() == "22" { Some(CkDataException) }
        else                 { Some(CkOther) }
    }
}

/// Specific shape of an integrity / constraint violation. Drives
/// HTTP status mapping (409 vs 422) and observability labels.
public type ConstraintKind is
      CkNotNull              // 23502 — missing NOT NULL value
    | CkForeignKey           // 23503 — FK violation
    | CkUnique               // 23505 — UNIQUE / PRIMARY KEY collision
    | CkCheck                // 23514 — CHECK constraint failure
    | CkRestrictViolation    // 23001 — RESTRICT-class FK
    | CkDataException        // 22xxx — value outside type domain
    | CkOther;               // 23000 / 23xxx unrecognised

implement ConstraintKind {
    public fn label(&self) -> Text {
        match self {
            CkNotNull           => "not_null".clone(),
            CkForeignKey        => "foreign_key".clone(),
            CkUnique            => "unique".clone(),
            CkCheck             => "check".clone(),
            CkRestrictViolation => "restrict".clone(),
            CkDataException     => "data_exception".clone(),
            CkOther             => "integrity_other".clone(),
        }
    }

    public fn equals(&self, other: &ConstraintKind) -> Bool {
        match (self, other) {
            (CkNotNull,           CkNotNull)           => true,
            (CkForeignKey,        CkForeignKey)        => true,
            (CkUnique,            CkUnique)            => true,
            (CkCheck,             CkCheck)             => true,
            (CkRestrictViolation, CkRestrictViolation) => true,
            (CkDataException,     CkDataException)     => true,
            (CkOther,             CkOther)             => true,
            _                                          => false,
        }
    }
}

// -----------------------------------------------------------------------------
// Error category — drives IntoResponse status and retry policy.
// -----------------------------------------------------------------------------

public type ErrorCategory is
      EcTransient    // network blip, retryable
    | EcPermanent    // constraint violation, schema mismatch
    | EcSecurity     // auth, capability — never echo to client
    | EcClient       // bad input — 400-class
    | EcUpstream;    // server-side bug — 5xx + log

// -----------------------------------------------------------------------------
// Sub-error kinds.
// -----------------------------------------------------------------------------

public type ConnectionErrorKind is
      CekDnsFailure(Text)
    | CekConnectRefused
    | CekTlsHandshakeFailed(Text)
    | CekProtocolMismatch(Text)
    | CekServerTerminated
    | CekKeepaliveTimeout;

public type AuthErrorKind is
      AekBadCredentials
    | AekScramFailed(Text)
    | AekChannelBindingMismatch
    | AekIamTokenExpired
    | AekRoleNotPermitted(Text);

public type TimeoutPhase is
      TpConnect
    | TpStatement
    | TpIdle
    | TpAcquire;

public type PoolErrorKind is
      PekExhausted
    | PekDraining
    | PekHealthCheckFailed
    | PekConfigInvalid(Text);

/// Vendor-specific payload — adapter modules implement their own
/// concrete type and wrap into `Adapter(AdapterSpecific.From(impl))`.
/// We keep this opaque via `Text` here; adapters that want richer
/// behaviour use the `is_retryable_adapter` hook on `DbError`.
public type AdapterSpecific is {
    adapter: AdapterId,
    code: Text,
    message: Text,
    retryable: Bool,
};

// -----------------------------------------------------------------------------
// DbError — the surface every adapter speaks.
// -----------------------------------------------------------------------------

/// Wire-decoder context that explains *which* column on *what* row
/// failed and what the server claimed it was sending.
public type DecodeFault is {
    column_index: Int,
    column_name: Text,
    expected_type: Text,
    found_oid: Int,
    detail: Text,
};

public type EncodeFault is {
    param_index: Int,
    type_name: Text,
    reason: Text,
};

public type DbError is
      ConnectionFailed { source: ConnectionErrorKind, adapter: AdapterId }
    | QueryFailed     { sql_state: SqlState, message: Text, position: Maybe<Int> }
    | DecodeFailed    { fault: DecodeFault }
    | EncodeFailed    { fault: EncodeFault }
    | TimedOut        { phase: TimeoutPhase }
    | Cancelled
    | RefinementViolated { column: Text, predicate: Text }
    | PoolFailure     { kind: PoolErrorKind }
    | AuthFailed      { kind: AuthErrorKind }
    | Adapter(AdapterSpecific);

implement DbError {
    /// Short human-readable summary — never includes secrets / SQL
    /// text. For full context use `DbError.detail()`.
    public fn message(&self) -> Text {
        match self {
            ConnectionFailed { adapter, .. } =>
                f"connection to {adapter.name()} failed",
            QueryFailed { sql_state, .. } =>
                f"query failed: SQLSTATE {sql_state.code()}",
            DecodeFailed { fault } =>
                f"row decode failed at column {fault.column_index} ({fault.column_name})",
            EncodeFailed { fault } =>
                f"param encode failed at index {fault.param_index} ({fault.type_name})",
            TimedOut { phase } =>
                f"timeout in phase {phase_name(phase)}",
            Cancelled            => "query cancelled".clone(),
            RefinementViolated { column, .. } =>
                f"refinement violation on column {column}",
            PoolFailure { kind } =>
                f"pool failure: {pool_kind_name(kind)}",
            AuthFailed { kind } =>
                f"authentication failed: {auth_kind_name(kind)}",
            Adapter(spec)        =>
                f"{spec.adapter.name()} error {spec.code}: {spec.message}",
        }
    }

    /// Is the error worth retrying with the same operation? Drives
    /// `run_with_retry`. False positives are bugs — never retry a
    /// constraint violation or a syntax error.
    public fn is_retryable(&self) -> Bool {
        match self {
            ConnectionFailed { .. }                       => true,
            QueryFailed { sql_state, .. }                 => sql_state.is_retryable(),
            TimedOut { phase: TpStatement }               => true,
            TimedOut { phase: TpIdle }                    => true,
            TimedOut { phase: TpAcquire }                 => true,
            TimedOut { .. }                               => false,
            Cancelled                                     => false,
            RefinementViolated { .. }                     => false,
            PoolFailure { kind: PekHealthCheckFailed }    => true,
            PoolFailure { kind: PekExhausted }            => true,
            PoolFailure { .. }                            => false,
            AuthFailed { .. }                             => false,
            DecodeFailed { .. }                           => false,
            EncodeFailed { .. }                           => false,
            Adapter(spec)                                 => spec.retryable,
        }
    }

    /// Did the error come from a `CHECK` / `UNIQUE` / `FOREIGN KEY`
    /// violation? Useful for upsert-patterns and surfacing 409 to API
    /// clients.
    public fn is_constraint_violation(&self) -> Bool {
        match self {
            QueryFailed { sql_state, .. } => sql_state.is_integrity(),
            RefinementViolated { .. }     => true,
            _                             => false,
        }
    }

    /// Unified accessor: returns a structured `ConstraintViolation`
    /// regardless of whether the failure was caught client-side
    /// (`RefinementViolated` — SMT/Z3 caught the parameter before
    /// the wire trip) or server-side (`QueryFailed` with a SQLSTATE
    /// 22xxx / 23xxx code). Handler code that just wants the column
    /// + kind for a 409 / 422 response uses this; the variant
    /// distinction stays available for callers that care about the
    /// detection boundary.
    public fn as_constraint_violation(&self) -> Maybe<ConstraintViolation> {
        match self {
            RefinementViolated { column, predicate } =>
                Some(ConstraintViolation {
                    column: Some(column.clone()),
                    predicate: Some(predicate.clone()),
                    kind: CkCheck,                           // refinements
                                                              // emit CHECK
                                                              // semantics on
                                                              // both sides
                    detected_at: VdClientPreflight,
                }),
            QueryFailed { sql_state, message, .. } => {
                if !sql_state.is_integrity() { return None; }
                Some(ConstraintViolation {
                    // PG / MySQL rarely echo the column name in the
                    // protocol-level message; extracting it requires
                    // the `c=...` ErrorResponse field that the wire
                    // layer captures separately. v1 surfaces None;
                    // adapter-specific paths can populate via
                    // `set_constraint_column` once the wire-layer
                    // captures the field.
                    column: None,
                    predicate: extract_constraint_name(message),
                    kind: match sql_state.integrity_kind() {
                        Some(k) => k,
                        None    => CkOther,
                    },
                    detected_at: VdServerReject,
                })
            }
            _ => None,
        }
    }

    /// Used by `IntoResponse` and by metrics labels.
    public fn category(&self) -> ErrorCategory {
        match self {
            ConnectionFailed { .. }     => EcTransient,
            TimedOut { .. }             => EcTransient,
            PoolFailure { .. }          => EcTransient,
            AuthFailed { .. }           => EcSecurity,
            QueryFailed { sql_state, .. } => {
                if sql_state.is_integrity() {
                    EcClient
                } else if sql_state.is_retryable() {
                    EcTransient
                } else {
                    EcUpstream
                }
            }
            DecodeFailed { .. }         => EcUpstream,
            EncodeFailed { .. }         => EcClient,
            Cancelled                   => EcClient,
            RefinementViolated { .. }   => EcClient,
            Adapter(spec)               => {
                if spec.retryable { EcTransient } else { EcUpstream }
            }
        }
    }
}

// -----------------------------------------------------------------------------
// Helpers (kept private — `DbError.message` consumes them).
// -----------------------------------------------------------------------------

fn phase_name(p: &TimeoutPhase) -> Text {
    match p {
        TpConnect    => "connect".clone(),
        TpStatement  => "statement".clone(),
        TpIdle       => "idle".clone(),
        TpAcquire    => "acquire".clone(),
    }
}

fn pool_kind_name(k: &PoolErrorKind) -> Text {
    match k {
        PekExhausted              => "exhausted".clone(),
        PekDraining               => "draining".clone(),
        PekHealthCheckFailed      => "health_check_failed".clone(),
        PekConfigInvalid(_)       => "config_invalid".clone(),
    }
}

fn auth_kind_name(k: &AuthErrorKind) -> Text {
    match k {
        AekBadCredentials               => "bad_credentials".clone(),
        AekScramFailed(_)               => "scram_failed".clone(),
        AekChannelBindingMismatch       => "channel_binding_mismatch".clone(),
        AekIamTokenExpired              => "iam_token_expired".clone(),
        AekRoleNotPermitted(_)          => "role_not_permitted".clone(),
    }
}

// =============================================================================
// Display + Debug + Eq for the error taxonomy
// =============================================================================
//

// AuthFailed Display surfaces only the kind tag — never SCRAM
// payloads, never role names, never token state — to avoid
// becoming an oracle for credential probing. Adapter messages
// are passed through (vendor controls them).
//

// =============================================================================

implement Display for AdapterId {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(self.name().as_str())
    }
}

implement Debug for AdapterId {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        let s = match self {
            AdPostgres => "AdPostgres",
            AdSqlite   => "AdSqlite",
            AdMysql    => "AdMysql",
        };
        f.write_str(s)
    }
}

implement Eq for AdapterId {
    fn eq(&self, other: &AdapterId) -> Bool {
        match (self, other) {
            (AdPostgres, AdPostgres) => true,
            (AdSqlite,   AdSqlite)   => true,
            (AdMysql,    AdMysql)    => true,
            _ => false,
        }
    }
}

implement Display for SqlState {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(self.code.as_str())
    }
}

implement Debug for SqlState {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"SqlState({self.code})".as_str())
    }
}

implement Eq for SqlState {
    fn eq(&self, other: &SqlState) -> Bool {
        self.code == other.code
    }
}

implement Display for ErrorCategory {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        let s = match self {
            EcTransient => "transient",
            EcPermanent => "permanent",
            EcSecurity  => "security",
            EcClient    => "client",
            EcUpstream  => "upstream",
        };
        f.write_str(s)
    }
}

implement Debug for ErrorCategory {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        let s = match self {
            EcTransient => "EcTransient",
            EcPermanent => "EcPermanent",
            EcSecurity  => "EcSecurity",
            EcClient    => "EcClient",
            EcUpstream  => "EcUpstream",
        };
        f.write_str(s)
    }
}

implement Eq for ErrorCategory {
    fn eq(&self, other: &ErrorCategory) -> Bool {
        match (self, other) {
            (EcTransient, EcTransient) => true,
            (EcPermanent, EcPermanent) => true,
            (EcSecurity,  EcSecurity)  => true,
            (EcClient,    EcClient)    => true,
            (EcUpstream,  EcUpstream)  => true,
            _ => false,
        }
    }
}

implement Display for TimeoutPhase {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(phase_name(self).as_str())
    }
}

implement Debug for TimeoutPhase {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        let s = match self {
            TpConnect   => "TpConnect",
            TpStatement => "TpStatement",
            TpIdle      => "TpIdle",
            TpAcquire   => "TpAcquire",
        };
        f.write_str(s)
    }
}

implement Eq for TimeoutPhase {
    fn eq(&self, other: &TimeoutPhase) -> Bool {
        match (self, other) {
            (TpConnect,   TpConnect)   => true,
            (TpStatement, TpStatement) => true,
            (TpIdle,      TpIdle)      => true,
            (TpAcquire,   TpAcquire)   => true,
            _ => false,
        }
    }
}

implement Display for PoolErrorKind {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(pool_kind_name(self).as_str())
    }
}

implement Debug for PoolErrorKind {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            PekExhausted          => f.write_str("PekExhausted"),
            PekDraining           => f.write_str("PekDraining"),
            PekHealthCheckFailed  => f.write_str("PekHealthCheckFailed"),
            PekConfigInvalid(m)   => f.write_str(f"PekConfigInvalid({m})".as_str()),
        }
    }
}

implement Eq for PoolErrorKind {
    fn eq(&self, other: &PoolErrorKind) -> Bool {
        match (self, other) {
            (PekExhausted,          PekExhausted)         => true,
            (PekDraining,           PekDraining)          => true,
            (PekHealthCheckFailed,  PekHealthCheckFailed) => true,
            (PekConfigInvalid(a),   PekConfigInvalid(b))  => a == b,
            _ => false,
        }
    }
}

implement Display for ConnectionErrorKind {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            CekDnsFailure(m)            => f.write_str(f"DNS resolution failed: {m}".as_str()),
            CekConnectRefused           => f.write_str("connection refused"),
            CekTlsHandshakeFailed(m)    => f.write_str(f"TLS handshake failed: {m}".as_str()),
            CekProtocolMismatch(m)      => f.write_str(f"wire protocol mismatch: {m}".as_str()),
            CekServerTerminated         => f.write_str("server terminated connection"),
            CekKeepaliveTimeout         => f.write_str("keepalive timeout"),
        }
    }
}

implement Debug for ConnectionErrorKind {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            CekDnsFailure(m)         => f.write_str(f"CekDnsFailure({m})".as_str()),
            CekConnectRefused        => f.write_str("CekConnectRefused"),
            CekTlsHandshakeFailed(m) => f.write_str(f"CekTlsHandshakeFailed({m})".as_str()),
            CekProtocolMismatch(m)   => f.write_str(f"CekProtocolMismatch({m})".as_str()),
            CekServerTerminated      => f.write_str("CekServerTerminated"),
            CekKeepaliveTimeout      => f.write_str("CekKeepaliveTimeout"),
        }
    }
}

implement Eq for ConnectionErrorKind {
    fn eq(&self, other: &ConnectionErrorKind) -> Bool {
        match (self, other) {
            (CekDnsFailure(a),         CekDnsFailure(b))         => a == b,
            (CekConnectRefused,        CekConnectRefused)        => true,
            (CekTlsHandshakeFailed(a), CekTlsHandshakeFailed(b)) => a == b,
            (CekProtocolMismatch(a),   CekProtocolMismatch(b))   => a == b,
            (CekServerTerminated,      CekServerTerminated)      => true,
            (CekKeepaliveTimeout,      CekKeepaliveTimeout)      => true,
            _ => false,
        }
    }
}

implement Display for AuthErrorKind {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        // Surface only the kind tag — never SCRAM payloads,
        // never role names — to avoid credential-probe oracles.
        f.write_str(auth_kind_name(self).as_str())
    }
}

implement Debug for AuthErrorKind {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            AekBadCredentials         => f.write_str("AekBadCredentials"),
            AekScramFailed(_)         => f.write_str("AekScramFailed(<redacted>)"),
            AekChannelBindingMismatch => f.write_str("AekChannelBindingMismatch"),
            AekIamTokenExpired        => f.write_str("AekIamTokenExpired"),
            AekRoleNotPermitted(_)    => f.write_str("AekRoleNotPermitted(<redacted>)"),
        }
    }
}

implement Eq for AuthErrorKind {
    fn eq(&self, other: &AuthErrorKind) -> Bool {
        match (self, other) {
            (AekBadCredentials,         AekBadCredentials)         => true,
            (AekScramFailed(a),         AekScramFailed(b))         => a == b,
            (AekChannelBindingMismatch, AekChannelBindingMismatch) => true,
            (AekIamTokenExpired,        AekIamTokenExpired)        => true,
            (AekRoleNotPermitted(a),    AekRoleNotPermitted(b))    => a == b,
            _ => false,
        }
    }
}

implement Display for AdapterSpecific {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"{self.adapter.name()} error {self.code}: {self.message}".as_str())
    }
}

implement Debug for AdapterSpecific {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"AdapterSpecific {{ adapter: {self.adapter:?}, code: {self.code}, message: {self.message}, retryable: {self.retryable} }}".as_str())
    }
}

implement Eq for AdapterSpecific {
    fn eq(&self, other: &AdapterSpecific) -> Bool {
        self.adapter == other.adapter
            && self.code == other.code
            && self.message == other.message
            && self.retryable == other.retryable
    }
}

implement Display for DecodeFault {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"column {self.column_index} ({self.column_name}) expected {self.expected_type}, server-OID {self.found_oid}: {self.detail}".as_str())
    }
}

implement Debug for DecodeFault {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"DecodeFault {{ column_index: {self.column_index}, column_name: {self.column_name}, expected_type: {self.expected_type}, found_oid: {self.found_oid}, detail: {self.detail} }}".as_str())
    }
}

implement Eq for DecodeFault {
    fn eq(&self, other: &DecodeFault) -> Bool {
        self.column_index == other.column_index
            && self.column_name == other.column_name
            && self.expected_type == other.expected_type
            && self.found_oid == other.found_oid
            && self.detail == other.detail
    }
}

implement Display for EncodeFault {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"param {self.param_index} ({self.type_name}): {self.reason}".as_str())
    }
}

implement Debug for EncodeFault {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"EncodeFault {{ param_index: {self.param_index}, type_name: {self.type_name}, reason: {self.reason} }}".as_str())
    }
}

implement Eq for EncodeFault {
    fn eq(&self, other: &EncodeFault) -> Bool {
        self.param_index == other.param_index
            && self.type_name == other.type_name
            && self.reason == other.reason
    }
}

implement Display for DbError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(self.message().as_str())
    }
}

implement Debug for DbError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            ConnectionFailed { source, adapter } =>
                f.write_str(f"ConnectionFailed {{ source: {source:?}, adapter: {adapter:?} }}".as_str()),
            QueryFailed { sql_state, message, position } =>
                f.write_str(f"QueryFailed {{ sql_state: {sql_state:?}, message: {message}, position: {position:?} }}".as_str()),
            DecodeFailed { fault } =>
                f.write_str(f"DecodeFailed {{ fault: {fault:?} }}".as_str()),
            EncodeFailed { fault } =>
                f.write_str(f"EncodeFailed {{ fault: {fault:?} }}".as_str()),
            TimedOut { phase } =>
                f.write_str(f"TimedOut {{ phase: {phase:?} }}".as_str()),
            Cancelled => f.write_str("Cancelled"),
            RefinementViolated { column, predicate } =>
                f.write_str(f"RefinementViolated {{ column: {column}, predicate: {predicate} }}".as_str()),
            PoolFailure { kind } =>
                f.write_str(f"PoolFailure {{ kind: {kind:?} }}".as_str()),
            AuthFailed { kind } =>
                f.write_str(f"AuthFailed {{ kind: {kind:?} }}".as_str()),
            Adapter(spec) =>
                f.write_str(f"Adapter({spec:?})".as_str()),
        }
    }
}

implement Eq for DbError {
    fn eq(&self, other: &DbError) -> Bool {
        match (self, other) {
            (ConnectionFailed { source: sa, adapter: aa },
             ConnectionFailed { source: sb, adapter: ab })          => sa == sb && aa == ab,
            (QueryFailed { sql_state: ssa, message: ma, position: pa },
             QueryFailed { sql_state: ssb, message: mb, position: pb })
                                                                    => ssa == ssb && ma == mb && pa == pb,
            (DecodeFailed { fault: a },     DecodeFailed { fault: b }) => a == b,
            (EncodeFailed { fault: a },     EncodeFailed { fault: b }) => a == b,
            (TimedOut { phase: a },         TimedOut { phase: b })     => a == b,
            (Cancelled,                     Cancelled)                 => true,
            (RefinementViolated { column: ca, predicate: pa },
             RefinementViolated { column: cb, predicate: pb })         => ca == cb && pa == pb,
            (PoolFailure { kind: a },       PoolFailure { kind: b })   => a == b,
            (AuthFailed { kind: a },        AuthFailed { kind: b })    => a == b,
            (Adapter(a),                    Adapter(b))                => a == b,
            _ => false,
        }
    }
}

// =============================================================================
// ConstraintViolation — unified detail for client-preflight + server-reject
// =============================================================================
//
// Both `RefinementViolated` (SMT/Z3 caught a parameter before it
// went on the wire) and `QueryFailed { sql_state: 23xxx }` (the
// database's CHECK / UNIQUE / FK constraint rejected the row)
// represent "your data violates an invariant". This type is the
// shape they collapse to for handler code that wants one accessor
// for both paths.
//
// Variants stay distinct in `DbError` because they carry different
// observability signal — a client-preflight catch never hit the
// pool, never burned a connection, and signals that the application
// has end-to-end refinement coverage. A server-reject catch means
// the wire trip happened (and burned the round-trip latency); over
// time, an increase in server-reject share is a code-quality
// signal that refinement annotations are missing.

/// Where the constraint failure was detected.
public type ViolationDetection is
      VdClientPreflight       // SMT/Z3 caught it client-side; never hit wire
    | VdServerReject;         // database CHECK / UNIQUE / FK rejected the row

implement ViolationDetection {
    public fn label(&self) -> Text {
        match self {
            VdClientPreflight => "client_preflight".clone(),
            VdServerReject    => "server_reject".clone(),
        }
    }

    public fn equals(&self, other: &ViolationDetection) -> Bool {
        match (self, other) {
            (VdClientPreflight, VdClientPreflight) => true,
            (VdServerReject,    VdServerReject)    => true,
            _                                      => false,
        }
    }
}

/// Unified shape returned by `DbError.as_constraint_violation()`.
/// Drives `IntoResponse`'s 409-vs-422 status mapping and the
/// `db.client.constraint.*` metric set.
public type ConstraintViolation is {
    /// Column responsible for the violation, when the wire
    /// protocol surfaces it. Currently `None` from the server-side
    /// path — extracting it requires the `c=` ErrorResponse field
    /// that the wire layer captures into a separate slot; v1 leaves
    /// it `None` and adapters can populate via a follow-up. The
    /// client-side path always populates it from the
    /// `RefinementViolated.column` field.
    column: Maybe<Text>,
    /// The constraint expression text (best-effort). For
    /// client-preflight this is the refinement predicate source;
    /// for server-reject it's the constraint NAME extracted from
    /// the diagnostic message (PG / MySQL surface
    /// "violates check constraint \"<name>\"" — we lift the name
    /// out for stable metric labels).
    predicate: Maybe<Text>,
    /// Specific kind of constraint that fired.
    kind: ConstraintKind,
    /// Detection boundary.
    detected_at: ViolationDetection,
};

implement ConstraintViolation {
    /// Stable label combining kind + detection — useful as a
    /// metric-cardinality-bounded tag.
    public fn metric_tag(&self) -> Text {
        let mut t: Text = self.detected_at.label();
        t.push_str(&"/".clone());
        t.push_str(&self.kind.label());
        t
    }
}

/// Lift the constraint name out of a vendor diagnostic message.
/// Looks for the canonical pattern `"\"<name>\""` Postgres / MySQL
/// emit ("violates check constraint \"<name>\"" / "Duplicate entry
/// '...' for key '<name>'"). Returns `None` when no such substring
/// is present — the caller treats the predicate as anonymous.
fn extract_constraint_name(message: &Text) -> Maybe<Text> {
    let bytes = message.as_bytes();
    let n = bytes.len() as Int;
    // Find the first `"`; capture until the next `"`.
    let mut start: Int = -1;
    let mut i: Int = 0;
    while i < n {
        if (bytes[i] as Int) == 0x22 {        // ASCII `"`
            start = i + 1;
            break;
        }
        i = i + 1;
    }
    if start < 0 { return None; }
    let mut end: Int = -1;
    let mut j: Int = start;
    while j < n {
        if (bytes[j] as Int) == 0x22 {
            end = j;
            break;
        }
        j = j + 1;
    }
    if end < 0 || end <= start { return None; }
    let mut buf: List<Byte> = List.with_capacity(end - start);
    let mut k: Int = start;
    while k < end {
        buf.push(bytes[k]);
        k = k + 1;
    }
    match Text.from_utf8(buf) {
        Ok(t)  => Some(t),
        Err(_) => None,
    }
}
