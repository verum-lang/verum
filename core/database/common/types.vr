// =============================================================================
// core/database/common/types.vr — Spindle wire-data types
// =============================================================================
// Layer: 3 (Database — common surface)
// Spec: internal/specs/database.md §4.1, §5.1
// =============================================================================
//

// Vendor-neutral wire shapes. Every adapter sees rows / params through
// these types; vendor-specific OID dictionaries live in adapter modules
// and are folded back to / from these via `AdapterId`.
//

// Performance note. `WireRow` and `WireBuf` are designed for
// allocation-free hot paths: row-bytes are borrowed from the connection
// arena (CBGR), `WireBuf.write_*` methods append in place, and decoders
// return `&[Byte]` slices that escape-analyse into the query-arena
// lifetime per database.md §4.2.
// =============================================================================

module core.database.common.types;

mount core.*;
mount base.{Result, Ok, Err, Text, Maybe, None, Some};
mount collections.List;
mount mem.raw_ops.{memcpy, store_byte, load_byte};
mount core.database.common.error.{DbError, DecodeFault, EncodeFault, AdapterId};
mount core.database.common.arena.{SpindleArena};

// -----------------------------------------------------------------------------
// TypeOid — vendor-neutral OID space.
// -----------------------------------------------------------------------------

/// A Spindle-internal type tag. Adapters map vendor codes (Postgres
/// pg_type.oid, MySQL field_type, SQLite type-affinity) into this
/// shared space at the wire boundary so user code reasons about a
/// single dictionary.
///

/// We store the tag as an `Int` rather than a packed enum because new
/// types appear (postgres extensions, custom domains) and the adapter
/// keeps a richer per-vendor table. The constants below are the core
/// types that EVERY adapter must support.
public type TypeOid is { value: Int };

implement TypeOid {
    public fn new(value: Int) -> TypeOid {
        TypeOid { value: value }
    }
    public fn value(&self) -> Int { self.value }
    public fn equals(&self, other: &TypeOid) -> Bool { self.value == other.value }
}

// Core OID dictionary — stable across vendors; per-vendor maps live in
// adapter modules (e.g. `core.database.postgres.types::oid_to_pg_type`).
public const OID_NULL:        Int = 0;
public const OID_BOOL:        Int = 1;
public const OID_INT2:        Int = 2;
public const OID_INT4:        Int = 3;
public const OID_INT8:        Int = 4;
public const OID_FLOAT4:      Int = 5;
public const OID_FLOAT8:      Int = 6;
public const OID_TEXT:        Int = 7;
public const OID_BYTEA:       Int = 8;
public const OID_UUID:        Int = 9;
public const OID_DATE:        Int = 10;
public const OID_TIME:        Int = 11;
public const OID_TIMESTAMP:   Int = 12;
public const OID_TIMESTAMPTZ: Int = 13;
public const OID_INTERVAL:    Int = 14;
public const OID_NUMERIC:     Int = 15;
public const OID_JSON:        Int = 16;
public const OID_JSONB:       Int = 17;
public const OID_ARRAY:       Int = 18;     // generic — element-OID in metadata
public const OID_RECORD:      Int = 19;
public const OID_UNKNOWN:     Int = 20;

// -----------------------------------------------------------------------------
// Wire format — text vs binary.
// -----------------------------------------------------------------------------

/// Whether a wire payload is text-encoded (CSV-like, ASCII-printable)
/// or binary-encoded (network byte order). Postgres extended-protocol
/// negotiates this per column; MySQL binary protocol is always binary;
/// SQLite stores in its own serial-type encoding and we surface it as
/// binary.
public type WireFormat is FmtText | FmtBinary;

// -----------------------------------------------------------------------------
// ColumnSchema / RowSchema — describe the shape returned by a query.
// -----------------------------------------------------------------------------

public type ColumnSchema is {
    name: Text,
    type_oid: TypeOid,
    nullable: Bool,
    format: WireFormat,
    /// Element OID for arrays / record types; `OID_UNKNOWN` otherwise.
    element_oid: TypeOid,
    /// Refined-type predicate the *generator* of this query proved
    /// holds. Carried through so `SELECT age FROM users` returns
    /// `Maybe<Age>` instead of `Maybe<Int>`. Empty if no refinement.
    refinement: Text,
};

implement ColumnSchema {
    public fn new(name: Text, type_oid: TypeOid, nullable: Bool, format: WireFormat) -> ColumnSchema {
        ColumnSchema {
            name: name,
            type_oid: type_oid,
            nullable: nullable,
            format: format,
            element_oid: TypeOid.new(OID_UNKNOWN),
            refinement: "".clone(),
        }
    }

    public fn with_element(self, elem: TypeOid) -> ColumnSchema {
        ColumnSchema {
            element_oid: elem,
            .. self
        }
    }

    public fn with_refinement(self, predicate: Text) -> ColumnSchema {
        ColumnSchema {
            refinement: predicate,
            .. self
        }
    }
}

public type RowSchema is {
    columns: List<ColumnSchema>,
};

implement RowSchema {
    public fn empty() -> RowSchema {
        RowSchema { columns: [] }
    }

    public fn from_columns(cols: List<ColumnSchema>) -> RowSchema {
        RowSchema { columns: cols }
    }

    public fn column_count(&self) -> Int {
        self.columns.len() as Int
    }

    /// Linear scan — schemas are typically small (<32 columns) and this
    /// stays cache-friendly. Returns `None` if the column is not
    /// present, never panics.
    public fn index_of(&self, name: &Text) -> Maybe<Int> {
        let mut i = 0;
        while i < self.columns.len() as Int {
            if self.columns[i].name == *name {
                return Some(i);
            }
            i = i + 1;
        }
        None
    }

    public fn column(&self, i: Int) -> Maybe<&ColumnSchema> {
        if i < 0 || i >= self.columns.len() as Int {
            None
        } else {
            Some(&self.columns[i])
        }
    }
}

// -----------------------------------------------------------------------------
// WireRow — one row as the connection saw it on the wire.
// -----------------------------------------------------------------------------

/// One column's bytes plus the format it was sent in. `bytes` is
/// borrowed from the per-query CBGR arena; never holds heap unless the
/// caller `to_owned`s it.
public type WireValue is
      WvNull
    | WvPresent { bytes: List<Byte>, format: WireFormat };

public type WireRow is {
    values: List<WireValue>,
};

implement WireRow {
    public fn empty() -> WireRow { WireRow { values: [] } }

    public fn with_values(values: List<WireValue>) -> WireRow {
        WireRow { values: values }
    }

    public fn column_count(&self) -> Int {
        self.values.len() as Int
    }

    /// `None` if column-index is out of range OR the value is SQL-NULL.
    /// Adapters call this and decode-on-demand.
    public fn bytes(&self, col: Int) -> Maybe<&List<Byte>> {
        if col < 0 || col >= self.values.len() as Int {
            return None;
        }
        match &self.values[col] {
            WvNull              => None,
            WvPresent { bytes, .. } => Some(bytes),
        }
    }

    public fn is_null(&self, col: Int) -> Bool {
        if col < 0 || col >= self.values.len() as Int {
            return true;
        }
        match &self.values[col] {
            WvNull         => true,
            WvPresent { .. } => false,
        }
    }

    public fn format(&self, col: Int) -> Maybe<WireFormat> {
        if col < 0 || col >= self.values.len() as Int {
            return None;
        }
        match &self.values[col] {
            WvNull                  => None,
            WvPresent { format, .. } => Some(format.clone()),
        }
    }
}

// -----------------------------------------------------------------------------
// WireBuf — append-only byte buffer for parameter encoding.
// -----------------------------------------------------------------------------

/// Append-only byte buffer used by `Params.encode`. Lives in the
/// connection arena — reset between requests, no per-query alloc.
///

/// The integer writers always emit network byte order (big-endian).
/// This matches Postgres v3 binary protocol and MySQL binary protocol;
/// SQLite's adapter swaps on encode at the boundary to its native
/// little-endian record format.
public type WireBuf is {
    bytes: List<Byte>,
};

implement WireBuf {
    public fn new() -> WireBuf {
        WireBuf { bytes: [] }
    }

    public fn with_capacity(cap: Int) -> WireBuf {
        WireBuf { bytes: List.with_capacity(cap) }
    }

    public fn len(&self) -> Int { self.bytes.len() as Int }

    public fn as_bytes(&self) -> &[Byte] { &self.bytes }

    /// Reset for reuse — keeps the underlying capacity so subsequent
    /// requests inherit a warmed buffer.
    public fn clear(&mut self) {
        self.bytes.clear();
    }

    public fn put_u8(&mut self, v: Int) {
        self.bytes.push((v & 0xFF) as Byte);
    }

    public fn put_u16_be(&mut self, v: Int) {
        self.bytes.push(((v >> 8) & 0xFF) as Byte);
        self.bytes.push((v & 0xFF) as Byte);
    }

    public fn put_u32_be(&mut self, v: Int) {
        self.bytes.push(((v >> 24) & 0xFF) as Byte);
        self.bytes.push(((v >> 16) & 0xFF) as Byte);
        self.bytes.push(((v >> 8) & 0xFF) as Byte);
        self.bytes.push((v & 0xFF) as Byte);
    }

    public fn put_i32_be(&mut self, v: Int) {
        self.put_u32_be(v);   // two's-complement layout matches.
    }

    public fn put_u64_be(&mut self, v: Int) {
        self.bytes.push(((v >> 56) & 0xFF) as Byte);
        self.bytes.push(((v >> 48) & 0xFF) as Byte);
        self.bytes.push(((v >> 40) & 0xFF) as Byte);
        self.bytes.push(((v >> 32) & 0xFF) as Byte);
        self.bytes.push(((v >> 24) & 0xFF) as Byte);
        self.bytes.push(((v >> 16) & 0xFF) as Byte);
        self.bytes.push(((v >> 8) & 0xFF) as Byte);
        self.bytes.push((v & 0xFF) as Byte);
    }

    public fn put_i64_be(&mut self, v: Int) {
        self.put_u64_be(v);
    }

    public fn put_bytes(&mut self, src: &[Byte]) {
        let mut i = 0;
        while i < src.len() {
            self.bytes.push(src[i]);
            i = i + 1;
        }
    }

    /// Postgres / MySQL pattern: 4-byte BE length prefix followed by
    /// payload, with `-1` denoting SQL NULL.
    public fn put_lp_bytes(&mut self, payload: Maybe<&[Byte]>) {
        match payload {
            None         => self.put_i32_be(-1),
            Some(b)      => {
                self.put_i32_be(b.len() as Int);
                self.put_bytes(b);
            }
        }
    }

    /// Null-terminated UTF-8 string — the Postgres v3 startup-message
    /// encoding for parameter-name / value pairs.
    public fn put_cstr(&mut self, s: &Text) {
        self.put_bytes(s.as_bytes());
        self.bytes.push(0 as Byte);
    }
}

// -----------------------------------------------------------------------------
// WireReader — counterpart to WireBuf, big-endian integer view over a slice.
// -----------------------------------------------------------------------------

public type WireReader is {
    src: List<Byte>,
    pos: Int,
};

public type WireReadError is
      WrShortRead { wanted: Int, available: Int }
    | WrInvalidUtf8;

implement Display for WireReadError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            WrShortRead { wanted, available } =>
                f.write_str(f"wire read short: wanted {wanted}, available {available}".as_str()),
            WrInvalidUtf8 =>
                f.write_str("wire read: invalid UTF-8"),
        }
    }
}

implement Debug for WireReadError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            WrShortRead { wanted, available } =>
                f.write_str(f"WrShortRead {{ wanted: {wanted}, available: {available} }}".as_str()),
            WrInvalidUtf8 =>
                f.write_str("WrInvalidUtf8"),
        }
    }
}

implement Eq for WireReadError {
    fn eq(&self, other: &WireReadError) -> Bool {
        match (self, other) {
            (WrShortRead { wanted: wa, available: aa },
             WrShortRead { wanted: wb, available: ab }) => wa == wb && aa == ab,
            (WrInvalidUtf8, WrInvalidUtf8) => true,
            _ => false,
        }
    }
}

implement WireReader {
    public fn new(src: List<Byte>) -> WireReader {
        WireReader { src: src, pos: 0 }
    }

    public fn position(&self) -> Int { self.pos }

    public fn remaining(&self) -> Int {
        (self.src.len() as Int) - self.pos
    }

    fn need(&self, n: Int) -> Result<(), WireReadError> {
        if self.remaining() < n {
            Err(WrShortRead { wanted: n, available: self.remaining() })
        } else {
            Ok(())
        }
    }

    public fn read_u8(&mut self) -> Result<Int, WireReadError> {
        self.need(1)?;
        let b = self.src[self.pos as Int] as Int;
        self.pos = self.pos + 1;
        Ok(b & 0xFF)
    }

    public fn read_u16_be(&mut self) -> Result<Int, WireReadError> {
        self.need(2)?;
        let hi = self.src[self.pos as Int] as Int;
        let lo = self.src[(self.pos + 1) as Int] as Int;
        self.pos = self.pos + 2;
        Ok(((hi & 0xFF) << 8) | (lo & 0xFF))
    }

    public fn read_u32_be(&mut self) -> Result<Int, WireReadError> {
        self.need(4)?;
        let p = self.pos as Int;
        let v = ((self.src[p] as Int) & 0xFF) << 24
              | ((self.src[p + 1] as Int) & 0xFF) << 16
              | ((self.src[p + 2] as Int) & 0xFF) << 8
              | ((self.src[p + 3] as Int) & 0xFF);
        self.pos = self.pos + 4;
        Ok(v)
    }

    public fn read_i32_be(&mut self) -> Result<Int, WireReadError> {
        let u = self.read_u32_be()?;
        // sign-extend from 32 bits.
        if (u & 0x8000_0000) != 0 {
            Ok(u | (-1 ^ 0xFFFF_FFFF))
        } else {
            Ok(u)
        }
    }

    public fn read_bytes(&mut self, n: Int) -> Result<List<Byte>, WireReadError> {
        self.need(n)?;
        let mut out: List<Byte> = [];
        let mut i = 0;
        while i < n {
            out.push(self.src[(self.pos + i) as Int]);
            i = i + 1;
        }
        self.pos = self.pos + n;
        Ok(out)
    }

    /// 4-byte length-prefixed payload; `-1` decodes as `None` (SQL NULL).
    public fn read_lp_bytes(&mut self) -> Result<Maybe<List<Byte>>, WireReadError> {
        let len = self.read_i32_be()?;
        if len < 0 {
            Ok(None)
        } else {
            let payload = self.read_bytes(len)?;
            Ok(Some(payload))
        }
    }

    /// Read until first NUL byte; the NUL is consumed but not returned.
    public fn read_cstr(&mut self) -> Result<Text, WireReadError> {
        let start = self.pos as Int;
        let mut i = start;
        let n = self.src.len() as Int;
        while i < n && (self.src[i] as Int) != 0 {
            i = i + 1;
        }
        if i >= n {
            return Err(WrShortRead { wanted: 1, available: 0 });
        }
        let mut out: List<Byte> = [];
        let mut j = start;
        while j < i {
            out.push(self.src[j]);
            j = j + 1;
        }
        self.pos = i + 1;     // skip the NUL
        match Text.from_utf8(out) {
            Ok(s)  => Ok(s),
            Err(_) => Err(WrInvalidUtf8),
        }
    }
}

// =============================================================================
// Arena-backed wire primitives — the zero-allocation hot-path counterpart to
// `WireBuf` / `WireRow`. These bump-allocate from a `SpindleArena` (typically
// the connection arena) instead of the heap, so a steady-state checkout of
// the pool produces zero per-query allocations and `release_healthy` resets
// every byte in O(1) via the generation bump.
// =============================================================================

// -----------------------------------------------------------------------------
// ArenaSlice — addressable byte range carved out of a `SpindleArena`.
// -----------------------------------------------------------------------------

/// Pointer / length / generation triple for a byte region inside an
/// arena. The `generation` field mirrors the arena's generation at
/// the time of carve-out; consumers MUST validate it against the
/// owning arena before dereferencing (the arena's `reset` invalidates
/// every outstanding `ArenaSlice` in O(1)).
///
/// `ArenaSlice` is intentionally Copy-able so it can be stashed in
/// row records, codec state, and decoder return values without
/// dragging a borrow through. Validation is a constant-time check
/// against the arena's current generation; if it fails, decoders
/// produce `DbError.DecodeError` and the connection is not poisoned
/// (the bug is in the caller's reference handling, not the wire).
public type ArenaSlice is {
    /// Raw pointer into the arena's contiguous buffer.
    ptr: Int,
    /// Length in bytes.
    len: Int,
    /// Arena generation at the time of carve-out — invalidated when
    /// the owning arena resets.
    generation: Int,
};

implement ArenaSlice {
    /// Construct an empty slice. Used as a tombstone for SQL-NULL
    /// columns; never dereferenced.
    public fn empty() -> ArenaSlice {
        ArenaSlice { ptr: 0, len: 0, generation: 0 }
    }

    /// True if this slice predates the current arena generation. The
    /// CBGR generation check on the underlying memory will catch any
    /// dereference, but adapters call this proactively to surface a
    /// clean `DecodeError` instead of a use-after-reset trap.
    public fn is_stale(&self, arena: &SpindleArena) -> Bool {
        self.generation != arena.generation()
    }

    /// Length in bytes.
    public fn len(&self) -> Int { self.len }

    /// True iff length is zero.
    public fn is_empty(&self) -> Bool { self.len == 0 }

    /// Materialise as a heap `List<Byte>` — escape hatch when the
    /// caller cannot honour the arena lifetime (handing decoded
    /// values to a long-lived application cache, for example). Pays
    /// one allocation; subsequent reads do not touch the arena.
    public fn to_owned(&self, arena: &SpindleArena) -> Maybe<List<Byte>> {
        if self.is_stale(arena) {
            return None;
        }
        let mut out: List<Byte> = List.with_capacity(self.len);
        let mut i: Int = 0;
        while i < self.len {
            out.push(load_byte(self.ptr + i) as Byte);
            i = i + 1;
        }
        Some(out)
    }

    /// Read a single byte at offset `off`. Returns `None` if `off` is
    /// out of range or the slice is stale. Used by codecs that peek a
    /// few bytes (sql-state class, type tag, etc).
    public fn byte_at(&self, off: Int, arena: &SpindleArena) -> Maybe<Int> {
        if self.is_stale(arena) || off < 0 || off >= self.len {
            return None;
        }
        Some(load_byte(self.ptr + off) & 0xFF)
    }

    public fn equals(&self, other: &ArenaSlice) -> Bool {
        self.ptr == other.ptr && self.len == other.len && self.generation == other.generation
    }
}

// -----------------------------------------------------------------------------
// ArenaWireBuf — append-only byte buffer backed by a `SpindleArena`.
// -----------------------------------------------------------------------------

/// Append-only buffer that bump-allocates pages from a `SpindleArena`
/// as it grows. Mirrors `WireBuf`'s big-endian writers exactly; the
/// difference is that `ArenaWireBuf.bytes()` returns a stable
/// `ArenaSlice` valid until the next arena reset, NOT a heap-owned
/// `List<Byte>`.
///
/// Growth strategy: start from a configurable minimum chunk
/// (`ARENA_WIRE_BUF_MIN_CHUNK`); when capacity is exhausted, request a
/// fresh allocation of `max(current_cap * 2, request_size)` bytes,
/// memcpy the existing payload, and continue. The old chunk is
/// abandoned (the arena will reclaim it on its next reset). For
/// well-sized arenas this fires at most once per checkout, and never
/// in steady state.
///
/// Lifetime: the buffer borrows the arena for the duration of every
/// `put_*` call (mutable borrow). Between calls the buffer just
/// stores `(ptr, len, cap, generation)` — the underlying memory
/// stays mapped as long as the arena's generation does not advance.
public type ArenaWireBuf is {
    /// Pointer to the current chunk's first byte, or 0 if empty /
    /// stale.
    ptr: Int,
    /// Bytes written since allocation.
    len: Int,
    /// Capacity of the current chunk in bytes.
    cap: Int,
    /// Arena generation observed at the most recent allocation —
    /// invalidates on `arena.reset`.
    generation: Int,
};

/// Initial chunk for `ArenaWireBuf.with_arena`. Sized so that the
/// vast majority of Postgres extended-protocol parameter blocks
/// (single-row INSERT bind, typed select with ≤ 12 params) fit
/// without growth.
public const ARENA_WIRE_BUF_MIN_CHUNK: Int = 512;

implement ArenaWireBuf {
    /// Empty buffer — lazy first allocation at the first `put_*`.
    /// Avoids burning arena bytes on a buffer that may never be
    /// written (e.g. a `Params = ()` impl).
    public fn empty() -> ArenaWireBuf {
        ArenaWireBuf { ptr: 0, len: 0, cap: 0, generation: 0 }
    }

    /// Pre-allocate `cap` bytes immediately. Use when the caller has
    /// a tight upper bound (Postgres header, MySQL packet header).
    public fn with_arena(arena: &mut SpindleArena, cap: Int) -> ArenaWireBuf {
        let request = if cap < ARENA_WIRE_BUF_MIN_CHUNK { ARENA_WIRE_BUF_MIN_CHUNK } else { cap };
        let p = arena.alloc_bytes(request);
        if p == 0 {
            return ArenaWireBuf.empty();
        }
        ArenaWireBuf {
            ptr: p,
            len: 0,
            cap: request,
            generation: arena.generation(),
        }
    }

    public fn len(&self) -> Int { self.len }
    public fn capacity(&self) -> Int { self.cap }
    public fn is_empty(&self) -> Bool { self.len == 0 }

    /// Slice over the bytes written so far, valid until the next
    /// arena reset.
    public fn as_slice(&self) -> ArenaSlice {
        ArenaSlice { ptr: self.ptr, len: self.len, generation: self.generation }
    }

    /// Reset the buffer's logical state without giving its capacity
    /// back. The arena owns the bytes — they get rewound on the next
    /// scope restore or arena reset. Useful when a single
    /// `ArenaWireBuf` is reused across multiple wire frames in one
    /// query (e.g. extended-protocol Parse / Bind / Execute).
    public fn truncate(&mut self) {
        self.len = 0;
    }

    // -------------------------------------------------------------------------
    // Growth
    // -------------------------------------------------------------------------

    /// Ensure the buffer has space for `extra` more bytes. Allocates
    /// a fresh chunk and copies if needed. Returns true on success;
    /// false if the arena is exhausted (caller must propagate as
    /// `EncodeError`).
    fn ensure(&mut self, arena: &mut SpindleArena, extra: Int) -> Bool {
        if extra <= 0 {
            return true;
        }
        // Stale buffer (arena reset under us) — restart from scratch.
        if self.generation != arena.generation() {
            self.ptr = 0;
            self.len = 0;
            self.cap = 0;
            self.generation = 0;
        }
        let needed = self.len + extra;
        if needed <= self.cap {
            return true;
        }
        let mut new_cap = if self.cap < ARENA_WIRE_BUF_MIN_CHUNK { ARENA_WIRE_BUF_MIN_CHUNK } else { self.cap * 2 };
        while new_cap < needed {
            new_cap = new_cap * 2;
        }
        let new_ptr = arena.alloc_bytes(new_cap);
        if new_ptr == 0 {
            return false;
        }
        if self.ptr != 0 && self.len > 0 {
            let _ = memcpy(new_ptr, self.ptr, self.len);
        }
        self.ptr = new_ptr;
        self.cap = new_cap;
        self.generation = arena.generation();
        true
    }

    // -------------------------------------------------------------------------
    // Big-endian primitive writers — mirror `WireBuf`.
    // -------------------------------------------------------------------------

    /// Append one byte; returns false on arena exhaustion.
    public fn put_u8(&mut self, arena: &mut SpindleArena, v: Int) -> Bool {
        if !self.ensure(arena, 1) { return false; }
        let _ = store_byte(self.ptr + self.len, v & 0xFF);
        self.len = self.len + 1;
        true
    }

    public fn put_u16_be(&mut self, arena: &mut SpindleArena, v: Int) -> Bool {
        if !self.ensure(arena, 2) { return false; }
        let _ = store_byte(self.ptr + self.len,     (v >> 8) & 0xFF);
        let _ = store_byte(self.ptr + self.len + 1,  v       & 0xFF);
        self.len = self.len + 2;
        true
    }

    public fn put_u32_be(&mut self, arena: &mut SpindleArena, v: Int) -> Bool {
        if !self.ensure(arena, 4) { return false; }
        let _ = store_byte(self.ptr + self.len,     (v >> 24) & 0xFF);
        let _ = store_byte(self.ptr + self.len + 1, (v >> 16) & 0xFF);
        let _ = store_byte(self.ptr + self.len + 2, (v >> 8)  & 0xFF);
        let _ = store_byte(self.ptr + self.len + 3,  v        & 0xFF);
        self.len = self.len + 4;
        true
    }

    public fn put_i32_be(&mut self, arena: &mut SpindleArena, v: Int) -> Bool {
        self.put_u32_be(arena, v)
    }

    public fn put_u64_be(&mut self, arena: &mut SpindleArena, v: Int) -> Bool {
        if !self.ensure(arena, 8) { return false; }
        let _ = store_byte(self.ptr + self.len,     (v >> 56) & 0xFF);
        let _ = store_byte(self.ptr + self.len + 1, (v >> 48) & 0xFF);
        let _ = store_byte(self.ptr + self.len + 2, (v >> 40) & 0xFF);
        let _ = store_byte(self.ptr + self.len + 3, (v >> 32) & 0xFF);
        let _ = store_byte(self.ptr + self.len + 4, (v >> 24) & 0xFF);
        let _ = store_byte(self.ptr + self.len + 5, (v >> 16) & 0xFF);
        let _ = store_byte(self.ptr + self.len + 6, (v >> 8)  & 0xFF);
        let _ = store_byte(self.ptr + self.len + 7,  v        & 0xFF);
        self.len = self.len + 8;
        true
    }

    public fn put_i64_be(&mut self, arena: &mut SpindleArena, v: Int) -> Bool {
        self.put_u64_be(arena, v)
    }

    /// Bulk append. Lowered to a single `llvm.memcpy` for SIMD-class
    /// throughput.
    public fn put_bytes(&mut self, arena: &mut SpindleArena, src: &[Byte]) -> Bool {
        let n = src.len() as Int;
        if n == 0 { return true; }
        if !self.ensure(arena, n) { return false; }
        // Walk the source slice byte-by-byte. The list-backed slice
        // does not expose a raw base pointer, so we cannot memcpy
        // straight from it; the per-byte loop is small enough that
        // LLVM lowers it efficiently in -O.
        let mut i: Int = 0;
        while i < n {
            let _ = store_byte(self.ptr + self.len + i, (src[i] as Int) & 0xFF);
            i = i + 1;
        }
        self.len = self.len + n;
        true
    }

    /// Postgres / MySQL pattern: 4-byte BE length prefix followed by
    /// payload, with `-1` denoting SQL NULL.
    public fn put_lp_bytes(&mut self, arena: &mut SpindleArena, payload: Maybe<&[Byte]>) -> Bool {
        match payload {
            None => self.put_i32_be(arena, -1),
            Some(b) => {
                if !self.put_i32_be(arena, b.len() as Int) { return false; }
                self.put_bytes(arena, b)
            }
        }
    }

    /// Null-terminated UTF-8 string — Postgres v3 startup-message
    /// convention.
    public fn put_cstr(&mut self, arena: &mut SpindleArena, s: &Text) -> Bool {
        let bytes = s.as_bytes();
        if !self.put_bytes(arena, bytes) { return false; }
        self.put_u8(arena, 0)
    }
}

// -----------------------------------------------------------------------------
// ArenaWireValue / ArenaWireRow — decoded row borrowed from arena.
// -----------------------------------------------------------------------------

/// Counterpart of `WireValue` whose payload is an `ArenaSlice` instead
/// of a heap `List<Byte>`. Decoders return this for every column;
/// callers materialise into the application type via the `Row`
/// protocol's `from_wire` (which can call `to_owned` if it needs to
/// outlive the arena scope).
public type ArenaWireValue is
      AvNull
    | AvPresent { slice: ArenaSlice, format: WireFormat };

implement ArenaWireValue {
    public fn is_null(&self) -> Bool {
        match self { AvNull => true, _ => false }
    }

    public fn slice(&self) -> Maybe<ArenaSlice> {
        match self {
            AvNull               => None,
            AvPresent { slice, .. } => Some(slice.clone()),
        }
    }

    public fn format(&self) -> Maybe<WireFormat> {
        match self {
            AvNull                  => None,
            AvPresent { format, .. } => Some(format.clone()),
        }
    }
}

/// Counterpart of `WireRow`. `values` is `List<ArenaWireValue>` —
/// the spine itself lives on the heap (one allocation per row, so
/// `query` returning N rows does N allocations for the spine), but
/// every byte of every column lives inside the arena. For the
/// streaming `query_stream` path the spine can also be arena-backed
/// via `ArenaWireRow.in_arena` — see below.
public type ArenaWireRow is {
    values: List<ArenaWireValue>,
    /// Arena generation observed at row construction. The spine
    /// itself is heap-owned, but every contained slice is keyed to
    /// this generation; `is_stale` short-circuits decoders that
    /// would otherwise touch invalidated memory.
    generation: Int,
};

implement ArenaWireRow {
    public fn empty() -> ArenaWireRow {
        ArenaWireRow { values: [], generation: 0 }
    }

    public fn with_values(arena: &SpindleArena, values: List<ArenaWireValue>) -> ArenaWireRow {
        ArenaWireRow { values: values, generation: arena.generation() }
    }

    public fn column_count(&self) -> Int {
        self.values.len() as Int
    }

    public fn is_stale(&self, arena: &SpindleArena) -> Bool {
        self.generation != arena.generation()
    }

    public fn value(&self, col: Int) -> Maybe<&ArenaWireValue> {
        if col < 0 || col >= self.values.len() as Int {
            None
        } else {
            Some(&self.values[col])
        }
    }

    public fn is_null(&self, col: Int) -> Bool {
        match self.value(col) {
            None    => true,
            Some(v) => v.is_null(),
        }
    }

    public fn slice(&self, col: Int) -> Maybe<ArenaSlice> {
        match self.value(col) {
            None    => None,
            Some(v) => v.slice(),
        }
    }
}

