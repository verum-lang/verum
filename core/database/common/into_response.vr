// =============================================================================
// core/database/common/into_response.vr — DbError → HTTP Response bridge
// =============================================================================
// Layer: 3 (Database — common surface)
// Spec: internal/specs/database.md §5.6, internal/specs/net-framework.md §5.6
// =============================================================================
//
// Wires `core.database.common.error.DbError` into the Weft framework's
// `IntoResponse` protocol so handlers that use `[Database]` get
// `?`-propagation to a typed HTTP response with no extra ceremony.
//
// The mapping is conservative: server-internal detail (SQL text,
// vendor error codes, position offsets, internal message bodies)
// is NEVER echoed to clients — instead we emit a stable shape per
// category. The full DbError still arrives at the configured logger
// via the framework's tracing layer; the response carries only the
// public-safe summary.
//
// Constraint violations get more specific HTTP status than the
// generic `EcClient → 400` mapping. The unified
// `DbError.as_constraint_violation` accessor lets us route both
// client-preflight catches (RefinementViolated) AND server-rejects
// (QueryFailed { sql_state: 23xxx }) through the same logic, so
// downstream consumers don't need to pattern-match the variant.
//
//  Constraint kind                          Status  Reason
//  -----------------------------------------------------------------------------
//  CkUnique / CkForeignKey / CkRestrict  → 409 Conflict
//  CkCheck / CkNotNull / CkDataException → 422 Unprocessable Entity
//
//  Other categories ─────────────────────────────────────────────────────────
//  EcTransient                            → 503 Service Unavailable
//  EcPermanent                            → 500 Internal Server Error
//  EcSecurity                             → 403 Forbidden
//  EcClient (non-constraint)              → 400 Bad Request "<msg>"
//  EcUpstream                             → 502 Bad Gateway
// =============================================================================

@arch_module(
    exposes: [Capability.Read(ResourceTag.Database("*")), Capability.Write(ResourceTag.Database("*"))],
    requires: [],
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LCls,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.database.common.into_response;

mount core.*;
mount base.{Text, Maybe, None, Some};
mount core.net.http.{Response, StatusCode};
mount core.net.weft.error.IntoResponse;
mount core.net.weft.response_ext.{
    resp_status, resp_with_body_text,
};
mount core.database.common.error.{
    DbError, ErrorCategory, ConstraintViolation, ConstraintKind,
    EcTransient, EcPermanent, EcSecurity, EcClient, EcUpstream,
    CkNotNull, CkForeignKey, CkUnique, CkCheck, CkRestrictViolation,
    CkDataException, CkOther,
};

implement IntoResponse for DbError {
    fn into_response(self) -> Response {
        // Constraint violations short-circuit the category lookup
        // — they have a dedicated HTTP status mapping that's more
        // useful to clients than the generic 400. The accessor
        // collapses RefinementViolated (client-preflight) and
        // QueryFailed { sql_state: 23xxx } (server-reject) into
        // the same `ConstraintViolation` shape so we don't repeat
        // the mapping for both code paths.
        match self.as_constraint_violation() {
            Some(cv) => {
                let (status, body) = render_for_constraint(&cv, &self);
                let resp = resp_status(status);
                return resp_with_body_text(resp, body);
            }
            None => {}
        }
        let category = self.category();
        let (status, body) = render_for_category(&category, &self);
        let resp = resp_status(status);
        resp_with_body_text(resp, body)
    }
}

fn render_for_constraint(cv: &ConstraintViolation, err: &DbError) -> (StatusCode, Text) {
    match cv.kind {
        // Conflict-class constraints: the row's data is internally
        // consistent but conflicts with existing rows. 409 Conflict
        // is the canonical HTTP semantic — clients typically retry
        // with a different key (UPSERT, alternative ID).
        CkUnique             => (StatusCode.new(409), "conflict".clone()),
        CkForeignKey         => (StatusCode.new(409), "foreign key violation".clone()),
        CkRestrictViolation  => (StatusCode.new(409), "restrict violation".clone()),

        // Validation-class: the row's data itself is wrong (out of
        // range, missing required field, regex mismatch). 422
        // Unprocessable Entity per RFC 4918 — the request was
        // syntactically valid but the content failed validation.
        CkCheck              => (StatusCode.new(422), "validation failed".clone()),
        CkNotNull            => (StatusCode.new(422), "missing required field".clone()),
        CkDataException      => (StatusCode.new(422), "value out of range".clone()),

        // Forward-compat — unrecognised 23xxx codes fall back to
        // the safe, shape-preserving 400.
        CkOther              => (StatusCode.new(400), err.message()),
    }
}

fn render_for_category(category: &ErrorCategory, err: &DbError) -> (StatusCode, Text) {
    match category {
        EcTransient => (StatusCode.new(503), "service temporarily unavailable".clone()),
        EcPermanent => (StatusCode.new(500), "internal error".clone()),
        EcSecurity  => (StatusCode.new(403), "access denied".clone()),
        EcUpstream  => (StatusCode.new(502), "upstream error".clone()),
        EcClient    => {
            // DbError.message() is already de-detailed (no SQL text,
            // no vendor codes — the constructors only carry safe
            // summaries). Forwarding it tells the client what shape
            // of validation failed without leaking server internals.
            (StatusCode.new(400), err.message())
        }
    }
}
