// =============================================================================
// core/database/common/pool_impl.vr — concrete ConnectionPool<C>
// =============================================================================
// Layer: 3 (Database — common implementation)
// Spec: internal/specs/database.md §4.3
// =============================================================================
//

// Generic connection pool implementation parameterised over a
// connection type `C` and a factory closure that produces fresh
// connections on demand. Per-vendor `SqlitePool` / `PgPool` /
// `MysqlPool` are thin wrappers that pin `C` and inject the
// vendor-specific factory.
//

// Internals:
//  * `Mutex<PoolInner<C>>` guards the idle queue and bookkeeping.
//  * `idle: List<C>` is a LIFO stack — recent connections are
//  served first so warm sockets stay warm and TCP RST'd ones get
//  evicted on the next health-check.
//  * `outstanding` counts checked-out connections; the pool refuses
//  to allocate beyond `max_connections`.
//  * `acquire_timeout_ms` bounds the wait for an available slot.
//  We poll-and-sleep rather than condvar-await for portability;
//  the production runtime swaps in `core.async.notify` when the
//  async-pool variant lands.
//

// Returned `PoolHandle` is affine — drop after use to release the
// connection. The vendor-specific façade owns the recycle / discard
// decision via `release_kind`:
//  * `Healthy` — return to idle pool.
//  * `Discard(reason)` — close + decrement outstanding (the next
//  acquire reopens via the factory).
// =============================================================================

@arch_module(
    exposes: [Capability.Read(ResourceTag.Database("*")), Capability.Write(ResourceTag.Database("*"))],
    requires: [],
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LCls,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.database.common.pool_impl;

mount core.*;
mount base.{Result, Ok, Err, Text, Maybe, None, Some};
mount collections.List;
mount sync.mutex.Mutex;
mount sync.condvar.Condvar;
mount time.instant.Instant;
mount core.database.common.error.{DbError, AdapterId, AdapterSpecific, PoolErrorKind};
mount core.database.common.arena.{SpindleArena, ArenaPhase, ArenaStats, ApConnection};

// -----------------------------------------------------------------------------
// Configuration
// -----------------------------------------------------------------------------

public type PoolConfig is {
    /// Connections held even when idle. The pool launches `min_connections`
    /// eagerly during `launch()` so the first acquire is never a cold
    /// connect. 0 = lazy — every connection is built on first acquire.
    min_connections: Int,
    /// Hard cap on total live connections (idle + checked out). Acquires
    /// past this point park on a timer until a release frees a slot or
    /// `acquire_timeout_ms` elapses.
    max_connections: Int,
    /// Acquire timeout — DbError.PoolFailure { kind: PekExhausted } after.
    acquire_timeout_ms: Int,
    /// DEPRECATED. Was used by the old poll-and-sleep `acquire`
    /// loop; the current implementation parks acquirers on a
    /// `Condvar` and is woken in O(1) by `release_healthy` /
    /// `release_discard`. Kept to preserve constructor-shape
    /// compatibility for existing call sites; ignored on the hot
    /// path. Will be removed once all adapter wrappers stop
    /// passing it explicitly.
    poll_interval_ms: Int,
    /// Adapter id stamped onto every error this pool produces. Filled
    /// in by the per-vendor wrapper.
    adapter_id: AdapterId,
}

implement PoolConfig {
    public fn default(adapter_id: AdapterId) -> PoolConfig {
        PoolConfig {
            min_connections: 1,
            max_connections: 16,
            acquire_timeout_ms: 30_000,
            poll_interval_ms: 5,
            adapter_id: adapter_id,
        }
    }

    public fn with_min(self, n: Int) -> PoolConfig {
        PoolConfig { min_connections: n, .. self }
    }
    public fn with_max(self, n: Int) -> PoolConfig {
        PoolConfig { max_connections: n, .. self }
    }
    public fn with_acquire_timeout_ms(self, ms: Int) -> PoolConfig {
        PoolConfig { acquire_timeout_ms: ms, .. self }
    }
}

// -----------------------------------------------------------------------------
// Release verdict
// -----------------------------------------------------------------------------

public type ReleaseKind is
      Healthy
    | Discard(Text);     // reason — usually the propagated error text

// -----------------------------------------------------------------------------
// Internal state
// -----------------------------------------------------------------------------

type PoolInner<C> is {
    idle: List<C>,
    /// Per-slot connection arenas pinned to currently-idle connections.
    /// Reused across checkouts — `acquire` grabs the arena alongside
    /// the connection so the new owner inherits a primed bump pointer
    /// without paying the mmap on first use. `release_healthy` bumps
    /// the generation (O(1)) before pushing the slot back here, so
    /// every reference carved by the previous owner is invalidated.
    idle_arenas: List<SpindleArena>,
    outstanding: Int,
    /// Monotonic counter for assigning checkouts a unique ID — useful
    /// for tracing and for the `PoolHandle.checked_out_at_ms` slot
    /// in the protocol surface.
    next_id: Int,
    /// Total successful acquires since launch.
    total_acquired: Int,
    /// Total acquire timeouts (PekExhausted).
    total_timeouts: Int,
    /// Total errors during connect / checkout.
    total_errors: Int,
    /// Cumulative arena resets — one per `release_healthy`. Feeds the
    /// `db.pool.connection.recycled_count` metric.
    total_arena_resets: Int,
}

// -----------------------------------------------------------------------------
// ConnectionPool
// -----------------------------------------------------------------------------

public type ConnectionPool<C> is {
    config: PoolConfig,
    /// Factory closure boxed into a function-pointer-like value. The
    /// pool re-invokes this whenever it needs to build a fresh
    /// connection. Errors propagate verbatim.
    factory: fn() -> Result<C, DbError>,
    inner: Mutex<PoolInner<C>>,
    /// Acquirer wakeup primitive. Every `release_healthy` /
    /// `release_discard` notifies one waiter; `drain` notifies all.
    /// Replaces the previous poll-and-sleep loop with a real
    /// futex-backed wait — acquirers are woken in O(1) the moment
    /// a slot frees instead of after a 5 ms polling tick.
    cond: Condvar,
    /// Pool-scoped arena. Lives the entire pool lifetime; holds
    /// schema snapshots, prepared-statement cache entries, vendor
    /// metadata. NEVER reset while the pool is live (its references
    /// outlive every checkout). Wrapped in a `Mutex` so concurrent
    /// acquires can register cached prepared statements without
    /// stepping on each other.
    pool_arena: Mutex<SpindleArena>,
}

implement<C> ConnectionPool<C> {
    /// Construct + warm — pre-opens `min_connections` upfront. If any
    /// of the eager connects fails we return that error and drop the
    /// already-open ones (caller can retry with a smaller min).
    public fn launch(
        config: PoolConfig,
        factory: fn() -> Result<C, DbError>,
    ) -> Result<ConnectionPool<C>, DbError> {
        if config.max_connections < 1 {
            return Err(DbError.PoolFailure {
                kind: PoolErrorKind.PekConfigInvalid("max_connections < 1".clone()),
            });
        }
        if config.min_connections < 0 || config.min_connections > config.max_connections {
            return Err(DbError.PoolFailure {
                kind: PoolErrorKind.PekConfigInvalid("min_connections out of range".clone()),
            });
        }
        let mut idle: List<C> = List.new();
        let mut idle_arenas: List<SpindleArena> = List.new();
        let mut i: Int = 0;
        while i < config.min_connections {
            match factory() {
                Ok(c)  => {
                    idle.push(c);
                    // Pre-warm a connection arena per eagerly-opened
                    // slot so the first acquirer never pays the
                    // initial mmap.
                    idle_arenas.push(SpindleArena.new_connection(i + 1));
                }
                Err(e) => { return Err(e); }
            }
            i = i + 1;
        }
        let inner = PoolInner {
            idle: idle,
            idle_arenas: idle_arenas,
            outstanding: 0,
            // `next_id` starts past the warmed slots' owner_ids so
            // their diagnostics stay distinguishable.
            next_id: config.min_connections + 1,
            total_acquired: 0,
            total_timeouts: 0,
            total_errors: 0,
            total_arena_resets: 0,
        };
        Ok(ConnectionPool {
            config: config,
            factory: factory,
            inner: Mutex.new(inner),
            cond: Condvar.new(),
            pool_arena: Mutex.new(SpindleArena.new_pool()),
        })
    }

    /// Acquire one connection. Reuses an idle one when available;
    /// otherwise opens a fresh one if we are below `max_connections`;
    /// otherwise parks on a condvar until a slot frees or the
    /// `acquire_timeout_ms` deadline elapses.
    ///
    /// Wake-up flow:
    ///   * `release_healthy` / `release_discard` notify_one after
    ///     dropping the inner-state lock — wake-up cost is one
    ///     futex_wake when waiters > 0, otherwise zero.
    ///   * `drain` notify_alls so every parked acquirer learns the
    ///     pool is shutting down and can bail with `PekExhausted`.
    ///
    /// Latency: a release that frees a slot reaches the next
    /// acquirer in ~one syscall instead of the previous
    /// `poll_interval_ms` (default 5 ms) tick. Under load, that's
    /// the difference between p99 acquire latency tracking the
    /// query latency and being floored at `poll_interval_ms`.
    public fn acquire(&self) -> Result<PooledConnection<C>, DbError> {
        let total_deadline_ns = (self.config.acquire_timeout_ms as Int) * 1_000_000;
        let start = Instant.now();
        loop {
            // -----------------------------------------------------------------
            // Fast path 1 — pop an idle slot under the inner-state lock.
            // -----------------------------------------------------------------
            let mut guard = match self.inner.lock() {
                Ok(g)  => g,
                Err(_) => { return Err(self.poisoned_err()); }
            };
            if guard.idle.len() > 0 {
                let conn = match guard.idle.pop() {
                    Some(c) => c,
                    None    => { return Err(self.poisoned_err()); }
                };
                let arena = match guard.idle_arenas.pop() {
                    Some(a) => a,
                    None    => SpindleArena.new_connection(guard.next_id),
                };
                guard.outstanding = guard.outstanding + 1;
                guard.total_acquired = guard.total_acquired + 1;
                let id = guard.next_id;
                guard.next_id = guard.next_id + 1;
                return Ok(PooledConnection {
                    conn: Some(conn),
                    arena: Some(arena),
                    pool: self,
                    id: id,
                });
            }

            // -----------------------------------------------------------------
            // Fast path 2 — room to open a new connection. Reserve the
            // slot while holding the lock so a parallel acquirer sees
            // us as `outstanding`; drop the lock for the (possibly
            // slow) factory call so concurrent releases can land.
            // -----------------------------------------------------------------
            let total = (guard.idle.len() as Int) + guard.outstanding;
            if total < self.config.max_connections {
                guard.outstanding = guard.outstanding + 1;
                let id_for_factory = guard.next_id;
                let _ = guard;     // drop before factory call
                match (self.factory)() {
                    Ok(conn) => {
                        let mut g = match self.inner.lock() {
                            Ok(g)  => g,
                            Err(_) => { return Err(self.poisoned_err()); }
                        };
                        g.total_acquired = g.total_acquired + 1;
                        let id = g.next_id;
                        g.next_id = g.next_id + 1;
                        return Ok(PooledConnection {
                            conn: Some(conn),
                            arena: Some(SpindleArena.new_connection(id)),
                            pool: self,
                            id: id,
                        });
                    }
                    Err(e) => {
                        let mut g = match self.inner.lock() {
                            Ok(g)  => g,
                            Err(_) => { return Err(self.poisoned_err()); }
                        };
                        if g.outstanding > 0 {
                            g.outstanding = g.outstanding - 1;
                        }
                        g.total_errors = g.total_errors + 1;
                        let _ = g;
                        // Wake one parked acquirer — we just freed
                        // the reserved slot they may have been
                        // waiting on.
                        self.cond.notify_one();
                        let _ = id_for_factory;
                        return Err(e);
                    }
                }
            }

            // -----------------------------------------------------------------
            // Slow path — pool full. Park on the condvar with the
            // remaining timeout. wait_timeout consumes the guard and
            // returns it (re-locked) on wake.
            // -----------------------------------------------------------------
            let elapsed_ns = start.elapsed().as_nanos();
            if elapsed_ns >= total_deadline_ns {
                guard.total_timeouts = guard.total_timeouts + 1;
                return Err(DbError.PoolFailure {
                    kind: PoolErrorKind.PekExhausted,
                });
            }
            let remaining_ns = total_deadline_ns - elapsed_ns;
            match self.cond.wait_timeout(guard, remaining_ns) {
                Ok((g, timed_out)) => {
                    if timed_out {
                        let mut g2 = g;
                        g2.total_timeouts = g2.total_timeouts + 1;
                        return Err(DbError.PoolFailure {
                            kind: PoolErrorKind.PekExhausted,
                        });
                    }
                    let _ = g;     // drop and retry the fast paths
                }
                Err(_) => return Err(self.poisoned_err()),
            }
        }
    }

    /// Release a checked-out connection. Healthy → recycled; Discard →
    /// closed + slot count decremented. Returning a connection always
    /// succeeds (the connection itself may already be closed; we just
    /// drop it).
    ///
    /// Healthy-path arena handling: the freshly-released arena is
    /// *reset* (generation++) before being parked in `idle_arenas`.
    /// This is the load-bearing CBGR step — every `ThinRef` /
    /// `ArenaSlice` carved out during the previous checkout becomes
    /// generation-stale on the next dereference, so leaked
    /// references caught by application code surface as a clean
    /// `DecodeError` rather than corrupting the next checkout's
    /// state. Cost: a single integer add and a bump-pointer rewind,
    /// O(1) regardless of how many bytes were allocated during the
    /// session.
    ///
    /// Discard-path: the arena is destroyed alongside the
    /// connection. The next acquire builds a fresh arena via the
    /// factory + `new_connection`.
    ///
    /// Wakeup discipline: the inner-state lock is released BEFORE
    /// `cond.notify_one()`. The mutex-then-notify ordering is the
    /// canonical low-contention pattern — the next acquirer wakes
    /// and immediately re-acquires the inner-state lock without
    /// fighting us for it. `Condvar.notify_one` is unconditional
    /// (see `core/sync/condvar.vr`), so the wake reaches a parked
    /// waiter even if `waiters > 0` was not yet visible to us.
    public fn release(&self, conn: C, mut arena: SpindleArena, kind: ReleaseKind) {
        {
            let mut guard = match self.inner.lock() {
                Ok(g)  => g,
                Err(_) => { return; }   // poisoned — silently drop the conn
            };
            match kind {
                Healthy => {
                    arena.reset();
                    guard.total_arena_resets = guard.total_arena_resets + 1;
                    guard.idle.push(conn);
                    guard.idle_arenas.push(arena);
                }
                Discard(_reason) => {
                    arena.destroy();
                    let _ = conn;     // dropped, factory rebuilds on next acquire
                }
            }
            if guard.outstanding > 0 {
                guard.outstanding = guard.outstanding - 1;
            }
            // Implicit drop of `guard` happens here — must be before
            // the notify so the woken acquirer can re-lock with no
            // contention.
        }
        self.cond.notify_one();
    }

    /// Read-only handle to the pool arena. The `Mutex` guards
    /// concurrent `alloc_bytes` / `snapshot` calls (callers register
    /// schema-snap entries, prepared statement metadata, etc).
    /// Long-lived references obtained through this lock MUST honour
    /// the pool's own lifetime — they outlive every checkout but die
    /// with the pool itself.
    public fn pool_arena(&self) -> &Mutex<SpindleArena> {
        &self.pool_arena
    }

    /// Drain — refuse new acquires (caller policed at handler scope),
    /// wait for in-flight checkouts to release, then close every idle
    /// connection AND destroy its parked arena. The connection drop
    /// is the responsibility of `C`'s destructor.
    ///
    /// Implementation: parks on the same `cond` as `acquire` —
    /// every `release_*` notifies, so we wake the moment
    /// `outstanding` could plausibly have hit zero and re-check
    /// under the lock. `notify_all` here ensures parked acquirers
    /// also learn the pool is shutting down (their next wake-up
    /// surface ends in `PekExhausted`).
    public fn drain(&self, deadline_ms: Int) -> Result<(), DbError> {
        // Wake every parked acquirer so they can re-evaluate and
        // bail with `PekExhausted` instead of holding the deadline.
        self.cond.notify_all();
        let total_deadline_ns = (deadline_ms as Int) * 1_000_000;
        let start = Instant.now();
        loop {
            let mut guard = match self.inner.lock() {
                Ok(g)  => g,
                Err(_) => { return Err(self.poisoned_err()); }
            };
            if guard.outstanding == 0 {
                // Tear down every parked arena before dropping the
                // List — `SpindleArena.destroy` releases the
                // underlying mmap'd buffer back to the OS.
                let mut i: Int = 0;
                let n = guard.idle_arenas.len() as Int;
                while i < n {
                    guard.idle_arenas[i].destroy();
                    i = i + 1;
                }
                guard.idle = List.new();
                guard.idle_arenas = List.new();
                return Ok(());
            }
            let elapsed_ns = start.elapsed().as_nanos();
            if elapsed_ns >= total_deadline_ns {
                return Err(DbError.PoolFailure {
                    kind: PoolErrorKind.PekDraining,
                });
            }
            let remaining_ns = total_deadline_ns - elapsed_ns;
            match self.cond.wait_timeout(guard, remaining_ns) {
                Ok((g, _timed_out)) => { let _ = g; /* loop re-checks */ }
                Err(_) => return Err(self.poisoned_err()),
            }
        }
    }

    /// Snapshot — total / idle / in_use / waiting / total_acquired /
    /// total_timeouts / total_errors / total_arena_resets.
    /// Useful for metrics emit (`db.pool.*`).
    public fn stats(&self) -> PoolStatsSnapshot {
        let guard = match self.inner.lock() {
            Ok(g)  => g,
            Err(_) => {
                return PoolStatsSnapshot {
                    total: 0, idle: 0, in_use: 0,
                    total_acquired: 0, total_timeouts: 0, total_errors: 0,
                    total_arena_resets: 0,
                };
            }
        };
        let idle = guard.idle.len() as Int;
        let in_use = guard.outstanding;
        PoolStatsSnapshot {
            total: idle + in_use,
            idle: idle,
            in_use: in_use,
            total_acquired: guard.total_acquired,
            total_timeouts: guard.total_timeouts,
            total_errors: guard.total_errors,
            total_arena_resets: guard.total_arena_resets,
        }
    }

    // -------------------------------------------------------------------------
    // Internals
    // -------------------------------------------------------------------------

    fn poisoned_err(&self) -> DbError {
        DbError.Adapter(AdapterSpecific {
            adapter: self.config.adapter_id.clone(),
            code: "POOL_POISONED".clone(),
            message: "pool mutex poisoned".clone(),
            retryable: false,
        })
    }
}

// -----------------------------------------------------------------------------
// PooledConnection — checkout handle.
// -----------------------------------------------------------------------------

/// Affine RAII handle. Caller MUST consume via `release_healthy` or
/// `release_discard`; the destructor's behaviour for an unconsumed
/// handle is to release as healthy (defensive — we'd rather leak a
/// possibly-bad connection back into the pool than leak the slot).
///
/// Carries a `SpindleArena` alongside the connection so adapter
/// code (`Connection.execute`, `Connection.query`, ...) can carve
/// per-query scopes without re-discovering "which arena does this
/// connection live in". Arena lifetime: born at first acquire (or
/// reused from the parked idle slot), reset on every healthy
/// release (generation-bump invalidates stale references), destroyed
/// on discard.
public type PooledConnection<C> is {
    conn: Maybe<C>,
    arena: Maybe<SpindleArena>,
    pool: &ConnectionPool<C>,
    id: Int,
}

implement<C> PooledConnection<C> {
    public fn id(&self) -> Int { self.id }

    /// Borrow the connection mutably — the body runs the actual
    /// query. Affine consume happens via release_*.
    public fn conn_mut(&mut self) -> &mut C {
        match &mut self.conn {
            Some(c) => c,
            None    => panic("PooledConnection: connection already released"),
        }
    }

    public fn conn_ref(&self) -> &C {
        match &self.conn {
            Some(c) => c,
            None    => panic("PooledConnection: connection already released"),
        }
    }

    /// Borrow the connection-scoped arena mutably. Adapter code
    /// passes this into `with_query_scope` / `with_tx_scope` so the
    /// per-query bump pointer rewinds at the right boundary.
    ///
    /// Lifetime: the arena lives as long as the `PooledConnection`
    /// itself; on `release_healthy` it is reset (generation++) and
    /// parked back in the pool's idle queue.
    public fn arena_mut(&mut self) -> &mut SpindleArena {
        match &mut self.arena {
            Some(a) => a,
            None    => panic("PooledConnection: arena already released"),
        }
    }

    public fn arena_ref(&self) -> &SpindleArena {
        match &self.arena {
            Some(a) => a,
            None    => panic("PooledConnection: arena already released"),
        }
    }

    /// Snapshot for metrics emission. Stable to call on a live or
    /// in-flight handle.
    public fn arena_stats(&self) -> Maybe<ArenaStats> {
        match &self.arena {
            Some(a) => Some(ArenaStats.from_arena(a)),
            None    => None,
        }
    }

    /// Return the connection to the pool as healthy. Resets the
    /// arena's generation in O(1) so any reference that escaped the
    /// previous handler scope becomes stale before the next
    /// acquirer sees the slot.
    public fn release_healthy(mut self) {
        let c = match self.conn {
            Some(c) => c,
            None    => { return; }
        };
        let a = match self.arena {
            Some(a) => a,
            None    => SpindleArena.new_connection(self.id),
        };
        self.conn = None;
        self.arena = None;
        self.pool.release(c, a, Healthy);
    }

    /// Discard the connection (will be reopened on next acquire).
    /// The arena is destroyed alongside.
    public fn release_discard(mut self, reason: Text) {
        let c = match self.conn {
            Some(c) => c,
            None    => { return; }
        };
        let a = match self.arena {
            Some(a) => a,
            None    => SpindleArena.new_connection(self.id),
        };
        self.conn = None;
        self.arena = None;
        self.pool.release(c, a, Discard(reason));
    }
}

// -----------------------------------------------------------------------------
// Stats snapshot
// -----------------------------------------------------------------------------

public type PoolStatsSnapshot is {
    total: Int,
    idle: Int,
    in_use: Int,
    total_acquired: Int,
    total_timeouts: Int,
    total_errors: Int,
    /// Cumulative arena generation-bumps (one per healthy release).
    /// Equals total successful checkout cycles in steady state. Feeds
    /// `db.pool.arena.reset_total` per spec §7.6.
    total_arena_resets: Int,
}
