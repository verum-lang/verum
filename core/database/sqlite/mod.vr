// =============================================================================
// core/database/sqlite/mod.vr — Spindle SQLite adapter
// =============================================================================
// Layer: 3 (Database — SQLite namespace)
// Spec: internal/specs/sqlite-native.md (engine), internal/specs/database.md §6.2
// =============================================================================
//
// Two-tier layout:
//
//   * `core.database.sqlite.{adapter,connection,error}` — Spindle
//     adapter façade. Carries the unified `core.database.common.error.
//     DbError`, exposes `SqliteAdapter` / `SqliteConfig` / `Sqlite-
//     Connection` for user code.
//
//   * `core.database.sqlite.native` — pure-Verum SQLite reimplementation
//     (loom). The façade above sits on top of `native.l7_api`; once
//     loom's WAL + PosixVfs land (T3 / T4) the file-backed code path
//     stops returning UNSUPPORTED.
// =============================================================================

module core.database.sqlite;

// Loom — pure-Verum engine.
public module native;

// Spindle adapter façade.
public module error;
public module connection;
public module adapter;
public module pool;
public module introspect;

// Re-exports — keep the user-facing surface compact.
public mount .adapter.{
    SqliteAdapter, SqliteConfig, SqliteJournalMode, SqliteTarget,
    StMemory, StSharedMemory, StFile,
    JmDelete, JmTruncate, JmPersist, JmMemory, JmWal, JmOff,
};
public mount .connection.{
    SqliteConnection, SqliteValue, SqliteCapability,
    SvNull, SvInt, SvReal, SvText, SvBlob,
    ScRead, ScReadWrite, ScAdmin,
    Transaction, TxKind, TkDeferred, TkImmediate, TkExclusive,
    BackupSession, BackupOutcome, BackupStepRequest,
    PragmaValue, PvNull, PvInt, PvText, PvBool,
    PragmaKind,
    CommitHook, RollbackHook, UpdateHook, PreUpdateHook,
    AuthorizerHook, BusyHandler, ProgressHandler, TraceHook,
};
public mount .error.dberr_from_loom;
public mount .pool.SqlitePool;
public mount .introspect.introspect as introspect_sqlite;
