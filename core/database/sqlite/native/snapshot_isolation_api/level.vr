// Isolation level.

module core.database.sqlite.native.snapshot_isolation_api.level;

mount base.{Bool, Text};

public type IsolationLevel is
    | IlReadCommitted      // default in WAL — fresh snapshot per stmt
    | IlRepeatableRead     // BEGIN pins a snapshot — reads never diverge
    | IlSerializable       // BEGIN EXCLUSIVE — plus write-write conflicts ordered
    ;

public fn level_name(l: &IsolationLevel) -> Text {
    match l {
        IlReadCommitted  => "READ COMMITTED".clone(),
        IlRepeatableRead => "REPEATABLE READ".clone(),
        IlSerializable   => "SERIALIZABLE".clone(),
    }
}

// Read-anomaly permissibility (per ANSI-SQL):
//   ReadCommitted:    allows non-repeatable reads + phantoms
//   RepeatableRead:   allows phantoms, blocks non-repeatable reads
//   Serializable:     blocks all three
public fn allows_nonrepeatable_read(l: &IsolationLevel) -> Bool {
    match l { IlReadCommitted => true, _ => false }
}

public fn allows_phantom_read(l: &IsolationLevel) -> Bool {
    match l {
        IlSerializable => false,
        _              => true,
    }
}

public fn default_in_wal_mode() -> IsolationLevel { IlReadCommitted }

// Sort order by strictness for the planner's rules.
public fn strictness_rank(l: &IsolationLevel) -> Int {
    match l {
        IlReadCommitted  => 0,
        IlRepeatableRead => 1,
        IlSerializable   => 2,
    }
}

public fn is_stronger_than(a: &IsolationLevel, b: &IsolationLevel) -> Bool {
    strictness_rank(a) > strictness_rank(b)
}
