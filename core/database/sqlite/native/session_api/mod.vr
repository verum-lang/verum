// =============================================================================
// core/database/sqlite/native/session_api/mod.vr
// =============================================================================
// Layer: 7 (façade — sqlite3session_* surface)
// Spec: SQLite C API — session extension.
//
//   sqlite3session_create(db, name, &out)       → new session
//   sqlite3session_attach(sess, zTab)           → attach table
//   sqlite3session_enable(sess, bEnable)
//   sqlite3session_indirect(sess, bIndirect)
//   sqlite3session_table_filter(sess, xFilter, pArg)
//   sqlite3session_changeset(sess, &sz, &out)   → emit changeset
//   sqlite3session_patchset(sess, &sz, &out)
//   sqlite3session_diff(sess, zFrom, zTable, …) → diff-mode changeset
//   sqlite3session_delete(sess)                 → release
//   sqlite3session_isempty(sess)                → 1 / 0
//
// Submodules:
//   * `handle`  — Session descriptor (id, schema, enabled/indirect flags)
//   * `op`      — SessionOp sum enumerating C-API entry points
//   * `outcome` — typed return (Ok / SessionEmpty / Failed)
// =============================================================================

module core.database.sqlite.native.session_api;

public module handle;
public module op;
public module outcome;
