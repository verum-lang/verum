module core.database.sqlite.native.l6_session.connection;

// =============================================================================
// l6_session/connection.vr — per-session handle
// =============================================================================
// Layer: 6
// Spec: sqlite-native.md §4.8 + §16
//
// A `Connection` is what user code holds to talk to loom. It bundles:
//
//   * Mode               — Read / Write / Admin capability marker
//   * Pager actor ref    — single-writer L1 pager (v1 keeps the Pager
//                          by value; async actor IPC lands later)
//   * Schema cache       — L6.4
//   * Transaction state  — autocommit / nested-savepoint counter
//
// Capability types (spec §4.8):
//
//   * Read   — SELECT + PRAGMA query_only
//   * Write  — Read + INSERT/UPDATE/DELETE (no DDL)
//   * Admin  — Write + DDL + writable_schema + VACUUM
//
// Mode upgrades are disallowed — the type carries the capability, so
// accidental `readonly.execute(INSERT...)` is a compile-time error at
// the L7 facade, not a runtime SQLITE_READONLY.
//
// The v1 ships everything as a single sum type (ConnectionMode) because
// Verum v1 doesn't yet wire phantom-type capabilities through generic
// implements; the sum-type runtime check is the bridge. L7 will wrap
// it behind a trait hierarchy once that lands.
// =============================================================================

mount core.*;
mount collections.{List, Map};
mount base.{Result, Ok, Err, Text, Maybe};
mount core.database.sqlite.native.l0_vfs.OpenFlags;
mount core.database.sqlite.native.l1_pager.{
    Pager, pager_open_memory, pager_open_file_rwc, pager_open_file_ro,
};
mount core.database.sqlite.native.l4_vdbe.Register;
mount core.database.sqlite.native.l6_session.schema_cache.{
    SchemaCache, schema_cache_new,
};
mount core.database.sqlite.native.ext.registry.{
    FnRegistry, registry_new,
};
mount core.database.sqlite.native.ext.hooks.{
    CommitDecision, CdAllow, CdAbort,
};
mount core.database.sqlite.native.pragmas.config.{
    PragmaConfig, pragma_config_default,
};
mount core.database.sqlite.native.incrblob.engine.{
    BlobEngine, engine_new as blob_engine_new,
};

// -----------------------------------------------------------------------------
// Mode
// -----------------------------------------------------------------------------

public type ConnectionMode is CmRead | CmWrite | CmAdmin;

public fn mode_can_write(m: ConnectionMode) -> Bool {
    match m {
        CmRead  => false,
        CmWrite | CmAdmin => true,
    }
}

public fn mode_can_ddl(m: ConnectionMode) -> Bool {
    match m {
        CmAdmin => true,
        _ => false,
    }
}

public fn mode_name(m: ConnectionMode) -> Text {
    match m {
        CmRead  => "read".clone(),
        CmWrite => "write".clone(),
        CmAdmin => "admin".clone(),
    }
}

// -----------------------------------------------------------------------------
// Transaction state
// -----------------------------------------------------------------------------

public type TxMode is TmAutocommit | TmDeferred | TmImmediate | TmExclusive;

public type TxState is {
    mode: TxMode,
    depth: Int,                  // 0 = autocommit; 1+ = savepoint depth
    active: Bool,                // true once an explicit BEGIN has fired
};

public fn tx_state_autocommit() -> TxState {
    TxState { mode: TmAutocommit, depth: 0, active: false }
}

// -----------------------------------------------------------------------------
// Connection
// -----------------------------------------------------------------------------

public type ConnectionError is
      NotWritable
    | NotAdmin
    | TxAlreadyActive
    | TxNotActive
    | IoError(Text);

implement Display for ConnectionError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            NotWritable     => f.write_str("sqlite connection not writable"),
            NotAdmin        => f.write_str("sqlite connection not admin"),
            TxAlreadyActive => f.write_str("sqlite transaction already active"),
            TxNotActive     => f.write_str("sqlite no active transaction"),
            IoError(m)      => f.write_str(f"sqlite connection I/O error: {m}".as_str()),
        }
    }
}

implement Debug for ConnectionError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            NotWritable     => f.write_str("NotWritable"),
            NotAdmin        => f.write_str("NotAdmin"),
            TxAlreadyActive => f.write_str("TxAlreadyActive"),
            TxNotActive     => f.write_str("TxNotActive"),
            IoError(m)      => f.write_str(f"IoError({m})".as_str()),
        }
    }
}

implement Eq for ConnectionError {
    fn eq(&self, other: &ConnectionError) -> Bool {
        match (self, other) {
            (NotWritable,     NotWritable)     => true,
            (NotAdmin,        NotAdmin)        => true,
            (TxAlreadyActive, TxAlreadyActive) => true,
            (TxNotActive,     TxNotActive)     => true,
            (IoError(a),      IoError(b))      => a == b,
            _ => false,
        }
    }
}

public type Connection is {
    mode: ConnectionMode,
    pager: Pager,
    schema: SchemaCache,
    tx: TxState,
    path: Text,                  // ":memory:" / absolute path / URI
    next_root_page: Int,         // bump-allocator for CREATE TABLE / CREATE INDEX
                                  // (first user table starts at page 2; page 1 is
                                  // the main DB header + sqlite_schema root).
    // Connection-scoped persistent row-store. Maps each table's
    // `root_page` to its current row list. A prepared statement's
    // CursorTable is per-statement (lives inside VdbeState), but
    // OpenRead / OpenWrite seed the cursor slot from this map before
    // execution and Insert / Delete writeback after. This is the
    // bridge that makes INSERT-then-SELECT in the same connection
    // actually see the inserted rows — real pager-backed row
    // persistence plugs in here once the actor IPC lands.
    table_store: Map<Int, List<List<Register>>>,
    /// Per-connection function & hook registry — holds scalar /
    /// aggregate / window function entries plus the eight observation
    /// hook slots (commit / rollback / update / pre_update /
    /// authorizer / busy / progress / trace).  Last subscriber wins.
    /// See `core.database.sqlite.native.ext.registry`.
    registry: FnRegistry,
    /// Per-connection PRAGMA state (cache_size, journal_mode,
    /// synchronous, …).  Driven by `pragmas/dispatch.execute`; read
    /// by every code path that wants to honour a PRAGMA the user has
    /// set (foreign_keys gate in CHECK violation, query_only gate in
    /// .execute, etc.).
    pragma_cfg: PragmaConfig,
    /// Live `sqlite3_blob_*` handles owned by this connection.  Each
    /// `blob_open` call mints a stable handle_id; `blob_close` marks
    /// the slot closed but keeps the entry so subsequent calls with
    /// the same id surface a clean `BeAborted` rather than a stale
    /// reference.  See `core.database.sqlite.native.incrblob`.
    blob_engine: BlobEngine,
};

/// Open an in-memory connection with the given mode. All three modes
/// work on `:memory:` — there's no file-permission layer to honour.
public fn open_memory(mode: ConnectionMode) -> Result<Connection, ConnectionError> {
    let pager = match pager_open_memory() {
        Ok(p)  => p,
        Err(_) => { return Err(IoError("pager_open_memory failed".clone())); }
    };
    Ok(Connection {
        mode: mode,
        pager: pager,
        schema: schema_cache_new(),
        tx: tx_state_autocommit(),
        path: ":memory:".clone(),
        next_root_page: 2,
        table_store: Map.new(),
        registry: registry_new(),
        pragma_cfg: pragma_config_default(),
        blob_engine: blob_engine_new(),
    })
}

public fn open_readonly_memory() -> Result<Connection, ConnectionError> {
    open_memory(CmRead)
}

public fn open_readwrite_memory() -> Result<Connection, ConnectionError> {
    open_memory(CmWrite)
}

public fn open_admin_memory() -> Result<Connection, ConnectionError> {
    open_memory(CmAdmin)
}

/// Open a file-backed connection. The capability mode determines
/// whether the underlying pager opens read-only or read/write/create.
public fn open_file(path: &Text, mode: ConnectionMode) -> Result<Connection, ConnectionError> {
    let pager = match mode {
        CmRead => match pager_open_file_ro(path) {
            Ok(p)  => p,
            Err(_) => { return Err(IoError("pager_open_file_ro failed".clone())); }
        },
        CmWrite | CmAdmin => match pager_open_file_rwc(path) {
            Ok(p)  => p,
            Err(_) => { return Err(IoError("pager_open_file_rwc failed".clone())); }
        },
    };
    Ok(Connection {
        mode: mode,
        pager: pager,
        schema: schema_cache_new(),
        tx: tx_state_autocommit(),
        path: path.clone(),
        next_root_page: 2,
        table_store: Map.new(),
        registry: registry_new(),
        pragma_cfg: pragma_config_default(),
        blob_engine: blob_engine_new(),
    })
}

implement Connection {
    public fn mode(&self) -> ConnectionMode { self.mode }
    public fn path_text(&self) -> &Text { &self.path }
    public fn schema_generation(&self) -> Int { self.schema.gen() }
    public fn is_in_tx(&self) -> Bool { self.tx.active }
    public fn tx_depth(&self) -> Int { self.tx.depth }

    // -------------------------------------------------------------------------
    // Capability guards — L7 facade calls these before dispatching
    // -------------------------------------------------------------------------

    public fn ensure_writable(&self) -> Result<(), ConnectionError> {
        if mode_can_write(self.mode) { Ok(()) } else { Err(NotWritable) }
    }

    public fn ensure_admin(&self) -> Result<(), ConnectionError> {
        if mode_can_ddl(self.mode) { Ok(()) } else { Err(NotAdmin) }
    }

    // -------------------------------------------------------------------------
    // Transaction boundary
    // -------------------------------------------------------------------------

    public fn begin_tx(&mut self, mode: TxMode) -> Result<(), ConnectionError> {
        match self.ensure_writable() { Ok(_) => {}, Err(e) => { return Err(e); } }
        if self.tx.active { return Err(TxAlreadyActive); }
        self.tx = TxState { mode: mode, depth: 1, active: true };
        Ok(())
    }

    public fn commit_tx(&mut self) -> Result<(), ConnectionError> {
        if !self.tx.active { return Err(TxNotActive); }
        // Fire commit-hook BEFORE finalising tx.  Hook may veto
        // (CdAbort) — in that case we treat it as a constraint
        // violation and force a rollback instead.  Matches the SQLite
        // C API semantics for sqlite3_commit_hook.
        let veto: Maybe<Text> = match &mut self.registry.commit_hook {
            None => None,
            Some(h) => {
                let hook_ref = &mut **h;
                match hook_ref.on_commit() {
                    CdAllow      => None,
                    CdAbort(msg) => Some(msg),
                }
            }
        };
        match veto {
            None => {
                self.tx = tx_state_autocommit();
                Ok(())
            }
            Some(msg) => {
                // Commit aborted by hook → rollback the tx and emit
                // the hook's rejection reason via IoError until a
                // dedicated "constraint by hook" error variant lands.
                self.tx = tx_state_autocommit();
                Err(IoError(msg))
            }
        }
    }

    public fn rollback_tx(&mut self) -> Result<(), ConnectionError> {
        if !self.tx.active { return Err(TxNotActive); }
        self.tx = tx_state_autocommit();
        // Notify rollback-hook AFTER state transitions so observers
        // see the post-rollback world.  Notification only — no veto.
        match &mut self.registry.rollback_hook {
            None => {}
            Some(h) => {
                let hook_ref = &mut **h;
                hook_ref.on_rollback();
            }
        }
        Ok(())
    }

    /// Borrow the hook + function registry.  Used by the L7 façade to
    /// expose `Database.set_*_hook` / `register_scalar` etc.
    public fn registry_view(&self) -> &FnRegistry { &self.registry }
    public fn registry_mut(&mut self) -> &mut FnRegistry { &mut self.registry }

    /// Borrow the per-connection PRAGMA state.  Used by the L7 typed
    /// pragma façade and by code paths that read pragma flags
    /// (foreign_keys, query_only, etc.) inline during execution.
    public fn pragma_cfg_view(&self) -> &PragmaConfig { &self.pragma_cfg }
    public fn pragma_cfg_mut(&mut self) -> &mut PragmaConfig { &mut self.pragma_cfg }

    /// Borrow the per-connection BLOB engine — the bookkeeping layer
    /// for `sqlite3_blob_open` / `_read` / `_write` / `_close`.
    public fn blob_engine_view(&self) -> &BlobEngine { &self.blob_engine }
    public fn blob_engine_mut(&mut self) -> &mut BlobEngine { &mut self.blob_engine }

    /// Savepoint push — increments depth without replacing `tx.mode`.
    /// Caller is responsible for issuing the SAVEPOINT VDBE opcode.
    public fn savepoint_push(&mut self) {
        if !self.tx.active {
            self.tx = TxState { mode: TmDeferred, depth: 1, active: true };
        }
        self.tx.depth = self.tx.depth + 1;
    }

    public fn savepoint_pop(&mut self) -> Result<(), ConnectionError> {
        if !self.tx.active || self.tx.depth <= 0 {
            return Err(TxNotActive);
        }
        self.tx.depth = self.tx.depth - 1;
        if self.tx.depth == 0 {
            self.tx = tx_state_autocommit();
        }
        Ok(())
    }

    // -------------------------------------------------------------------------
    // Schema access (exposed mutably for the Admin path)
    // -------------------------------------------------------------------------

    public fn schema(&self) -> &SchemaCache { &self.schema }
    public fn schema_mut(&mut self) -> &mut SchemaCache { &mut self.schema }

    /// Allocate a fresh root_page for a new B-tree (CREATE TABLE /
    /// CREATE INDEX). Bumps the internal counter and returns the
    /// assigned page number. v1 uses a simple bump; the real pager's
    /// free-list allocator takes over in a follow-up.
    public fn allocate_root_page(&mut self) -> Int {
        let p = self.next_root_page;
        self.next_root_page = self.next_root_page + 1;
        // Seed an empty row store entry so Insert/Rewind find a bucket.
        let _ = self.table_store.insert(p, List.new());
        p
    }

    public fn peek_next_root_page(&self) -> Int { self.next_root_page }

    // -------------------------------------------------------------------------
    // Persistent table store — backs INSERT/SELECT-across-statements
    // -------------------------------------------------------------------------

    /// Current rows at `root_page`. Returns empty list if unknown.
    public fn rows_at(&self, root_page: Int) -> List<List<Register>> {
        if !self.table_store.contains_key(root_page) {
            return List.new();
        }
        clone_rows(&self.table_store.get(root_page))
    }

    /// Replace rows at `root_page`. Creates the slot if absent.
    public fn set_rows_at(&mut self, root_page: Int, rows: List<List<Register>>) {
        let _ = self.table_store.insert(root_page, rows);
    }

    /// Has this root_page been registered? (CREATE TABLE allocates.)
    public fn has_table_at(&self, root_page: Int) -> Bool {
        self.table_store.contains_key(root_page)
    }

    /// Row count at `root_page`; 0 on missing.
    public fn row_count_at(&self, root_page: Int) -> Int {
        if !self.table_store.contains_key(root_page) { return 0; }
        self.table_store.get(root_page).len()
    }

    /// Drop a table's rows. Called after successful DROP TABLE.
    public fn forget_table_rows(&mut self, root_page: Int) {
        if self.table_store.contains_key(root_page) {
            let _ = self.table_store.remove(root_page);
        }
    }

    // -------------------------------------------------------------------------
    // Pager access — internal, consumed by the statement executor
    // -------------------------------------------------------------------------

    public fn pager(&self) -> &Pager { &self.pager }
    public fn pager_mut(&mut self) -> &mut Pager { &mut self.pager }
}

fn clone_rows(xs: &List<List<Register>>) -> List<List<Register>> {
    let mut out: List<List<Register>> = List.new();
    let mut i: Int = 0;
    while i < xs.len() {
        let row = &xs[i];
        let mut copy: List<Register> = List.new();
        let mut j: Int = 0;
        while j < row.len() {
            copy.push(row[j]);
            j = j + 1;
        }
        out.push(copy);
        i = i + 1;
    }
    out
}
