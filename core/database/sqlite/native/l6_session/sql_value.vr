module core.database.sqlite.native.l6_session.sql_value;

// =============================================================================
// l6_session/sql_value.vr — First-class SQLite value type for the L6 API (#158)
// =============================================================================
// Layer: 6
// Spec: sqlite-native.md §17 (PreparedStatement column extraction)
//
// Pre-fix: `PreparedStatement.column(n)` returned the raw L4 `Register`
// enum (`RNull` / `RInt` / `RReal` / `RText` / `RBlob` / `RRowId`).
// That coupled the L6 API to the L4 internal representation, leaked
// the `RRowId` distinction (which has no SQLite-API equivalent), and
// shipped no per-column type tag, no coercion methods, and no UTF-16
// access path.  Every consumer had to hand-roll Register destructuring.
//
// Post-fix: this module ships the canonical `SqlValue` sum type +
// `ColumnType` tag + coercion methods that match `sqlite3_column_*`
// semantics 1-to-1.  Conversion from `Register` is local + total
// (no Result; coercions are best-effort just like the C API).
//
// Architecture: pure data — no mutation, no I/O, no dependency on
// the pager or the cursor table.  All conversions are O(1) modulo
// a Text/Blob clone (the L4 register is borrowed; the SqlValue takes
// ownership of its payload — matches SQLite's "the returned value is
// valid until the next sqlite3_step() / sqlite3_reset()" contract).
//
// SQLite type-coercion rules (§17.5):
//
//   column_int(NULL)    = 0
//   column_int(REAL)    = trunc(REAL) clamped to i64
//   column_int(TEXT)    = parsed leading-decimal-prefix (0 on parse-fail)
//   column_int(BLOB)    = 0
//   column_double(NULL) = 0.0
//   column_double(INT)  = INT as f64
//   column_double(TEXT) = parse_double (0.0 on parse-fail)
//   column_double(BLOB) = 0.0
//   column_text(NULL)   = "" (the C API returns NULL pointer; Verum
//                              equivalent is the empty Text)
//   column_text(INT)    = decimal repr
//   column_text(REAL)   = decimal repr
//   column_text(BLOB)   = empty (UTF-8 view of arbitrary bytes is
//                                undefined behaviour)
//   column_blob(NULL)   = []
//   column_blob(TEXT)   = UTF-8 bytes of the text
//   column_blob(BLOB)   = the bytes
//   column_blob(INT)    = []
//
// =============================================================================

mount core.*;
mount collections.List;
mount base.{Text, Maybe};
mount core.database.sqlite.native.l4_vdbe.register.{
    Register, RNull, RInt, RReal, RText, RBlob, RRowId,
};

// -----------------------------------------------------------------------------
// SqlValue — the canonical SQLite value type
// -----------------------------------------------------------------------------

/// First-class SQLite value.  What `column_value(n)` returns.
///
/// Variants match SQLite's storage classes per §3.2.  `RRowId` from
/// the L4 register is folded into `VInt` here — the rowid is just an
/// integer at the SQLite-API surface (the distinction matters only
/// for cursor positioning, not for value extraction).
public type SqlValue is
      VNull
    | VInt(Int64)
    | VReal(Float64)
    | VText(Text)
    | VBlob(List<Byte>);

/// Storage-class tag — what `sqlite3_column_type(stmt, n)` returns.
/// Variants match SQLite's `SQLITE_NULL` / `SQLITE_INTEGER` /
/// `SQLITE_FLOAT` / `SQLITE_TEXT` / `SQLITE_BLOB` constants 1-to-1.
public type ColumnType is
      CtNull
    | CtInt
    | CtReal
    | CtText
    | CtBlob;

/// Numeric code matching the SQLite C API constants.  Useful for
/// FFI bindings + for serialisation:
///
///   1 SQLITE_INTEGER
///   2 SQLITE_FLOAT
///   3 SQLITE_TEXT
///   4 SQLITE_BLOB
///   5 SQLITE_NULL
public fn column_type_code(t: &ColumnType) -> Int {
    match t {
        CtInt  => 1,
        CtReal => 2,
        CtText => 3,
        CtBlob => 4,
        CtNull => 5,
    }
}

// -----------------------------------------------------------------------------
// Register adapter — the boundary between L4 and L6
// -----------------------------------------------------------------------------

/// Lift a Register into a SqlValue.  Cloning Text/Blob payloads is
/// necessary because the SqlValue outlives the register (which lives
/// in the per-step VdbeState and is overwritten on the next step).
pub fn sql_value_from_register(r: &Register) -> SqlValue {
    match r {
        RNull        => VNull,
        RInt(i)      => VInt(i),
        RRowId(i)    => VInt(i),
        RReal(x)     => VReal(x),
        RText(ref t) => VText(t.clone()),
        RBlob(ref b) => VBlob(b.clone()),
    }
}

/// Lower a SqlValue into a Register — used by the bind path so
/// callers can hand a SqlValue straight to `bind_value`.
pub fn register_from_sql_value(v: &SqlValue) -> Register {
    match v {
        VNull        => RNull,
        VInt(i)      => RInt(i),
        VReal(x)     => RReal(x),
        VText(ref t) => RText(t.clone()),
        VBlob(ref b) => RBlob(b.clone()),
    }
}

// -----------------------------------------------------------------------------
// Type tag accessor
// -----------------------------------------------------------------------------

/// `value_type(v)` — equivalent to `sqlite3_column_type(stmt, n)`.
pub fn value_type(v: &SqlValue) -> ColumnType {
    match v {
        VNull    => CtNull,
        VInt(_)  => CtInt,
        VReal(_) => CtReal,
        VText(_) => CtText,
        VBlob(_) => CtBlob,
    }
}

// -----------------------------------------------------------------------------
// Coercion — matches sqlite3_column_int / _double / _text / _blob
// -----------------------------------------------------------------------------

/// Coerce to Int64 per SQLite §17.5.  Total — never panics, never
/// returns Result; parse failures yield 0.
pub fn value_to_int(v: &SqlValue) -> Int64 {
    match v {
        VNull    => 0_i64,
        VInt(i)  => i,
        VReal(x) => float_to_i64_trunc(x),
        VText(ref t) => parse_leading_int(t),
        VBlob(_) => 0_i64,
    }
}

/// Coerce to Float64 per SQLite §17.5.  Same totality contract.
pub fn value_to_real(v: &SqlValue) -> Float64 {
    match v {
        VNull    => 0.0,
        VInt(i)  => i as Float64,
        VReal(x) => x,
        VText(ref t) => parse_leading_real(t),
        VBlob(_) => 0.0,
    }
}

/// Coerce to Text per SQLite §17.5.  NULL → "" (C API returns NULL
/// pointer; we return the empty Text — equivalent observable for
/// Verum callers since there's no null-Text distinction).
pub fn value_to_text(v: &SqlValue) -> Text {
    match v {
        VNull    => "".clone(),
        VInt(i)  => int64_to_text(i),
        VReal(x) => float_to_text(x),
        VText(ref t) => t.clone(),
        VBlob(_) => "".clone(),
    }
}

/// Coerce to Blob per SQLite §17.5.  TEXT → UTF-8 bytes (the
/// canonical mapping); INT/REAL/NULL → empty.
pub fn value_to_blob(v: &SqlValue) -> List<Byte> {
    match v {
        VNull    => List.new(),
        VInt(_)  => List.new(),
        VReal(_) => List.new(),
        VText(ref t) => text_to_byte_list(t),
        VBlob(ref b) => b.clone(),
    }
}

/// `value_bytes(v)` — `sqlite3_column_bytes`.  Returns the byte
/// length of the value's storage representation (TEXT → UTF-8 byte
/// count; BLOB → blob length; INT/REAL/NULL → 0).
pub fn value_bytes(v: &SqlValue) -> Int {
    match v {
        VNull    => 0,
        VInt(_)  => 0,
        VReal(_) => 0,
        VText(ref t) => t.as_bytes().len(),
        VBlob(ref b) => b.len(),
    }
}

/// `value_to_text16(v)` — `sqlite3_column_text16` analogue.  Returns
/// the value coerced to Text then re-encoded as UTF-16 code units.
/// Each code unit is a 16-bit value in the low half of the `Int`
/// (Verum's stdlib `encode_utf16` returns `List<Int>` of the same
/// shape).  Surrogate pairs are emitted naturally for code points
/// > U+FFFF.
pub fn value_to_text16(v: &SqlValue) -> List<Int> {
    let t = value_to_text(v);
    t.encode_utf16()
}

/// `value_bytes16(v)` — `sqlite3_column_bytes16`.  Number of BYTES
/// the UTF-16 encoding occupies (= 2 × number of code units).
pub fn value_bytes16(v: &SqlValue) -> Int {
    let units = value_to_text16(v);
    units.len() * 2
}

// -----------------------------------------------------------------------------
// Construction helpers — convenience for callers building SqlValue
// without going through Register
// -----------------------------------------------------------------------------

pub fn sql_null() -> SqlValue { VNull }
pub fn sql_int(i: Int64) -> SqlValue { VInt(i) }
pub fn sql_real(x: Float64) -> SqlValue { VReal(x) }
pub fn sql_text(t: Text) -> SqlValue { VText(t) }
pub fn sql_blob(b: List<Byte>) -> SqlValue { VBlob(b) }

/// Build a SqlValue from UTF-16 code units — `sqlite3_bind_text16`
/// analogue.  Returns VNull on decode failure (mismatched surrogate
/// pair or invalid sequence).
pub fn sql_text_from_utf16(units: &List<Int>) -> SqlValue {
    let slice = units.as_slice();
    match Text.from_utf16(slice) {
        Ok(t)  => VText(t),
        Err(_) => VNull,
    }
}

// -----------------------------------------------------------------------------
// Internal helpers — type-coercion implementations
// -----------------------------------------------------------------------------

/// Truncate a Float64 toward zero, clamping to i64 range.  Matches
/// SQLite's `sqlite3VdbeIntegerAffinity`: large reals saturate at
/// i64::MAX/MIN; NaN coerces to 0.
fn float_to_i64_trunc(x: Float64) -> Int64 {
    if x != x { return 0_i64; }  // NaN
    let max_f: Float64 = 9223372036854775807.0_f64;
    let min_f: Float64 = -9223372036854775808.0_f64;
    if x >= max_f { return 9223372036854775807_i64; }
    if x <= min_f { return -9223372036854775807_i64 - 1_i64; }
    x as Int64
}

/// Parse a leading decimal-integer prefix; matches SQLite's
/// `sqlite3Atoi64` lossy semantics — leading whitespace skipped,
/// optional sign, digits consumed greedily; non-digit suffix
/// silently dropped; returns 0 when no digits are found.
fn parse_leading_int(t: &Text) -> Int64 {
    let bytes = t.as_bytes();
    let mut i: Int = 0;
    // Skip whitespace.
    while i < bytes.len() {
        let c = bytes[i];
        if c == (0x20 as Byte) || c == (0x09 as Byte) || c == (0x0A as Byte) || c == (0x0D as Byte) {
            i = i + 1;
        } else {
            i = bytes.len() + 1;  // break
        }
    }
    if i > bytes.len() { i = i - 1 - bytes.len() + bytes.len(); }
    // ^ awkward Verum break — use a simpler shape:
    let mut k: Int = 0;
    while k < bytes.len() {
        let c = bytes[k];
        if c == (0x20 as Byte) || c == (0x09 as Byte) || c == (0x0A as Byte) || c == (0x0D as Byte) {
            k = k + 1;
        } else {
            break;
        }
    }
    let mut neg: Bool = false;
    if k < bytes.len() {
        if bytes[k] == (0x2D as Byte) { neg = true; k = k + 1; }       // '-'
        else if bytes[k] == (0x2B as Byte) { k = k + 1; }              // '+'
    }
    let mut acc: Int64 = 0_i64;
    let mut any: Bool = false;
    while k < bytes.len() {
        let c = bytes[k];
        if c >= (0x30 as Byte) && c <= (0x39 as Byte) {
            acc = acc * 10_i64 + ((c as Int64) - (0x30 as Int64));
            any = true;
            k = k + 1;
        } else {
            break;
        }
    }
    if !any { return 0_i64; }
    if neg { 0_i64 - acc } else { acc }
}

/// Parse a leading decimal-real prefix; matches SQLite's
/// `sqlite3AtoF` lossy semantics — leading whitespace skipped,
/// optional sign + integer part + optional `.fraction` + optional
/// `eExponent`.  Returns 0.0 on full parse failure.
fn parse_leading_real(t: &Text) -> Float64 {
    let bytes = t.as_bytes();
    let mut k: Int = 0;
    while k < bytes.len() {
        let c = bytes[k];
        if c == (0x20 as Byte) || c == (0x09 as Byte) || c == (0x0A as Byte) || c == (0x0D as Byte) {
            k = k + 1;
        } else {
            break;
        }
    }
    let mut neg: Bool = false;
    if k < bytes.len() {
        if bytes[k] == (0x2D as Byte) { neg = true; k = k + 1; }
        else if bytes[k] == (0x2B as Byte) { k = k + 1; }
    }
    let mut int_part: Float64 = 0.0;
    let mut any_digit: Bool = false;
    while k < bytes.len() {
        let c = bytes[k];
        if c >= (0x30 as Byte) && c <= (0x39 as Byte) {
            int_part = int_part * 10.0 + ((c as Int) - 0x30) as Float64;
            any_digit = true;
            k = k + 1;
        } else {
            break;
        }
    }
    let mut frac_part: Float64 = 0.0;
    let mut frac_div: Float64 = 1.0;
    if k < bytes.len() && bytes[k] == (0x2E as Byte) {  // '.'
        k = k + 1;
        while k < bytes.len() {
            let c = bytes[k];
            if c >= (0x30 as Byte) && c <= (0x39 as Byte) {
                frac_div = frac_div * 10.0;
                frac_part = frac_part * 10.0 + ((c as Int) - 0x30) as Float64;
                any_digit = true;
                k = k + 1;
            } else {
                break;
            }
        }
    }
    let mut value: Float64 = int_part + (frac_part / frac_div);
    // Optional exponent.
    if k < bytes.len() && (bytes[k] == (0x65 as Byte) || bytes[k] == (0x45 as Byte)) {  // 'e' / 'E'
        k = k + 1;
        let mut exp_neg: Bool = false;
        if k < bytes.len() {
            if bytes[k] == (0x2D as Byte) { exp_neg = true; k = k + 1; }
            else if bytes[k] == (0x2B as Byte) { k = k + 1; }
        }
        let mut exp: Int = 0;
        let mut any_exp: Bool = false;
        while k < bytes.len() {
            let c = bytes[k];
            if c >= (0x30 as Byte) && c <= (0x39 as Byte) {
                exp = exp * 10 + ((c as Int) - 0x30);
                any_exp = true;
                k = k + 1;
            } else {
                break;
            }
        }
        if any_exp {
            let mut p: Float64 = 1.0;
            let mut i: Int = 0;
            while i < exp { p = p * 10.0; i = i + 1; }
            if exp_neg { value = value / p; } else { value = value * p; }
        }
    }
    if !any_digit { return 0.0; }
    if neg { 0.0 - value } else { value }
}

/// Cheap Int64 → decimal Text without going through the full
/// stdlib Display path (avoids pulling Formatter through the L6 API).
fn int64_to_text(i: Int64) -> Text {
    if i == 0_i64 { return "0".clone(); }
    let neg = i < 0_i64;
    let mut x: Int64 = if neg { 0_i64 - i } else { i };
    let mut digits: List<Byte> = List.new();
    while x > 0_i64 {
        let d = (x % 10_i64) as Int;
        digits.push((0x30 + d) as Byte);
        x = x / 10_i64;
    }
    let mut out: List<Byte> = List.new();
    if neg { out.push(0x2D as Byte); }
    let mut k: Int = digits.len() - 1;
    while k >= 0 { out.push(digits[k]); k = k - 1; }
    Text.from_bytes(&out).unwrap_or("0".clone())
}

/// Best-effort Float64 → Text — strips trailing zeros from the
/// fractional part for readability.  Doesn't attempt full IEEE-754
/// round-trip precision; matches SQLite's "%!.15g" default to within
/// a few digits for typical values.  Negative zeros render as "-0".
fn float_to_text(x: Float64) -> Text {
    if x != x { return "NaN".clone(); }
    if x == 0.0 { return "0.0".clone(); }
    let neg = x < 0.0;
    let mut v: Float64 = if neg { 0.0 - x } else { x };
    // Decompose into integer + fractional.
    let int_part_i: Int64 = v as Int64;
    let int_text = int64_to_text(int_part_i);
    let mut frac: Float64 = v - (int_part_i as Float64);
    let mut out: List<Byte> = List.new();
    if neg {
        out.push(0x2D as Byte);
    }
    let int_bytes = int_text.as_bytes();
    let mut i: Int = 0;
    while i < int_bytes.len() { out.push(int_bytes[i]); i = i + 1; }
    out.push(0x2E as Byte);  // '.'
    // Emit up to 6 fractional digits.
    let mut k: Int = 0;
    while k < 6 && frac > 0.0 {
        frac = frac * 10.0;
        let d = frac as Int64;
        out.push((0x30 as Int64 + d) as Byte);
        frac = frac - (d as Float64);
        k = k + 1;
    }
    if k == 0 { out.push(0x30 as Byte); }   // ensure at least "x.0"
    Text.from_bytes(&out).unwrap_or("0.0".clone())
}

/// Convert a Text into an owned List<Byte> (UTF-8 bytes).  Used by
/// `value_to_blob(VText(...))`.
fn text_to_byte_list(t: &Text) -> List<Byte> {
    let raw = t.as_bytes();
    let mut out: List<Byte> = List.new();
    let mut i: Int = 0;
    while i < raw.len() { out.push(raw[i]); i = i + 1; }
    out
}
