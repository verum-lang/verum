@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.database.sqlite.native.l6_session;

// =============================================================================
// core/database/sqlite/native/l6_session/mod.vr — Session layer (L6)
// =============================================================================
// Layer: 6 — the Connection / SchemaCache / PreparedStatement surface.
// Dependencies: l4_vdbe, l5_sql, l1_pager
// =============================================================================

public module schema_cache;
public module connection;
public module statement;
public module bridge;
public module statement_cache;
public module sqlite_schema_parser;
public module statement_lifecycle;
public module sql_value;

public mount .schema_cache.{
    ColumnMeta, TableKind, TableMeta, IndexMeta,
    SessionSchemaError, SchemaCache,
    schema_cache_new, table_meta_from_create,
};

public mount .connection.{
    ConnectionMode, TxMode, TxState, Connection, ConnectionError,
    tx_state_autocommit,
    open_memory, open_readonly_memory, open_readwrite_memory, open_admin_memory,
    open_file,
    mode_can_write, mode_can_ddl, mode_name,
};

public mount .statement.{
    ParamBindings, PreparedStatement, StmtError,
    param_bindings_new, prepare, prepare_with_schema,
};

public mount .bridge.{
    seed_cursors_from_connection, writeback_cursors_to_connection,
};

public mount .statement_cache.{
    StatementCache, CachedSlot,
    statement_cache_new, statement_cache_default,
};

public mount .sqlite_schema_parser.{
    SchemaRow, SchemaRowKind, SchemaRowError, LoadReport,
    SrkTable, SrkIndex, SrkView, SrkTrigger, SrkUnknown,
    classify_row_type, decode_schema_row,
    schema_row_to_table_meta, schema_row_to_index_meta,
    load_schema_from_rows,
};

public mount .statement_lifecycle.{
    LifecycleError, StepOutcome, ExecOutcome,
    SoRowReady, SoDone, SoErrored,
    bind_positional, bind_named, clear_bindings,
    step_one, reset, finalize,
    column_count, column_name, column_declared_type,
    column_value, column_kind,
    // Rich SqlValue-based accessors (#158)
    column_sql_value, column_type, column_type_int,
    column_int, column_double, column_text, column_text16,
    column_blob, column_bytes, column_bytes16,
    bind_sql_value, bind_text16,
    execute_collect,
};

public mount .sql_value.{
    SqlValue, VNull, VInt, VReal, VText, VBlob,
    ColumnType, CtNull, CtInt, CtReal, CtText, CtBlob,
    sql_value_from_register, register_from_sql_value,
    value_type, value_to_int, value_to_real, value_to_text,
    value_to_blob, value_to_text16, value_bytes, value_bytes16,
    sql_null, sql_int, sql_real, sql_text, sql_blob,
    sql_text_from_utf16, column_type_code,
};
