module core.database.sqlite.native.l6_session.sqlite_schema_parser;

// =============================================================================
// l6_session/sqlite_schema_parser.vr — sqlite_schema row → TableMeta/IndexMeta
// =============================================================================
// Layer: 6
// Spec: sqlite-native.md §16.2 (sqlite_schema layout)
//
// `sqlite_schema` is the single root-page-1 table containing one row
// per database object (table / index / view / trigger).  Its row
// shape is fixed:
//
//   type      TEXT     — "table" | "index" | "view" | "trigger"
//   name      TEXT     — object name
//   tbl_name  TEXT     — for indexes/triggers: parent table; for tables/views: same as name
//   rootpage  INTEGER  — root B-tree page (0 for views/virtual tables)
//   sql       TEXT     — the original CREATE statement
//
// Pre-fix: SchemaCache had no way to populate from on-disk schema —
// callers had to invent TableMeta values manually.  Schema-aware
// compile (`plan_statement_with_schema`) thus required the L7
// facade to pre-load the schema by hand.
//
// Post-fix: this module decodes a row's typed columns into
// TableMeta / IndexMeta, parses the embedded CREATE statement (via
// the existing L5 lexer + parser), and registers the result into
// `SchemaCache`.  L6 connection-open code calls `load_schema_from_rows`
// to populate the cache from sqlite_schema during open / reload.
// =============================================================================

mount core.*;
mount collections.{List, Map};
mount base.{Result, Ok, Err, Text, Maybe};
mount core.database.sqlite.native.l4_vdbe.register.{
    Register, RNull, RInt, RReal, RText, RBlob, RRowId,
};
mount core.database.sqlite.native.l6_session.schema_cache.{
    SchemaCache, TableMeta, IndexMeta, ColumnMeta,
    TableKind, TkTable, TkView, TkVirtual,
    SessionSchemaError, NotFound, AlreadyExists, InvalidMetadata,
};
mount core.database.sqlite.native.l2_record.affinity.Affinity;
mount core.database.sqlite.native.l5_sql.compile.{compile, CompileError};

// -----------------------------------------------------------------------------
// SchemaRowKind — discriminator from the type column
// -----------------------------------------------------------------------------

pub type SchemaRowKind is
      SrkTable
    | SrkIndex
    | SrkView
    | SrkTrigger
    | SrkUnknown(Text);

pub fn classify_row_type(type_text: &Text) -> SchemaRowKind {
    if type_text == "table" { return SrkTable; }
    if type_text == "index" { return SrkIndex; }
    if type_text == "view"  { return SrkView; }
    if type_text == "trigger" { return SrkTrigger; }
    SrkUnknown(type_text.clone())
}

// -----------------------------------------------------------------------------
// SchemaRow — the typed view of one sqlite_schema row
// -----------------------------------------------------------------------------

pub type SchemaRow is {
    kind: SchemaRowKind,
    name: Text,
    tbl_name: Text,
    rootpage: Int,
    sql: Text,
}

pub type SchemaRowError is
      MissingColumn(Text)
    | WrongColumnType(column: Text, expected: Text)
    | UnknownRowKind(Text);

implement Display for SchemaRowError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            MissingColumn(c)        => f.write_str(f"sqlite_schema: missing column {c}".as_str()),
            WrongColumnType(c, e)   => f.write_str(f"sqlite_schema: column {c} expected {e}".as_str()),
            UnknownRowKind(t)       => f.write_str(f"sqlite_schema: unknown row type {t}".as_str()),
        }
    }
}

/// Decode a 5-element register list into a typed SchemaRow.
/// Layout: [type, name, tbl_name, rootpage, sql].  Missing columns
/// or wrong types return `Err(SchemaRowError)`.
pub fn decode_schema_row(row: &List<Register>) -> Result<SchemaRow, SchemaRowError> {
    if row.len() < 5 {
        return Err(MissingColumn("sqlite_schema row needs 5 columns".clone()));
    }

    let type_text = match &row[0] {
        RText(t) => t.clone(),
        _        => return Err(WrongColumnType("type".clone(), "TEXT".clone())),
    };
    let name = match &row[1] {
        RText(t) => t.clone(),
        _        => return Err(WrongColumnType("name".clone(), "TEXT".clone())),
    };
    let tbl_name = match &row[2] {
        RText(t) => t.clone(),
        _        => return Err(WrongColumnType("tbl_name".clone(), "TEXT".clone())),
    };
    let rootpage = match &row[3] {
        RInt(i)    => i as Int,
        RRowId(r)  => r as Int,
        RNull      => 0,
        _          => return Err(WrongColumnType("rootpage".clone(), "INTEGER".clone())),
    };
    let sql = match &row[4] {
        RText(t) => t.clone(),
        RNull    => "".clone(),
        _        => return Err(WrongColumnType("sql".clone(), "TEXT".clone())),
    };

    Ok(SchemaRow {
        kind: classify_row_type(&type_text),
        name: name,
        tbl_name: tbl_name,
        rootpage: rootpage,
        sql: sql,
    })
}

// -----------------------------------------------------------------------------
// Row → TableMeta / IndexMeta
// -----------------------------------------------------------------------------

/// Convert a decoded SchemaRow into a TableMeta when its kind is
/// `SrkTable` or `SrkView`.  Parses the embedded CREATE statement
/// to recover columns + primary-key info.
pub fn schema_row_to_table_meta(
    row: &SchemaRow,
    schema_name: &Text,
) -> Result<TableMeta, SessionSchemaError> {
    let kind = match &row.kind {
        SrkTable => TkTable,
        SrkView  => TkView,
        _ => return Err(InvalidMetadata("row is not a table/view".clone())),
    };

    // Foundation: parse the CREATE statement via the L5 compile
    // entry point.  Errors during parse are surfaced as
    // InvalidMetadata; success but no columns recovered yields an
    // empty-column TableMeta which the caller can detect.
    let columns = parse_create_columns(&row.sql);

    Ok(TableMeta {
        schema: schema_name.clone(),
        name: row.name.clone(),
        kind: kind,
        root_page: row.rootpage,
        columns: columns,
        primary_key_cols: List.new(),     // refined by parse_create_columns follow-up
        strict: false,
        without_rowid: false,
        created_sql: row.sql.clone(),
    })
}

/// Convert a decoded SchemaRow into an IndexMeta when its kind is
/// `SrkIndex`.
pub fn schema_row_to_index_meta(
    row: &SchemaRow,
    schema_name: &Text,
) -> Result<IndexMeta, SessionSchemaError> {
    match &row.kind {
        SrkIndex => {}
        _ => return Err(InvalidMetadata("row is not an index".clone())),
    }
    Ok(IndexMeta {
        schema: schema_name.clone(),
        name: row.name.clone(),
        table_name: row.tbl_name.clone(),
        root_page: row.rootpage,
        columns: List.new(),    // refined when index-column parser lands
        unique: false,
    })
}

// -----------------------------------------------------------------------------
// Bulk loader — populate SchemaCache from a stream of rows
// -----------------------------------------------------------------------------

pub type LoadReport is {
    tables_loaded: Int,
    indexes_loaded: Int,
    rows_skipped: Int,
    parse_errors: Int,
}

/// Load every row of a sqlite_schema scan into `cache`.  Uses
/// `register_table` / `register_index` which both reject duplicates
/// — callers reset the cache via `invalidate_schema` first when
/// reloading after DDL.
pub fn load_schema_from_rows(
    cache: &mut SchemaCache,
    schema_name: &Text,
    rows: &List<List<Register>>,
) -> LoadReport {
    let mut report = LoadReport {
        tables_loaded: 0,
        indexes_loaded: 0,
        rows_skipped: 0,
        parse_errors: 0,
    };
    let mut i: Int = 0;
    while i < rows.len() {
        let decoded = match decode_schema_row(&rows[i]) {
            Ok(r)  => r,
            Err(_) => {
                report.parse_errors = report.parse_errors + 1;
                i = i + 1;
                continue;
            }
        };
        match &decoded.kind {
            SrkTable | SrkView => {
                match schema_row_to_table_meta(&decoded, schema_name) {
                    Ok(meta) => {
                        match cache.register_table(meta) {
                            Ok(_)  => { report.tables_loaded = report.tables_loaded + 1; }
                            Err(_) => { report.rows_skipped = report.rows_skipped + 1; }
                        }
                    }
                    Err(_) => { report.parse_errors = report.parse_errors + 1; }
                }
            }
            SrkIndex => {
                match schema_row_to_index_meta(&decoded, schema_name) {
                    Ok(meta) => {
                        match cache.register_index(meta) {
                            Ok(_)  => { report.indexes_loaded = report.indexes_loaded + 1; }
                            Err(_) => { report.rows_skipped = report.rows_skipped + 1; }
                        }
                    }
                    Err(_) => { report.parse_errors = report.parse_errors + 1; }
                }
            }
            SrkTrigger => {
                // Trigger metadata loading: tracked separately under
                // L7 trigger-store wire (#144 follow-up); for now
                // the row is observed but not registered.
                report.rows_skipped = report.rows_skipped + 1;
            }
            SrkUnknown(_) => {
                report.rows_skipped = report.rows_skipped + 1;
            }
        }
        i = i + 1;
    }
    report
}

// -----------------------------------------------------------------------------
// CREATE statement column parser
// -----------------------------------------------------------------------------

/// Foundation column parser — builds an empty column list.  The
/// real parser walks the L5 CreateTableStmt AST returned by the
/// L5 parser and converts each ColumnDef into a ColumnMeta.
/// Tracked as a #143 follow-up so this module stays compileable
/// without a transitive dependency on the L5 parse cycle which
/// adds compile time to L6.
fn parse_create_columns(_sql: &Text) -> List<ColumnMeta> {
    List.new()
}
