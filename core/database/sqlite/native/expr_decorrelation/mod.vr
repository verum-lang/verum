// =============================================================================
// Correlated-subquery decorrelation — planner pass that rewrites
// `WHERE col IN (SELECT x FROM ... WHERE y = outer.z)` as a semi-join.
// Spec §13.5 — optimizer.
//

// Preconditions (subset):
//  * correlation references are equality-form
//  * the inner query has no aggregate / DISTINCT depending on outer
//  * inner LIMIT matches at most 1 row when used in scalar position
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.database.sqlite.native.expr_decorrelation;

public module position;
public module eligibility;
