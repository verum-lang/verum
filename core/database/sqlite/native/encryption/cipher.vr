// =============================================================================
// encryption/cipher.vr — PageCipher protocol + built-in implementations
// =============================================================================
// Spec: sqlite-native.md §23 (security)
//
// `PageCipher` is the per-page encrypt / decrypt boundary the pager
// invokes for every disk I/O. Three built-in impls:
//
//   * `NullCipher`     — passthrough; used for testing + when an
//                         encryption-enabled binary opens a plaintext db
//   * `AesGcmCipher`   — AES-256-GCM with per-page nonce; backed by
//                         core.security.aead.aes_gcm.Aes256Gcm
//   * `Chacha20Cipher` — ChaCha20-Poly1305 backed by
//                         core.security.aead.chacha20_poly1305
//
// All three are surfaced via the same protocol so the pager can
// switch them at startup without recompiling.
//
// # Per-page nonce derivation
//
// The 12-byte nonce is derived deterministically from `page_no`:
// the low 4 bytes encode the page number little-endian, the upper 8
// bytes are zero. Safe so long as the same (key, page_no) is never
// re-encrypted with two different plaintexts — the standard SQLite
// page-rewrite pattern (in-place page update under a single key)
// triggers exactly this hazard at WAL checkpoint time. Callers that
// need rewrite-safe encryption MUST rotate the key on each page
// rewrite (KeyRing handles this) or compose with a per-write
// counter via the kdf module. The SOUNDNESS comment in
// core/security/aead/aes_gcm.vr explains the keystream-reuse
// catastrophe in detail.
//
// # Wire format
//
// Each encrypted page is laid out as:
//
//     [ nonce (12 bytes) || ciphertext (N bytes) || tag (16 bytes) ]
//
// where N is the plaintext length. `overhead_bytes()` reports
// `nonce_len + tag_len`. Callers size the page accordingly.
//
// # Authenticity
//
// `decrypt` returns `CeAuthFailure` on tag-verification failure and
// does NOT expose any plaintext (the underlying AEAD verifies tag
// before producing output). A wrong key, tampered ciphertext, or
// tampered nonce all surface as `CeAuthFailure` — never silent
// success.
// =============================================================================

module core.database.sqlite.native.encryption.cipher;

mount core.*;
mount base.{Text, Bool, Result, Ok, Err};
mount collections.List;
mount core.security.cipher.aes.{AesKey256};
mount core.security.cipher.chacha20.{ChaChaKey, ChaChaNonce};
mount core.security.aead.aes_gcm.{Aes256Gcm, GcmError};
mount core.security.aead.chacha20_poly1305.{ChaCha20Poly1305, AeadError};

// -----------------------------------------------------------------------------
// CipherError
// -----------------------------------------------------------------------------

public type CipherError is
      CeWrongKey
    | CeAuthFailure
    | CeMalformedPage
    | CeUnsupported(Text);

// -----------------------------------------------------------------------------
// PageCipher protocol
// -----------------------------------------------------------------------------

public type PageCipher is protocol {
    fn name(&self) -> Text;
    /// Bytes added to each page when encrypted (nonce + auth tag).
    fn overhead_bytes(&self) -> Int;

    /// Encrypts `plaintext` (length = page_size - overhead_bytes()),
    /// returning ciphertext of length `page_size`.
    fn encrypt(
        &self,
        page_no: Int,
        plaintext: &List<Byte>,
    ) -> Result<List<Byte>, CipherError>;

    /// Inverse of encrypt.
    fn decrypt(
        &self,
        page_no: Int,
        ciphertext: &List<Byte>,
    ) -> Result<List<Byte>, CipherError>;
};

// -----------------------------------------------------------------------------
// NullCipher — passthrough
// -----------------------------------------------------------------------------

public type NullCipher is { unit: Bool };
public fn null_cipher() -> NullCipher { NullCipher { unit: true } }

implement PageCipher for NullCipher {
    fn name(&self) -> Text { "null".clone() }
    fn overhead_bytes(&self) -> Int { 0 }
    fn encrypt(&self, _pgno: Int, plaintext: &List<Byte>) -> Result<List<Byte>, CipherError> {
        Ok(clone_bytes(plaintext))
    }
    fn decrypt(&self, _pgno: Int, ciphertext: &List<Byte>) -> Result<List<Byte>, CipherError> {
        Ok(clone_bytes(ciphertext))
    }
}

// -----------------------------------------------------------------------------
// AesGcmCipher — AES-256-GCM (NIST SP 800-38D)
// -----------------------------------------------------------------------------

public const AES_GCM_NONCE_BYTES: Int = 12;
public const AES_GCM_TAG_BYTES: Int = 16;
public const AES_KEY_BYTES: Int = 32;

public type AesGcmCipher is {
    /// 256-bit master key — supplied by KeyDerivation on creation.
    /// Length is exactly AES_KEY_BYTES (validated at construction).
    key: AesKey256,
}

public fn aes_gcm_cipher(key: List<Byte>) -> Result<AesGcmCipher, CipherError> {
    if key.len() != AES_KEY_BYTES {
        return Err(CeUnsupported("AES-256-GCM requires 32-byte key".clone()));
    }
    let mut k: AesKey256 = [0; 32];
    let mut i: Int = 0;
    while i < AES_KEY_BYTES { k[i] = key[i]; i = i + 1; }
    Ok(AesGcmCipher { key: k })
}

implement PageCipher for AesGcmCipher {
    fn name(&self) -> Text { "aes-256-gcm".clone() }
    fn overhead_bytes(&self) -> Int { AES_GCM_NONCE_BYTES + AES_GCM_TAG_BYTES }

    fn encrypt(&self, page_no: Int, plaintext: &List<Byte>) -> Result<List<Byte>, CipherError> {
        let nonce = derive_page_nonce_12(page_no);
        let cipher = Aes256Gcm.new(&self.key);

        let mut ciphertext: List<Byte> = List.with_capacity(plaintext.len());
        let mut tag: [Byte; 16] = [0; 16];
        let aad: [Byte; 0] = [];
        cipher.encrypt(&nonce, &aad, plaintext.as_slice(), &mut ciphertext, &mut tag);

        // Wire layout: nonce || ciphertext || tag.
        let total = AES_GCM_NONCE_BYTES + plaintext.len() + AES_GCM_TAG_BYTES;
        let mut out: List<Byte> = List.with_capacity(total);
        let mut i: Int = 0;
        while i < AES_GCM_NONCE_BYTES { out.push(nonce[i]); i = i + 1; }
        let mut j: Int = 0;
        while j < ciphertext.len() { out.push(ciphertext[j]); j = j + 1; }
        let mut t: Int = 0;
        while t < AES_GCM_TAG_BYTES { out.push(tag[t]); t = t + 1; }
        Ok(out)
    }

    fn decrypt(&self, _page_no: Int, ciphertext: &List<Byte>) -> Result<List<Byte>, CipherError> {
        if ciphertext.len() < AES_GCM_NONCE_BYTES + AES_GCM_TAG_BYTES {
            return Err(CeMalformedPage);
        }
        let payload_len = ciphertext.len() - AES_GCM_NONCE_BYTES - AES_GCM_TAG_BYTES;

        // Slice the wire layout back apart. The AEAD verifies tag
        // before exposing any plaintext, so wrong-key / tampered
        // input surfaces as TagMismatch — never silent success.
        let mut nonce: [Byte; 12] = [0; 12];
        let mut k: Int = 0;
        while k < AES_GCM_NONCE_BYTES { nonce[k] = ciphertext[k]; k = k + 1; }

        let mut tag: [Byte; 16] = [0; 16];
        let tag_off = AES_GCM_NONCE_BYTES + payload_len;
        let mut tt: Int = 0;
        while tt < AES_GCM_TAG_BYTES { tag[tt] = ciphertext[tag_off + tt]; tt = tt + 1; }

        let body_slice = ciphertext.as_slice();
        let body_view = &body_slice[AES_GCM_NONCE_BYTES..tag_off];

        let cipher = Aes256Gcm.new(&self.key);
        let aad: [Byte; 0] = [];
        let mut plaintext: List<Byte> = List.with_capacity(payload_len);
        match cipher.decrypt(&nonce, &aad, body_view, &tag, &mut plaintext) {
            Ok(()) => Ok(plaintext),
            Err(GcmError.TagMismatch) => Err(CeAuthFailure),
            Err(GcmError.InvalidInput { reason: _ }) => Err(CeMalformedPage),
            Err(GcmError.InputTooLarge { limit_bytes: _ }) => Err(CeMalformedPage),
        }
    }
}

// -----------------------------------------------------------------------------
// Chacha20Cipher — ChaCha20-Poly1305 (RFC 8439)
// -----------------------------------------------------------------------------

public const CHACHA_NONCE_BYTES: Int = 12;
public const CHACHA_TAG_BYTES: Int = 16;

public type Chacha20Cipher is { key: ChaChaKey }

public fn chacha20_cipher(key: List<Byte>) -> Result<Chacha20Cipher, CipherError> {
    if key.len() != AES_KEY_BYTES {
        return Err(CeUnsupported("ChaCha20-Poly1305 requires 32-byte key".clone()));
    }
    let mut k: ChaChaKey = [0; 32];
    let mut i: Int = 0;
    while i < AES_KEY_BYTES { k[i] = key[i]; i = i + 1; }
    Ok(Chacha20Cipher { key: k })
}

implement PageCipher for Chacha20Cipher {
    fn name(&self) -> Text { "chacha20-poly1305".clone() }
    fn overhead_bytes(&self) -> Int { CHACHA_NONCE_BYTES + CHACHA_TAG_BYTES }

    fn encrypt(&self, page_no: Int, plaintext: &List<Byte>) -> Result<List<Byte>, CipherError> {
        let nonce: ChaChaNonce = derive_page_nonce_12(page_no);
        let cipher = ChaCha20Poly1305.new(&self.key);

        let mut ciphertext: List<Byte> = List.with_capacity(plaintext.len());
        let mut tag: [Byte; 16] = [0; 16];
        let aad: [Byte; 0] = [];
        cipher.encrypt(&nonce, &aad, plaintext.as_slice(), &mut ciphertext, &mut tag);

        let total = CHACHA_NONCE_BYTES + plaintext.len() + CHACHA_TAG_BYTES;
        let mut out: List<Byte> = List.with_capacity(total);
        let mut i: Int = 0;
        while i < CHACHA_NONCE_BYTES { out.push(nonce[i]); i = i + 1; }
        let mut j: Int = 0;
        while j < ciphertext.len() { out.push(ciphertext[j]); j = j + 1; }
        let mut t: Int = 0;
        while t < CHACHA_TAG_BYTES { out.push(tag[t]); t = t + 1; }
        Ok(out)
    }

    fn decrypt(&self, _pgno: Int, ciphertext: &List<Byte>) -> Result<List<Byte>, CipherError> {
        if ciphertext.len() < CHACHA_NONCE_BYTES + CHACHA_TAG_BYTES {
            return Err(CeMalformedPage);
        }
        let payload_len = ciphertext.len() - CHACHA_NONCE_BYTES - CHACHA_TAG_BYTES;

        let mut nonce: ChaChaNonce = [0; 12];
        let mut k: Int = 0;
        while k < CHACHA_NONCE_BYTES { nonce[k] = ciphertext[k]; k = k + 1; }

        let mut tag: [Byte; 16] = [0; 16];
        let tag_off = CHACHA_NONCE_BYTES + payload_len;
        let mut tt: Int = 0;
        while tt < CHACHA_TAG_BYTES { tag[tt] = ciphertext[tag_off + tt]; tt = tt + 1; }

        let body_slice = ciphertext.as_slice();
        let body_view = &body_slice[CHACHA_NONCE_BYTES..tag_off];

        let cipher = ChaCha20Poly1305.new(&self.key);
        let aad: [Byte; 0] = [];
        let mut plaintext: List<Byte> = List.with_capacity(payload_len);
        match cipher.decrypt(&nonce, &aad, body_view, &tag, &mut plaintext) {
            Ok(()) => Ok(plaintext),
            Err(AeadError.TagMismatch) => Err(CeAuthFailure),
            Err(AeadError.InvalidInput { reason: _ }) => Err(CeMalformedPage),
            Err(AeadError.InputTooLarge { limit_bytes: _ }) => Err(CeMalformedPage),
        }
    }
}

// -----------------------------------------------------------------------------
// Helpers
// -----------------------------------------------------------------------------

fn clone_bytes(b: &List<Byte>) -> List<Byte> {
    let mut out: List<Byte> = List.new();
    let mut i: Int = 0;
    while i < b.len() { out.push(b[i]); i = i + 1; }
    out
}

/// Derive a 12-byte nonce deterministically from a page number.
/// Layout: low 4 bytes = page_no LE, upper 8 bytes = zero. Safe
/// so long as `(key, page_no)` is never re-encrypted under a
/// different plaintext (see header documentation).
fn derive_page_nonce_12(page_no: Int) -> [Byte; 12] {
    let mut n: [Byte; 12] = [0; 12];
    let mut i: Int = 0;
    while i < 4 {
        n[i] = ((page_no >> (i * 8)) & 255) as Byte;
        i = i + 1;
    }
    n
}
