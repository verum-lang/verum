// =============================================================================
// encryption/kdf.vr — KeyDerivation protocol + impls
// =============================================================================
// Spec: sqlite-native.md §23 (security)
//
// Derives a per-database master key from caller-supplied secret
// material. Three impls:
//
//   * `RawKey`         — pass-through: caller already has a 32-byte
//                         key, no KDF needed
//   * `Pbkdf2Sha256`   — PBKDF2-HMAC-SHA256 (matches SQLCipher v3
//                         default)
//   * `ScryptSimple`   — scrypt with caller-controlled cost params
//
// `KdfParams` carries the salt + iteration count and is persisted in
// the file's reserved-space header so reopening a database can
// re-derive without storing the key.
// =============================================================================

module core.database.sqlite.native.encryption.kdf;

mount core.*;
mount base.{Text, Bool, Result, Ok, Err};
mount collections.List;
mount core.security.kdf.pbkdf2.{pbkdf2_hmac_sha256, Pbkdf2Error};

// -----------------------------------------------------------------------------
// KdfError
// -----------------------------------------------------------------------------

public type KdfError is
      KeBadParams(Text)
    | KeUnsupported(Text)
    | KeWeakKey;

implement Display for KdfError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            KeBadParams(m)   => f.write_str(f"sqlite KDF bad params: {m}".as_str()),
            KeUnsupported(m) => f.write_str(f"sqlite KDF unsupported: {m}".as_str()),
            KeWeakKey        => f.write_str("sqlite KDF rejected weak key"),
        }
    }
}

implement Debug for KdfError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            KeBadParams(m)   => f.write_str(f"KeBadParams({m})".as_str()),
            KeUnsupported(m) => f.write_str(f"KeUnsupported({m})".as_str()),
            KeWeakKey        => f.write_str("KeWeakKey"),
        }
    }
}

implement Eq for KdfError {
    fn eq(&self, other: &KdfError) -> Bool {
        match (self, other) {
            (KeBadParams(a),   KeBadParams(b))   => a == b,
            (KeUnsupported(a), KeUnsupported(b)) => a == b,
            (KeWeakKey,        KeWeakKey)        => true,
            _ => false,
        }
    }
}

// -----------------------------------------------------------------------------
// KdfParams
// -----------------------------------------------------------------------------

public type KdfParams is {
    /// Random per-database salt — typically 16 bytes.
    salt: List<Byte>,
    /// Iteration count (PBKDF2) or N (scrypt).
    cost: Int,
    /// Output key length in bytes (typically 32 for AES-256).
    key_len: Int,
}

public fn params_default() -> KdfParams {
    KdfParams {
        salt: zero_bytes(16),
        cost: 256000,        // SQLCipher v4 default
        key_len: 32,
    }
}

fn zero_bytes(n: Int) -> List<Byte> {
    let mut out: List<Byte> = List.with_capacity(n);
    let mut i: Int = 0;
    while i < n { out.push(0 as Byte); i = i + 1; }
    out
}

implement KdfParams {
    public fn with_salt(mut self, salt: List<Byte>) -> KdfParams {
        self.salt = salt;
        self
    }
    public fn with_cost(mut self, cost: Int) -> KdfParams {
        self.cost = cost;
        self
    }
    public fn with_key_len(mut self, key_len: Int) -> KdfParams {
        self.key_len = key_len;
        self
    }
}

// -----------------------------------------------------------------------------
// KeyDerivation protocol
// -----------------------------------------------------------------------------

public type KeyDerivation is protocol {
    fn name(&self) -> Text;
    fn derive(
        &self,
        secret: &List<Byte>,
        params: &KdfParams,
    ) -> Result<List<Byte>, KdfError>;
};

// -----------------------------------------------------------------------------
// RawKey — passthrough
// -----------------------------------------------------------------------------

public type RawKey is { unit: Bool };
public fn raw_key() -> RawKey { RawKey { unit: true } }

implement KeyDerivation for RawKey {
    fn name(&self) -> Text { "raw".clone() }
    fn derive(&self, secret: &List<Byte>, params: &KdfParams) -> Result<List<Byte>, KdfError> {
        if secret.len() != params.key_len {
            return Err(KeBadParams("raw key length mismatch".clone()));
        }
        let mut out: List<Byte> = List.with_capacity(secret.len());
        out.extend_from_slice(secret.as_slice());
        Ok(out)
    }
}

// -----------------------------------------------------------------------------
// Pbkdf2Sha256
// -----------------------------------------------------------------------------

public type Pbkdf2Sha256 is { unit: Bool };
public fn pbkdf2_sha256() -> Pbkdf2Sha256 { Pbkdf2Sha256 { unit: true } }

implement KeyDerivation for Pbkdf2Sha256 {
    fn name(&self) -> Text { "pbkdf2-sha256".clone() }
    fn derive(&self, secret: &List<Byte>, params: &KdfParams) -> Result<List<Byte>, KdfError> {
        if params.cost < 1000 { return Err(KeBadParams("PBKDF2 iteration count < 1000".clone())); }
        if params.key_len <= 0 { return Err(KeBadParams("zero key_len".clone())); }
        // Wire to the real PBKDF2-HMAC-SHA256 in core.security.kdf.pbkdf2.
        // Pre-fix this was an XOR-only "contract-only stub" labeled
        // "NOT cryptographically safe" — using it as the SQLCipher v3
        // key-derivation primitive would have produced trivially
        // recoverable database keys regardless of cost setting.  Now
        // the real RFC 8018 §5.2 PBKDF2 with HMAC-SHA256 PRF is used,
        // matching SQLCipher v3 default behaviour.
        match pbkdf2_hmac_sha256(
            secret.as_slice(),
            params.salt.as_slice(),
            params.cost as UInt32,
            params.key_len,
        ) {
            Ok(bytes) => Ok(bytes),
            Err(e) => Err(KeBadParams(f"pbkdf2_hmac_sha256 rejected params: {e:?}".into())),
        }
    }
}

// -----------------------------------------------------------------------------
// ScryptSimple
// -----------------------------------------------------------------------------

public type ScryptSimple is { unit: Bool };
public fn scrypt_simple() -> ScryptSimple { ScryptSimple { unit: true } }

implement KeyDerivation for ScryptSimple {
    fn name(&self) -> Text { "scrypt".clone() }
    fn derive(&self, _secret: &List<Byte>, params: &KdfParams) -> Result<List<Byte>, KdfError> {
        if params.cost < 16 { return Err(KeBadParams("scrypt N too small".clone())); }
        if params.key_len <= 0 { return Err(KeBadParams("zero key_len".clone())); }
        // No real scrypt implementation in core.security yet — the
        // legacy XOR-only stub was REMOVED here because returning
        // weakly-derived keys from a "scrypt" surface is worse than
        // returning a typed error: callers that ask for scrypt and
        // get back garbage cannot detect the lie, and the resulting
        // database files would be trivially decryptable.  Refuse the
        // call instead until a real scrypt lands; downstream callers
        // either fall back to PBKDF2 (which IS correctly wired) or
        // surface the unsupported-algorithm error to the user.
        Err(KeUnsupported(
            "scrypt is not yet implemented in core.security.kdf — use Pbkdf2Sha256".clone()
        ))
    }
}
