// =============================================================================
// version_api/identity.vr — version triple + sourceid
// =============================================================================
// Spec: SQLite C API
//
// The compiled-in version is <major>.<minor>.<patch>, encoded in
// sqlite3.h as SQLITE_VERSION_NUMBER = 1_000_000 * M + 1_000 * m + p.
// =============================================================================

module core.database.sqlite.native.version_api.identity;

mount core.*;
mount base.{Bool, Text};

public type LibVersion is {
    major: Int,
    minor: Int,
    patch: Int,
    source_id: Text,
}

public fn new_version(major: Int, minor: Int, patch: Int, source_id: Text) -> LibVersion {
    LibVersion { major: major, minor: minor, patch: patch, source_id: source_id }
}

public fn version_number(v: &LibVersion) -> Int {
    (v.major * 1_000_000) + (v.minor * 1_000) + v.patch
}

public fn version_text(v: &LibVersion) -> Text {
    let mut out = "".clone();
    push_int(&mut out, v.major);
    out.push_byte(0x2E as u8);
    push_int(&mut out, v.minor);
    out.push_byte(0x2E as u8);
    push_int(&mut out, v.patch);
    out
}

fn push_int(dst: &mut Text, n: Int) {
    if n == 0 { dst.push_byte(0x30 as u8); return; }
    if n < 0 { dst.push_byte(0x2D as u8); }
    // UInt64 magnitude — Int.MIN-safe.  The previous version
    // used `n = 0 - n` which overflows for Int.MIN, then did
    // iterative-position division on the still-negative value
    // producing garbage.  Rewritten to the canonical
    // build-digits-then-emit pattern; share the structure with
    // every other Int formatter in core/.
    let mut mag: UInt64 = if n < 0 {
        (((!n) as UInt64) + (1 as UInt64))
    } else {
        n as UInt64
    };
    let mut digits: List<Byte> = List.new();
    while mag > (0 as UInt64) {
        digits.push(((mag % (10 as UInt64)) + (0x30 as UInt64)) as u8);
        mag = mag / (10 as UInt64);
    }
    let mut i: Int = digits.len() - 1;
    while i >= 0 { dst.push_byte(digits[i]); i = i - 1; }
}
