// =============================================================================
// sqlite3_clear_bindings(stmt) — reset every bound parameter to NULL. Does
// NOT reset the program counter (sqlite3_reset does that); commonly called
// after a row-batch insert to avoid stale binds leaking into the next set.
// Spec App E.B.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.database.sqlite.native.clear_bindings_api;

public module clear;
