// =============================================================================
// l0_vfs/vfs_protocol.vr — VFS protocol and shared types
// =============================================================================
// Layer: 0
// Dependencies: core, collections
// Spec: sqlite-native.md §7
// =============================================================================
//
// The protocol every loom VFS must implement. Modelled on SQLite's
// `sqlite3_vfs`/`sqlite3_file` but expressed as a native Verum protocol
// with capability-typed handles and structured errors — no opaque C
// pointers, no error codes.
//
// # Mandatory operations
//
//   * `open / delete / access / full_pathname / current_time / random_bytes`
//     on the VFS itself
//   * `read / write / truncate / sync / file_size / lock / unlock`
//     on the file handle
//
// # Optional capabilities
//
//   * `fetch / unfetch`              — memory-mapped I/O
//   * `shm_map / shm_lock / ...`     — shared memory for WAL-index
//
// Implementations unable to service a given optional capability return
// `VfsError { kind: Unsupported, ... }` — callers must handle gracefully.
// =============================================================================

module core.database.sqlite.native.l0_vfs.vfs_protocol;

mount core.*;
mount collections.List;
mount base.{Result, Ok, Err, Text, Maybe};

// =============================================================================
// Shared flag / enum types
// =============================================================================

/// Open-time flags. Combinations are validated at open(); not every backend
/// supports every combination (e.g., MemDbVfs ignores `create`).
public type OpenFlags is {
    read_only: Bool,
    read_write: Bool,
    create: Bool,
    exclusive: Bool,
    main_db: Bool,
    temp_db: Bool,
    main_journal: Bool,
    wal: Bool,
    memory: Bool,
    delete_on_close: Bool,
    no_mutex: Bool,
    full_mutex: Bool,
    uri: Bool,
    no_follow: Bool,
};

/// Construct a zero-initialised `OpenFlags`.
public fn flags_default() -> OpenFlags {
    OpenFlags {
        read_only: false, read_write: false, create: false,
        exclusive: false, main_db: false, temp_db: false,
        main_journal: false, wal: false, memory: false,
        delete_on_close: false, no_mutex: false, full_mutex: false,
        uri: false, no_follow: false,
    }
}

/// Read-write + create + main DB — the default for user databases.
public fn flags_rwc() -> OpenFlags {
    let mut f = flags_default();
    f.read_write = true;
    f.create = true;
    f.main_db = true;
    f
}

/// Read-only open of an existing main database.
public fn flags_ro() -> OpenFlags {
    let mut f = flags_default();
    f.read_only = true;
    f.main_db = true;
    f
}

/// Flags for the `sync` call. `full` maps to `F_FULLFSYNC` on Darwin and
/// `fdatasync` on Linux/Windows. `data_only` skips metadata sync where the
/// platform lets us (faster, SQLite's default for WAL frame appends).
public type SyncFlags is {
    full: Bool,
    data_only: Bool,
};

/// Default sync — data only, no metadata flush.
public fn sync_default() -> SyncFlags {
    SyncFlags { full: false, data_only: true }
}

/// Full sync — matches `F_FULLFSYNC` / full `fsync` semantics.
public fn sync_full() -> SyncFlags {
    SyncFlags { full: true, data_only: false }
}

/// Five-state SQLite locking protocol (sqlite-native.md §7.4).
public type LockKind is
      Unlocked
    | Shared
    | Reserved
    | Pending
    | Exclusive;

// =============================================================================
// Error type
// =============================================================================

public type VfsError is {
    kind: VfsErrorKind,
    message: Text,
};

public type VfsErrorKind is
      NotFound
    | PermissionDenied
    | AlreadyExists
    | InvalidArgument
    | Interrupted
    | IoError
    | ShortRead
    | WriteFault
    | LockConflict
    | Unsupported
    | DiskFull
    | Corrupt
    | Closed;

// =============================================================================
// Access / device flags / timestamps (auxiliary types for the protocol surface)
// =============================================================================

/// `access(path, kind)` probe — matches SQLite's three-valued API.
public type AccessKind is
      Exists         // path is present in the filesystem
    | CanRead        // path is present and readable by the caller
    | CanReadWrite;  // path is present and read-writable by the caller

/// Device capability hints. Returned from `File.device_characteristics()`
/// to let the pager skip redundant fsyncs / exploit atomic page writes.
/// Flags track SQLite's `SQLITE_IOCAP_*` constants.
public type DeviceFlags is {
    atomic: Bool,                // any write ≤ sector_size is atomic
    atomic_512: Bool,
    atomic_1k:  Bool,
    atomic_2k:  Bool,
    atomic_4k:  Bool,
    atomic_8k:  Bool,
    atomic_16k: Bool,
    atomic_32k: Bool,
    atomic_64k: Bool,
    safe_append: Bool,           // appending beyond EOF never shrinks
    sequential:  Bool,           // kernel reads ahead in order
    undeletable_when_open: Bool, // Windows semantic
    powersafe_overwrite: Bool,
    immutable:   Bool,
    batch_atomic: Bool,
};

public fn device_flags_default() -> DeviceFlags {
    DeviceFlags {
        atomic: false,
        atomic_512: false, atomic_1k: false, atomic_2k: false,
        atomic_4k: false, atomic_8k: false, atomic_16k: false,
        atomic_32k: false, atomic_64k: false,
        safe_append: false, sequential: false,
        undeletable_when_open: false,
        powersafe_overwrite: false,
        immutable: false, batch_atomic: false,
    }
}

/// Nanoseconds-since-epoch timestamp returned from `VfsProtocol.current_time`.
/// The VFS selects between monotonic and wall-clock; WAL metadata uses wall,
/// rate-limit / backoff uses monotonic.
public type Timestamp is {
    nanos: Int64,
    is_monotonic: Bool,
};

/// Flags for `File.shm_lock`. SHARED/EXCLUSIVE for the kind of lock;
/// LOCK/UNLOCK for the direction. Matches SQLite's `SQLITE_SHM_*` bits.
public type ShmLockFlags is {
    lock: Bool,          // true = acquire, false = release
    exclusive: Bool,     // true = exclusive, false = shared
};

// =============================================================================
// File protocol — per-handle operations
// =============================================================================

/// Protocol every VFS-owned file handle implements. All methods are
/// blocking / synchronous; async wrappers live in `posix_vfs` once
/// io_uring / IOCP backends land.
///
/// `read` / `write` take absolute byte offsets (never disturb any implicit
/// cursor; there is no cursor). `sync(flags.full)` maps to F_FULLFSYNC on
/// Darwin, fsync on Linux, FlushFileBuffers on Windows.
///
/// Optional capabilities (`fetch` / `shm_*`) may return
/// `VfsError { kind: Unsupported }`; callers must handle gracefully.
public type SqliteFile is protocol {
    // -- Core I/O ------------------------------------------------------------

    fn read(&self, buf: &mut List<Byte>, offset: Int) -> Result<(), VfsError>;
    fn write(&mut self, buf: &[Byte], offset: Int) -> Result<(), VfsError>;
    fn truncate(&mut self, size: Int) -> Result<(), VfsError>;
    fn sync(&self, flags: SyncFlags) -> Result<(), VfsError>;
    fn file_size(&self) -> Result<Int, VfsError>;

    // -- Locking (5-state SQLite protocol) -----------------------------------

    fn lock(&mut self, kind: LockKind) -> Result<(), VfsError>;
    fn unlock(&mut self, kind: LockKind) -> Result<(), VfsError>;
    fn check_reserved_lock(&self) -> Result<Bool, VfsError>;

    // -- Device info ---------------------------------------------------------

    fn sector_size(&self) -> Int;
    fn device_characteristics(&self) -> DeviceFlags;

    // -- Optional: memory-mapped I/O -----------------------------------------

    fn fetch(&self, offset: Int, len: Int) -> Result<Maybe<List<Byte>>, VfsError>;
    fn unfetch(&self, offset: Int, buf: &[Byte]) -> Result<(), VfsError>;

    // -- Optional: WAL-index shared memory -----------------------------------

    fn shm_map(&mut self, region: Int, size: Int, extend: Bool)
        -> Result<List<Byte>, VfsError>;
    fn shm_lock(&mut self, start: Int, count: Int, flags: ShmLockFlags)
        -> Result<(), VfsError>;
    fn shm_barrier(&self);
    fn shm_unmap(&mut self, delete_flag: Bool);

    fn close(&mut self) -> Result<(), VfsError>;
};

// =============================================================================
// VfsProtocol — filesystem-level operations
// =============================================================================

/// Top-level VFS protocol. Concrete implementations: `MemDbVfs`,
/// `PosixVfs`, `Win32Vfs`, `MockVfs` (for DST). Each binds its own
/// associated `File` type (`Self.File` must implement `SqliteFile`).
public type VfsProtocol is protocol {
    type File;

    fn open(&self, path: &Text, flags: OpenFlags) -> Result<Self.File, VfsError>;
    fn delete(&self, path: &Text, sync_dir: Bool) -> Result<(), VfsError>;
    fn access(&self, path: &Text, kind: AccessKind) -> Result<Bool, VfsError>;
    fn full_pathname(&self, path: &Text) -> Result<Text, VfsError>;
    fn random_bytes(&self, len: Int) -> List<Byte>;
    fn current_time(&self) -> Timestamp;
    fn get_last_error(&self) -> Maybe<VfsError>;

    /// Minimum sleep granularity in microseconds. SQLite's `xSleep` hook.
    /// Backends should round the requested sleep up to this multiple.
    fn sleep_us(&self, micros: Int);
};
