module core.database.sqlite.native.l0_vfs.shm;

// =============================================================================
// l0_vfs/shm.vr — Shared-memory segments for the WAL-index
// =============================================================================
// Layer: 0
// Spec: sqlite-native.md §6.6 + §7.2
//
// SQLite's WAL-index (`<db>-shm` file) is a mmap(MAP_SHARED) region
// holding 2 header copies and 32 hash-tables of 4096 slots each.
// Cross-process WAL requires every reader/writer to see the same
// bytes — hence shared memory, not a plain file.
//
// This module defines the protocol `ShmSegment` that every shm backend
// implements, plus two backends:
//
//   * `InMemoryShm`    — process-local emulation; used on `:memory:`
//                        databases and in single-process DST tests.
//   * `MappedFileShm`  — mmap-backed, POSIX `mmap(MAP_SHARED, fd)` or
//                        Windows `CreateFileMapping/MapViewOfFile`.
//                        Platform wiring is deferred to L1 once the
//                        pager consumes it; v1 exposes the API shape.
//
// Regions are addressed by `(region_index, size)`; the spec fixes each
// region at 32 KiB (`SQLITE_SHM_REGION_SIZE`). Backends grow the file
// lazily as new regions are requested.
// =============================================================================

mount core.*;
mount collections.{List, Map};
mount base.{Result, Ok, Err, Text, Maybe};
mount core.database.sqlite.native.l0_vfs.vfs_protocol.{
    VfsError, VfsErrorKind, ShmLockFlags,
};

/// Each shm region is 32 KiB — the SQLite default. Backends should
/// reject requests for a different size unless they have a specific
/// tuning story.
public const SHM_REGION_SIZE: Int = 32 * 1024;

/// How many shared-lock slots the WAL-index publishes (shm.c §N_SHM_LOCKS).
public const SHM_NLOCK: Int = 8;

// -----------------------------------------------------------------------------
// Protocol
// -----------------------------------------------------------------------------

/// Backend surface every shm implementation satisfies. Tied to the
/// owning file; closing the file closes the segment.
public type ShmSegment is protocol {
    /// Map region `region_index`. If `extend` is true, the backend
    /// grows the backing storage to cover the new region; otherwise
    /// it returns Unsupported-equivalent if the region isn't already
    /// present. Returns a mutable view of the bytes for this region.
    fn map(&mut self, region_index: Int, size: Int, extend: Bool)
        -> Result<List<Byte>, VfsError>;

    /// Advisory lock on one or more of the WAL-index's fixed slot set
    /// (`start` in `0..SHM_NLOCK`, `count` such that start+count ≤ SHM_NLOCK).
    fn lock(&mut self, start: Int, count: Int, flags: ShmLockFlags)
        -> Result<(), VfsError>;

    /// Memory barrier — ensures writes become visible to other mappers.
    fn barrier(&self);

    /// Unmap the segment; if `delete_flag`, also delete the backing file.
    fn unmap(&mut self, delete_flag: Bool);
};

// -----------------------------------------------------------------------------
// InMemoryShm — process-local emulation
// -----------------------------------------------------------------------------

/// Single-process shm emulator. Holds region blobs by index in a Map.
/// Sufficient for:
///
///   * `:memory:` databases (there's no cross-process story anyway).
///   * DST tests where every "process" is a simulated task sharing the
///     same address space.
///
/// Production cross-process use requires `MappedFileShm` below.
public type InMemoryShm is {
    regions: Map<Int, List<Byte>>,
    slot_locks: List<Int>,            // SHM_NLOCK counters; +1 per shared, -1 per shared release;
                                      //                    large neg for exclusive.
    deleted: Bool,
};

public fn in_memory_shm() -> InMemoryShm {
    let mut slots: List<Int> = List.new();
    let mut i: Int = 0;
    while i < SHM_NLOCK {
        slots.push(0);
        i = i + 1;
    }
    InMemoryShm {
        regions: Map.new(),
        slot_locks: slots,
        deleted: false,
    }
}

implement ShmSegment for InMemoryShm {
    fn map(&mut self, region_index: Int, size: Int, extend: Bool)
        -> Result<List<Byte>, VfsError>
    {
        if size != SHM_REGION_SIZE {
            return Err(VfsError {
                kind: InvalidArgument,
                message: "InMemoryShm requires SHM_REGION_SIZE",
            });
        }
        if self.deleted {
            return Err(VfsError { kind: Closed, message: "shm deleted" });
        }
        if self.regions.contains_key(region_index) {
            return Ok(self.regions.get(region_index));
        }
        if !extend {
            return Err(VfsError {
                kind: NotFound,
                message: "shm region not present (extend=false)",
            });
        }
        let mut zeros: List<Byte> = List.new();
        let mut i: Int = 0;
        while i < size {
            zeros.push(0 as Byte);
            i = i + 1;
        }
        let _ = self.regions.insert(region_index, zeros);
        Ok(self.regions.get(region_index))
    }

    fn lock(&mut self, start: Int, count: Int, flags: ShmLockFlags)
        -> Result<(), VfsError>
    {
        if start < 0 || count <= 0 || start + count > SHM_NLOCK {
            return Err(VfsError {
                kind: InvalidArgument,
                message: "shm_lock: slot range out of bounds",
            });
        }

        // Exclusive acquire → require all slots clear, set each to -1.
        // Exclusive release → set back to 0.
        // Shared acquire    → require slot >= 0, increment.
        // Shared release    → decrement (assumes outstanding shared ref).
        let mut i: Int = start;
        if flags.lock {
            if flags.exclusive {
                // Pre-scan for any held slot → conflict.
                let mut j: Int = start;
                while j < start + count {
                    if self.slot_locks[j] != 0 {
                        return Err(VfsError {
                            kind: LockConflict,
                            message: "shm_lock: slot busy",
                        });
                    }
                    j = j + 1;
                }
                while i < start + count {
                    self.slot_locks[i] = -1;
                    i = i + 1;
                }
            } else {
                // Shared — must not see exclusive holders.
                let mut j: Int = start;
                while j < start + count {
                    if self.slot_locks[j] < 0 {
                        return Err(VfsError {
                            kind: LockConflict,
                            message: "shm_lock: exclusive held",
                        });
                    }
                    j = j + 1;
                }
                while i < start + count {
                    self.slot_locks[i] = self.slot_locks[i] + 1;
                    i = i + 1;
                }
            }
        } else {
            if flags.exclusive {
                while i < start + count {
                    self.slot_locks[i] = 0;
                    i = i + 1;
                }
            } else {
                while i < start + count {
                    if self.slot_locks[i] > 0 {
                        self.slot_locks[i] = self.slot_locks[i] - 1;
                    }
                    i = i + 1;
                }
            }
        }
        Ok(())
    }

    fn barrier(&self) {
        // In-process visibility is total — the caller's next load will
        // see the most recent store. No explicit fence required for
        // the VBC interpreter; AOT will emit an acquire/release fence
        // here once the lowering lands.
    }

    fn unmap(&mut self, delete_flag: Bool) {
        if delete_flag {
            // Drop all regions so a future `map(extend=true)` starts clean.
            self.regions = Map.new();
            self.deleted = true;
        }
    }
}

// -----------------------------------------------------------------------------
// MappedFileShm — mmap-backed production implementation (skeleton)
// -----------------------------------------------------------------------------
//
// Shape of the mmap-backed backend. Full mmap wiring lands with the L1
// WAL-index consumer (§8.3), which is the only caller that needs
// cross-process coherency. Right now this backend returns
// `Unsupported` for every call — an honest placeholder the pager can
// feature-detect against.

public type MappedFileShm is {
    path: Text,
    // Region index → mapping handle (future work: real pointer + length).
    // Kept as a blob-view map to stay symmetric with InMemoryShm.
    regions: Map<Int, List<Byte>>,
};

public fn mapped_file_shm(path: &Text) -> MappedFileShm {
    MappedFileShm {
        path: path.clone(),
        regions: Map.new(),
    }
}

implement ShmSegment for MappedFileShm {
    fn map(&mut self, _region_index: Int, _size: Int, _extend: Bool)
        -> Result<List<Byte>, VfsError>
    {
        Err(VfsError {
            kind: Unsupported,
            message: "MappedFileShm.map pending mmap wiring",
        })
    }

    fn lock(&mut self, _start: Int, _count: Int, _flags: ShmLockFlags)
        -> Result<(), VfsError>
    {
        Err(VfsError {
            kind: Unsupported,
            message: "MappedFileShm.lock pending fcntl wiring",
        })
    }

    fn barrier(&self) {}

    fn unmap(&mut self, _delete_flag: Bool) {}
}
