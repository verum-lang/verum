// =============================================================================
// pcache_api/engine.vr — xFetch / xUnpin / xRekey / xTruncate dispatch
// =============================================================================
// Spec: SQLite source — pcache1.c.
//
// This façade maps the C `sqlite3_pcache_*` surface onto the LRU
// cache.  The runtime binds real sqlite3_pcache_page pointers; the
// catalogue only models the control flow.
// =============================================================================

module core.database.sqlite.native.pcache_api.engine;

mount core.*;
mount base.{Bool};
mount core.database.sqlite.native.pcache_api.cache.{
    PageCache,
};

public type FetchOutcome is
      FoHit
    | FoMiss
    | FoRefused;          // max_pages exceeded AND nothing evictable

public fn is_hit(o: &FetchOutcome) -> Bool {
    match o {
        FoHit => true,
        _ => false,
    }
}

/// xFetch with createFlag >= 1 (allocate if necessary).  Returns Hit
/// on immediate re-use, Miss on fresh allocation, Refused when the
/// cache is over-limit with only pinned/dirty slots.
public fn sqlite3_pcache_fetch(c: &mut PageCache, page_no: Int64) -> FetchOutcome {
    let before = c.len();
    let hit = c.pin_page(page_no);
    let after = c.len();
    if hit { return FoHit; }
    if after == before && !hit { return FoRefused; }
    FoMiss
}

public fn sqlite3_pcache_unpin(c: &mut PageCache, page_no: Int64) -> Bool {
    c.unpin_page(page_no)
}

public fn sqlite3_pcache_truncate(c: &mut PageCache, watermark: Int64) -> Int {
    c.truncate(watermark)
}

public fn sqlite3_pcache_mark_dirty(c: &mut PageCache, page_no: Int64) -> Bool {
    c.mark_dirty_page(page_no)
}
