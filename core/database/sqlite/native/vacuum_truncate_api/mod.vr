// =============================================================================
// core/database/sqlite/native/vacuum_truncate_api/mod.vr
// =============================================================================
// Post-VACUUM file truncation — the DB file shrinks to the new logical size.
// Spec §10.5 — VACUUM.
//

// Rules:
//  * The new size is the number of used pages after rewrite × page_size.
//  * Freed pages at the tail are released to the filesystem.
//  * If PRAGMA incremental_vacuum is active, free pages are held in the
//  free-list trunk instead of returned immediately.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.database.sqlite.native.vacuum_truncate_api;

public module plan;
