// =============================================================================
// statistics/selectivity.vr — predicate selectivity estimator
// =============================================================================
// Spec: sqlite-native.md §13.2-§13.3
//
// Translates a `Predicate` against an index plus its stat1/stat4
// catalogues into a `Selectivity` (0.0..1.0). The planner
// multiplies independent predicates' selectivities to estimate
// row counts after WHERE.
// =============================================================================

module core.database.sqlite.native.statistics.selectivity;

mount core.*;
mount base.{Bool, Maybe};
mount collections.List;
mount core.database.sqlite.native.statistics.stat1.{Stat1Row};
mount core.database.sqlite.native.statistics.histogram.{
    Stat4Histogram, SampleKey,
};

// -----------------------------------------------------------------------------
// PredicateShape — abstracted form of one WHERE clause
// -----------------------------------------------------------------------------

public type PredicateShape is
      PsEquality(SampleKey)
    | PsRange(SampleKey, SampleKey)         // (lo, hi) — closed
    | PsLessThan(SampleKey)
    | PsIsNotNull
    | PsLike;                               // wildcard catch-all

// -----------------------------------------------------------------------------
// Selectivity
// -----------------------------------------------------------------------------

public type Selectivity is { ratio: Float64 }

public fn selectivity(ratio: Float64) -> Selectivity {
    let clamped = if ratio < (0.0 as Float64) { 0.0 as Float64 }
                  else if ratio > (1.0 as Float64) { 1.0 as Float64 }
                  else { ratio };
    Selectivity { ratio: clamped }
}

implement Selectivity {
    pub fn estimate_rows(&self, total: Int64) -> Int64 {
        ((total as Float64) * self.ratio) as Int64
    }
}

// -----------------------------------------------------------------------------
// Estimators
// -----------------------------------------------------------------------------

public fn estimate_with_stat1(pred: &PredicateShape, stat: &Stat1Row, n_cols: Int) -> Selectivity {
    let total = stat.total_rows;
    if total <= 0_i64 { return selectivity(1.0 as Float64); }
    match pred {
        PsEquality(_) => {
            // Equality on a leading prefix: rows / distinct_keys.
            let distinct = stat.distinct_keys(n_cols);
            if distinct <= 0_i64 { return selectivity(1.0 as Float64); }
            selectivity((1.0 as Float64) / (distinct as Float64))
        }
        PsRange(_, _) => {
            // Default range selectivity — 1/4 of the table.
            selectivity(0.25 as Float64)
        }
        PsLessThan(_) => {
            // Default LT selectivity — 1/3 of the table.
            selectivity(0.333 as Float64)
        }
        PsIsNotNull => {
            // Most rows are non-null in practice.
            selectivity(0.95 as Float64)
        }
        PsLike => {
            // Wildcard LIKE — assume 10%.
            selectivity(0.10 as Float64)
        }
    }
}

public fn estimate_with_stat4(pred: &PredicateShape, hist: &Stat4Histogram) -> Selectivity {
    let total = hist.total_rows;
    if total <= 0_i64 { return selectivity(1.0 as Float64); }
    match pred {
        PsEquality(k) => {
            let count = hist.estimate_eq(k);
            selectivity((count as Float64) / (total as Float64))
        }
        PsRange(lo, hi) => {
            let count = hist.estimate_range(lo, hi);
            selectivity((count as Float64) / (total as Float64))
        }
        PsLessThan(k) => {
            let count = hist.estimate_lt(k);
            selectivity((count as Float64) / (total as Float64))
        }
        PsIsNotNull => selectivity(0.95 as Float64),
        PsLike      => selectivity(0.10 as Float64),
    }
}

/// Combine two independent selectivities (e.g. two AND-ed predicates).
public fn combine_and(a: Selectivity, b: Selectivity) -> Selectivity {
    selectivity(a.ratio * b.ratio)
}

/// Combine two independent selectivities under OR.
public fn combine_or(a: Selectivity, b: Selectivity) -> Selectivity {
    selectivity(a.ratio + b.ratio - a.ratio * b.ratio)
}
