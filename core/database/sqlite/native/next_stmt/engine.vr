// =============================================================================
// next_stmt/engine.vr — sqlite3_next_stmt walker
// =============================================================================
// Spec: SQLite C API
//
// `sqlite3_next_stmt(db, 0)` returns the head; subsequent calls with
// the previous handle return the next entry.  Returns 0 (NULL) past
// the end.
// =============================================================================

module core.database.sqlite.native.next_stmt.engine;

mount core.*;
mount base.{Bool};
mount core.database.sqlite.native.next_stmt.stmt_list.{
    StmtList,
};

/// Returns the id immediately after `current` in `list`, or 0 if
/// `current` is the tail or not present.  Passing `current == 0`
/// returns the head.
public fn sqlite3_next_stmt(list: &StmtList, current: Int64) -> Int64 {
    if list.len() == 0 { return 0 as Int64; }
    if current == (0 as Int64) {
        return *list.ids.get(0);
    }
    let mut i: Int = 0;
    while i < list.len() {
        if *list.ids.get(i) == current {
            if i + 1 < list.len() {
                return *list.ids.get(i + 1);
            }
            return 0 as Int64;
        }
        i = i + 1;
    }
    0 as Int64
}

/// Iterator convenience: walk the entire list, yielding each id via
/// the supplied closure.
public fn walk_all(list: &StmtList, visit: fn(Int64)) {
    let mut current = sqlite3_next_stmt(list, 0 as Int64);
    while current != (0 as Int64) {
        (visit)(current);
        current = sqlite3_next_stmt(list, current);
    }
}
