// Verdict — the decision the reader must take.

module core.database.sqlite.native.hot_journal_detector.verdict;

mount core.database.sqlite.native.hot_journal_detector.signal.{
    Signal, is_absent, is_empty, has_owner, header_intact,
};
mount base.{Bool, Text};

public type Verdict is
    | VdNoJournal        // journal missing — proceed normally
    | VdStaleEmpty       // empty journal — unlink + proceed
    | VdOwnedByWriter    // someone holds EXCLUSIVE → they own the replay
    | VdMalformed        // header bad — ignore + warn (not hot)
    | VdHot              // must replay before reading
    ;

public fn verdict_name(v: &Verdict) -> Text {
    match v {
        VdNoJournal     => "no_journal".clone(),
        VdStaleEmpty    => "stale_empty".clone(),
        VdOwnedByWriter => "owned_by_writer".clone(),
        VdMalformed     => "malformed".clone(),
        VdHot           => "hot".clone(),
    }
}

public fn requires_replay(v: &Verdict) -> Bool {
    match v { VdHot => true, _ => false }
}

public fn safe_to_read_directly(v: &Verdict) -> Bool {
    match v {
        VdNoJournal     => true,
        VdStaleEmpty    => true,
        VdOwnedByWriter => true,
        _               => false,
    }
}

public fn classify(s: &Signal) -> Verdict {
    if is_absent(s)   { return VdNoJournal; }
    if is_empty(s)    { return VdStaleEmpty; }
    if has_owner(s)   { return VdOwnedByWriter; }
    if !header_intact(s) { return VdMalformed; }
    VdHot
}
