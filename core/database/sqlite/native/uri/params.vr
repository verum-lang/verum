// =============================================================================
// uri/params.vr — UriParams + recognised key enum
// =============================================================================
// Spec: SQLite URI filenames
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.database.sqlite.native.uri.params;

mount core.*;
mount base.{Text, Bool, Maybe};
mount collections.List;

// -----------------------------------------------------------------------------
// UriOpenMode
// -----------------------------------------------------------------------------

public type UriOpenMode is OmReadOnly | OmReadWrite | OmReadWriteCreate | OmMemory;

public fn open_mode_text(m: &UriOpenMode) -> Text {
    match m {
        OmReadOnly         => "ro".clone(),
        OmReadWrite        => "rw".clone(),
        OmReadWriteCreate  => "rwc".clone(),
        OmMemory           => "memory".clone(),
    }
}

public fn parse_mode(text: &Text) -> Maybe<UriOpenMode> {
    if *text == "ro".clone()     { return Maybe.Some(OmReadOnly); }
    if *text == "rw".clone()     { return Maybe.Some(OmReadWrite); }
    if *text == "rwc".clone()    { return Maybe.Some(OmReadWriteCreate); }
    if *text == "memory".clone() { return Maybe.Some(OmMemory); }
    Maybe.None
}

// -----------------------------------------------------------------------------
// CacheMode
// -----------------------------------------------------------------------------

public type CacheMode is CmShared | CmPrivate;

public fn cache_mode_text(c: &CacheMode) -> Text {
    match c {
        CmShared  => "shared".clone(),
        CmPrivate => "private".clone(),
    }
}

public fn parse_cache(text: &Text) -> Maybe<CacheMode> {
    if *text == "shared".clone()  { return Maybe.Some(CmShared); }
    if *text == "private".clone() { return Maybe.Some(CmPrivate); }
    Maybe.None
}

// -----------------------------------------------------------------------------
// UriQueryParam — generic (key, value) record
// -----------------------------------------------------------------------------

public type UriQueryParam is { key: Text, value: Text }

public fn query_param(key: Text, value: Text) -> UriQueryParam {
    UriQueryParam { key: key, value: value }
}

// -----------------------------------------------------------------------------
// UriParams — parsed flag bag
// -----------------------------------------------------------------------------

public type UriParams is {
    /// VFS module name (Maybe.None ⇒ default).
    vfs: Maybe<Text>,
    mode: Maybe<UriOpenMode>,
    cache: Maybe<CacheMode>,
    /// Powersafe overwrite — Maybe.None ⇒ VFS default.
    psow: Maybe<Bool>,
    nolock: Maybe<Bool>,
    immutable: Maybe<Bool>,
    /// Unrecognised query parameters — preserved verbatim.
    extra: List<UriQueryParam>,
}

public fn uri_params_default() -> UriParams {
    UriParams {
        vfs: Maybe.None,
        mode: Maybe.None,
        cache: Maybe.None,
        psow: Maybe.None,
        nolock: Maybe.None,
        immutable: Maybe.None,
        extra: List.new(),
    }
}

implement UriParams {
    public fn merge(&mut self, key: &Text, value: &Text) {
        if *key == "vfs".clone()     { self.vfs = Maybe.Some(value.clone()); return; }
        if *key == "mode".clone()    { self.mode = parse_mode(value); return; }
        if *key == "cache".clone()   { self.cache = parse_cache(value); return; }
        if *key == "psow".clone()    { self.psow = Maybe.Some(parse_bool(value)); return; }
        if *key == "nolock".clone()  { self.nolock = Maybe.Some(parse_bool(value)); return; }
        if *key == "immutable".clone() { self.immutable = Maybe.Some(parse_bool(value)); return; }
        self.extra.push(query_param(key.clone(), value.clone()));
    }

    public fn known_key_count(&self) -> Int {
        let mut n: Int = 0;
        match &self.vfs       { Maybe.Some(_) => { n = n + 1; } Maybe.None => {} }
        match &self.mode      { Maybe.Some(_) => { n = n + 1; } Maybe.None => {} }
        match &self.cache     { Maybe.Some(_) => { n = n + 1; } Maybe.None => {} }
        match &self.psow      { Maybe.Some(_) => { n = n + 1; } Maybe.None => {} }
        match &self.nolock    { Maybe.Some(_) => { n = n + 1; } Maybe.None => {} }
        match &self.immutable { Maybe.Some(_) => { n = n + 1; } Maybe.None => {} }
        n
    }
}

fn parse_bool(text: &Text) -> Bool {
    *text == "1".clone() || *text == "true".clone() || *text == "yes".clone()
}
