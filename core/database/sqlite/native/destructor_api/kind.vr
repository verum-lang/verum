// =============================================================================
// destructor_api/kind.vr — BindDestructorKind sum
// =============================================================================
// Spec: SQLite C API
// =============================================================================

module core.database.sqlite.native.destructor_api.kind;

mount core.*;
mount base.{Bool, Text};

/// SQLite's two magic pointer values.
public const SQLITE_STATIC: Int64     = 0 as Int64;
public const SQLITE_TRANSIENT: Int64  = -1 as Int64;

public type BindDestructorKind is
      DStatic
    | DTransient
    | DCustom(Int64);       // opaque destructor-function handle (non-NULL)

public fn destructor_ptr(d: &BindDestructorKind) -> Int64 {
    match d {
        DStatic       => SQLITE_STATIC,
        DTransient    => SQLITE_TRANSIENT,
        DCustom(h)    => *h,
    }
}

public fn destructor_name(d: &BindDestructorKind) -> Text {
    match d {
        DStatic     => "SQLITE_STATIC".clone(),
        DTransient  => "SQLITE_TRANSIENT".clone(),
        DCustom(_)  => "custom".clone(),
    }
}

public fn will_copy(d: &BindDestructorKind) -> Bool {
    match d {
        DTransient => true,
        _ => false,
    }
}

public fn will_invoke_callback(d: &BindDestructorKind) -> Bool {
    match d {
        DCustom(_) => true,
        _ => false,
    }
}

public fn from_ptr(ptr: Int64) -> BindDestructorKind {
    if ptr == SQLITE_STATIC    { return DStatic; }
    if ptr == SQLITE_TRANSIENT { return DTransient; }
    DCustom(ptr)
}
