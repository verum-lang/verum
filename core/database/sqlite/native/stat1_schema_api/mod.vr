// =============================================================================
// core/database/sqlite/native/stat1_schema_api/mod.vr
// =============================================================================
// sqlite_stat1 row shape — per ANALYZE output.
// Spec §13.2.1 — sqlite_stat1.
//

//  tbl TEXT — table name
//  idx TEXT — index name (NULL → whole-table stats)
//  stat TEXT — space-separated counts: "N k1 k2 ... kM"
//  N = total rows in index
//  ki = average number of rows with same first-i key cols
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.database.sqlite.native.stat1_schema_api;

public module row;
