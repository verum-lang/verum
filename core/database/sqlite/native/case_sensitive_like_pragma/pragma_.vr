// PRAGMA case_sensitive_like.
//
// Off (default): a LIKE b   is "BINARY-fold-ASCII" — A == a, Z == z.
// On:            a LIKE b   is byte-exact for the entire ASCII range.
// Note: SQLite never folds non-ASCII characters even in OFF mode unless ICU.

module core.database.sqlite.native.case_sensitive_like_pragma.pragma_;

mount base.{Bool, Text};

public type Mode is
    | InsensitiveAscii   // default — a == A, z == Z (ASCII only)
    | CaseSensitive      // byte-exact match
    ;

public fn default_mode() -> Mode { InsensitiveAscii }

public fn from_pragma_value(n: Int) -> Mode {
    if n == 0 { InsensitiveAscii } else { CaseSensitive }
}

public fn to_pragma_value(m: &Mode) -> Int {
    match m { InsensitiveAscii => 0, CaseSensitive => 1 }
}

public fn mode_name(m: &Mode) -> Text {
    match m {
        InsensitiveAscii => "off".clone(),
        CaseSensitive    => "on".clone(),
    }
}

// Folding rule applied per-byte when comparing literal-vs-pattern.
public fn folds_ascii(m: &Mode) -> Bool {
    match m {
        InsensitiveAscii => true,
        CaseSensitive    => false,
    }
}

// Apply the fold to a single ASCII byte.
public fn fold_byte(m: &Mode, b: Int) -> Int {
    if !folds_ascii(m) { return b; }
    if b >= 0x41 && b <= 0x5A { return b + 0x20; }
    b
}

// Equal-under-mode predicate for two ASCII bytes.
public fn bytes_equal(m: &Mode, a: Int, b: Int) -> Bool {
    fold_byte(m, a) == fold_byte(m, b)
}
