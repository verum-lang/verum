// sqlite3_stmt_busy — busy-state probe.

module core.database.sqlite.native.stmt_busy_api.state;

mount base.{Bool, Text};

// Compiled-stmt lifecycle phase.
public type Phase is
    | PhFresh         // just compiled or just sqlite3_reset()
    | PhRunning       // step() returned ROW; row is buffered
    | PhFinished      // step() returned DONE / ERROR
    | PhFinalized     // sqlite3_finalize() invoked
    ;

public fn phase_name(p: &Phase) -> Text {
    match p {
        PhFresh     => "fresh".clone(),
        PhRunning   => "running".clone(),
        PhFinished  => "finished".clone(),
        PhFinalized => "finalized".clone(),
    }
}

// sqlite3_stmt_busy returns 1 only in the Running phase.
public fn is_busy(p: &Phase) -> Int {
    match p { PhRunning => 1, _ => 0 }
}

public fn busy_bool(p: &Phase) -> Bool {
    is_busy(p) == 1
}

// Transition table.
public type Event is
    | EStep              // sqlite3_step
    | EReset             // sqlite3_reset
    | EFinalize          // sqlite3_finalize
    ;

public fn event_name(e: &Event) -> Text {
    match e {
        EStep     => "step".clone(),
        EReset    => "reset".clone(),
        EFinalize => "finalize".clone(),
    }
}

public fn next_phase(p: &Phase, e: &Event, last_step_returned_row: Bool) -> Phase {
    match p {
        PhFinalized => PhFinalized,         // terminal
        _ => match e {
            EFinalize => PhFinalized,
            EReset    => PhFresh,
            EStep     => if last_step_returned_row { PhRunning } else { PhFinished },
        },
    }
}

// Validity check: cannot step a finalized stmt.
public type CallCheck is
    | CcAllowed
    | CcMisuseFinalized
    ;

public fn check_call(p: &Phase, e: &Event) -> CallCheck {
    match p {
        PhFinalized => match e { EFinalize => CcAllowed, _ => CcMisuseFinalized },
        _ => CcAllowed,
    }
}

public fn check_name(c: &CallCheck) -> Text {
    match c {
        CcAllowed         => "allowed".clone(),
        CcMisuseFinalized => "misuse_finalized".clone(),
    }
}
