// =============================================================================
// changes/engine.vr — C-API name-aligned accessors
// =============================================================================
// Spec: SQLite C API
//
//   sqlite3_changes(db)              → int    (statement changes, 32-bit)
//   sqlite3_changes64(db)            → sqlite3_int64
//   sqlite3_total_changes(db)        → int
//   sqlite3_total_changes64(db)      → sqlite3_int64
//   sqlite3_last_insert_rowid(db)    → sqlite3_int64
//   sqlite3_set_last_insert_rowid(…) → void
//
// The 32-bit variants truncate via the standard cast (`as Int`).
// =============================================================================

module core.database.sqlite.native.changes.engine;

mount core.*;
mount base.{Bool};
mount core.database.sqlite.native.changes.counter.{
    ChangeCounter,
};

public fn sqlite3_changes(c: &ChangeCounter) -> Int {
    c.statement_changes as Int
}

public fn sqlite3_changes64(c: &ChangeCounter) -> Int64 {
    c.statement_changes
}

public fn sqlite3_total_changes(c: &ChangeCounter) -> Int {
    c.total_changes as Int
}

public fn sqlite3_total_changes64(c: &ChangeCounter) -> Int64 {
    c.total_changes
}

public fn sqlite3_last_insert_rowid(c: &ChangeCounter) -> Int64 {
    c.last_insert_rowid
}

public fn sqlite3_set_last_insert_rowid(c: &mut ChangeCounter, rowid: Int64) {
    c.override_last_insert_rowid(rowid);
}
