// =============================================================================
// export/value.vr — abstracted SQL value + textual rendering
// =============================================================================
// Spec: sqlite-native.md §22 (operational tooling — dump / restore)
//
// Export modules consume `ExportValue`, a five-variant sum that
// matches SQLite storage classes (NULL / INTEGER / REAL / TEXT /
// BLOB) with the ROLE of textual SQL-literal rendering.  Distinct
// from `l6_session::sql_value::SqlValue` (the SQLite-C-API-shaped
// value used by `sqlite3_column_*` / `sqlite3_bind_*`); the
// `from_sql_value` adapter at the bottom of this file lifts the
// canonical SqlValue into ExportValue for dump-pipeline use.
//
// Renamed from `SqlValue` (#162) to eliminate the variant-name
// clash with `l6_session::sql_value::SqlValue` — pattern-matching
// across modules used to dispatch unpredictably depending on
// import order.  Each type now reflects its role: SqlValue = API
// surface, ExportValue = rendering surface.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.database.sqlite.native.export.value;

mount core.*;
mount base.{Text, Bool};
mount collections.List;

// -----------------------------------------------------------------------------
// ExportValue — rendering-surface SQL value
// -----------------------------------------------------------------------------

public type ExportValue is
      EvNull
    | EvInteger(Int64)
    | EvReal(Float64)
    | EvText(Text)
    | EvBlob(List<Byte>);

/// Back-compat type alias — older callers still importing
/// `SqlValue` resolve through this until they migrate to the
/// `ExportValue` name.  Will be removed in a follow-up sweep
/// once every consumer is renamed.
public type SqlValue is ExportValue;

public fn ev_kind_name(v: &ExportValue) -> Text {
    match v {
        EvNull       => "NULL".clone(),
        EvInteger(_) => "INTEGER".clone(),
        EvReal(_)    => "REAL".clone(),
        EvText(_)    => "TEXT".clone(),
        EvBlob(_)    => "BLOB".clone(),
    }
}

/// Back-compat alias for sv_kind_name.
public fn sv_kind_name(v: &ExportValue) -> Text { ev_kind_name(v) }

// -----------------------------------------------------------------------------
// SQL literal rendering — used by the INSERT-statement emitter
// -----------------------------------------------------------------------------

public fn render_sql_literal(v: &ExportValue) -> Text {
    match v {
        EvNull       => "NULL".clone(),
        EvInteger(n) => render_int64(*n),
        EvReal(f)    => render_float(*f),
        EvText(t)    => quote_sql_text(t),
        EvBlob(b)    => render_blob_x(b),
    }
}

/// Single-quoted SQL string with `'` doubled inside.
public fn quote_sql_text(t: &Text) -> Text {
    let mut out = "'".clone();
    let bs = t.as_bytes();
    let mut i: Int = 0;
    while i < bs.len() {
        let b = bs[i];
        if b == (39 as Byte) {
            out.push_byte(39 as Byte);
            out.push_byte(39 as Byte);
        } else {
            out.push_byte(b);
        }
        i = i + 1;
    }
    out.push_byte(39 as Byte);
    out
}

/// Hex-blob literal — `X'48656c6c6f'`.
fn render_blob_x(b: &List<Byte>) -> Text {
    let mut out = "X'".clone();
    let mut i: Int = 0;
    while i < b.len() {
        let v = b[i];
        out.push_byte(hex_digit((v >> (4 as Byte)) & (15 as Byte)));
        out.push_byte(hex_digit(v & (15 as Byte)));
        i = i + 1;
    }
    out.push_byte(39 as Byte);
    out
}

fn hex_digit(n: Byte) -> Byte {
    if n < (10 as Byte) { n + (48 as Byte) } else { (n - (10 as Byte)) + (97 as Byte) }
}

fn render_int64(n: Int64) -> Text {
    // Int.MIN-safe via UInt64 magnitude. Previously `if neg { -n }`
    // wrapped Int64.MIN back to itself; the digit loop never entered
    // and the export rendered "-" with no magnitude — a real data-
    // loss bug for any DB column containing Int64.MIN written through
    // the export path.
    if n == 0_i64 { return "0".clone(); }
    let mut digits: List<Byte> = List.new();
    let neg = n < 0_i64;
    let mut x: UInt64 = if neg {
        (((!n) as UInt64) + 1_u64)
    } else {
        n as UInt64
    };
    while x > 0_u64 {
        let d: Byte = (x % 10_u64) as Byte;
        digits.push(d + (48 as Byte));
        x = x / 10_u64;
    }
    let mut out = Text.new();
    if neg { out.push_byte(45 as Byte); }
    let mut i: Int = digits.len() - 1;
    while i >= 0 { out.push_byte(digits[i]); i = i - 1; }
    out
}

/// Float renderer — mantissa-only, no exponent. We stick with
/// six significant digits which matches sqlite3's default REAL
/// formatting precisely enough for round-trippable text dumps.
fn render_float(f: Float64) -> Text {
    let neg = f < (0.0 as Float64);
    let abs_f: Float64 = if neg { -f } else { f };
    let int_part: Int64 = abs_f as Int64;
    let frac: Float64 = abs_f - (int_part as Float64);
    let scaled: Int64 = (frac * (1000000.0 as Float64)) as Int64;

    let mut out = Text.new();
    if neg { out.push_byte(45 as Byte); }
    push(&mut out, &render_int64(int_part));
    out.push_byte(46 as Byte);

    // zero-pad fractional digits to 6 places
    let mut digits: List<Byte> = List.new();
    let mut x: Int64 = if scaled < 0_i64 { -scaled } else { scaled };
    let mut placed: Int = 0;
    while placed < 6 {
        let d: Byte = ((x as Int) % 10) as Byte;
        digits.push(d + (48 as Byte));
        x = x / 10_i64;
        placed = placed + 1;
    }
    let mut i: Int = digits.len() - 1;
    while i >= 0 { out.push_byte(digits[i]); i = i - 1; }
    out
}

fn push(dst: &mut Text, s: &Text) {
    let bs = s.as_bytes();
    let mut i: Int = 0;
    while i < bs.len() { dst.push_byte(bs[i]); i = i + 1; }
}

// -----------------------------------------------------------------------------
// Bridge from the canonical L6 SqlValue (#162)
// -----------------------------------------------------------------------------

/// Lift a canonical `l6_session::sql_value::SqlValue` into the
/// rendering-surface `ExportValue`.  The conversion is structural
/// + total — every variant maps 1-to-1.  Use this at the dump-
/// pipeline boundary to keep the rendering layer decoupled from
/// the SQLite-API surface (which evolves to track sqlite3_*
/// behaviour) while sharing the underlying value carriers.
public fn from_sql_value(
    v: &core.database.sqlite.native.l6_session.sql_value.SqlValue,
) -> ExportValue {
    match v {
        core.database.sqlite.native.l6_session.sql_value.VNull    => EvNull,
        core.database.sqlite.native.l6_session.sql_value.VInt(i)  => EvInteger(i),
        core.database.sqlite.native.l6_session.sql_value.VReal(x) => EvReal(x),
        core.database.sqlite.native.l6_session.sql_value.VText(ref t) => EvText(t.clone()),
        core.database.sqlite.native.l6_session.sql_value.VBlob(ref b) => EvBlob(b.clone()),
    }
}
