// =============================================================================
// core/database/sqlite/native/hooks_api/mod.vr
// =============================================================================
// Layer: 7 (façade — public hook-registration C-API)
// Spec: SQLite C API — §19.5
//

//  sqlite3_commit_hook(db, xCb, pArg) → prev callback
//  sqlite3_rollback_hook(db, xCb, pArg) → prev
//  sqlite3_update_hook(db, xCb, pArg) → prev
//  sqlite3_preupdate_hook(db, xCb, pArg) → prev
//  sqlite3_wal_hook(db, xCb, pArg) → prev
//  sqlite3_autovacuum_pages(db, xCb, pArg, xDestroy)
//

// Complements `ext/hooks.vr` protocols; this catalogue models the
// public registration + slot-swap semantics.
//

// Submodules:
//  * `registration` — typed slot for each hook
//  * `op` — UpdateOp / ConflictOp taxonomy used by hooks
//  * `engine` — installs + replaces hooks, returns prev handle
// =============================================================================

module core.database.sqlite.native.hooks_api;

public module registration;
public module op;
public module engine;
public module dispatcher;

public mount .registration.{
    HookRegistration, HookKind,
    HkCommit, HkRollback, HkUpdate, HkPreupdate, HkWal, HkAutovacuumPages,
    new_registration, is_installed, kind_name,
};

public mount .engine.{
    HooksEngine, new_engine,
};

public mount .dispatcher.{
    ExtendedHooksEngine, ConnectionHooks,
    new_extended_engine, new_connection_hooks,
    CommitDecision, CdAllow, CdAbort,
    AuthDecision, AdAllow, AdDeny, AdIgnore,
    BusyDecision, BdRetry, BdGiveUp,
    ProgressDecision, PdContinue, PdInterrupt,
    UpdateOp, UoInsert, UoUpdate, UoDelete,
    UpdateHookCtx, PreUpdateHookCtx, AuthorizerCtx, TraceCtx,
    TraceEvent, TeStmtPrepared, TeStmtRow, TeStmtClose, TeProfile,
    fire_commit_hook, fire_rollback_hook,
    fire_update_hook, fire_pre_update_hook,
    fire_authorizer, fire_busy_handler, fire_progress_handler, fire_trace_hook,
};
