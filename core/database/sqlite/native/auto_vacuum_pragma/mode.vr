// PRAGMA auto_vacuum modes.

module core.database.sqlite.native.auto_vacuum_pragma.mode;

mount base.{Bool, Text};

public type AutoVacuumPragmaMode is
    | AvNone           // 0 — default
    | AvFull           // 1 — reclaim at every commit
    | AvIncremental    // 2 — pointer-map kept; reclaim via PRAGMA
    ;

public fn default_mode() -> AutoVacuumPragmaMode { AvNone }

public fn from_pragma_value(n: Int) -> AutoVacuumPragmaMode {
    if n <= 0 { return AvNone; }
    if n == 1 { return AvFull; }
    AvIncremental
}

public fn to_pragma_value(m: &AutoVacuumPragmaMode) -> Int {
    match m {
        AvNone        => 0,
        AvFull        => 1,
        AvIncremental => 2,
    }
}

public fn mode_name(m: &AutoVacuumPragmaMode) -> Text {
    match m {
        AvNone        => "none".clone(),
        AvFull        => "full".clone(),
        AvIncremental => "incremental".clone(),
    }
}

public fn maintains_pointer_map(m: &AutoVacuumPragmaMode) -> Bool {
    match m { AvNone => false, _ => true }
}

public fn reclaims_at_commit(m: &AutoVacuumPragmaMode) -> Bool {
    match m { AvFull => true, _ => false }
}

public fn supports_incremental_pragma(m: &AutoVacuumPragmaMode) -> Bool {
    match m { AvIncremental => true, _ => false }
}

// Outcome of trying to change auto_vacuum.  In SQLite, the change is honoured
// only on a freshly-created (empty) database; otherwise it's silently ignored.
public type SetOutcome is
    | SoApplied
    | SoIgnoredNotEmpty
    ;

public fn try_apply(db_has_tables: Bool) -> SetOutcome {
    if db_has_tables { SoIgnoredNotEmpty } else { SoApplied }
}

public fn outcome_name(o: &SetOutcome) -> Text {
    match o {
        SoApplied         => "applied".clone(),
        SoIgnoredNotEmpty => "ignored_not_empty".clone(),
    }
}

public fn was_applied(o: &SetOutcome) -> Bool {
    match o { SoApplied => true, _ => false }
}
