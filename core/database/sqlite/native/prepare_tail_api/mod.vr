// =============================================================================
// core/database/sqlite/native/prepare_tail_api/mod.vr
// =============================================================================
// Layer: 7 (façade — multi-statement prepare tail walking)
// Spec: SQLite C API — sqlite3_prepare_v2/v3 tail pointer.
//

// Each sqlite3_prepare call compiles the leading SQL statement and
// hands back a pointer into the remaining bytes. To walk a whole
// script the caller repeats prepare(tail) until the tail is empty (or
// entirely whitespace/comments).
//

// Submodules:
//  * `walker` — advance past a byte offset, skip whitespace + comments
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.database.sqlite.native.prepare_tail_api;

public module walker;
