// =============================================================================
// column/coerce.vr — typed coercion helpers
// =============================================================================
// Spec: SQLite C API
//
// `sqlite3_column_int64(stmt, i)` casts the underlying value to Int64
// regardless of its storage class. The C API documents the conversion
// rules; we reproduce them here. NULL → 0/0.0/empty Text/empty Blob.
// =============================================================================

module core.database.sqlite.native.column.coerce;

mount core.*;
mount base.{Text, Bool};
mount collections.List;
mount core.database.sqlite.native.column.value.{
    ColumnValue, CvNull, CvInt64, CvReal, CvText, CvBlob,
};

// -----------------------------------------------------------------------------
// to_int64
// -----------------------------------------------------------------------------

public fn to_int64(v: &ColumnValue) -> Int64 {
    match v {
        CvNull       => 0 as Int64,
        CvInt64(n)   => *n,
        CvReal(f)    => *f as Int64,
        CvText(t)    => parse_int64(t),
        CvBlob(b)    => parse_int64_from_blob(b),
    }
}

// -----------------------------------------------------------------------------
// to_double
// -----------------------------------------------------------------------------

public fn to_double(v: &ColumnValue) -> Float64 {
    match v {
        CvNull     => 0.0 as Float64,
        CvInt64(n) => *n as Float64,
        CvReal(f)  => *f,
        CvText(t)  => parse_real(t),
        CvBlob(_)  => 0.0 as Float64,
    }
}

// -----------------------------------------------------------------------------
// to_text
// -----------------------------------------------------------------------------

public fn to_text(v: &ColumnValue) -> Text {
    match v {
        CvNull       => Text.new(),
        CvInt64(n)   => render_int64(*n),
        CvReal(f)    => render_real(*f),
        CvText(t)    => t.clone(),
        CvBlob(b)    => blob_to_text(b),
    }
}

// -----------------------------------------------------------------------------
// to_blob
// -----------------------------------------------------------------------------

public fn to_blob(v: &ColumnValue) -> List<Byte> {
    match v {
        CvNull       => List.new(),
        CvBlob(b)    => {
            let mut out: List<Byte> = List.new();
            let mut i: Int = 0;
            while i < b.len() { out.push(b[i]); i = i + 1; }
            out
        }
        CvText(t)    => {
            let mut out: List<Byte> = List.new();
            let bs = t.as_bytes();
            let mut i: Int = 0;
            while i < bs.len() { out.push(bs[i]); i = i + 1; }
            out
        }
        _ => {
            let mut out: List<Byte> = List.new();
            let t = to_text(v);
            let bs = t.as_bytes();
            let mut i: Int = 0;
            while i < bs.len() { out.push(bs[i]); i = i + 1; }
            out
        }
    }
}

// -----------------------------------------------------------------------------
// Parsers + renderers
// -----------------------------------------------------------------------------

fn parse_int64(t: &Text) -> Int64 {
    let bs = t.as_bytes();
    if bs.len() == 0 { return 0 as Int64; }
    let mut i: Int = 0;
    let mut neg = false;
    if bs[0] == (45 as Byte) { neg = true; i = 1; }
    else if bs[0] == (43 as Byte) { i = 1; }
    let mut acc: Int64 = 0 as Int64;
    while i < bs.len() {
        let b = bs[i];
        if b < (48 as Byte) || b > (57 as Byte) { break; }
        acc = acc * (10 as Int64) + ((b - (48 as Byte)) as Int64);
        i = i + 1;
    }
    if neg { -acc } else { acc }
}

fn parse_int64_from_blob(b: &List<Byte>) -> Int64 {
    // Treat the first 8 bytes (or fewer) as big-endian Int64.
    let mut acc: Int64 = 0 as Int64;
    let cap = if b.len() < 8 { b.len() } else { 8 };
    let mut i: Int = 0;
    while i < cap {
        acc = (acc << (8 as Int64)) | ((b[i] as Int64) & (0xFF as Int64));
        i = i + 1;
    }
    acc
}

fn parse_real(t: &Text) -> Float64 {
    // Conservative: parse leading integer + fractional part. Not a
    // strtod replacement; the L4 interpreter has the full one.
    let bs = t.as_bytes();
    let mut i: Int = 0;
    let mut neg = false;
    if i < bs.len() && bs[i] == (45 as Byte) { neg = true; i = i + 1; }
    else if i < bs.len() && bs[i] == (43 as Byte) { i = i + 1; }
    let mut int_part: Float64 = 0.0 as Float64;
    while i < bs.len() && bs[i] >= (48 as Byte) && bs[i] <= (57 as Byte) {
        int_part = int_part * (10.0 as Float64) + (((bs[i] - (48 as Byte)) as Int) as Float64);
        i = i + 1;
    }
    if i < bs.len() && bs[i] == (46 as Byte) {
        i = i + 1;
        let mut scale: Float64 = 0.1 as Float64;
        while i < bs.len() && bs[i] >= (48 as Byte) && bs[i] <= (57 as Byte) {
            int_part = int_part + scale * (((bs[i] - (48 as Byte)) as Int) as Float64);
            scale = scale / (10.0 as Float64);
            i = i + 1;
        }
    }
    if neg { -int_part } else { int_part }
}

fn render_int64(n: Int64) -> Text {
    if n == (0 as Int64) { return "0".clone(); }
    let neg = n < (0 as Int64);
    let mut x: Int64 = if neg { -n } else { n };
    let mut digits: List<Byte> = List.new();
    while x > (0 as Int64) {
        digits.push((((x as Int) % 10) as Byte) + (48 as Byte));
        x = x / (10 as Int64);
    }
    let mut t = Text.new();
    if neg { t.push_byte(45 as Byte); }
    let mut i: Int = digits.len() - 1;
    while i >= 0 { t.push_byte(digits[i]); i = i - 1; }
    t
}

fn render_real(f: Float64) -> Text {
    let int_part: Int64 = f as Int64;
    render_int64(int_part)
}

fn blob_to_text(b: &List<Byte>) -> Text {
    let mut t = Text.new();
    let mut i: Int = 0;
    while i < b.len() { t.push_byte(b[i]); i = i + 1; }
    t
}
