// =============================================================================
// threadsafe/engine.vr — compile-time vs run-time mode
// =============================================================================
// Spec: SQLite C API
//
// The compile-time mode is fixed; sqlite3_config may request a
// DOWNGRADE (Serialized → MultiThread → SingleThread) but never an
// UPGRADE.  The engine records both the compile-time floor and the
// currently-effective mode.
// =============================================================================

module core.database.sqlite.native.threadsafe.engine;

mount core.*;
mount base.{Bool};
mount core.database.sqlite.native.threadsafe.mode.{
    TsMode, TsSingleThread, TsMultiThread, TsSerialized,
    mode_numeric,
};

public type ThreadsafeEngine is {
    compile_time: TsMode,
    effective: TsMode,
}

public fn new_engine(compile_time: TsMode) -> ThreadsafeEngine {
    let eff = clone_mode(&compile_time);
    ThreadsafeEngine { compile_time: compile_time, effective: eff }
}

/// Rank: Serialized(2) > MultiThread(1) > SingleThread(0).  Higher
/// rank = stronger safety guarantee.  Downgrades (lower rank than
/// compile-time) are accepted; upgrades are rejected.
fn rank(m: &TsMode) -> Int {
    match m {
        TsSerialized   => 2,
        TsMultiThread  => 1,
        TsSingleThread => 0,
    }
}

implement ThreadsafeEngine {
    pub fn request(&mut self, requested: TsMode) -> Bool {
        if rank(&requested) > rank(&self.compile_time) { return false; }
        self.effective = requested;
        true
    }

    pub fn effective_numeric(&self) -> Int {
        mode_numeric(&self.effective)
    }
}

fn clone_mode(m: &TsMode) -> TsMode {
    match m {
        TsSingleThread => TsSingleThread,
        TsMultiThread  => TsMultiThread,
        TsSerialized   => TsSerialized,
    }
}
