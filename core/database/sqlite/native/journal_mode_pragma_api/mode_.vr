// PRAGMA journal_mode modes (surface-level; full transition matrix in
// `journal_mode_transition` from wave 19).

module core.database.sqlite.native.journal_mode_pragma_api.mode_;

mount base.{Bool, Text};

public type JournalMode is
    | JmDelete       // default
    | JmTruncate
    | JmPersist
    | JmMemory
    | JmWal
    | JmOff
    ;

public fn default_mode() -> JournalMode { JmDelete }

public fn from_text(t: Text) -> JournalMode {
    if t == "delete".clone()   { return JmDelete; }
    if t == "truncate".clone() { return JmTruncate; }
    if t == "persist".clone()  { return JmPersist; }
    if t == "memory".clone()   { return JmMemory; }
    if t == "wal".clone()      { return JmWal; }
    if t == "off".clone()      { return JmOff; }
    JmDelete    // unknown → default
}

public fn mode_name(m: &JournalMode) -> Text {
    match m {
        JmDelete   => "delete".clone(),
        JmTruncate => "truncate".clone(),
        JmPersist  => "persist".clone(),
        JmMemory   => "memory".clone(),
        JmWal      => "wal".clone(),
        JmOff      => "off".clone(),
    }
}

// Three classifications.

public fn is_rollback_journal(m: &JournalMode) -> Bool {
    match m {
        JmDelete   => true,
        JmTruncate => true,
        JmPersist  => true,
        _ => false,
    }
}

public fn keeps_journal_file(m: &JournalMode) -> Bool {
    match m {
        JmDelete   => true,
        JmTruncate => true,
        JmPersist  => true,
        JmMemory   => false,    // RAM only
        JmWal      => false,    // WAL is a separate file
        JmOff      => false,
    }
}

public fn is_wal(m: &JournalMode) -> Bool {
    match m { JmWal => true, _ => false }
}

public fn is_safe_for_durability(m: &JournalMode) -> Bool {
    match m {
        JmOff    => false,
        JmMemory => false,
        _ => true,
    }
}

// Whether the choice is persistent across sessions (stored in the file).
public fn persists_across_sessions(m: &JournalMode) -> Bool {
    match m {
        JmWal      => true,
        JmDelete   => true,
        JmTruncate => true,
        JmPersist  => true,
        _ => false,
    }
}

// PRAGMA reply text: SQLite returns the *new* mode name on success.  Used
// by drivers to confirm the change actually applied.
public fn reply_text(m: &JournalMode) -> Text { mode_name(m) }
