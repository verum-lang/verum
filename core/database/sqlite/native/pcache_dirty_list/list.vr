// Dirty-page LRU list: MRU at front, LRU at back.

module core.database.sqlite.native.pcache_dirty_list.list;

mount core.database.sqlite.native.pcache_dirty_list.state.{
    DirtyState, DsClean, DsDirty, DsWriting, DsPinned,
    is_dirty, is_evictable, needs_flush,
};
mount base.{Bool, Int64};
mount core.collections.list.{List};

public type PageEntry is {
    page_number: u32,
    state: DirtyState,
    last_access_tick: Int64,
};

public fn entry(page_number: u32, state: DirtyState, tick: Int64) -> PageEntry {
    PageEntry { page_number: page_number, state: state, last_access_tick: tick }
}

public type DirtyList is {
    entries: List<PageEntry>,
    tick: Int64,
    dirty_count: Int64,
};

public fn new() -> DirtyList {
    DirtyList {
        entries: [].clone() as List<PageEntry>,
        tick: 0 as Int64,
        dirty_count: 0 as Int64,
    }
}

// Touch: move page to MRU position. Simple implementation — remove + insert.
public fn touch(mut l: DirtyList, page_number: u32, state: DirtyState) -> DirtyList {
    l.tick = l.tick + 1_i64;
    // Remove existing entry (if any) and recompute dirty count.
    let mut i: Int = 0;
    while i < l.entries.len() {
        if l.entries[i].page_number == page_number {
            if is_dirty(&l.entries[i].state) { l.dirty_count = l.dirty_count - 1_i64; }
            let _ = l.entries.remove(i);
            i = l.entries.len();
        } else {
            i = i + 1;
        }
    }
    let e = entry(page_number, state, l.tick);
    if is_dirty(&e.state) { l.dirty_count = l.dirty_count + 1_i64; }
    l.entries.insert(0, e);
    l
}

public fn size(l: &DirtyList) -> Int { l.entries.len() }

public fn dirty_count(l: &DirtyList) -> Int64 { l.dirty_count }

// Get LRU page (back of list); sentinel 0 if empty.
public fn lru_page(l: &DirtyList) -> u32 {
    if l.entries.len() == 0 { return 0 as u32; }
    l.entries[l.entries.len() - 1].page_number
}

public fn mru_page(l: &DirtyList) -> u32 {
    if l.entries.len() == 0 { return 0 as u32; }
    l.entries[0].page_number
}

public fn first_evictable(l: &DirtyList) -> u32 {
    let mut i: Int = l.entries.len() - 1;
    while i >= 0 {
        if is_evictable(&l.entries[i].state) { return l.entries[i].page_number; }
        i = i - 1;
    }
    0 as u32
}

public fn count_needing_flush(l: &DirtyList) -> Int64 {
    let mut n: Int64 = 0 as Int64;
    let mut i: Int = 0;
    while i < l.entries.len() {
        if needs_flush(&l.entries[i].state) { n = n + 1_i64; }
        i = i + 1;
    }
    n
}
