// =============================================================================
// close_api/engine.vr — close-state driver
// =============================================================================
// Spec: SQLite C API
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.database.sqlite.native.close_api.engine;

mount core.*;
mount base.{Bool};
mount core.database.sqlite.native.close_api.mode.{
    CloseMode, CmStrict, CmDeferred, rejects_on_busy,
};
mount core.database.sqlite.native.close_api.state.{
    ConnectionState, CsLive, CsZombie, CsClosed,
};

public type CloseEngine is {
    state: ConnectionState,
    /// Live prepared-statement count + open BLOB handles + backup
    /// objects that must be finalized before Zombie → Closed.
    outstanding: Int64,
    closes_attempted: Int64,
}

public fn new_engine() -> CloseEngine {
    CloseEngine {
        state: CsLive,
        outstanding: 0 as Int64,
        closes_attempted: 0 as Int64,
    }
}

implement CloseEngine {
    public fn register_stmt(&mut self) -> Bool {
        match &self.state {
            CsLive => {
                self.outstanding = self.outstanding + 1_i64;
                true
            }
            _ => false,
        }
    }

    public fn finalize_stmt(&mut self) {
        if self.outstanding > 0_i64 {
            self.outstanding = self.outstanding - 1_i64;
        }
        if self.outstanding == 0_i64 {
            match &self.state {
                CsZombie => self.state = CsClosed,
                _ => {}
            }
        }
    }

    /// Returns sqlite3 code: 0 (SQLITE_OK) or 5 (SQLITE_BUSY) for
    /// strict mode with outstanding statements.
    public fn close(&mut self, mode: &CloseMode) -> Int {
        self.closes_attempted = self.closes_attempted + 1_i64;
        match &self.state {
            CsClosed => return 0,
            _ => {}
        }
        if self.outstanding > 0_i64 {
            if rejects_on_busy(mode) {
                return 5;
            }
            self.state = CsZombie;
            return 0;
        }
        self.state = CsClosed;
        0
    }
}
