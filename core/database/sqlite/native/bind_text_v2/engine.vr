// =============================================================================
// bind_text_v2/engine.vr — per-stmt bind slot
// =============================================================================
// Spec: SQLite C API
// =============================================================================

module core.database.sqlite.native.bind_text_v2.engine;

mount core.*;
mount base.{Bool, Maybe};
mount collections.List;
mount core.database.sqlite.native.bind_text_v2.spec.{
    BindTextSpec, is_valid,
};

public type BindTextSlot is {
    index: Int,
    spec: Maybe<BindTextSpec>,
}

public fn empty_slot(index: Int) -> BindTextSlot {
    BindTextSlot { index: index, spec: Maybe.None }
}

public type BindTextEngine is {
    slots: List<BindTextSlot>,
    rejections: Int64,
}

public fn new_engine(n_params: Int) -> BindTextEngine {
    let mut slots: List<BindTextSlot> = List.new();
    let mut i: Int = 0;
    while i <= n_params { slots.push(empty_slot(i)); i = i + 1; }
    BindTextEngine { slots: slots, rejections: 0 as Int64 }
}

implement BindTextEngine {
    /// Returns SQLite code: 0 (OK), 25 (SQLITE_RANGE) on bad index,
    /// 1 (SQLITE_ERROR) on invalid spec shape.
    pub fn sqlite3_bind_text(&mut self, index: Int, spec: BindTextSpec) -> Int {
        if index <= 0 || index >= self.slots.len() {
            self.rejections = self.rejections + (1 as Int64);
            return 25;
        }
        if !is_valid(&spec) {
            self.rejections = self.rejections + (1 as Int64);
            return 1;
        }
        self.slots.get_mut(index).spec = Maybe.Some(spec);
        0
    }

    pub fn clear(&mut self, index: Int) -> Bool {
        if index <= 0 || index >= self.slots.len() { return false; }
        self.slots.get_mut(index).spec = Maybe.None;
        true
    }

    pub fn byte_len(&self, index: Int) -> Int64 {
        if index <= 0 || index >= self.slots.len() { return 0 as Int64; }
        match &self.slots.get(index).spec {
            Maybe.Some(s) => s.byte_len,
            Maybe.None => 0 as Int64,
        }
    }
}
