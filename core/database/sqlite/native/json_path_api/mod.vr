// =============================================================================
// core/database/sqlite/native/json_path_api/mod.vr
// =============================================================================
// JSON path syntax — used by JSON1 extension functions.
// Spec §16.5 — JSON1.
//
// Path grammar (simplified):
//   path ::= '$' segment*
//   segment ::= '.' name | '[' index ']'
//
// Examples:  $.foo, $[0], $.foo.bar[2], $.items[#-1] (last), $.**.bar (tree wildcard)
//
// =============================================================================

module core.database.sqlite.native.json_path_api;

public module segment;
public module path;
