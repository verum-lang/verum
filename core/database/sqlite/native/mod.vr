// =============================================================================
// core/database/sqlite/native/mod.vr
// =============================================================================
// Layer: 3 (Database — native SQLite implementation)
// Dependencies: core, collections, encoding, security, async, sync, mem, runtime
// Spec: internal/specs/sqlite-native.md
// Codename: loom
// =============================================================================
//
// Pure-Verum reimplementation of SQLite 3.x, layer-structured per
// sqlite-native.md §4:
//
//   L7  API           — Database, Statement, Transaction, Row (public surface)
//   L6  Session       — Connection<Mode>, schema cache, function registry
//   L5  SQL compiler  — lexer, parser, resolver, planner, codegen
//   L4  VDBE          — register-SSA bytecode virtual machine
//   L3  B-tree        — cursors, pages, balance, integrity
//   L2  Record        — varint/serial types/affinity/collation (uses stdlib)
//   L1  Pager         — actor-based, WAL + rollback journal, checkpointer
//   L0  VFS           — VfsProtocol abstraction, MemDbVfs, PosixVfs, Win32Vfs
//
// Orthogonal axes:
//
//   S   Supervision   — supervisor-tree over pager + checkpointer
//   O   Observability — core/tracing spans around every layer
//   V   Verification  — @verify contracts, SMT-discharged B-tree/WAL invariants
//   T   Testing       — DST, differential vs C-SQLite, fuzz (vcs/fuzz/sqlite/)
//
// # Stdlib reuse
//
// loom does NOT duplicate stdlib primitives. Specifically:
//
//   * `core.encoding.varint`         — SQLite varint encoding (Gap 4)
//   * `core.security.hash.crc32`     — WAL frame checksum (Gap 5)
//   * `core.collections.{btree,map}` — in-memory ordered maps for temp tables
//   * `core.mem.arena`               — CBGR arena for page cache
//   * `core.async.{nursery,channel}` — background tasks + actor mailboxes
//   * `core.runtime.supervisor`      — pager + checkpointer supervision
//   * `core.tracing`, `core.metrics` — observability
//   * `core.sys.*`                   — platform I/O, locking, durability
//
// # Status — v0.1 (2026-04-21)
//
// Scaffolded: L0 VfsProtocol, MemDbVfs; L2 Record header parse; L1 Pager
// skeleton. See README.md in this directory for detailed status table.
//
// =============================================================================

module core.database.sqlite.native;

// Layer 0: Virtual File System
public module l0_vfs;

// Layer 1: Pager (actor-based, CBGR page cache, WAL + rollback journal)
public module l1_pager;

// Layer 2: record / type affinity / collation
public module l2_record;

// Layer 3: B-tree (page layout, cursor, balance)
public module l3_btree;

// Layer 4: VDBE (opcodes, register file, interpreter)
public module l4_vdbe;

// Layer 5: SQL (lexer, AST, parser, planner, codegen)
public module l5_sql;

// Layer 6: Session (Connection, SchemaCache, PreparedStatement)
public module l6_session;

// Layer 7: public API (Database facade, DbError)
public module l7_api;

// Cross-cutting catalogues:
// - builtins: scalar / aggregate / window / JSON1 functions (§15)
// - pragmas:  PRAGMA registry, per-conn config, dispatch (§18)
// - vtabs:    virtual-table protocol + built-in modules (§16)
// - verify:   loom-side @verify contracts (§21)
public module builtins;
public module pragmas;
public module vtabs;
public module verify;
// - triggers/views/constraints: §17 schema-side feature catalogues
public module triggers;
public module views;
public module constraints;
// - ext: protocol-based Extensions API (§19) — user-defined fns + hooks
public module ext;
// - concurrency: pool / busy / snapshot / deadlock (§20)
public module concurrency;
// - testing: DST harness / differential / fuzz / coverage (§22)
public module testing;
// - opcode_catalog: Appendix C — full ~180-opcode taxonomy + Appendix D
//   error codes; complements l4_vdbe/opcode.vr without changing it.
public module opcode_catalog;
// - planner_cost: cost model + statistics for the L5 planner (§13.2-§13.4)
public module planner_cost;
// - subprograms: Gosub target registry for triggers / INSTEAD-OF views (§11.4)
public module subprograms;
// - optimizer: pre-emission peephole / jump-thread / DCE / const-fold passes (§11.5)
public module optimizer;
// - auth: Authorizer multi-hook composition + AuthAction taxonomy (§19.5)
public module auth;
// - distribution: version + features + build manifest (§23)
public module distribution;
// - backup: page-by-page online backup state machine + throttle policy (§22)
public module backup;
// - vacuum: full / incremental / auto-vacuum modes (§10.5 + PRAGMA auto_vacuum)
public module vacuum;
// - planner_passes: subquery flatten / decorrelate / magic-sets / window-plan (§13.5-§13.6)
public module planner_passes;
// - session: changeset / patchset / apply with ConflictResolver protocol (§22 CDC)
public module session;
// - index_variants: IndexKind taxonomy (Plain/Unique/Partial/Expression/Covering) (§13.3)
public module index_variants;
// - stmt_cache: per-Connection LRU prepared-statement cache (§11.1)
public module stmt_cache;
// - migrations: versioned schema migrations + DAG-toposort runner
public module migrations;
// - observability: counters / gauges / histograms + tracing spans (§22)
public module observability;
// - alter: online ALTER TABLE state machine (§17 schema evolution)
public module alter;
// - encryption: PageCipher + KeyDerivation + KeyRing protocols (§23 security)
public module encryption;
// - replication: WAL streaming primary→replica, role transitions, lag tracking (§22)
public module replication;
// - limits: per-Connection resource quotas with soft/strict enforcement (§22)
public module limits;
// - profiler: EXPLAIN ANALYZE-shaped per-opcode + per-plan-node stats (§22)
public module profiler;
// - export: schema_dump / data_dump / restore harness (§22)
public module export;
// - dst: deterministic simulation harness — seed/op/generator/fault/oracle/harness (§22.5)
public module dst;
// - fuzz: grammar / format / WAL mutators + corpus + crash bucket (§22.6)
public module fuzz;
// - differential: V vs C-SQLite case + result + comparator + oracle (§22.4)
public module differential;
// - test_vectors: codified Appendix E vectors (varint / record / WAL csum / btree)
public module test_vectors;
// - fts5: full-text search vtab — tokenizer/index/segment/merger/query/ranker (§16.2)
public module fts5;
// - rtree: N-dimensional R-tree spatial index (§16.3)
public module rtree;
// - statistics: sqlite_stat1/4 + selectivity estimator + ANALYZE driver (§13.2)
public module statistics;
// - integrity: integrity_check / quick_check / FK_check / cell_size_check (§10.7)
public module integrity;
