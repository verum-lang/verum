// PRAGMA legacy_alter_table handler.

module core.database.sqlite.native.legacy_alter_table_pragma.gate;

mount base.{Bool, Text};

public type LegacyAlterTableMode is
    | LaModern       // 0 — default; rename updates trigger/view bodies
    | LaLegacy       // 1 — old 3.24- substitution; references untouched
    ;

public fn default_mode() -> LegacyAlterTableMode { LaModern }

public fn from_pragma_value(n: Int) -> LegacyAlterTableMode {
    if n == 0 { LaModern } else { LaLegacy }
}

public fn to_pragma_value(m: &LegacyAlterTableMode) -> Int {
    match m { LaModern => 0, LaLegacy => 1 }
}

public fn mode_name(m: &LegacyAlterTableMode) -> Text {
    match m { LaModern => "modern".clone(), LaLegacy => "legacy".clone() }
}

public fn rewrites_dependent_objects(m: &LegacyAlterTableMode) -> Bool {
    match m { LaModern => true, LaLegacy => false }
}

// Behaviour switch invoked during ALTER TABLE RENAME.
public type RenameBehavior is
    | RbUpdateAllReferences      // modern: triggers, views, indexes get rewritten
    | RbNameOnly                  // legacy: just rename the table; refs may break
    ;

public fn behavior(m: &LegacyAlterTableMode) -> RenameBehavior {
    match m {
        LaModern => RbUpdateAllReferences,
        LaLegacy => RbNameOnly,
    }
}

public fn behavior_name(b: &RenameBehavior) -> Text {
    match b {
        RbUpdateAllReferences => "update_refs".clone(),
        RbNameOnly             => "name_only".clone(),
    }
}

// Whether dropping the table afterwards is required for safety in legacy.
public fn legacy_warning(m: &LegacyAlterTableMode) -> Bool {
    match m { LaLegacy => true, _ => false }
}
