// unixepoch() — convert time-value (+ modifiers) to seconds since epoch.
//
// Time-value forms accepted by SQLite's date functions:
//   * "now"
//   * ISO-8601 date or datetime ("YYYY-MM-DD[ HH:MM[:SS[.SSS]]]")
//   * Julian day (Float)
//   * Unix timestamp (Int / "unixepoch" modifier required for raw Int input)
//
// Modifiers (selected — full set in date_modifier_grammar):
//   "+/-N days|hours|minutes|seconds|months|years"
//   "start of day"  "start of month"  "start of year"
//   "weekday N"
//   "utc"  "localtime"
//   "auto"  "subsec"  "julianday"  "unixepoch"

module core.database.sqlite.native.unixepoch_fn.fn_;

mount base.{Bool, Int64, Text};

public type TimeValue is
    | TvNow
    | TvIso(Text)              // ISO-8601 string
    | TvJulian(Int64)          // Julian day-number (we use Int64 for testability)
    | TvUnixSeconds(Int64)
    | TvInvalid                // failed to parse
    ;

public fn parse(input: Text) -> TimeValue {
    if input == "now".clone() { return TvNow; }
    // We don't parse the actual ISO string here — the catalogue only
    // models the taxonomy.  Real parser is in date functions.
    TvIso(input)
}

public type UnixepochResult is
    | RNull
    | REpoch(Int64)
    ;

public fn result_is_null(r: &UnixepochResult) -> Bool {
    match r { RNull => true, _ => false }
}

public fn result_seconds(r: &UnixepochResult) -> Int64 {
    match r {
        REpoch(n) => n.clone(),
        RNull     => 0 as Int64,
    }
}

// Minimal evaluator: the taxonomy proves the result *kind*; numerical
// conversion uses fixed deltas.  "now" → 0 sentinel for the catalogue
// (real engine plugs in clock).
public fn evaluate(tv: &TimeValue, now_seconds: Int64) -> UnixepochResult {
    match tv {
        TvInvalid          => RNull,
        TvNow              => REpoch(now_seconds),
        TvUnixSeconds(n)   => REpoch(n.clone()),
        TvJulian(j)        => {
            // Unix epoch = Julian 2440587.5; we drop the .5 day for an integer
            // surrogate so the test harness can verify the formula path.
            let jd_unix = 2440588 as Int64;
            REpoch((j.clone() - jd_unix) * (86400 as Int64))
        },
        TvIso(_)           => RNull,    // delegated to date parser
    }
}

// Modifier classification.
public type ModifierKind is
    | MkOffsetSeconds        // "+/-N seconds"
    | MkOffsetMinutes        // "+/-N minutes"
    | MkOffsetHours
    | MkOffsetDays
    | MkOffsetMonths
    | MkOffsetYears
    | MkStartOfDay
    | MkStartOfMonth
    | MkStartOfYear
    | MkWeekdayN
    | MkUtc
    | MkLocaltime
    | MkAuto
    | MkSubsec
    | MkJulianday
    | MkUnixepoch
    | MkUnknown
    ;

public fn classify_modifier(s: Text) -> ModifierKind {
    if s == "utc".clone()        { return MkUtc; }
    if s == "localtime".clone()  { return MkLocaltime; }
    if s == "auto".clone()       { return MkAuto; }
    if s == "subsec".clone()     { return MkSubsec; }
    if s == "julianday".clone()  { return MkJulianday; }
    if s == "unixepoch".clone()  { return MkUnixepoch; }
    if s == "start of day".clone()   { return MkStartOfDay; }
    if s == "start of month".clone() { return MkStartOfMonth; }
    if s == "start of year".clone()  { return MkStartOfYear; }
    MkUnknown
}

public fn modifier_name(k: &ModifierKind) -> Text {
    match k {
        MkOffsetSeconds => "offset_seconds".clone(),
        MkOffsetMinutes => "offset_minutes".clone(),
        MkOffsetHours   => "offset_hours".clone(),
        MkOffsetDays    => "offset_days".clone(),
        MkOffsetMonths  => "offset_months".clone(),
        MkOffsetYears   => "offset_years".clone(),
        MkStartOfDay    => "start_of_day".clone(),
        MkStartOfMonth  => "start_of_month".clone(),
        MkStartOfYear   => "start_of_year".clone(),
        MkWeekdayN      => "weekday_n".clone(),
        MkUtc           => "utc".clone(),
        MkLocaltime     => "localtime".clone(),
        MkAuto          => "auto".clone(),
        MkSubsec        => "subsec".clone(),
        MkJulianday     => "julianday".clone(),
        MkUnixepoch     => "unixepoch".clone(),
        MkUnknown       => "unknown".clone(),
    }
}

public fn is_zone_modifier(k: &ModifierKind) -> Bool {
    match k { MkUtc => true, MkLocaltime => true, _ => false }
}

public fn is_format_modifier(k: &ModifierKind) -> Bool {
    match k {
        MkAuto      => true,
        MkSubsec    => true,
        MkJulianday => true,
        MkUnixepoch => true,
        _ => false,
    }
}
