// =============================================================================
// auth/decision.vr — combine multiple AuthDecisions
// =============================================================================
// Spec: sqlite-native.md §19.5
//
// SQLite returns one of three decisions per action:
//   * Allow     — proceed (compile + execute)
//   * Deny      — surface SQLITE_AUTH (compile fails)
//   * Ignore    — compile, but treat the value as NULL (e.g. for
//                  read-column → returns NULL instead of the cell)
//
// When multiple authorizer hooks are subscribed, we combine their
// answers by precedence: Deny > Ignore > Allow. This matches
// SQLite's "most restrictive wins" rule.
// =============================================================================

module core.database.sqlite.native.auth.decision;

mount core.*;
mount base.{Bool};
mount core.database.sqlite.native.ext.hooks.{
    AuthDecision, AdAllow, AdDeny, AdIgnore,
};

// Numeric precedence: lower wins (= more restrictive).
fn rank(d: &AuthDecision) -> Int {
    match d {
        AdDeny   => 0,
        AdIgnore => 1,
        AdAllow  => 2,
    }
}

/// Combine two decisions. Most-restrictive wins.
public fn combine(a: AuthDecision, b: AuthDecision) -> AuthDecision {
    if rank(&a) <= rank(&b) { a } else { b }
}

/// Decision name for tracing / EXPLAIN.
public fn name(d: &AuthDecision) -> base.Text {
    match d {
        AdAllow  => "ALLOW".clone(),
        AdDeny   => "DENY".clone(),
        AdIgnore => "IGNORE".clone(),
    }
}

/// True if the decision allows compilation (Allow OR Ignore).
public fn permits_compile(d: &AuthDecision) -> Bool {
    match d {
        AdAllow  => true,
        AdIgnore => true,
        AdDeny   => false,
    }
}

/// True if the decision substitutes NULL at runtime (Ignore only).
public fn forces_null(d: &AuthDecision) -> Bool {
    match d { AdIgnore => true, _ => false }
}
