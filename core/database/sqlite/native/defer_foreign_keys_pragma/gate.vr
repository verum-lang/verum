// PRAGMA defer_foreign_keys handler.

module core.database.sqlite.native.defer_foreign_keys_pragma.gate;

mount base.{Bool, Text};

public type DeferForeignKeysMode is
    | DfOff       // default
    | DfOn        // all FK checks deferred to COMMIT
    ;

public fn default_mode() -> DeferForeignKeysMode { DfOff }

public fn from_pragma_value(n: Int) -> DeferForeignKeysMode {
    if n == 0 { DfOff } else { DfOn }
}

public fn to_pragma_value(m: &DeferForeignKeysMode) -> Int {
    match m { DfOff => 0, DfOn => 1 }
}

public fn mode_name(m: &DeferForeignKeysMode) -> Text {
    match m { DfOff => "off".clone(), DfOn => "on".clone() }
}

// When does the engine actually validate a constraint?
public type CheckTime is
    | CtImmediate     // FK violation surfaces from the row-modifying stmt
    | CtAtCommit      // FK violation surfaces from COMMIT only
    ;

// Decision: depends on master FK gate and per-constraint deferral spec.
public fn check_time_for(
    fk_enforce_on: Bool,
    pragma_defer: &DeferForeignKeysMode,
    constraint_is_deferred: Bool,
) -> CheckTime {
    // FK enforcement disabled? No checks happen at all; immediate is a
    // harmless default.
    if !fk_enforce_on { return CtImmediate; }
    if constraint_is_deferred { return CtAtCommit; }
    match pragma_defer {
        DfOn  => CtAtCommit,
        DfOff => CtImmediate,
    }
}

public fn check_name(c: &CheckTime) -> Text {
    match c {
        CtImmediate => "immediate".clone(),
        CtAtCommit  => "at_commit".clone(),
    }
}

public fn is_deferred(c: &CheckTime) -> Bool {
    match c { CtAtCommit => true, _ => false }
}

// PRAGMA value resets to OFF at end-of-txn.
public fn after_txn_end(_m: &DeferForeignKeysMode) -> DeferForeignKeysMode { DfOff }
