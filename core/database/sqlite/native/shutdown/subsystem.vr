// =============================================================================
// shutdown/subsystem.vr — ShutdownSubsystem taxonomy
// =============================================================================
// Spec: SQLite C API
//
// Five subsystems initialised by sqlite3_initialize, torn down by
// sqlite3_shutdown in reverse order.
// =============================================================================

module core.database.sqlite.native.shutdown.subsystem;

mount core.*;
mount base.{Text, Bool};
mount collections.List;

public type ShutdownSubsystem is
      SsMutex
    | SsMem
    | SsPcache
    | SsPage
    | SsHeap;

public fn subsystem_name(s: &ShutdownSubsystem) -> Text {
    match s {
        SsMutex   => "mutex".clone(),
        SsMem     => "mem".clone(),
        SsPcache  => "pcache".clone(),
        SsPage    => "page".clone(),
        SsHeap    => "heap".clone(),
    }
}

/// Initialisation order — sqlite3_initialize walks this list low → high.
public fn init_order() -> List<ShutdownSubsystem> {
    let mut out: List<ShutdownSubsystem> = List.new();
    out.push(SsMutex);     // 1. mutexes first — every other subsystem needs them
    out.push(SsMem);       // 2. memory allocator
    out.push(SsPage);      // 3. page allocator (depends on mem)
    out.push(SsPcache);    // 4. page cache (depends on page)
    out.push(SsHeap);      // 5. heap state (depends on mem + page)
    out
}

/// sqlite3_shutdown walks the same list in REVERSE.
public fn shutdown_order() -> List<ShutdownSubsystem> {
    let init = init_order();
    let mut out: List<ShutdownSubsystem> = List.new();
    let mut i: Int = init.len() - 1;
    while i >= 0 {
        out.push(clone_subsystem(&init[i]));
        i = i - 1;
    }
    out
}

fn clone_subsystem(s: &ShutdownSubsystem) -> ShutdownSubsystem {
    match s {
        SsMutex   => SsMutex,
        SsMem     => SsMem,
        SsPcache  => SsPcache,
        SsPage    => SsPage,
        SsHeap    => SsHeap,
    }
}

/// True iff subsystem `before` must be initialised strictly before
/// subsystem `after` (i.e. `after` depends on `before`).
public fn precedes(before: &ShutdownSubsystem, after: &ShutdownSubsystem) -> Bool {
    let order = init_order();
    let mut idx_before: Int = -1;
    let mut idx_after: Int = -1;
    let mut i: Int = 0;
    while i < order.len() {
        if subsystem_name(&order[i]) == subsystem_name(before) { idx_before = i; }
        if subsystem_name(&order[i]) == subsystem_name(after)  { idx_after = i; }
        i = i + 1;
    }
    idx_before >= 0 && idx_after >= 0 && idx_before < idx_after
}
