// Varint byte-length probe + range boundaries.

module core.database.sqlite.native.varint_encode_api.lengths;

mount base.{Bool, Int64};

// Maximum value storable in exactly `n` bytes (where n in 1..9).
public fn max_value_for(n: Int) -> Int64 {
    // 7-bit per byte for bytes 1..8; byte 9 holds 8 bits → 64 bits total.
    if n <= 0 { return 0 as Int64; }
    if n >= 9 { return 0x7FFFFFFFFFFFFFFF_i64; }   // cap at Int64 max
    // 2^(7*n) - 1
    let mut result: Int64 = 1 as Int64;
    let mut i: Int = 0;
    while i < 7 * n {
        result = result * 2_i64;
        i = i + 1;
    }
    result - 1_i64
}

// Minimum byte count needed to encode `v` (non-negative Int64).
public fn encoded_length(v: Int64) -> Int {
    if v < 0_i64 { return 9; }     // large 2's-complement → 9 bytes
    if v <= max_value_for(1) { return 1; }
    if v <= max_value_for(2) { return 2; }
    if v <= max_value_for(3) { return 3; }
    if v <= max_value_for(4) { return 4; }
    if v <= max_value_for(5) { return 5; }
    if v <= max_value_for(6) { return 6; }
    if v <= max_value_for(7) { return 7; }
    if v <= max_value_for(8) { return 8; }
    9
}

// Decode-length probe: given the lead byte, how many bytes the varint spans.
public fn decode_length_from_lead(b0: u8) -> Int {
    // For SQLite varint, the 9-byte form has lead bits 0xFF; other lengths
    // are inferred by counting continuation bits in the first 8 bytes.
    // Simplified heuristic: if high bit is clear, length = 1; otherwise
    // probe the next bytes (caller supplies them in a fuller impl).
    if (b0 & (0x80 as u8)) == (0 as u8) { return 1; }
    // Need more bytes — returning -1 to signal "need more context".
    -1
}

// Constants
public fn max_length() -> Int { 9 }
public fn min_length() -> Int { 1 }

// Special case: varint 0 occupies 1 byte.
public fn length_of_zero() -> Int { 1 }
