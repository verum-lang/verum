// =============================================================================
// core/database/sqlite/native/varint_encode_api/mod.vr
// =============================================================================
// SQLite record-format varint — high-bit = continuation, 7 bits per byte for
// the first 8 bytes and 8 bits for the 9th.
// Spec §15.3 — varint encoding.
//
// Lengths:
//   v <= 2^7-1      — 1 byte
//   v <= 2^14-1     — 2 bytes
//   v <= 2^21-1     — 3 bytes
//   v <= 2^28-1     — 4 bytes
//   v <= 2^35-1     — 5 bytes
//   v <= 2^42-1     — 6 bytes
//   v <= 2^49-1     — 7 bytes
//   v <= 2^56-1     — 8 bytes
//   v <= 2^64-1     — 9 bytes
// =============================================================================

module core.database.sqlite.native.varint_encode_api;

public module lengths;
