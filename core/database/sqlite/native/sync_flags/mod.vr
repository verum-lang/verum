// =============================================================================
// core/database/sqlite/native/sync_flags/mod.vr
// =============================================================================
// Layer: 0 (façade — SQLITE_SYNC_* constants)
// Spec: SQLite C API — xSync flags
//
//   SQLITE_SYNC_NORMAL   = 0x00002
//   SQLITE_SYNC_FULL     = 0x00003
//   SQLITE_SYNC_DATAONLY = 0x00010
//
// Flags are OR-ed together; NORMAL and FULL are mutually exclusive
// (FULL is stricter); DATAONLY is orthogonal (skip metadata flush).
// =============================================================================

module core.database.sqlite.native.sync_flags;

mount core.*;
mount base.{Bool, Text};

public const SQLITE_SYNC_NORMAL: Int   = 0x00002;
public const SQLITE_SYNC_FULL: Int     = 0x00003;
public const SQLITE_SYNC_DATAONLY: Int = 0x00010;

public type FsyncMode is
      SmNormal
    | SmFull;

public fn mode_numeric(m: &FsyncMode) -> Int {
    match m {
        SmNormal => SQLITE_SYNC_NORMAL,
        SmFull   => SQLITE_SYNC_FULL,
    }
}

public fn mode_name(m: &FsyncMode) -> Text {
    match m {
        SmNormal => "NORMAL".clone(),
        SmFull   => "FULL".clone(),
    }
}

public fn is_full(m: &FsyncMode) -> Bool {
    match m {
        SmFull => true,
        _ => false,
    }
}

public type SyncFlagsPragma is {
    mode: FsyncMode,
    data_only: Bool,
}

public fn new_flags(mode: FsyncMode, data_only: Bool) -> SyncFlagsPragma {
    SyncFlagsPragma { mode: mode, data_only: data_only }
}

public fn flags_numeric(f: &SyncFlagsPragma) -> Int {
    let mut v = mode_numeric(&f.mode);
    if f.data_only { v = v | SQLITE_SYNC_DATAONLY; }
    v
}

public fn from_numeric(n: Int) -> SyncFlagsPragma {
    let mode = if (n & SQLITE_SYNC_FULL) == SQLITE_SYNC_FULL {
        SmFull
    } else {
        SmNormal
    };
    SyncFlagsPragma {
        mode: mode,
        data_only: (n & SQLITE_SYNC_DATAONLY) != 0,
    }
}
