// =============================================================================
// dbstat/series.vr — generate_series virtual table
// =============================================================================
// Spec: sqlite-native.md §16.4
//
// `generate_series(start, stop[, step])` produces one row per integer
// in `[start, stop]` advancing by `step` (default 1). Used as a
// table-valued function:
//
//   SELECT value FROM generate_series(1, 5);
//
// Pure-Verum state machine: emit rows on demand, no allocation up
// front. Mirrors SQLite's series.c implementation.
// =============================================================================

module core.database.sqlite.native.dbstat.series;

mount core.*;
mount base.{Bool, Maybe};
mount collections.List;

// -----------------------------------------------------------------------------
// SeriesParams
// -----------------------------------------------------------------------------

public type SeriesParams is {
    start: Int64,
    stop: Int64,
    step: Int64,
}

public fn series_params(start: Int64, stop: Int64, step: Int64) -> SeriesParams {
    SeriesParams { start: start, stop: stop, step: step }
}

public fn series_default_step() -> Int64 { 1 as Int64 }

// -----------------------------------------------------------------------------
// SeriesCursor — emits one Int64 at a time
// -----------------------------------------------------------------------------

public type SeriesCursor is {
    params: SeriesParams,
    /// Current value. Equal to `start` initially.
    current: Int64,
    eof: Bool,
}

public fn cursor_open(params: SeriesParams) -> SeriesCursor {
    let step = if params.step == 0_i64 { 1 as Int64 } else { params.step };
    let p = SeriesParams { start: params.start, stop: params.stop, step: step };
    let initial = p.start;
    let eof = if step > 0_i64 { initial > p.stop } else { initial < p.stop };
    SeriesCursor { params: p, current: initial, eof: eof }
}

implement SeriesCursor {
    public fn at_eof(&self) -> Bool { self.eof }

    public fn current_value(&self) -> Int64 { self.current }

    pub fn next(&mut self) {
        if self.eof { return; }
        let n = self.current + self.params.step;
        self.current = n;
        if self.params.step > 0_i64 {
            if n > self.params.stop { self.eof = true; }
        } else {
            if n < self.params.stop { self.eof = true; }
        }
    }

    /// Drain the cursor into a List<Int64> — bounded by `cap` to
    /// avoid runaway when stop=MAX_INT.
    pub fn collect(self_in: SeriesCursor, cap: Int) -> List<Int64> {
        let mut s = self_in;
        let mut out: List<Int64> = List.new();
        let mut i: Int = 0;
        while !s.at_eof() && i < cap {
            out.push(s.current_value());
            s.next();
            i = i + 1;
        }
        out
    }
}

// -----------------------------------------------------------------------------
// Estimated row count — used by the planner cost model
// -----------------------------------------------------------------------------

public fn estimate_row_count(p: &SeriesParams) -> Int64 {
    // Int.MIN-safe magnitudes. Series params arrive from user SQL —
    // `step = Int64.MIN` would make `-step` overflow back to MIN
    // (still negative), and the `span / abs_step` divisor goes
    // negative, producing a nonsense planner estimate. Compute
    // magnitudes via UInt64 then clamp the result back.
    let step = if p.step == 0_i64 { 1_i64 } else { p.step };
    let abs_step_u: UInt64 = if step < 0_i64 {
        (((!step) as UInt64) + 1_u64)
    } else {
        step as UInt64
    };
    let span_u: UInt64 = if p.stop > p.start {
        ((p.stop - p.start) as UInt64)
    } else {
        ((p.start - p.stop) as UInt64)
    };
    if abs_step_u == 0_u64 { return 1_i64; }
    let est = (span_u / abs_step_u) + 1_u64;
    // Clamp to Int64.MAX in case the unsigned estimate doesn't fit.
    if est > 9_223_372_036_854_775_807_u64 {
        9_223_372_036_854_775_807_i64
    } else {
        est as Int64
    }
}
