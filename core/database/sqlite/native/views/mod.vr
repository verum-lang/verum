// View catalogue. Views in SQLite are CREATE-time-frozen SELECTs;
// the planner inlines them at every reference. INSTEAD-OF triggers
// on a view turn it writable.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.database.sqlite.native.views;

public module spec;
public module store;
