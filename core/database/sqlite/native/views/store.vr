// =============================================================================
// views/store.vr — per-Connection view storage
// =============================================================================
// Layer: 6
// Spec: sqlite-native.md §17.2
// =============================================================================

module core.database.sqlite.native.views.store;

mount core.*;
mount base.{Text, Maybe, Bool, Result, Ok, Err};
mount collections.List;
mount core.database.sqlite.native.views.spec.{ViewDef};

public type ViewStoreError is VseDuplicateName | VseNotFound;

implement Display for ViewStoreError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        let s = match self {
            VseDuplicateName => "sqlite view: duplicate name",
            VseNotFound      => "sqlite view: not found",
        };
        f.write_str(s)
    }
}

implement Debug for ViewStoreError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        let s = match self {
            VseDuplicateName => "VseDuplicateName",
            VseNotFound      => "VseNotFound",
        };
        f.write_str(s)
    }
}

implement Eq for ViewStoreError {
    fn eq(&self, other: &ViewStoreError) -> Bool {
        match (self, other) {
            (VseDuplicateName, VseDuplicateName) => true,
            (VseNotFound,      VseNotFound)      => true,
            _ => false,
        }
    }
}

public type ViewStore is { views: List<ViewDef> };

public fn view_store_new() -> ViewStore { ViewStore { views: List.new() } }

implement ViewStore {
    public fn count(&self) -> Int { self.views.len() }

    public fn add(&mut self, def: ViewDef, if_not_exists: Bool) -> Result<(), ViewStoreError> {
        if self.lookup_idx(&def.name).is_some() {
            if if_not_exists { return Ok(()); }
            return Err(VseDuplicateName);
        }
        self.views.push(clone_def(&def));
        Ok(())
    }

    public fn drop_named(&mut self, name: &Text) -> Bool {
        match self.lookup_idx(name) {
            Some(i) => {
                let mut new_views: List<ViewDef> = List.new();
                let mut k: Int = 0;
                while k < self.views.len() {
                    if k != i { new_views.push(clone_def(&self.views[k])); }
                    k = k + 1;
                }
                self.views = new_views;
                true
            }
            None => false,
        }
    }

    public fn lookup(&self, name: &Text) -> Maybe<ViewDef> {
        match self.lookup_idx(name) {
            Some(i) => Some(clone_def(&self.views[i])),
            None    => None,
        }
    }

    fn lookup_idx(&self, name: &Text) -> Maybe<Int> {
        let mut i: Int = 0;
        while i < self.views.len() {
            if self.views[i].name == name { return Some(i); }
            i = i + 1;
        }
        None
    }

    public fn names(&self) -> List<Text> {
        let mut out: List<Text> = List.new();
        let mut i: Int = 0;
        while i < self.views.len() {
            out.push(self.views[i].name.clone());
            i = i + 1;
        }
        out
    }
}

fn clone_def(d: &ViewDef) -> ViewDef {
    let mut aliases: List<Text> = List.new();
    let mut i: Int = 0;
    while i < d.column_aliases.len() {
        aliases.push(d.column_aliases[i].clone());
        i = i + 1;
    }
    ViewDef {
        name: d.name.clone(),
        schema_name: d.schema_name.clone(),
        column_aliases: aliases,
        select_sql: d.select_sql.clone(),
        is_temp: d.is_temp,
    }
}
