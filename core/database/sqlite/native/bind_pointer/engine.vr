// =============================================================================
// bind_pointer/engine.vr — per-slot storage + type-gated fetch
// =============================================================================
// Spec: SQLite C API
//
// An engine is a flat list indexed by 1-based parameter position
// (slot 0 is not valid, to match sqlite3_bind_* convention).
// =============================================================================

module core.database.sqlite.native.bind_pointer.engine;

mount core.*;
mount base.{Bool};
mount collections.List;
mount core.database.sqlite.native.bind_pointer.tag.{
    PointerTag, new_tag,
};
mount core.database.sqlite.native.bind_pointer.handle.{
    TypedPointer, empty_pointer, is_empty, fetch_if_match,
};

public type BindPointerEngine is {
    slots: List<TypedPointer>,
}

public fn new_engine(n_params: Int) -> BindPointerEngine {
    let mut slots: List<TypedPointer> = List.new();
    let mut i: Int = 0;
    while i <= n_params { slots.push(empty_pointer()); i = i + 1; }
    BindPointerEngine { slots: slots }
}

implement BindPointerEngine {
    pub fn sqlite3_bind_pointer(&mut self, index: Int, ptr: TypedPointer) -> Bool {
        if index <= 0 || index >= self.slots.len() { return false; }
        self.slots.get_mut(index).tag = ptr.tag;
        self.slots.get_mut(index).handle = ptr.handle;
        self.slots.get_mut(index).has_deleter = ptr.has_deleter;
        true
    }

    pub fn sqlite3_value_pointer(&self, index: Int, want: &PointerTag) -> Int64 {
        if index <= 0 || index >= self.slots.len() { return 0 as Int64; }
        fetch_if_match(self.slots.get(index), want)
    }

    pub fn clear(&mut self, index: Int) -> Bool {
        if index <= 0 || index >= self.slots.len() { return false; }
        self.slots.get_mut(index).tag = new_tag("".clone());
        self.slots.get_mut(index).handle = 0 as Int64;
        self.slots.get_mut(index).has_deleter = false;
        true
    }

    pub fn slot_count(&self) -> Int { self.slots.len() - 1 }
}
