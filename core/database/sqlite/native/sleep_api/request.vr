// =============================================================================
// sleep_api/request.vr — SleepRequest
// =============================================================================
// Spec: SQLite C API
// =============================================================================

module core.database.sqlite.native.sleep_api.request;

mount core.*;
mount base.{Bool};

public type SleepRequest is {
    milliseconds: Int,
}

public fn new_request(ms: Int) -> SleepRequest {
    SleepRequest { milliseconds: ms }
}

public fn is_noop(r: &SleepRequest) -> Bool {
    r.milliseconds <= 0
}

public fn to_ns(r: &SleepRequest) -> Int64 {
    if r.milliseconds <= 0 { return 0 as Int64; }
    (r.milliseconds as Int64) * 1_000_000_i64
}
