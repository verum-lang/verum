// =============================================================================
// vtabs/protocol.vr — VirtualTable + VirtualCursor protocols
// =============================================================================
// Layer: 6
// Spec: sqlite-native.md §16.1
//
// The two protocols every loom virtual table must implement, plus
// a small `VtabError` taxonomy mirroring SQLite's vtab error codes.
//
// We deliberately avoid `async fn` here in the v0.1 protocol — the
// VDBE interpreter is currently synchronous, and async cursors will
// arrive together with the planner-driven streaming push (§13.4).
// Keeping the protocol synchronous lets us land dbstat /
// generate_series today without dragging the async runtime in.
// =============================================================================

module core.database.sqlite.native.vtabs.protocol;

mount core.*;
mount base.{Text, Result, Maybe};
mount collections.List;
mount core.database.sqlite.native.l4_vdbe.register.{Register, RNull};

// -----------------------------------------------------------------------------
// VtabError
// -----------------------------------------------------------------------------

public type VtabError is
      VtabUnsupported(Text)
    | VtabConstraint(Text)
    | VtabSchemaInvalid(Text)
    | VtabIo(Text)
    | VtabInternal(Text);

// -----------------------------------------------------------------------------
// Schema announced by a vtab implementation
// -----------------------------------------------------------------------------

public type VtabColumn is {
    name: Text,
    /// SQLite affinity sigil — "INTEGER", "TEXT", "REAL", "BLOB", "NUMERIC",
    /// or "" for default (empty → NUMERIC).
    affinity: Text,
    is_hidden: Bool,
};

public type VtabSchema is {
    /// "CREATE TABLE x(...)" string the planner uses for column resolution.
    create_sql: Text,
    columns: List<VtabColumn>,
};

// -----------------------------------------------------------------------------
// VirtualCursor protocol
// -----------------------------------------------------------------------------

public type VirtualCursor is protocol {
    /// Begin a scan with the planner-supplied filter.
    fn filter(
        &mut self,
        index_num: Int,
        index_str: &Text,
        args: &List<Register>,
    ) -> Result<(), VtabError>;

    /// Advance one row.
    fn next_row(&mut self) -> Result<(), VtabError>;

    /// Cursor exhausted?
    fn eof(&self) -> Bool;

    /// Read column `idx` (0-based).
    fn column(&self, idx: Int) -> Register;

    /// SQLite-compatible 64-bit rowid for the current row.
    fn rowid(&self) -> Int64;
};

// -----------------------------------------------------------------------------
// VirtualTable protocol
// -----------------------------------------------------------------------------

public type VirtualTable is protocol {
    type Cursor: VirtualCursor;

    /// Called when the table is first CREATEd (CREATE VIRTUAL TABLE x USING m(...))
    fn create(&self, args: &List<Text>) -> Result<VtabSchema, VtabError>;

    /// Called when a previously-created vtab is opened.
    fn connect(&self, args: &List<Text>) -> Result<VtabSchema, VtabError>;

    /// Planner asks: "given these column constraints, propose an index."
    fn best_index(&self, info: &mut IndexInfo) -> Result<(), VtabError>;

    /// Open a fresh cursor.
    fn open_cursor(&self) -> Result<Self.Cursor, VtabError>;

    /// Read-only by default — writable subclass overrides.
    fn is_writable(&self) -> Bool { false }

    /// `args[0] == RNull`            → INSERT (returns new rowid)
    /// `args[0] != RNull, len == 2`  → DELETE
    /// `args[0] != RNull, len > 2`   → UPDATE
    fn update(&mut self, args: &List<Register>) -> Result<Int64, VtabError> {
        let _ = args;
        Err(VtabUnsupported("vtab is read-only".clone()))
    }

    /// Drop a CREATE VIRTUAL TABLE backing.
    fn destroy(&mut self) -> Result<(), VtabError> {
        Ok(())
    }
};

// -----------------------------------------------------------------------------
// IndexInfo — passed to `best_index`
// -----------------------------------------------------------------------------
//
// Mirrors `sqlite3_index_info`. The vtab returns:
//   * which constraint slots it can satisfy and at what arg slot
//   * whether the cursor will return rows in the requested order
//     (skipping a sort in the planner)
//   * a synthetic `index_num` + `index_str` carried back to `filter`
//
// The planner reads `estimated_cost` to pick between candidate
// access plans (vtab vs. brute-force scan).
// =============================================================================

public type ConstraintOp is
      OpEq | OpGt | OpLe | OpLt | OpGe | OpMatch | OpLike | OpGlob
    | OpRegexp | OpIsNotNull | OpIsNull | OpIsNotEqual;

public type Constraint is {
    column: Int,
    op: ConstraintOp,
    usable: Bool,
};

public type ConstraintUsage is {
    arg_slot: Int,        // 0 = unused, 1+ = argv slot
    omit: Bool,           // true = vtab handles, planner skips
};

public type OrderBy is {
    column: Int,
    desc: Bool,
};

public type IndexInfo is {
    constraints: List<Constraint>,
    order_by: List<OrderBy>,
    constraint_usage: List<ConstraintUsage>,
    index_num: Int,
    index_str: Text,
    needs_to_free: Bool,
    order_consumed: Bool,
    estimated_cost: Float64,
    estimated_rows: Int64,
};

public fn index_info_new() -> IndexInfo {
    IndexInfo {
        constraints: List.new(),
        order_by: List.new(),
        constraint_usage: List.new(),
        index_num: 0,
        index_str: Text.new(),
        needs_to_free: false,
        order_consumed: false,
        estimated_cost: 1000000.0,
        estimated_rows: 25 as Int64,
    }
}
