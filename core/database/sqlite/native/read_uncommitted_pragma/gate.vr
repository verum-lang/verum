// PRAGMA read_uncommitted handler.

module core.database.sqlite.native.read_uncommitted_pragma.gate;

mount base.{Bool, Text};

public type ReadUncommittedMode is
    | RuOff      // 0 — default; READ COMMITTED isolation
    | RuOn       // 1 — see uncommitted writes (shared-cache only)
    ;

public fn default_mode() -> ReadUncommittedMode { RuOff }

public fn from_pragma_value(n: Int) -> ReadUncommittedMode {
    if n == 0 { RuOff } else { RuOn }
}

public fn to_pragma_value(m: &ReadUncommittedMode) -> Int {
    match m { RuOff => 0, RuOn => 1 }
}

public fn mode_name(m: &ReadUncommittedMode) -> Text {
    match m { RuOff => "off".clone(), RuOn => "on".clone() }
}

// Effective behaviour depends on cache + journal mode.
public type ReadUncommittedEffect is
    | EfReadCommitted        // RuOff or non-shared-cache
    | EfReadUncommitted       // RuOn + shared-cache + non-WAL
    | EfIgnoredInWal          // RuOn + WAL mode (snapshot isolation always)
    ;

public fn resolve_effect(m: &ReadUncommittedMode, in_shared_cache: Bool, in_wal: Bool) -> ReadUncommittedEffect {
    if !in_shared_cache { return EfReadCommitted; }
    match m {
        RuOff => EfReadCommitted,
        RuOn  => if in_wal { EfIgnoredInWal } else { EfReadUncommitted },
    }
}

public fn effect_name(e: &ReadUncommittedEffect) -> Text {
    match e {
        EfReadCommitted    => "read_committed".clone(),
        EfReadUncommitted  => "read_uncommitted".clone(),
        EfIgnoredInWal     => "ignored_in_wal".clone(),
    }
}

public fn allows_dirty_reads(e: &ReadUncommittedEffect) -> Bool {
    match e { EfReadUncommitted => true, _ => false }
}

// Risk classification — dirty reads can lead to phantom rows.
public fn is_risky(e: &ReadUncommittedEffect) -> Bool {
    allows_dirty_reads(e)
}
