// =============================================================================
// core/database/sqlite/native/result_codes/mod.vr
// =============================================================================
// Layer: 7 (façade — constant families not in errors/code)
// Spec: Appendix D + sqlite3.h
//
// errors/code.vr covers the primary SQLITE_* error codes.  This
// catalogue collects the other integer-constant families SQLite
// exposes:
//
//   * SQLITE_CHECKPOINT_*
//   * SQLITE_VTAB_*
//   * SQLITE_CHANGESET_*
//   * SQLITE_DETERMINISTIC / SQLITE_DIRECTONLY / SQLITE_INNOCUOUS
//   * SQLITE_OPEN_EXRESCODE
//   * SQLITE_PROTOCOL (rank)
//
// Submodules:
//   * `checkpoint`  — sqlite3_wal_checkpoint_v2 modes
//   * `vtab`        — SQLITE_VTAB_* constraint/constraint-usage flags
//   * `changeset`   — SQLITE_CHANGESET_* conflict codes
//   * `function`    — SQLITE_DETERMINISTIC / DIRECTONLY / INNOCUOUS (func flags)
// =============================================================================

module core.database.sqlite.native.result_codes;

public module checkpoint;
public module vtab;
public module changeset;
public module function;
