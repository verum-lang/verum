// URI parameter decoders.

module core.database.sqlite.native.uri_param_decode_api.decoder;

mount base.{Bool, Int64, Text, Maybe};

// ASCII upper-case fold.
fn to_upper(b: u8) -> u8 {
    if b >= 0x61 as u8 && b <= 0x7A as u8 {
        return (b - 0x20 as u8) as u8;
    }
    b
}

fn eq_ci(a: &Text, b: &Text) -> Bool {
    let ab = a.as_bytes();
    let bb = b.as_bytes();
    if ab.len() != bb.len() { return false; }
    let mut i: Int = 0;
    while i < ab.len() {
        if to_upper(ab[i]) != to_upper(bb[i]) { return false; }
        i = i + 1;
    }
    true
}

// sqlite3_uri_boolean — case-insensitive yes/no/on/off/true/false/1/0.
public fn parse_boolean(raw: &Text, default_when_missing: Bool) -> Bool {
    if raw.len() == 0 { return default_when_missing; }
    if eq_ci(raw, &"1".clone())     { return true; }
    if eq_ci(raw, &"yes".clone())   { return true; }
    if eq_ci(raw, &"on".clone())    { return true; }
    if eq_ci(raw, &"true".clone())  { return true; }
    if eq_ci(raw, &"0".clone())     { return false; }
    if eq_ci(raw, &"no".clone())    { return false; }
    if eq_ci(raw, &"off".clone())   { return false; }
    if eq_ci(raw, &"false".clone()) { return false; }
    default_when_missing
}

// Recognised boolean keyword set.
public fn known_boolean_keyword_count() -> Int { 8 }

fn is_digit(b: u8) -> Bool {
    b >= 0x30 as u8 && b <= 0x39 as u8
}

// sqlite3_uri_int64 — strict integer parse (digits only after optional sign).
public fn parse_int64(raw: &Text, default_when_invalid: Int64) -> Int64 {
    let bs = raw.as_bytes();
    if bs.len() == 0 { return default_when_invalid; }
    let mut i: Int = 0;
    let mut negative = false;
    if bs[0] == (0x2D as u8) { negative = true; i = 1; }
    else if bs[0] == (0x2B as u8) { i = 1; }
    if i >= bs.len() { return default_when_invalid; }
    let mut acc: Int64 = 0 as Int64;
    let mut had_digit = false;
    while i < bs.len() {
        if !is_digit(bs[i]) { return default_when_invalid; }
        let d = (bs[i] - (0x30 as u8)) as Int64;
        acc = acc * (10 as Int64) + d;
        had_digit = true;
        i = i + 1;
    }
    if !had_digit { return default_when_invalid; }
    if negative { -acc } else { acc }
}

// sqlite3_uri_parameter — pass-through; helper just trims surrounding spaces.
public fn parameter_value(raw: &Text) -> Text {
    let bs = raw.as_bytes();
    let mut start: Int = 0;
    let mut end: Int = bs.len();
    while start < end {
        let b = bs[start];
        if b == (0x20 as u8) || b == (0x09 as u8) { start = start + 1; }
        else { start = end + 1; }   // break
    }
    // The above breaks awkwardly — recompute properly.
    let mut s: Int = 0;
    while s < bs.len() && (bs[s] == (0x20 as u8) || bs[s] == (0x09 as u8)) {
        s = s + 1;
    }
    let mut e: Int = bs.len();
    while e > s && (bs[e - 1] == (0x20 as u8) || bs[e - 1] == (0x09 as u8)) {
        e = e - 1;
    }
    let mut out = "".clone();
    let mut k: Int = s;
    while k < e {
        out.push_byte(bs[k]);
        k = k + 1;
    }
    out
}

public fn is_present(raw: &Text) -> Bool {
    parameter_value(raw).len() > 0
}
