// =============================================================================
// csv_vtab_api/schema.vr — CSV schema inference
// =============================================================================
// Spec: SQLite ext/misc/csv.c
//
// When the caller doesn't supply `schema=...`, the vtab infers
// "CREATE TABLE x(c0 TEXT, c1 TEXT, …)" from the first row's column
// count (or from the explicit `columns=N` option).
// =============================================================================

module core.database.sqlite.native.csv_vtab_api.schema;

mount core.*;
mount base.{Bool, Maybe, Text};
mount core.database.sqlite.native.csv_vtab_api.options.{
    CsvVtabOptions,
};

fn push_text(dst: &mut Text, s: &Text) {
    let bs = s.as_bytes();
    let mut i: Int = 0;
    while i < bs.len() { dst.push_byte(bs[i]); i = i + 1; }
}

fn push_int(dst: &mut Text, n: Int) {
    // Two's-complement-safe magnitude. The naive `n = 0 - n` for the
    // negative branch overflows on Int.MIN (`0 - Int.MIN` is
    // unrepresentable, wraps back to Int.MIN), and the subsequent
    // digit-counting `while x > 0` loop never enters — emitting
    // garbage like `(` (0x28 = 0x30 + (-8)) instead of the true
    // value. Accumulate magnitude in UInt64 so every Int including
    // Int.MIN round-trips exactly.
    if n == 0 { dst.push_byte(0x30 as u8); return; }
    let negative = n < 0;
    if negative { dst.push_byte(0x2D as u8); }
    let mut mag: UInt64 = if negative {
        (((!n) as UInt64) + 1_u64)
    } else {
        n as UInt64
    };
    // Worst case: 20 digits for UInt64.
    let mut buf: [Byte; 20] = [0_u8; 20];
    let mut i: Int = 19;
    while mag > 0_u64 {
        buf[i] = ((mag % 10_u64) as Byte) + 0x30_u8;
        mag = mag / 10_u64;
        i = i - 1;
    }
    let mut k: Int = i + 1;
    while k <= 19 { dst.push_byte(buf[k]); k = k + 1; }
}

public fn infer_schema(opts: &CsvVtabOptions, first_row_columns: Int) -> Text {
    match &opts.schema {
        Maybe.Some(s) => return s.clone(),
        Maybe.None => {}
    }
    let n_cols = match &opts.columns {
        Maybe.Some(n) => *n,
        Maybe.None => first_row_columns,
    };
    let mut out = "CREATE TABLE x(".clone();
    let mut i: Int = 0;
    while i < n_cols {
        if i > 0 { push_text(&mut out, &", ".clone()); }
        push_text(&mut out, &"c".clone());
        push_int(&mut out, i);
        push_text(&mut out, &" TEXT".clone());
        i = i + 1;
    }
    push_text(&mut out, &")".clone());
    out
}

public fn effective_column_count(opts: &CsvVtabOptions, first_row_columns: Int) -> Int {
    match &opts.columns {
        Maybe.Some(n) => *n,
        Maybe.None => first_row_columns,
    }
}
