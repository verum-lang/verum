// sqlite3_stmt_isexplain — EXPLAIN-mode classifier.

module core.database.sqlite.native.stmt_isexplain_api.probe;

mount base.{Bool, Text};

public type Mode is
    | MNotExplain          // 0
    | MExplain             // 1 — EXPLAIN <stmt>
    | MQueryPlan           // 2 — EXPLAIN QUERY PLAN <stmt>
    ;

public fn from_code(n: Int) -> Mode {
    if n <= 0 { return MNotExplain; }
    if n == 1 { return MExplain; }
    MQueryPlan
}

public fn to_code(m: &Mode) -> Int {
    match m {
        MNotExplain => 0,
        MExplain    => 1,
        MQueryPlan  => 2,
    }
}

public fn mode_name(m: &Mode) -> Text {
    match m {
        MNotExplain => "not_explain".clone(),
        MExplain    => "explain".clone(),
        MQueryPlan  => "query_plan".clone(),
    }
}

// Predicate helpers.
public fn is_explain(m: &Mode) -> Bool {
    match m { MNotExplain => false, _ => true }
}

public fn is_opcode_dump(m: &Mode) -> Bool {
    match m { MExplain => true, _ => false }
}

public fn is_query_plan(m: &Mode) -> Bool {
    match m { MQueryPlan => true, _ => false }
}

// Number of result columns each mode emits.  EXPLAIN: 8 cols; EQP: 4 cols.
public fn result_column_count(m: &Mode) -> Int {
    match m {
        MNotExplain => 0,    // depends on the underlying SELECT — not fixed
        MExplain    => 8,
        MQueryPlan  => 4,
    }
}

// Header strings for the shell .header on output.
public fn first_column_name(m: &Mode) -> Text {
    match m {
        MNotExplain => "".clone(),
        MExplain    => "addr".clone(),
        MQueryPlan  => "id".clone(),
    }
}
