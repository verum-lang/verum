// =============================================================================
// bitvec_test_api/harness.vr — test-schedule driver
// =============================================================================
// Spec: SQLite test-control PagerBitmap harness.
// =============================================================================

module core.database.sqlite.native.bitvec_test_api.harness;

mount core.*;
mount base.{Bool};
mount core.database.sqlite.native.bitvec_test_api.bitvec.{
    PagerBitmap, get, set, clear,
};

public type TestOp is
      ToSet(Int)
    | ToClear(Int);

public type TestResult is {
    ops_applied: Int64,
    set_duplicates: Int64,
    clear_misses: Int64,
    final_population: Int,
    assertion_count: Int64,
}

public fn new_result() -> TestResult {
    TestResult {
        ops_applied: 0 as Int64,
        set_duplicates: 0 as Int64,
        clear_misses: 0 as Int64,
        final_population: 0,
        assertion_count: 0 as Int64,
    }
}

public fn apply_op(v: &mut PagerBitmap, op: &TestOp, r: &mut TestResult) {
    r.ops_applied = r.ops_applied + 1_i64;
    match op {
        ToSet(i) => {
            if !set(v, *i) { r.set_duplicates = r.set_duplicates + 1_i64; }
        }
        ToClear(i) => {
            if !clear(v, *i) { r.clear_misses = r.clear_misses + 1_i64; }
        }
    }
}

public fn finalize(v: &PagerBitmap, r: &mut TestResult) {
    r.final_population = v.population;
    r.assertion_count = r.assertion_count + 1_i64;
}
