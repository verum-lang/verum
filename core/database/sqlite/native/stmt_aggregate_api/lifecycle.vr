// Aggregation-lifecycle state machine.

module core.database.sqlite.native.stmt_aggregate_api.lifecycle;

mount base.{Bool, Text, Int64};

public type AggregatePhase is
    | PaIdle           // no active aggregation
    | PaAccumulating   // xStep calls in progress
    | PaFinalizing     // xFinal running (terminal call)
    | PaDone
    ;

public fn phase_name(p: &AggregatePhase) -> Text {
    match p {
        PaIdle         => "idle".clone(),
        PaAccumulating => "accumulating".clone(),
        PaFinalizing   => "finalizing".clone(),
        PaDone         => "done".clone(),
    }
}

public type AggState is {
    phase: AggregatePhase,
    rows_stepped: Int64,
    rows_inverted: Int64,
    values_emitted: Int64,
};

public fn fresh() -> AggState {
    AggState {
        phase: PaIdle,
        rows_stepped: 0 as Int64,
        rows_inverted: 0 as Int64,
        values_emitted: 0 as Int64,
    }
}

public fn begin(mut s: AggState) -> AggState {
    s.phase = PaAccumulating;
    s
}

public fn step(mut s: AggState) -> AggState {
    s.rows_stepped = s.rows_stepped + 1_i64;
    s
}

public fn inverse(mut s: AggState) -> AggState {
    s.rows_inverted = s.rows_inverted + 1_i64;
    s
}

public fn emit_value(mut s: AggState) -> AggState {
    s.values_emitted = s.values_emitted + 1_i64;
    s
}

public fn finalize(mut s: AggState) -> AggState {
    s.phase = PaFinalizing;
    s
}

public fn complete(mut s: AggState) -> AggState {
    s.phase = PaDone;
    s
}

// Net rows currently in the aggregate window.
public fn live_row_count(s: &AggState) -> Int64 {
    s.rows_stepped - s.rows_inverted
}

public fn is_window_use(s: &AggState) -> Bool {
    s.rows_inverted > 0_i64 || s.values_emitted > 0_i64
}

public fn is_plain_aggregate_use(s: &AggState) -> Bool {
    s.rows_inverted == 0_i64 && s.values_emitted == 0_i64
}
