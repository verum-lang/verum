// PRAGMA page_count — total page count + bytes-on-disk projection.

module core.database.sqlite.native.page_count_pragma.reading;

mount base.{Bool, Int64, Text};

public type PageCountReading is {
    total_pages: Int64,
    page_size_bytes: Int,
};

public fn new(total_pages: Int64, page_size: Int) -> PageCountReading {
    let zero = 0 as Int64;
    let mut t = if total_pages < zero { zero } else { total_pages };
    let mut ps = page_size;
    if ps < 0 { ps = 0; }
    PageCountReading { total_pages: t, page_size_bytes: ps }
}

public fn empty_reading() -> PageCountReading {
    PageCountReading { total_pages: 0 as Int64, page_size_bytes: 0 }
}

public fn is_empty(r: &PageCountReading) -> Bool {
    r.total_pages == 0_i64
}

public fn file_size_bytes(r: &PageCountReading) -> Int64 {
    r.total_pages * (r.page_size_bytes as Int64)
}

// Validity: SQLite page sizes are powers of two between 512 and 65536.
public type SizeCheck is
    | ScValid
    | ScNotPowerOfTwo
    | ScOutOfRange
    ;

public fn check_page_size(ps: Int) -> SizeCheck {
    if ps < 512 || ps > 65536 { return ScOutOfRange; }
    let mut x = ps;
    while x > 1 {
        if x % 2 != 0 { return ScNotPowerOfTwo; }
        x = x / 2;
    }
    ScValid
}

public fn check_name(c: &SizeCheck) -> Text {
    match c {
        ScValid          => "valid".clone(),
        ScNotPowerOfTwo  => "not_pow2".clone(),
        ScOutOfRange     => "out_of_range".clone(),
    }
}

public fn is_valid_size(c: &SizeCheck) -> Bool {
    match c { ScValid => true, _ => false }
}

// Common multipliers for human readability.
public fn megabytes(r: &PageCountReading) -> Int64 {
    file_size_bytes(r) / 1_048_576_i64
}

public fn pages_per_megabyte(r: &PageCountReading) -> Int64 {
    if r.page_size_bytes == 0 { return 0 as Int64; }
    1_048_576_i64 / (r.page_size_bytes as Int64)
}
