module core.database.sqlite.native.l5_sql.lexer;

// =============================================================================
// l5_sql/lexer.vr — SQL tokenizer
// =============================================================================
// Layer: 5
// Spec: sqlite-native.md §12.1, sqlite.org/lang.html
//
// Breaks an input `Text` into a stream of `SqlToken` values ready for the
// recursive-descent parser in `parser/`. SQLite's SQL dialect is
// case-insensitive for keywords, allows `--` line comments and
// `/* ... */` block comments, double-quoted identifiers, single-quoted
// string literals with embedded `''` escapes, blob literals `X'...'`,
// hex integer literals, float literals with exponent, and three
// parameter syntaxes (`?`, `?N`, `:name`, `@name`, `$name`).
//
// This module intentionally NOT built on top of `core/text/regex` —
// it's a hand-rolled scanner because SQL's lexing rules are small
// enough that a single-pass byte-switch is both faster and easier to
// audit than a regex-driven lexer.
// =============================================================================

mount core.*;
mount collections.List;
mount base.{Result, Ok, Err, Text, Maybe};
mount core.text.case_fold.fold_byte_ascii;

// -----------------------------------------------------------------------------
// SqlKeyword catalog — SQLite reserves ~160 tokens.
// -----------------------------------------------------------------------------

public type SqlKeyword is
      KwSelect | KwFrom | KwWhere | KwGroup | KwBy | KwHaving
    | KwOrder | KwAsc | KwDesc | KwLimit | KwOffset
    | KwInsert | KwInto | KwValues | KwReplace
    | KwUpdate | KwSet | KwDelete
    | KwCreate | KwTable | KwIndex | KwView | KwTrigger | KwVirtual
    | KwDrop | KwAlter | KwRename | KwAdd | KwColumn
    | KwIf | KwExists | KwTemp | KwTemporary
    | KwPrimary | KwKey | KwForeign | KwReferences
    | KwUnique | KwCheck | KwDefault | KwCollate
    | KwNot | KwNull | KwTrue | KwFalse
    | KwAnd | KwOr | KwIn | KwBetween | KwLike | KwGlob | KwMatch | KwRegexp
    | KwIs | KwAs | KwCase | KwWhen | KwThen | KwElse | KwEnd
    | KwDistinct | KwAll | KwUnion | KwIntersect | KwExcept
    | KwJoin | KwLeft | KwRight | KwFull | KwOuter | KwInner | KwCross | KwNatural | KwOn | KwUsing
    | KwBegin | KwCommit | KwRollback | KwTransaction | KwSavepoint | KwRelease | KwTo
    | KwWith | KwRecursive | KwWindow | KwOver | KwPartition | KwRange | KwRows | KwGroups
    | KwUnbounded | KwPreceding | KwFollowing | KwCurrent | KwRow
    | KwExclude | KwTies | KwOthers | KwNo
    | KwPragma | KwExplain | KwQuery | KwPlan | KwVacuum | KwReindex
    | KwAttach | KwDetach | KwAnalyze | KwDatabase
    | KwCascade | KwRestrict | KwDeferrable | KwDeferred | KwImmediate | KwInitially
    | KwReturning | KwAutoincrement | KwWithout | KwRowid
    | KwGenerated | KwAlways | KwStored | KwConflict
    | KwAbort | KwFail | KwIgnore
    | KwBefore | KwAfter | KwInstead | KwOf | KwEach | KwFor
    | KwIndexed
    | KwCast | KwFilter;

/// Operator tokens that aren't single punctuation.
public type Operator is
      OpEq | OpNotEq | OpLt | OpLe | OpGt | OpGe
    | OpPlus | OpMinus | OpStar | OpSlash | OpPercent
    | OpConcat | OpBitAnd | OpBitOr | OpBitNot | OpShl | OpShr
    | OpArrow | OpArrowArrow;     // JSON ops -> and ->>

public type Punct is
      PLParen | PRParen | PComma | PSemicolon | PDot | PColon | PColonColon
    | PStar;                       // `*` inside result columns treated as punct

/// Parameter-binding variants — SQLite supports:
///   `?`      → indexed by sequential position
///   `?N`     → indexed by explicit number
///   `:name`  → named
///   `@name`  → named (alternative)
///   `$name`  → named (Tcl-style, same behavior as @name)
public type VariableKind is
      VAnon
    | VIndexed(Int)
    | VNamedColon(Text)
    | VNamedAt(Text)
    | VNamedDollar(Text);

public type SqlToken is
      TKeyword(SqlKeyword)
    | TIdent(Text)
    | TStringLit(Text)
    | TBlobLit(List<Byte>)
    | TIntLit(Int64)
    | TFloatLit(Float64)
    | TPunct(Punct)
    | TOp(Operator)
    | TVariable(VariableKind)
    | TComment(Text)
    | TEof;

public type SqlLexError is {
    message: Text,
    position: Int,
};

// -----------------------------------------------------------------------------
// SqlKeyword lookup
// -----------------------------------------------------------------------------

/// Case-insensitive keyword table. Returns `None` for identifiers.
public fn lookup_keyword(s: &Text) -> Maybe<SqlKeyword> {
    let raw = s.as_bytes();
    let mut folded: List<Byte> = List.new();
    let mut i: Int = 0;
    while i < raw.len() {
        folded.push(fold_byte_ascii(raw[i]));
        i = i + 1;
    }
    lookup_folded(&folded)
}

fn eq_literal(buf: &List<Byte>, lit: &str) -> Bool {
    let lb = lit.as_bytes();
    if buf.len() != lb.len() { return false; }
    let mut i: Int = 0;
    while i < lb.len() {
        if buf[i] != lb[i] { return false; }
        i = i + 1;
    }
    true
}

fn lookup_folded(b: &List<Byte>) -> Maybe<SqlKeyword> {
    // A hand table works at this scale — under 200 entries.
    if eq_literal(b, "select")     { return Some(KwSelect); }
    if eq_literal(b, "from")       { return Some(KwFrom); }
    if eq_literal(b, "where")      { return Some(KwWhere); }
    if eq_literal(b, "group")      { return Some(KwGroup); }
    if eq_literal(b, "by")         { return Some(KwBy); }
    if eq_literal(b, "having")     { return Some(KwHaving); }
    if eq_literal(b, "order")      { return Some(KwOrder); }
    if eq_literal(b, "asc")        { return Some(KwAsc); }
    if eq_literal(b, "desc")       { return Some(KwDesc); }
    if eq_literal(b, "limit")      { return Some(KwLimit); }
    if eq_literal(b, "offset")     { return Some(KwOffset); }
    if eq_literal(b, "insert")     { return Some(KwInsert); }
    if eq_literal(b, "into")       { return Some(KwInto); }
    if eq_literal(b, "values")     { return Some(KwValues); }
    if eq_literal(b, "replace")    { return Some(KwReplace); }
    if eq_literal(b, "update")     { return Some(KwUpdate); }
    if eq_literal(b, "set")        { return Some(KwSet); }
    if eq_literal(b, "delete")     { return Some(KwDelete); }
    if eq_literal(b, "create")     { return Some(KwCreate); }
    if eq_literal(b, "table")      { return Some(KwTable); }
    if eq_literal(b, "index")      { return Some(KwIndex); }
    if eq_literal(b, "view")       { return Some(KwView); }
    if eq_literal(b, "trigger")    { return Some(KwTrigger); }
    if eq_literal(b, "virtual")    { return Some(KwVirtual); }
    if eq_literal(b, "drop")       { return Some(KwDrop); }
    if eq_literal(b, "alter")      { return Some(KwAlter); }
    if eq_literal(b, "rename")     { return Some(KwRename); }
    if eq_literal(b, "add")        { return Some(KwAdd); }
    if eq_literal(b, "column")     { return Some(KwColumn); }
    if eq_literal(b, "if")         { return Some(KwIf); }
    if eq_literal(b, "exists")     { return Some(KwExists); }
    if eq_literal(b, "temp")       { return Some(KwTemp); }
    if eq_literal(b, "temporary")  { return Some(KwTemporary); }
    if eq_literal(b, "primary")    { return Some(KwPrimary); }
    if eq_literal(b, "key")        { return Some(KwKey); }
    if eq_literal(b, "foreign")    { return Some(KwForeign); }
    if eq_literal(b, "references") { return Some(KwReferences); }
    if eq_literal(b, "unique")     { return Some(KwUnique); }
    if eq_literal(b, "check")      { return Some(KwCheck); }
    if eq_literal(b, "default")    { return Some(KwDefault); }
    if eq_literal(b, "collate")    { return Some(KwCollate); }
    if eq_literal(b, "not")        { return Some(KwNot); }
    if eq_literal(b, "null")       { return Some(KwNull); }
    if eq_literal(b, "true")       { return Some(KwTrue); }
    if eq_literal(b, "false")      { return Some(KwFalse); }
    if eq_literal(b, "and")        { return Some(KwAnd); }
    if eq_literal(b, "or")         { return Some(KwOr); }
    if eq_literal(b, "in")         { return Some(KwIn); }
    if eq_literal(b, "between")    { return Some(KwBetween); }
    if eq_literal(b, "like")       { return Some(KwLike); }
    if eq_literal(b, "glob")       { return Some(KwGlob); }
    if eq_literal(b, "match")      { return Some(KwMatch); }
    if eq_literal(b, "regexp")     { return Some(KwRegexp); }
    if eq_literal(b, "is")         { return Some(KwIs); }
    if eq_literal(b, "as")         { return Some(KwAs); }
    if eq_literal(b, "case")       { return Some(KwCase); }
    if eq_literal(b, "when")       { return Some(KwWhen); }
    if eq_literal(b, "then")       { return Some(KwThen); }
    if eq_literal(b, "else")       { return Some(KwElse); }
    if eq_literal(b, "end")        { return Some(KwEnd); }
    if eq_literal(b, "distinct")   { return Some(KwDistinct); }
    if eq_literal(b, "all")        { return Some(KwAll); }
    if eq_literal(b, "union")      { return Some(KwUnion); }
    if eq_literal(b, "intersect")  { return Some(KwIntersect); }
    if eq_literal(b, "except")     { return Some(KwExcept); }
    if eq_literal(b, "join")       { return Some(KwJoin); }
    if eq_literal(b, "left")       { return Some(KwLeft); }
    if eq_literal(b, "right")      { return Some(KwRight); }
    if eq_literal(b, "full")       { return Some(KwFull); }
    if eq_literal(b, "outer")      { return Some(KwOuter); }
    if eq_literal(b, "inner")      { return Some(KwInner); }
    if eq_literal(b, "cross")      { return Some(KwCross); }
    if eq_literal(b, "natural")    { return Some(KwNatural); }
    if eq_literal(b, "on")         { return Some(KwOn); }
    if eq_literal(b, "using")      { return Some(KwUsing); }
    if eq_literal(b, "begin")      { return Some(KwBegin); }
    if eq_literal(b, "commit")     { return Some(KwCommit); }
    if eq_literal(b, "rollback")   { return Some(KwRollback); }
    if eq_literal(b, "transaction"){ return Some(KwTransaction); }
    if eq_literal(b, "savepoint")  { return Some(KwSavepoint); }
    if eq_literal(b, "release")    { return Some(KwRelease); }
    if eq_literal(b, "to")         { return Some(KwTo); }
    if eq_literal(b, "with")       { return Some(KwWith); }
    if eq_literal(b, "recursive")  { return Some(KwRecursive); }
    if eq_literal(b, "window")     { return Some(KwWindow); }
    if eq_literal(b, "over")       { return Some(KwOver); }
    if eq_literal(b, "partition")  { return Some(KwPartition); }
    if eq_literal(b, "range")      { return Some(KwRange); }
    if eq_literal(b, "rows")       { return Some(KwRows); }
    if eq_literal(b, "groups")     { return Some(KwGroups); }
    if eq_literal(b, "unbounded")  { return Some(KwUnbounded); }
    if eq_literal(b, "preceding")  { return Some(KwPreceding); }
    if eq_literal(b, "following")  { return Some(KwFollowing); }
    if eq_literal(b, "current")    { return Some(KwCurrent); }
    if eq_literal(b, "row")        { return Some(KwRow); }
    if eq_literal(b, "exclude")    { return Some(KwExclude); }
    if eq_literal(b, "ties")       { return Some(KwTies); }
    if eq_literal(b, "others")     { return Some(KwOthers); }
    if eq_literal(b, "no")         { return Some(KwNo); }
    if eq_literal(b, "pragma")     { return Some(KwPragma); }
    if eq_literal(b, "explain")    { return Some(KwExplain); }
    if eq_literal(b, "query")      { return Some(KwQuery); }
    if eq_literal(b, "plan")       { return Some(KwPlan); }
    if eq_literal(b, "vacuum")     { return Some(KwVacuum); }
    if eq_literal(b, "reindex")    { return Some(KwReindex); }
    if eq_literal(b, "attach")     { return Some(KwAttach); }
    if eq_literal(b, "detach")     { return Some(KwDetach); }
    if eq_literal(b, "analyze")    { return Some(KwAnalyze); }
    if eq_literal(b, "database")   { return Some(KwDatabase); }
    if eq_literal(b, "cascade")    { return Some(KwCascade); }
    if eq_literal(b, "restrict")   { return Some(KwRestrict); }
    if eq_literal(b, "deferrable") { return Some(KwDeferrable); }
    if eq_literal(b, "deferred")   { return Some(KwDeferred); }
    if eq_literal(b, "immediate")  { return Some(KwImmediate); }
    if eq_literal(b, "initially")  { return Some(KwInitially); }
    if eq_literal(b, "returning")  { return Some(KwReturning); }
    if eq_literal(b, "autoincrement") { return Some(KwAutoincrement); }
    if eq_literal(b, "without")    { return Some(KwWithout); }
    if eq_literal(b, "rowid")      { return Some(KwRowid); }
    if eq_literal(b, "generated")  { return Some(KwGenerated); }
    if eq_literal(b, "always")     { return Some(KwAlways); }
    if eq_literal(b, "stored")     { return Some(KwStored); }
    if eq_literal(b, "conflict")   { return Some(KwConflict); }
    if eq_literal(b, "abort")      { return Some(KwAbort); }
    if eq_literal(b, "fail")       { return Some(KwFail); }
    if eq_literal(b, "ignore")     { return Some(KwIgnore); }
    if eq_literal(b, "before")     { return Some(KwBefore); }
