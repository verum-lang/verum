}

// -----------------------------------------------------------------------------
// Byte-class helpers
// -----------------------------------------------------------------------------

fn is_ws(b: Byte) -> Bool {
    b == (0x20 as Byte) || b == (0x09 as Byte)
    || b == (0x0A as Byte) || b == (0x0D as Byte)
    || b == (0x0B as Byte) || b == (0x0C as Byte)
}

fn is_digit(b: Byte) -> Bool {
    b >= (0x30 as Byte) && b <= (0x39 as Byte)
}

fn is_hex(b: Byte) -> Bool {
    is_digit(b)
    || (b >= (0x41 as Byte) && b <= (0x46 as Byte))
    || (b >= (0x61 as Byte) && b <= (0x66 as Byte))
}

fn is_alpha(b: Byte) -> Bool {
    (b >= (0x41 as Byte) && b <= (0x5A as Byte))
    || (b >= (0x61 as Byte) && b <= (0x7A as Byte))
    || b == (0x5F as Byte)    // '_'
}

fn is_ident_cont(b: Byte) -> Bool {
    is_alpha(b) || is_digit(b) || b == (0x24 as Byte)   // '$' allowed in SQLite idents
}

fn hex_digit_value(b: Byte) -> Int64 {
    if is_digit(b) { return (b - (0x30 as Byte)) as Int64; }
    if b >= (0x41 as Byte) && b <= (0x46 as Byte) {
        return ((b - (0x41 as Byte)) as Int64) + 10_i64;
    }
    ((b - (0x61 as Byte)) as Int64) + 10_i64
}

// -----------------------------------------------------------------------------
// Lexer state
// -----------------------------------------------------------------------------

public type LexerState is {
    input: List<Byte>,
    pos: Int,
    tokens: List<SqlToken>,
};

fn lexer_new(input: &Text) -> LexerState {
    let raw = input.as_bytes();
    let mut buf: List<Byte> = List.new();
    let mut i: Int = 0;
    while i < raw.len() {
        buf.push(raw[i]);
        i = i + 1;
    }
    LexerState { input: buf, pos: 0, tokens: List.new() }
}

fn peek(st: &LexerState, offset: Int) -> Byte {
    let idx = st.pos + offset;
    if idx >= st.input.len() { return 0 as Byte; }
    st.input[idx]
}

fn at_eof(st: &LexerState) -> Bool {
    st.pos >= st.input.len()
}

fn push_tok(st: &mut LexerState, t: SqlToken) {
    st.tokens.push(t);
}

// -----------------------------------------------------------------------------
// Main tokenizer
// -----------------------------------------------------------------------------

public fn lex(input: &Text) -> Result<List<SqlToken>, SqlLexError> {
    let mut st = lexer_new(input);

    while !at_eof(&st) {
        let b = peek(&st, 0);

        // Whitespace.
        if is_ws(b) { st.pos = st.pos + 1; continue; }

        // Line comment `-- ... \n`.
        if b == (0x2D as Byte) && peek(&st, 1) == (0x2D as Byte) {
            st.pos = st.pos + 2;
            while !at_eof(&st) && peek(&st, 0) != (0x0A as Byte) {
                st.pos = st.pos + 1;
            }
            continue;
        }

        // Block comment `/* ... */`.
        if b == (0x2F as Byte) && peek(&st, 1) == (0x2A as Byte) {
            st.pos = st.pos + 2;
            while !at_eof(&st) {
                if peek(&st, 0) == (0x2A as Byte) && peek(&st, 1) == (0x2F as Byte) {
                    st.pos = st.pos + 2;
                    break;
                }
                st.pos = st.pos + 1;
            }
            continue;
        }

        // String literal `'...''...'`.
        if b == (0x27 as Byte) {
            match lex_string(&mut st) {
                Ok(tok) => { push_tok(&mut st, tok); continue; }
                Err(e)  => return Err(e),
            }
        }

        // Double-quoted identifier.
        if b == (0x22 as Byte) {
            match lex_quoted_ident(&mut st) {
                Ok(tok) => { push_tok(&mut st, tok); continue; }
                Err(e)  => return Err(e),
            }
        }

        // Backtick identifier (MySQL-compat SQLite supports).
        if b == (0x60 as Byte) {
            match lex_quoted_ident_with_delim(&mut st, 0x60 as Byte) {
                Ok(tok) => { push_tok(&mut st, tok); continue; }
                Err(e)  => return Err(e),
            }
        }

        // Blob literal `X'...hex...'` or `x'...'`.
        if (b == (0x58 as Byte) || b == (0x78 as Byte)) && peek(&st, 1) == (0x27 as Byte) {
            match lex_blob(&mut st) {
                Ok(tok) => { push_tok(&mut st, tok); continue; }
                Err(e)  => return Err(e),
            }
        }

        // Number.
        if is_digit(b) {
            match lex_number(&mut st) {
                Ok(tok) => { push_tok(&mut st, tok); continue; }
                Err(e)  => return Err(e),
            }
        }

        // Leading-dot float: `.5`.
        if b == (0x2E as Byte) && is_digit(peek(&st, 1)) {
            match lex_number(&mut st) {
                Ok(tok) => { push_tok(&mut st, tok); continue; }
                Err(e)  => return Err(e),
            }
        }

        // Identifier / keyword.
        if is_alpha(b) {
            push_tok(&mut st, lex_identifier(&mut st));
            continue;
        }

        // Parameter bindings.
        if b == (0x3F as Byte) {       // '?'
            push_tok(&mut st, lex_anon_or_indexed(&mut st));
            continue;
        }
        if b == (0x3A as Byte) && is_alpha(peek(&st, 1)) {   // ':name'
            push_tok(&mut st, lex_named_variable(&mut st, 0x3A as Byte, VNamedColon));
            continue;
        }
        if b == (0x40 as Byte) && is_alpha(peek(&st, 1)) {   // '@name'
            push_tok(&mut st, lex_named_variable(&mut st, 0x40 as Byte, VNamedAt));
            continue;
        }
        if b == (0x24 as Byte) && is_alpha(peek(&st, 1)) {   // '$name'
            push_tok(&mut st, lex_named_variable(&mut st, 0x24 as Byte, VNamedDollar));
            continue;
        }

        // Punctuation / operators.
        match lex_punct_or_op(&mut st) {
            Ok(tok) => { push_tok(&mut st, tok); continue; }
            Err(e)  => return Err(e),
        }
    }

    st.tokens.push(TEof);
    Ok(st.tokens)
}

// -----------------------------------------------------------------------------
// Sub-lexers
// -----------------------------------------------------------------------------

fn lex_string(st: &mut LexerState) -> Result<SqlToken, SqlLexError> {
    // Consume opening quote.
    st.pos = st.pos + 1;
    let mut out: List<Byte> = List.new();
    while !at_eof(st) {
        let b = peek(st, 0);
        if b == (0x27 as Byte) {
            if peek(st, 1) == (0x27 as Byte) {
                // Escaped quote `''`.
                out.push(0x27 as Byte);
                st.pos = st.pos + 2;
                continue;
            }
            st.pos = st.pos + 1;
            return Ok(TStringLit(Text.from_bytes(&out).unwrap_or("".clone())));
        }
        out.push(b);
        st.pos = st.pos + 1;
    }
    Err(SqlLexError { message: "unterminated string literal".clone(), position: st.pos })
}

fn lex_quoted_ident(st: &mut LexerState) -> Result<SqlToken, SqlLexError> {
    lex_quoted_ident_with_delim(st, 0x22 as Byte)
}

fn lex_quoted_ident_with_delim(st: &mut LexerState, delim: Byte) -> Result<SqlToken, SqlLexError> {
    st.pos = st.pos + 1;
    let mut out: List<Byte> = List.new();
    while !at_eof(st) {
        let b = peek(st, 0);
        if b == delim {
            if peek(st, 1) == delim {
                out.push(delim);
                st.pos = st.pos + 2;
                continue;
            }
            st.pos = st.pos + 1;
            return Ok(TIdent(Text.from_bytes(&out).unwrap_or("".clone())));
        }
        out.push(b);
        st.pos = st.pos + 1;
    }
    Err(SqlLexError { message: "unterminated quoted identifier".clone(), position: st.pos })
}

fn lex_blob(st: &mut LexerState) -> Result<SqlToken, SqlLexError> {
    // Skip 'X' / 'x'.
    st.pos = st.pos + 1;
    // Opening quote.
    st.pos = st.pos + 1;
    let mut out: List<Byte> = List.new();
    while !at_eof(st) {
        let b = peek(st, 0);
        if b == (0x27 as Byte) {
            st.pos = st.pos + 1;
            if (out.len() & 1) != 0 {
                return Err(SqlLexError { message: "odd hex digit count in blob literal".clone(), position: st.pos });
            }
            let mut bytes: List<Byte> = List.new();
            let mut i: Int = 0;
            while i + 1 < out.len() {
                let hi = hex_digit_value(out[i]);
                let lo = hex_digit_value(out[i + 1]);
                bytes.push((((hi as Int) << 4) | (lo as Int)) as Byte);
                i = i + 2;
            }
            return Ok(TBlobLit(bytes));
        }
        if !is_hex(b) {
            return Err(SqlLexError { message: "non-hex digit in blob literal".clone(), position: st.pos });
        }
        out.push(b);
        st.pos = st.pos + 1;
    }
    Err(SqlLexError { message: "unterminated blob literal".clone(), position: st.pos })
}

fn lex_number(st: &mut LexerState) -> Result<SqlToken, SqlLexError> {
    // Hex literal `0x...`.
    if peek(st, 0) == (0x30 as Byte) && (peek(st, 1) == (0x78 as Byte) || peek(st, 1) == (0x58 as Byte)) {
        st.pos = st.pos + 2;
        let mut v: Int64 = 0 as Int64;
        let mut saw: Bool = false;
        while !at_eof(st) && is_hex(peek(st, 0)) {
            v = (v << 4) | hex_digit_value(peek(st, 0));
            st.pos = st.pos + 1;
            saw = true;
        }
        if !saw {
            return Err(SqlLexError { message: "hex literal needs at least one digit".clone(), position: st.pos });
        }
        return Ok(TIntLit(v));
    }

    let start = st.pos;
    // Integer part.
    while !at_eof(st) && is_digit(peek(st, 0)) { st.pos = st.pos + 1; }
    let mut is_float = false;
    if !at_eof(st) && peek(st, 0) == (0x2E as Byte) {
        is_float = true;
        st.pos = st.pos + 1;
        while !at_eof(st) && is_digit(peek(st, 0)) { st.pos = st.pos + 1; }
    }
    if !at_eof(st) && (peek(st, 0) == (0x65 as Byte) || peek(st, 0) == (0x45 as Byte)) {
        is_float = true;
        st.pos = st.pos + 1;
        if !at_eof(st) && (peek(st, 0) == (0x2B as Byte) || peek(st, 0) == (0x2D as Byte)) {
            st.pos = st.pos + 1;
        }
        while !at_eof(st) && is_digit(peek(st, 0)) { st.pos = st.pos + 1; }
    }

    // Extract substring.
    let mut digits: List<Byte> = List.new();
    let mut i: Int = start;
    while i < st.pos {
        digits.push(st.input[i]);
        i = i + 1;
    }
    if is_float {
        let x = parse_float_from_bytes(&digits);
        Ok(TFloatLit(x))
    } else {
        let n = parse_int_from_bytes(&digits);
        Ok(TIntLit(n))
    }
}

fn parse_int_from_bytes(b: &List<Byte>) -> Int64 {
    // SQL integer literals come from user-supplied SQL — apply
    // 3-layer overflow defense. Saturates at Int64.MAX on hostile
    // input (matches SQLite's `sqlite3DecOrHexToI64` best-effort
    // behaviour: tokens that don't fit get capped, the rest of the
    // statement still parses).
    let mut v: Int64 = 0 as Int64;
    let mut i: Int = 0;
    while i < b.len() {
        if i >= 19 || v > 922_337_203_685_477_580_i64 {
            // Saturate; consume remaining digits so the lexer
            // cursor lands past the malformed literal.
            return 9_223_372_036_854_775_807_i64;
        }
        let d = (b[i] - (0x30 as Byte)) as Int64;
        v = v * 10_i64 + d;
        if v < 0_i64 { return 9_223_372_036_854_775_807_i64; }
        i = i + 1;
    }
    v
}

fn parse_float_from_bytes(b: &List<Byte>) -> Float64 {
    let mut int_part: Float64 = 0.0;
    let mut i: Int = 0;
    while i < b.len() && b[i] >= (0x30 as Byte) && b[i] <= (0x39 as Byte) {
        int_part = int_part * 10.0 + ((b[i] - (0x30 as Byte)) as Float64);
        i = i + 1;
    }
    let mut frac: Float64 = 0.0;
    let mut div: Float64 = 1.0;
    if i < b.len() && b[i] == (0x2E as Byte) {
        i = i + 1;
        while i < b.len() && b[i] >= (0x30 as Byte) && b[i] <= (0x39 as Byte) {
            frac = frac * 10.0 + ((b[i] - (0x30 as Byte)) as Float64);
            div = div * 10.0;
            i = i + 1;
        }
    }
    let mut value = int_part + frac / div;
    if i < b.len() && (b[i] == (0x65 as Byte) || b[i] == (0x45 as Byte)) {
        i = i + 1;
        let mut neg = false;
        if i < b.len() && b[i] == (0x2D as Byte) { neg = true; i = i + 1; }
        else if i < b.len() && b[i] == (0x2B as Byte) { i = i + 1; }
        let mut e: Int = 0;
        while i < b.len() {
            e = e * 10 + ((b[i] - (0x30 as Byte)) as Int);
            i = i + 1;
        }
        let mut factor: Float64 = 1.0;
        let mut k: Int = 0;
        while k < e {
            factor = factor * 10.0;
            k = k + 1;
        }
        if neg { value = value / factor; } else { value = value * factor; }
    }
    value
}

fn lex_identifier(st: &mut LexerState) -> SqlToken {
    let start = st.pos;
    while !at_eof(st) && is_ident_cont(peek(st, 0)) {
        st.pos = st.pos + 1;
    }
    let mut raw: List<Byte> = List.new();
    let mut i: Int = start;
    while i < st.pos {
        raw.push(st.input[i]);
        i = i + 1;
    }
    let t = Text.from_bytes(&raw).unwrap_or("".clone());
    match lookup_keyword(&t) {
        Some(kw) => TKeyword(kw),
        None     => TIdent(t),
    }
}

fn lex_anon_or_indexed(st: &mut LexerState) -> SqlToken {
    st.pos = st.pos + 1;
    if at_eof(st) || !is_digit(peek(st, 0)) {
        return TVariable(VAnon);
    }
    // `?N` indexed-parameter index. SQLite caps at SQLITE_LIMIT_VARIABLE_NUMBER
    // (default 999, hard max 32766). Cap the digit run at 6 — enough for any
    // legal value, blocks `?99999999999999999999`-style overflow attacks
    // that would wrap n past Int.MAX into a small positive value.
    let mut n: Int = 0;
    let mut digit_count: Int = 0;
    while !at_eof(st) && is_digit(peek(st, 0)) {
        if digit_count >= 6 {
            // Consume the rest of the digits so the cursor advances
            // past the malformed token; saturate at 32767 (one past
            // SQLite's hard limit, which downstream handlers reject).
            while !at_eof(st) && is_digit(peek(st, 0)) {
                st.pos = st.pos + 1;
            }
            return TVariable(VIndexed(32767));
        }
        n = n * 10 + ((peek(st, 0) - (0x30 as Byte)) as Int);
        digit_count = digit_count + 1;
        st.pos = st.pos + 1;
    }
    TVariable(VIndexed(n))
}

fn lex_named_variable(st: &mut LexerState, sigil: Byte, wrapper: fn(Text) -> VariableKind) -> SqlToken {
    let _ = sigil;
    st.pos = st.pos + 1;
    let start = st.pos;
    while !at_eof(st) && is_ident_cont(peek(st, 0)) {
        st.pos = st.pos + 1;
    }
    let mut raw: List<Byte> = List.new();
    let mut i: Int = start;
    while i < st.pos {
        raw.push(st.input[i]);
        i = i + 1;
    }
    TVariable(wrapper(Text.from_bytes(&raw).unwrap_or("".clone())))
}

fn lex_punct_or_op(st: &mut LexerState) -> Result<SqlToken, SqlLexError> {
    let b = peek(st, 0);
    match b {
        0x28 => { st.pos = st.pos + 1; Ok(TPunct(PLParen)) },
        0x29 => { st.pos = st.pos + 1; Ok(TPunct(PRParen)) },
        0x2C => { st.pos = st.pos + 1; Ok(TPunct(PComma)) },
        0x3B => { st.pos = st.pos + 1; Ok(TPunct(PSemicolon)) },
        0x2E => { st.pos = st.pos + 1; Ok(TPunct(PDot)) },
        0x2A => { st.pos = st.pos + 1; Ok(TPunct(PStar)) },
        0x2B => { st.pos = st.pos + 1; Ok(TOp(OpPlus)) },
        0x2D => { st.pos = st.pos + 1; Ok(TOp(OpMinus)) },
        0x2F => { st.pos = st.pos + 1; Ok(TOp(OpSlash)) },
        0x25 => { st.pos = st.pos + 1; Ok(TOp(OpPercent)) },
        0x3D => {
            st.pos = st.pos + 1;
            if !at_eof(st) && peek(st, 0) == (0x3D as Byte) { st.pos = st.pos + 1; }
            Ok(TOp(OpEq))
        }
        0x21 => {
            if peek(st, 1) == (0x3D as Byte) {
                st.pos = st.pos + 2;
                Ok(TOp(OpNotEq))
            } else {
                Err(SqlLexError { message: "unexpected '!'".clone(), position: st.pos })
            }
        }
        0x3C => {
            st.pos = st.pos + 1;
            if !at_eof(st) && peek(st, 0) == (0x3D as Byte) {
                st.pos = st.pos + 1; Ok(TOp(OpLe))
            } else if !at_eof(st) && peek(st, 0) == (0x3E as Byte) {
                st.pos = st.pos + 1; Ok(TOp(OpNotEq))   // `<>` alt spelling
            } else if !at_eof(st) && peek(st, 0) == (0x3C as Byte) {
                st.pos = st.pos + 1; Ok(TOp(OpShl))
            } else {
                Ok(TOp(OpLt))
            }
        }
        0x3E => {
            st.pos = st.pos + 1;
            if !at_eof(st) && peek(st, 0) == (0x3D as Byte) {
                st.pos = st.pos + 1; Ok(TOp(OpGe))
            } else if !at_eof(st) && peek(st, 0) == (0x3E as Byte) {
                st.pos = st.pos + 1; Ok(TOp(OpShr))
            } else {
                Ok(TOp(OpGt))
            }
        }
        0x7C => {
            if peek(st, 1) == (0x7C as Byte) {
                st.pos = st.pos + 2; Ok(TOp(OpConcat))
            } else {
                st.pos = st.pos + 1; Ok(TOp(OpBitOr))
            }
        }
        0x26 => { st.pos = st.pos + 1; Ok(TOp(OpBitAnd)) }
        0x7E => { st.pos = st.pos + 1; Ok(TOp(OpBitNot)) }
        0x3A => {
            // Bare ':' punct or '::' operator.
            if peek(st, 1) == (0x3A as Byte) {
                st.pos = st.pos + 2; Ok(TPunct(PColonColon))
            } else {
                st.pos = st.pos + 1; Ok(TPunct(PColon))
            }
        }
        _ => Err(SqlLexError { message: "unexpected character".clone(), position: st.pos }),
    }
}
