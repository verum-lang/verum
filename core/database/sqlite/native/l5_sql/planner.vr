@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.database.sqlite.native.l5_sql.planner;

// =============================================================================
// l5_sql/planner.vr — AST → PlanNode tree
// =============================================================================
// Layer: 5
// Spec: sqlite-native.md §13
//

// The planner turns a parsed `Statement` into a `PlanNode` tree that
// the codegen walks into VDBE opcodes. In the loom v1 this is a
// minimal *structural* planner — no index selection, no join
// reordering, no subquery flattening. It exists so the compile
// pipeline can progress past "AST in hand" to "VDBE program on disk".
//

// Cost-based optimisation lands in follow-up patches; the shape of
// `PlanNode` is already right for it (every transformation is a
// node-level rewrite).
//

// Shape today:
//

//  PnValues — rows of constant expressions, no source
//  PnTableScan — full scan of a single table
//  PnFilter(child, predicate) — attach WHERE
//  PnProject(child, columns) — attach SELECT list
//  PnSort(child, terms) — attach ORDER BY
//  PnLimit(child, limit, offset)— attach LIMIT/OFFSET
//  PnInsert(table, columns, source_plan, on_conflict)
//  PnDelete(table, predicate)
//  PnUpdate(table, assignments, predicate)
//

// Every PlanNode carries enough information for codegen without
// re-walking the AST.
// =============================================================================

mount core.*;
mount collections.List;
mount base.{Result, Ok, Err, Text, Maybe};
mount core.database.sqlite.native.l5_sql.ast.{
    Statement, Expr, SqlLiteral, BinOp,
    SelectStmt, SelectKind, SimpleSelect, CompoundOp,
    ResultColumnItem, FromItem, SqlJoinKind, JoinClause,
    OrderTerm, LimitClause, OrderDirection,
    InsertStmt, InsertSource, SqlOnConflict,
    UpdateStmt, UpdateAssignment,
    DeleteStmt,
    TableRef, CreateTableStmt,
};

// -----------------------------------------------------------------------------
// PlanError
// -----------------------------------------------------------------------------

public type PlanError is {
    message: Text,
};

public fn plan_error(msg: Text) -> PlanError { PlanError { message: msg } }

implement Display for PlanError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"sqlite plan error: {self.message}".as_str())
    }
}

implement Debug for PlanError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"PlanError {{ message: {self.message} }}".as_str())
    }
}

implement Eq for PlanError {
    fn eq(&self, other: &PlanError) -> Bool {
        self.message == other.message
    }
}

// -----------------------------------------------------------------------------
// PlanColumn — resolved output column
// -----------------------------------------------------------------------------

public type PlanColumn is {
    alias: Text,                 // user-visible name (may be empty)
    expr: Expr,                  // expression produced
};

// -----------------------------------------------------------------------------
// PlanNode
// -----------------------------------------------------------------------------

public type PlanNode is
      PnValues(rows: List<List<Expr>>, column_count: Int)
    | PnTableScan(table: TableRef, cursor_id: Int, column_count: Int)
    | PnFilter(child: Heap<PlanNode>, predicate: Expr)
    | PnProject(child: Heap<PlanNode>, columns: List<PlanColumn>)
    | PnSort(child: Heap<PlanNode>, terms: List<OrderTerm>)
    | PnDistinct(child: Heap<PlanNode>, n_proj: Int)
    // Sort-based GROUP BY over a single-table source. `source` is the
    // pre-project plan node (PnTableScan or PnFilter(PnTableScan));
    // `group_exprs` evaluate in the source scope; `projection` is the
    // SELECT-list (each column is either an EColumnRef into the group
    // keys or an aggregate call); `having` is the optional post-group
    // filter.
    | PnGroupBy(
          source: Heap<PlanNode>,
          group_exprs: List<Expr>,
          projection: List<PlanColumn>,
          having: Maybe<Expr>,
      )
    // Nested-loop INNER JOIN of two TableScans. `on` is the ON clause
    // (pre-resolved to use EColumnRef over both scopes). Outer WHERE
    // lives in an enclosing PnFilter.
    // UNION ALL — concatenate two plan pipelines' ResultRow emissions.
    | PnUnionAll(left: Heap<PlanNode>, right: Heap<PlanNode>)
    // UNION (distinct) — concatenate then dedup. n_proj is the
    // projected column count (both sides must agree; the planner
    // enforces this where schema is available).
    | PnUnion(left: Heap<PlanNode>, right: Heap<PlanNode>, n_proj: Int)
    // INTERSECT (distinct) — emit rows present in BOTH sides.
    | PnIntersect(left: Heap<PlanNode>, right: Heap<PlanNode>, n_proj: Int)
    // EXCEPT (distinct) — emit rows present in left but NOT in right.
    | PnExcept(left: Heap<PlanNode>, right: Heap<PlanNode>, n_proj: Int)
    | PnNestedLoopJoin(
          left_table: TableRef,
          left_cid: Int,
          left_ncols: Int,
          right_table: TableRef,
          right_cid: Int,
          right_ncols: Int,
          on: Maybe<Expr>,
          is_left_outer: Bool,
      )
    | PnLimit(child: Heap<PlanNode>, limit: Expr, offset: Maybe<Expr>)
    | PnInsert(table: TableRef, columns: List<Text>, source: Heap<PlanNode>, on_conflict: Maybe<SqlOnConflict>)
    | PnDelete(table: TableRef, cursor_id: Int, predicate: Maybe<Expr>)
    | PnUpdate(table: TableRef, cursor_id: Int, n_cols: Int, assignments: List<UpdateAssignment>, predicate: Maybe<Expr>)
    | PnCreateTable(stmt: CreateTableStmt)
    | PnDrop(kind: DropPlanKind, if_exists: Bool, target: TableRef)
    | PnTransaction(tx: TxAction)
    | PnPragma(name: Text, value: Maybe<Expr>)
    // DDL side-effects we don't need to codegen beyond a Halt — the
    // facade layer applies schema-cache mutations pre-compile.
    | PnNoop;

public type DropPlanKind is DpkTable | DpkIndex | DpkView | DpkTrigger;

public type TxAction is
      TxBegin
    | TxCommit
    | TxRollback(savepoint: Maybe<Text>)
    | TxSavepoint(name: Text)
    | TxRelease(name: Text);

// -----------------------------------------------------------------------------
// Planning top-level
// -----------------------------------------------------------------------------

public fn plan_statement(stmt: &Statement) -> Result<PlanNode, PlanError> {
    match stmt {
        SSelect(sel)        => plan_select(sel),
        SInsert(ins)        => plan_insert(ins),
        SUpdate(upd)        => plan_update(upd),
        SDelete(del)        => plan_delete(del),
        SCreateTable(ct)    => Result.Ok(PnCreateTable(clone_create_table(ct))),
        SCreateIndex(_)     => Result.Ok(PnNoop),
        SCreateView(_)      => Result.Ok(PnNoop),
        SDropTable(f, t)    => Result.Ok(PnDrop(DpkTable, f, clone_table_ref(t))),
        SDropIndex(f, t)    => Result.Ok(PnDrop(DpkIndex, f, clone_table_ref(t))),
        SDropView(f, t)     => Result.Ok(PnDrop(DpkView, f, clone_table_ref(t))),
        SDropTrigger(f, t)  => Result.Ok(PnDrop(DpkTrigger, f, clone_table_ref(t))),
        SBeginTransaction   => Result.Ok(PnTransaction(TxBegin)),
        SCommit             => Result.Ok(PnTransaction(TxCommit)),
        SRollback(sp)       => Result.Ok(PnTransaction(TxRollback(clone_opt_text(sp)))),
        SSavepoint(n)       => Result.Ok(PnTransaction(TxSavepoint(n.clone()))),
        SRelease(n)         => Result.Ok(PnTransaction(TxRelease(n.clone()))),
        SPragma(name, val)  => Result.Ok(PnPragma(name.clone(), clone_opt_expr(val))),
        SExplain(_, _)      => Result.Err(plan_error("EXPLAIN planning not supported yet".clone())),
        _                   => Result.Err(plan_error("statement kind not supported by v1 planner".clone())),
    }
}

// -----------------------------------------------------------------------------
// SELECT
// -----------------------------------------------------------------------------

fn plan_select(sel: &SelectStmt) -> Result<PlanNode, PlanError> {
    // Compound SELECT — recursively plan both sides, then wrap in the
    // corresponding compound node. Outer ORDER BY / LIMIT (held on
    // `sel`) is applied AFTER the compound op, mirroring SQL semantics.
    let simple = match sel.kind {
        SkSimple(ref s) => s,
        SkCompound(op, ref lhs, ref rhs) => {
            let lp = plan_select(lhs)?;
            let rp = plan_select(rhs)?;
            let n_proj = compound_proj_count(lhs);
            let mut compound: PlanNode = match op {
                CoUnionAll  => PnUnionAll(Heap(lp), Heap(rp)),
                CoUnion     => PnUnion(Heap(lp), Heap(rp), n_proj),
                CoIntersect => PnIntersect(Heap(lp), Heap(rp), n_proj),
                CoExcept    => PnExcept(Heap(lp), Heap(rp), n_proj),
            };
            // Outer ORDER BY / LIMIT applies to the compound result.
            if sel.order_by.len() > 0 {
                compound = PnSort(Heap(compound), clone_order_terms(&sel.order_by));
            }
            match sel.limit {
                Maybe.Some(ref lc) => {
                    let off: Maybe<Expr> = match lc.offset {
                        Maybe.Some(ref e) => Maybe.Some(clone_expr(e)),
                        Maybe.None => Maybe.None,
                    };
                    compound = PnLimit(Heap(compound), clone_expr(&lc.limit), off);
                }
                Maybe.None => {}
            }
            return Result.Ok(compound);
        }
    };

    // Source: either FROM clause or VALUES-like bare SELECT (no FROM).
    let mut node: PlanNode = match simple.from {
        Maybe.Some(ref fi) => plan_from_item(fi, 0)?,
        Maybe.None => {
            // SELECT without FROM produces one row of constants — model
            // as PnValues with a single row of the result exprs.
            let mut row: List<Expr> = List.new();
            let mut i: Int = 0;
            while i < simple.result_columns.len() {
                match simple.result_columns[i] {
                    RcExpr(ref e, _) => row.push(clone_expr(e)),
                    RcStar | RcTableStar(_) => {
                        return Result.Err(plan_error("SELECT * with no FROM is invalid".clone()));
                    }
                }
                i = i + 1;
            }
            let mut rows: List<List<Expr>> = List.new();
            let col_count = row.len();
            rows.push(row);
            PnValues(rows, col_count)
        }
    };

    // WHERE.
    match simple.where_clause {
        Maybe.Some(ref w) => { node = PnFilter(Heap(node), clone_expr(w)); }
        Maybe.None => {}
    }

    // Projection (always attach — keeps codegen uniform). Skip when
    // source is PnValues (columns already materialised as-is).
    let needs_project = match node { PnValues(_, _) => false, _ => true };
    if needs_project {
        let mut cols: List<PlanColumn> = List.new();
        let mut i: Int = 0;
        while i < simple.result_columns.len() {
            match simple.result_columns[i] {
                RcExpr(ref e, ref alias) => {
                    cols.push(PlanColumn { alias: alias.clone(), expr: clone_expr(e) });
                }
                RcStar => {
                    // Codegen materialises `*` by querying the cursor's
                    // declared n_cols at emit time; we carry a
                    // placeholder literal to signal it.
                    cols.push(PlanColumn { alias: "*".clone(), expr: ELit(LStar) });
                }
                RcTableStar(ref tref) => {
                    // Same deal but scoped to one table.
                    cols.push(PlanColumn { alias: tref.name.clone() + ".*".clone(), expr: ELit(LStar) });
                }
            }
            i = i + 1;
        }
        node = PnProject(Heap(node), cols);
    }

    // ORDER BY.
    if sel.order_by.len() > 0 {
        node = PnSort(Heap(node), clone_order_terms(&sel.order_by));
    }

    // LIMIT / OFFSET.
    match sel.limit {
        Maybe.Some(ref lc) => {
            let off: Maybe<Expr> = match lc.offset {
                Maybe.Some(ref e) => Maybe.Some(clone_expr(e)),
                Maybe.None => Maybe.None,
            };
            node = PnLimit(Heap(node), clone_expr(&lc.limit), off);
        }
        Maybe.None => {}
    }

    Result.Ok(node)
}

fn plan_from_item(fi: &FromItem, cursor_id: Int) -> Result<PlanNode, PlanError> {
    match fi {
        FiTable(ref tref) => Result.Ok(PnTableScan(clone_table_ref(tref), cursor_id, -1)),
        FiSubquery(_, _)  => Result.Err(plan_error("subquery FROM not supported in v1".clone())),
        FiJoin(_, _)      => Result.Err(plan_error("JOIN planning not supported in v1".clone())),
    }
}

// -----------------------------------------------------------------------------
// INSERT / UPDATE / DELETE
// -----------------------------------------------------------------------------

fn plan_insert(ins: &InsertStmt) -> Result<PlanNode, PlanError> {
    let source = match ins.source {
        IsValues(ref rows) => {
            let cloned = clone_rows(rows);
            let col_count = if cloned.len() == 0 { 0 } else { cloned[0].len() };
            PnValues(cloned, col_count)
        }
        IsDefault => PnValues(List.new(), 0),
        IsSelect(_) => { return Result.Err(plan_error("INSERT ... SELECT not supported in v1".clone())); }
    };
    Result.Ok(PnInsert(
        clone_table_ref(&ins.table),
        clone_text_list(&ins.columns),
        Heap(source),
        clone_opt_on_conflict(&ins.on_conflict),
    ))
}

fn plan_update(upd: &UpdateStmt) -> Result<PlanNode, PlanError> {
    let cursor_id = 0;
    let pred: Maybe<Expr> = match upd.where_clause {
        Maybe.Some(ref e) => Maybe.Some(clone_expr(e)),
        Maybe.None => Maybe.None,
    };
    Result.Ok(PnUpdate(
        clone_table_ref(&upd.table),
        cursor_id,
        0,                               // n_cols unknown without schema
        clone_assignments(&upd.assignments),
        pred,
    ))
}

fn plan_delete(del: &DeleteStmt) -> Result<PlanNode, PlanError> {
    let cursor_id = 0;
    let pred: Maybe<Expr> = match del.where_clause {
        Maybe.Some(ref e) => Maybe.Some(clone_expr(e)),
        Maybe.None => Maybe.None,
    };
    Result.Ok(PnDelete(clone_table_ref(&del.table), cursor_id, pred))
}

// -----------------------------------------------------------------------------
// Deep-clone helpers (Verum v1 has no derive(Clone) for these)
// -----------------------------------------------------------------------------

public fn clone_table_ref(t: &TableRef) -> TableRef {
    TableRef {
        schema: t.schema.clone(),
        name: t.name.clone(),
        alias: t.alias.clone(),
    }
}

fn clone_opt_text(o: &Maybe<Text>) -> Maybe<Text> {
    match o {
        Maybe.Some(ref s) => Maybe.Some(s.clone()),
        Maybe.None => Maybe.None,
    }
}

fn clone_opt_on_conflict(o: &Maybe<SqlOnConflict>) -> Maybe<SqlOnConflict> {
    match o {
        Maybe.Some(ref c) => Maybe.Some(c),
        Maybe.None => Maybe.None,
    }
}

fn clone_text_list(xs: &List<Text>) -> List<Text> {
    let mut out: List<Text> = List.new();
    let mut i: Int = 0;
    while i < xs.len() {
        out.push(xs[i].clone());
        i = i + 1;
    }
    out
}

fn clone_rows(rows: &List<List<Expr>>) -> List<List<Expr>> {
    let mut out: List<List<Expr>> = List.new();
    let mut i: Int = 0;
    while i < rows.len() {
        let mut row: List<Expr> = List.new();
        let mut j: Int = 0;
        while j < rows[i].len() {
            row.push(clone_expr(&rows[i][j]));
            j = j + 1;
        }
        out.push(row);
        i = i + 1;
    }
    out
}

fn clone_assignments(xs: &List<UpdateAssignment>) -> List<UpdateAssignment> {
    let mut out: List<UpdateAssignment> = List.new();
    let mut i: Int = 0;
    while i < xs.len() {
        out.push(UpdateAssignment {
            column: xs[i].column.clone(),
            col_idx: xs[i].col_idx,
            value: clone_expr(&xs[i].value),
        });
        i = i + 1;
    }
    out
}

// Recover the projection width of a planned subtree. Used as a
// fallback when the AST-side `compound_proj_count` returns -1 (i.e.
// the lhs uses `SELECT *` / `t.*`); the post-projection plan node
// structure exposes the resolved count.
fn plan_node_proj_count(node: &PlanNode) -> Int {
    match node {
        PnProject(_, ref cols) => cols.len(),
        PnDistinct(_, n_proj) => n_proj,
        PnGroupBy(_, _, ref projection, _) => projection.len(),
        PnValues(_, col_count) => col_count,
        PnSort(ref child, _) => plan_node_proj_count(child),
        PnLimit(ref child, _, _) => plan_node_proj_count(child),
        PnFilter(ref child, _) => plan_node_proj_count(child),
        PnUnion(_, _, n_proj) => n_proj,
        PnIntersect(_, _, n_proj) => n_proj,
        PnExcept(_, _, n_proj) => n_proj,
        PnUnionAll(ref l, _) => plan_node_proj_count(l),
        // Conservative fallback — codegen will reject this anyway.
        _ => 0,
    }
}

// Walk a SELECT statement to find the column count produced by the
// leftmost simple SELECT. Compound semantics (UNION, INTERSECT,
// EXCEPT) require both sides to have the same column count; we use
// the left side as the reference (mirrors SQLite's own behaviour).
//

// Returns -1 for `SELECT *` / `SELECT t.*` since the actual column
// count needs schema; those cases fall through to the schema-aware
// planner which has access to table metadata.
fn compound_proj_count(sel: &SelectStmt) -> Int {
    match sel.kind {
        SkSimple(ref s) => {
            let mut count: Int = 0;
            let mut i: Int = 0;
            while i < s.result_columns.len() {
                match s.result_columns[i] {
                    RcExpr(_, _) => { count = count + 1; }
                    RcStar | RcTableStar(_) => { return -1; }
                }
                i = i + 1;
            }
            count
        }
        SkCompound(_, ref lhs, _) => compound_proj_count(lhs),
    }
}

fn clone_order_terms(xs: &List<OrderTerm>) -> List<OrderTerm> {
    let mut out: List<OrderTerm> = List.new();
    let mut i: Int = 0;
    while i < xs.len() {
        out.push(OrderTerm {
            expr: clone_expr(&xs[i].expr),
            direction: xs[i].direction,
            nulls_first: xs[i].nulls_first,
        });
        i = i + 1;
    }
    out
}

fn clone_opt_expr(o: &Maybe<Expr>) -> Maybe<Expr> {
    match o {
        Maybe.Some(ref e) => Maybe.Some(clone_expr(e)),
        Maybe.None => Maybe.None,
    }
}

public fn clone_expr(e: &Expr) -> Expr {
    match e {
        ELit(ref lit)      => ELit(clone_literal(lit)),
        EColumn(ref t, ref n) => EColumn(clone_table_ref(t), n.clone()),
        EVar(ref s)        => EVar(s.clone()),
        EPositional(n)     => EPositional(n),
        EUnary(op, ref x)  => EUnary(op, Heap(clone_expr(x))),
        EBinary(op, ref a, ref b) => EBinary(op, Heap(clone_expr(a)), Heap(clone_expr(b))),
        EFunc(ref n, ref args, d) => EFunc(n.clone(), clone_expr_list(args), d),
        ECase(ref s, ref arms, ref el) => ECase(
            match s { Maybe.Some(ref x) => Maybe.Some(Heap(clone_expr(x))), Maybe.None => Maybe.None },
            clone_case_arms(arms),
            match el { Maybe.Some(ref x) => Maybe.Some(Heap(clone_expr(x))), Maybe.None => Maybe.None },
        ),
        EIn(ref e, ref xs, neg) => EIn(Heap(clone_expr(e)), clone_expr_list(xs), neg),
        // Subquery expressions are rejected by the resolver
        // (`TooComplex("subquery in expression")`) before reaching
        // clone_expr. Pre-fix these arms silently coerced to
        // `ELit(LNull)`, so any future code path that cloned a
        // pre-resolution expression would smuggle NULL into a subquery
        // position — `WHERE id IN (SELECT ...)` becomes `WHERE id IN
        // NULL` ≡ unknown-for-every-row → empty result set. Panic
        // loudly instead so the bug surfaces immediately rather than
        // returning a wrong-answer result set.
        EInSubquery(_, _, _) => panic("clone_expr: EInSubquery should be rejected by the resolver before clone"),
        EBetween(ref e, ref lo, ref hi, neg) => EBetween(
            Heap(clone_expr(e)), Heap(clone_expr(lo)), Heap(clone_expr(hi)), neg,
        ),
        ELike(ref e, ref p, ref esc, neg) => ELike(
            Heap(clone_expr(e)),
            Heap(clone_expr(p)),
            match esc { Maybe.Some(ref x) => Maybe.Some(Heap(clone_expr(x))), Maybe.None => Maybe.None },
            neg,
        ),
        ECast(ref x, ref t) => ECast(Heap(clone_expr(x)), t.clone()),
        ECollate(ref x, ref n) => ECollate(Heap(clone_expr(x)), n.clone()),
        EExists(_, _)   => panic("clone_expr: EExists should be rejected by the resolver before clone"),
        ESubquery(_)    => panic("clone_expr: ESubquery should be rejected by the resolver before clone"),
        ENullIf(ref a, ref b) => ENullIf(Heap(clone_expr(a)), Heap(clone_expr(b))),
        ECoalesce(ref xs)     => ECoalesce(clone_expr_list(xs)),
        EColumnRef(cid, idx)  => EColumnRef(cid, idx),
    }
}

fn clone_expr_list(xs: &List<Expr>) -> List<Expr> {
    let mut out: List<Expr> = List.new();
    let mut i: Int = 0;
    while i < xs.len() {
        out.push(clone_expr(&xs[i]));
        i = i + 1;
    }
    out
}

fn clone_case_arms(xs: &List<(Expr, Expr)>) -> List<(Expr, Expr)> {
    let mut out: List<(Expr, Expr)> = List.new();
    let mut i: Int = 0;
    while i < xs.len() {
        out.push((clone_expr(&xs[i].0), clone_expr(&xs[i].1)));
        i = i + 1;
    }
    out
}

fn clone_literal(l: &SqlLiteral) -> SqlLiteral {
    match l {
        LNull  => LNull,
        LInt(i) => LInt(i),
        LReal(x) => LReal(x),
        LText(ref s) => LText(s.clone()),
        LBlob(ref b) => {
            let mut out: List<Byte> = List.with_capacity(b.len());
            out.extend_from_slice(b.as_slice());
            LBlob(out)
        }
        LTrue => LTrue,
        LFalse => LFalse,
        LCurrentDate => LCurrentDate,
        LCurrentTime => LCurrentTime,
        LCurrentTimestamp => LCurrentTimestamp,
        LStar => LStar,
    }
}

fn clone_create_table(ct: &CreateTableStmt) -> CreateTableStmt {
    // Constraints cloning is heavy — for v1 the planner just forwards
    // the AST value; clone by pushing it through a constructor that
    // the codegen never mutates.
    CreateTableStmt {
        if_not_exists: ct.if_not_exists,
        temporary: ct.temporary,
        table: clone_table_ref(&ct.table),
        columns: ct.columns.clone(),
        constraints: ct.constraints.clone(),
        strict: ct.strict,
        without_rowid: ct.without_rowid,
    }
}

// =============================================================================
// Schema-aware planning — threads SchemaCache through for TableScan
// =============================================================================

mount core.database.sqlite.native.l6_session.schema_cache.{SchemaCache, TableMeta};
mount core.database.sqlite.native.l5_sql.resolver.{
    ColumnScope, resolve_expr, scope_from_table_meta,
    ResolveError,
};

/// Plan a statement against a live SchemaCache. For SELECT over a
/// single FROM table the planner:
///

///  1. Looks up the table's metadata (root_page, column list).
///  2. Builds a ColumnScope and resolves EColumn → EColumnRef in
///  every result-column expression + WHERE predicate.
///  3. Emits PnTableScan with the real root_page + n_cols, wraps
///  with PnFilter / PnProject / PnLimit.
///

/// For non-SELECT statements the schema cache is consulted only for
/// validation hooks; the rest falls through to plain `plan_statement`.
public fn plan_statement_with_schema(
    stmt: &Statement,
    schema: &SchemaCache,
) -> Result<PlanNode, PlanError> {
    match stmt {
        SSelect(ref sel) => plan_select_with_schema(sel, schema),
        SUpdate(ref upd) => plan_update_with_schema(upd, schema),
        SDelete(ref del) => plan_delete_with_schema(del, schema),
        SInsert(ref ins) => plan_insert_with_schema(ins, schema),
        _ => plan_statement(stmt),
    }
}

fn plan_insert_with_schema(
    ins: &InsertStmt,
    schema: &SchemaCache,
) -> Result<PlanNode, PlanError> {
    let source = match ins.source {
        IsValues(ref rows) => {
            let cloned = clone_rows(rows);
            let col_count = if cloned.len() == 0 { 0 } else { cloned[0].len() };
            PnValues(cloned, col_count)
        }
        IsDefault => PnValues(List.new(), 0),
        IsSelect(ref sel) => {
            // INSERT ... SELECT delegates to the SELECT planner so the
            // sub-query gets full FROM/WHERE/JOIN/GROUP BY/ORDER BY
            // resolution. The PnInsert wrapper below treats the result
            // as a row stream — column count is determined by the
            // SELECT's projection, validated against the INSERT column
            // list (or table schema if no explicit column list) downstream
            // by the codegen.
            match plan_select_with_schema(sel, schema) {
                Result.Ok(p)  => p,
                Result.Err(e) => { return Result.Err(e); }
            }
        }
    };
    Result.Ok(PnInsert(
        clone_table_ref(&ins.table),
        clone_text_list(&ins.columns),
        Heap(source),
        clone_opt_on_conflict(&ins.on_conflict),
    ))
}

fn plan_update_with_schema(
    upd: &UpdateStmt,
    schema: &SchemaCache,
) -> Result<PlanNode, PlanError> {
    let meta = match schema.lookup_table(&upd.table.schema, &upd.table.name) {
        Result.Ok(m)  => m,
        Result.Err(_) => { return Result.Err(plan_error("UPDATE on unknown table".clone())); }
    };

    let cursor_id: Int = 0;
    let scope = scope_from_table_meta(cursor_id, upd.table.alias.clone(), &meta);
    let mut scopes: List<ColumnScope> = List.new();
    scopes.push(scope);

    // Resolve each assignment: look up col_idx + resolve the value
    // expression's column references.
    let mut resolved: List<UpdateAssignment> = List.new();
    let mut i: Int = 0;
    while i < upd.assignments.len() {
        let a = &upd.assignments[i];
        let mut col_idx: Int = -1;
        let mut k: Int = 0;
        while k < meta.columns.len() {
            if meta.columns[k].name == a.column.clone() {
                col_idx = k;
                break;
            }
            k = k + 1;
        }
        if col_idx < 0 {
            return Result.Err(plan_error("SET references unknown column".clone()));
        }
        let value = match resolve_expr(&a.value, &scopes) {
            Result.Ok(e)  => e,
            Result.Err(_) => { return Result.Err(plan_error("SET value resolution failed".clone())); }
        };
        resolved.push(UpdateAssignment {
            column: a.column.clone(),
            col_idx: col_idx,
            value: value,
        });
        i = i + 1;
    }

    let pred: Maybe<Expr> = match upd.where_clause {
        Maybe.Some(ref e) => {
            match resolve_expr(e, &scopes) {
                Result.Ok(r)  => Maybe.Some(r),
                Result.Err(_) => { return Result.Err(plan_error("UPDATE WHERE resolve failed".clone())); }
            }
        }
        Maybe.None => Maybe.None,
    };

    Result.Ok(PnUpdate(
        clone_table_ref(&upd.table),
        cursor_id,
        meta.columns.len(),
        resolved,
        pred,
    ))
}

fn plan_delete_with_schema(
    del: &DeleteStmt,
    schema: &SchemaCache,
) -> Result<PlanNode, PlanError> {
    let meta = match schema.lookup_table(&del.table.schema, &del.table.name) {
        Result.Ok(m)  => m,
        Result.Err(_) => { return Result.Err(plan_error("DELETE from unknown table".clone())); }
    };
    let cursor_id: Int = 0;
    let scope = scope_from_table_meta(cursor_id, del.table.alias.clone(), &meta);
    let mut scopes: List<ColumnScope> = List.new();
    scopes.push(scope);

    let pred: Maybe<Expr> = match del.where_clause {
        Maybe.Some(ref e) => {
            match resolve_expr(e, &scopes) {
                Result.Ok(r)  => Maybe.Some(r),
                Result.Err(_) => { return Result.Err(plan_error("DELETE WHERE resolve failed".clone())); }
            }
        }
        Maybe.None => Maybe.None,
    };

    Result.Ok(PnDelete(clone_table_ref(&del.table), cursor_id, pred))
}

/// Resolve the SELECT's FROM clause. Returns the pre-WHERE plan
/// node + the column scopes + the "primary" meta for `SELECT *`
/// expansion + the default cursor_id for qualified column lookup.
///

/// v1 handles: FROM t, FROM t JOIN u ON … (INNER / CROSS only,
/// single-level JOIN). Subqueries and RIGHT/FULL/LEFT OUTER joins
/// defer to a later pass.
fn plan_from_for_select(
    fi: &FromItem,
    schema: &SchemaCache,
) -> Result<(PlanNode, List<ColumnScope>, TableMeta, Int), PlanError> {
    match fi {
        FiTable(ref t) => {
            let meta = match schema.lookup_table(&t.schema, &t.name) {
                Result.Ok(m)  => m,
                Result.Err(_) => { return Result.Err(plan_error("unknown table".clone())); }
            };
            let mut scopes: List<ColumnScope> = List.new();
            scopes.push(scope_from_table_meta(0, t.alias.clone(), &meta));
            let node = PnTableScan(clone_table_ref(t), 0, meta.columns.len());
            Result.Ok((node, scopes, meta, 0))
        }
        FiJoin(ref left_fi, ref jc) => {
            let lt_orig = match left_fi {
                FiTable(ref x) => x,
                _ => { return Result.Err(plan_error("nested JOINs pending in v1".clone())); }
            };
            let rt_orig = match jc.right {
                ref right_fi => match right_fi {
                    FiTable(ref x) => x,
                    _ => { return Result.Err(plan_error("JOIN right side must be a table in v1".clone())); }
                }
            };
            // RIGHT OUTER JOIN normalizes to LEFT OUTER with sides
            // swapped (the preserved side becomes the outer loop).
            // FULL OUTER JOIN rewrites to (LEFT JOIN) UNION ALL
            // (swapped-LEFT-JOIN-WHERE-IS-NULL) — handled separately
            // below since it produces a non-PnNestedLoopJoin top node.
            if jc.kind == JFullOuter {
                let lmeta_full = match schema.lookup_table(&lt_orig.schema, &lt_orig.name) {
                    Result.Ok(m)  => m,
                    Result.Err(_) => { return Result.Err(plan_error("JOIN left table unknown".clone())); }
                };
                let rmeta_full = match schema.lookup_table(&rt_orig.schema, &rt_orig.name) {
                    Result.Ok(m)  => m,
                    Result.Err(_) => { return Result.Err(plan_error("JOIN right table unknown".clone())); }
                };

                // Side 1: A LEFT JOIN B ON c — scopes [A@0, B@1].
                let mut scopes_l: List<ColumnScope> = List.new();
                scopes_l.push(scope_from_table_meta(0, lt_orig.alias.clone(), &lmeta_full));
                scopes_l.push(scope_from_table_meta(1, rt_orig.alias.clone(), &rmeta_full));
                let on_l: Maybe<Expr> = match jc.on {
                    Maybe.Some(ref e) => match resolve_expr(e, &scopes_l) {
                        Result.Ok(r)  => Maybe.Some(r),
                        Result.Err(_) => { return Result.Err(plan_error("FULL OUTER JOIN ON resolve (left side) failed".clone())); }
                    },
                    Maybe.None => Maybe.None,
                };
                let left_join = PnNestedLoopJoin(
                    clone_table_ref(lt_orig), 0, lmeta_full.columns.len(),
                    clone_table_ref(rt_orig), 1, rmeta_full.columns.len(),
                    on_l, true,
                );

                // Side 2: B LEFT JOIN A ON c — scopes [B@0, A@1] (sides swapped).
                let mut scopes_r: List<ColumnScope> = List.new();
                scopes_r.push(scope_from_table_meta(0, rt_orig.alias.clone(), &rmeta_full));
                scopes_r.push(scope_from_table_meta(1, lt_orig.alias.clone(), &lmeta_full));
                let on_r: Maybe<Expr> = match jc.on {
                    Maybe.Some(ref e) => match resolve_expr(e, &scopes_r) {
                        Result.Ok(r)  => Maybe.Some(r),
                        Result.Err(_) => { return Result.Err(plan_error("FULL OUTER JOIN ON resolve (right side) failed".clone())); }
                    },
                    Maybe.None => Maybe.None,
                };
                let swapped = PnNestedLoopJoin(
                    clone_table_ref(rt_orig), 0, rmeta_full.columns.len(),
                    clone_table_ref(lt_orig), 1, lmeta_full.columns.len(),
                    on_r, true,
                );

                // Filter: emit only rows where A had no match — A.<col0> IS NULL
                // (LEFT JOIN nullifies ALL right-side cols on no-match, so
                // any one column suffices as the sentinel). A is at cursor
                // 1 in the swapped scope.
                if lmeta_full.columns.len() == 0 {
                    return Result.Err(plan_error("FULL OUTER JOIN with empty-column left table".clone()));
                }
                let null_filter = EBinary(
                    BIs,
                    Heap(EColumnRef(1, 0)),
                    Heap(ELit(LNull)),
                );
                let filtered = PnFilter(Heap(swapped), null_filter);

                // PnProject: reorder swapped output [B.cols..., A.cols...]
                // → [A.cols..., B.cols...] so the UNION ALL operands have
                // matching column shape.
                let mut project_cols: List<PlanColumn> = List.new();
                let mut ai: Int = 0;
                while ai < lmeta_full.columns.len() {
                    project_cols.push(PlanColumn {
                        alias: lmeta_full.columns[ai].name.clone(),
                        expr:  EColumnRef(1, ai),    // A is at cursor 1
                    });
                    ai = ai + 1;
                }
                let mut bj: Int = 0;
                while bj < rmeta_full.columns.len() {
                    project_cols.push(PlanColumn {
                        alias: rmeta_full.columns[bj].name.clone(),
                        expr:  EColumnRef(0, bj),    // B is at cursor 0
                    });
                    bj = bj + 1;
                }
                let projected = PnProject(Heap(filtered), project_cols);

                let union_node = PnUnionAll(Heap(left_join), Heap(projected));

                // Outer scope for the surrounding query: A@0, B@1 (matches
                // left_join's natural shape, which UNION ALL preserves).
                let mut scopes_out: List<ColumnScope> = List.new();
                scopes_out.push(scope_from_table_meta(0, lt_orig.alias.clone(), &lmeta_full));
                scopes_out.push(scope_from_table_meta(1, rt_orig.alias.clone(), &rmeta_full));
                return Result.Ok((union_node, scopes_out, lmeta_full, 0));
            }

            let (lt, rt, is_left_outer) = match jc.kind {
                JInner | JCross => (lt_orig, rt_orig, false),
                JLeftOuter      => (lt_orig, rt_orig, true),
                JRightOuter     => (rt_orig, lt_orig, true),
                _ => { return Result.Err(plan_error("unrecognised JOIN kind".clone())); }
            };
            let lmeta = match schema.lookup_table(&lt.schema, &lt.name) {
                Result.Ok(m)  => m,
                Result.Err(_) => { return Result.Err(plan_error("JOIN left table unknown".clone())); }
            };
            let rmeta = match schema.lookup_table(&rt.schema, &rt.name) {
                Result.Ok(m)  => m,
                Result.Err(_) => { return Result.Err(plan_error("JOIN right table unknown".clone())); }
            };
            let mut scopes: List<ColumnScope> = List.new();
            scopes.push(scope_from_table_meta(0, lt.alias.clone(), &lmeta));
            scopes.push(scope_from_table_meta(1, rt.alias.clone(), &rmeta));
            let on_resolved: Maybe<Expr> = match jc.on {
                Maybe.Some(ref e) => match resolve_expr(e, &scopes) {
                    Result.Ok(r)  => Maybe.Some(r),
                    Result.Err(_) => { return Result.Err(plan_error("JOIN ON resolve failed".clone())); }
                },
                Maybe.None => Maybe.None,
            };
            let node = PnNestedLoopJoin(
                clone_table_ref(lt), 0, lmeta.columns.len(),
                clone_table_ref(rt), 1, rmeta.columns.len(),
                on_resolved,
                is_left_outer,
            );
            Result.Ok((node, scopes, lmeta, 0))
        }
        _ => Result.Err(plan_error("only FROM <table> or FROM a JOIN b supported in v1".clone())),
    }
}

fn plan_select_with_schema(
    sel: &SelectStmt,
    schema: &SchemaCache,
) -> Result<PlanNode, PlanError> {
    let simple = match sel.kind {
        SkSimple(ref s) => s,
        SkCompound(op, ref lhs, ref rhs) => {
            let lp = match plan_select_with_schema(lhs, schema) {
                Result.Ok(p)  => p, Result.Err(e) => { return Result.Err(e); }
            };
            let rp = match plan_select_with_schema(rhs, schema) {
                Result.Ok(p)  => p, Result.Err(e) => { return Result.Err(e); }
            };
            // Determine projection width — when the lhs is a simple
            // SELECT with no `*`, we know it from result_columns; for
            // `*`/`t.*` or nested compounds we resort to the count
            // produced by the lhs subplan structure. The codegen
            // never reads n_proj < 0; the schema resolver above has
            // already enforced agreement.
            let n_proj_left = compound_proj_count(lhs);
            let n_proj = if n_proj_left < 0 {
                plan_node_proj_count(&lp)
            } else {
                n_proj_left
            };
            let mut compound: PlanNode = match op {
                CoUnionAll  => PnUnionAll(Heap(lp), Heap(rp)),
                CoUnion     => PnUnion(Heap(lp), Heap(rp), n_proj),
                CoIntersect => PnIntersect(Heap(lp), Heap(rp), n_proj),
                CoExcept    => PnExcept(Heap(lp), Heap(rp), n_proj),
            };
            // Outer ORDER BY / LIMIT applies AFTER the compound op.
            if sel.order_by.len() > 0 {
                let mut resolved_terms: List<OrderTerm> = List.new();
                let mut t: Int = 0;
                while t < sel.order_by.len() {
                    let term = &sel.order_by[t];
                    // Compound ORDER BY can only reference position-
                    // independent expressions / column-position numbers;
                    // for v1 we accept the literal expr without scope
                    // resolution (matches schema-free planner).
                    resolved_terms.push(OrderTerm {
                        expr: clone_expr(&term.expr),
                        direction: term.direction,
                        nulls_first: term.nulls_first,
                    });
                    t = t + 1;
                }
                compound = PnSort(Heap(compound), resolved_terms);
            }
            match sel.limit {
                Maybe.Some(ref lc) => {
                    let off: Maybe<Expr> = match lc.offset {
                        Maybe.Some(ref e) => Maybe.Some(clone_expr(e)),
                        Maybe.None => Maybe.None,
                    };
                    compound = PnLimit(Heap(compound), clone_expr(&lc.limit), off);
                }
                Maybe.None => {}
            }
            return Result.Ok(compound);
        }
    };

    // No FROM → fall back to the schema-free planner.
    match simple.from {
        Maybe.None => { return plan_select(sel); }
        _ => {}
    }

    // Resolve FROM — single table, or single nested-loop JOIN of two.
    let from_res = match simple.from {
        Maybe.Some(ref fi) => plan_from_for_select(fi, schema),
        Maybe.None => { return Result.Err(plan_error("unreachable".clone())); }
    };
    let (node_pre_where, scopes, meta, cursor_id) = match from_res {
        Result.Ok(v)  => v,
        Result.Err(e) => { return Result.Err(e); }
    };
    let mut node: PlanNode = node_pre_where;

    // WHERE.
    match simple.where_clause {
        Maybe.Some(ref w) => {
            let resolved = match resolve_expr(w, &scopes) {
                Result.Ok(e)  => e,
                Result.Err(_) => { return Result.Err(plan_error("WHERE resolve failed".clone())); }
            };
            node = PnFilter(Heap(node), resolved);
        }
        Maybe.None => {}
    }

    // Projection — resolve every result column expression.
    let mut plan_cols: List<PlanColumn> = List.new();
    let mut i: Int = 0;
    while i < simple.result_columns.len() {
        match simple.result_columns[i] {
            RcExpr(ref e, ref alias) => {
                let resolved = match resolve_expr(e, &scopes) {
                    Result.Ok(r)  => r,
                    Result.Err(_) => { return Result.Err(plan_error("SELECT-list resolve failed".clone())); }
                };
                plan_cols.push(PlanColumn { alias: alias.clone(), expr: resolved });
            }
            RcStar => {
                // Expand `*` into one EColumnRef per column.
                let mut k: Int = 0;
                while k < meta.columns.len() {
                    plan_cols.push(PlanColumn {
                        alias: meta.columns[k].name.clone(),
                        expr: EColumnRef(cursor_id, k),
                    });
                    k = k + 1;
                }
            }
            RcTableStar(_) => {
                let mut k: Int = 0;
                while k < meta.columns.len() {
                    plan_cols.push(PlanColumn {
                        alias: meta.columns[k].name.clone(),
                        expr: EColumnRef(cursor_id, k),
                    });
                    k = k + 1;
                }
            }
        }
        i = i + 1;
    }
    let n_proj = plan_cols.len();

    // GROUP BY — if present, short-circuit the plain PnProject path
    // and emit a PnGroupBy wrapping the pre-project source.
    if simple.group_by.len() > 0 {
        let mut resolved_keys: List<Expr> = List.new();
        let mut g: Int = 0;
        while g < simple.group_by.len() {
            let resolved = match resolve_expr(&simple.group_by[g], &scopes) {
                Result.Ok(e)  => e,
                Result.Err(_) => { return Result.Err(plan_error("GROUP BY resolve failed".clone())); }
            };
            resolved_keys.push(resolved);
            g = g + 1;
        }
        let having: Maybe<Expr> = match simple.having {
            Maybe.Some(ref h) => match resolve_expr(h, &scopes) {
                Result.Ok(e)  => Maybe.Some(e),
                Result.Err(_) => { return Result.Err(plan_error("HAVING resolve failed".clone())); }
            },
            Maybe.None => Maybe.None,
        };
        node = PnGroupBy(Heap(node), resolved_keys, plan_cols, having);
    } else {
        node = PnProject(Heap(node), plan_cols);
        // DISTINCT — wrap after projection so the distinct rows match what
        // the user would see.
        if simple.distinct {
            node = PnDistinct(Heap(node), n_proj);
        }
    }

    // ORDER BY — resolve every term's expression against the same scope.
    if sel.order_by.len() > 0 {
        let mut resolved_terms: List<OrderTerm> = List.new();
        let mut t: Int = 0;
        while t < sel.order_by.len() {
            let term = &sel.order_by[t];
            let r_expr = match resolve_expr(&term.expr, &scopes) {
                Result.Ok(e)  => e,
                Result.Err(_) => { return Result.Err(plan_error("ORDER BY resolve failed".clone())); }
            };
            resolved_terms.push(OrderTerm {
                expr: r_expr,
                direction: term.direction,
                nulls_first: term.nulls_first,
            });
            t = t + 1;
        }
        node = PnSort(Heap(node), resolved_terms);
    }

    // LIMIT / OFFSET.
    match sel.limit {
        Maybe.Some(ref lc) => {
            let off: Maybe<Expr> = match lc.offset {
                Maybe.Some(ref e) => Maybe.Some(clone_expr(e)),
                Maybe.None => Maybe.None,
            };
            node = PnLimit(Heap(node), clone_expr(&lc.limit), off);
        }
        Maybe.None => {}
    }

    Result.Ok(node)
}
