module core.database.sqlite.native.l5_sql.parser.dml;

// =============================================================================
// l5_sql/parser/dml.vr — INSERT / UPDATE / DELETE
// =============================================================================
// Layer: 5
// Spec: sqlite.org/lang_{insert,update,delete}.html
//
// Grammar (minus the long tail of SQLite-specific niceties that land
// once planner+codegen can honour them):
//
//   insert-stmt = INSERT [OR conflict-action] INTO qualified-name
//                  [ ( col {, col} ) ]
//                  ( VALUES ( expr {, expr} ) {, ( expr ... )}
//                    | select-stmt
//                    | DEFAULT VALUES )
//                  [ RETURNING result-col {, result-col} ]
//
//   update-stmt = UPDATE [OR conflict-action] qualified-name
//                  SET column '=' expr {, column '=' expr}
//                  [ FROM from-clause ]
//                  [ WHERE expr ]
//                  [ RETURNING result-col {, result-col} ]
//
//   delete-stmt = DELETE FROM qualified-name
//                  [ WHERE expr ]
//                  [ RETURNING result-col {, result-col} ]
// =============================================================================

mount core.*;
mount collections.List;
mount base.{Result, Ok, Err, Text, Maybe};
mount core.database.sqlite.native.l5_sql.lexer.{
    Token, Keyword, Operator, Punct,
};
mount core.database.sqlite.native.l5_sql.ast.{
    Expr, ResultColumnItem, TableRef,
    InsertStmt, InsertSource, OnConflict,
    UpdateStmt, UpdateAssignment,
    DeleteStmt,
};
mount core.database.sqlite.native.l5_sql.parser.token_stream.{
    SqlTokenStream, ParseError, parse_error,
};
mount core.database.sqlite.native.l5_sql.parser.expr.parse_expr;

// -----------------------------------------------------------------------------
// INSERT
// -----------------------------------------------------------------------------

public fn parse_insert(ts: &mut SqlTokenStream) -> Result<InsertStmt, ParseError> {
    let replacing_form = ts.accept_keyword(KwReplace);
    let mut conflict: Maybe<OnConflict> = None;

    if !replacing_form {
        match ts.expect_keyword(KwInsert) { Ok(_) => {}, Err(e) => { return Err(e); } }
        // Optional `OR <conflict-action>`.
        if ts.accept_keyword(KwOr) {
            let c = match parse_conflict_action(ts) {
                Ok(c)  => c, Err(e) => { return Err(e); }
            };
            conflict = Some(c);
        }
    } else {
        conflict = Some(OcReplace);
    }

    match ts.expect_keyword(KwInto) { Ok(_) => {}, Err(e) => { return Err(e); } }

    let table = match parse_qualified_name(ts) {
        Ok(t)  => t, Err(e) => { return Err(e); }
    };

    // Optional column list: `(col1, col2, ...)`.
    let mut columns: List<Text> = List.new();
    if ts.accept_punct(PLParen) {
        loop {
            let col = match ts.expect_ident() {
                Ok(s)  => s, Err(e) => { return Err(e); }
            };
            columns.push(col);
            if !ts.accept_punct(PComma) { break; }
        }
        match ts.expect_punct(PRParen) { Ok(_) => {}, Err(e) => { return Err(e); } }
    }

    // Source — VALUES / SELECT / DEFAULT VALUES.
    let source = match parse_insert_source(ts) {
        Ok(s)  => s, Err(e) => { return Err(e); }
    };

    // Optional RETURNING.
    let returning = match parse_returning(ts) {
        Ok(v)  => v, Err(e) => { return Err(e); }
    };

    Ok(InsertStmt {
        table: table,
        columns: columns,
        source: source,
        on_conflict: conflict,
        returning: returning,
    })
}

fn parse_insert_source(ts: &mut SqlTokenStream) -> Result<InsertSource, ParseError> {
    if ts.accept_keyword(KwDefault) {
        match ts.expect_keyword(KwValues) { Ok(_) => {}, Err(e) => { return Err(e); } }
        return Ok(IsDefault);
    }
    if ts.accept_keyword(KwValues) {
        let mut rows: List<List<Expr>> = List.new();
        loop {
            match ts.expect_punct(PLParen) { Ok(_) => {}, Err(e) => { return Err(e); } }
            let mut row: List<Expr> = List.new();
            if !ts.check_punct(PRParen) {
                loop {
                    let e = match parse_expr(ts) {
                        Ok(x)  => x, Err(err) => { return Err(err); }
                    };
                    row.push(e);
                    if !ts.accept_punct(PComma) { break; }
                }
            }
            match ts.expect_punct(PRParen) { Ok(_) => {}, Err(e) => { return Err(e); } }
            rows.push(row);
            if !ts.accept_punct(PComma) { break; }
        }
        return Ok(IsValues(rows));
    }
    // SELECT source lands when select's sub-query path is wired; for
    // the v1 insert we expose the gap.
    Err(parse_error(
        "INSERT ... SELECT not yet supported in L5.4 initial cut".clone(),
        ts.position(),
    ))
}

// -----------------------------------------------------------------------------
// UPDATE
// -----------------------------------------------------------------------------

public fn parse_update(ts: &mut SqlTokenStream) -> Result<UpdateStmt, ParseError> {
    match ts.expect_keyword(KwUpdate) { Ok(_) => {}, Err(e) => { return Err(e); } }

    let mut conflict: Maybe<OnConflict> = None;
    if ts.accept_keyword(KwOr) {
        let c = match parse_conflict_action(ts) {
            Ok(c)  => c, Err(e) => { return Err(e); }
        };
        conflict = Some(c);
    }

    let table = match parse_qualified_name(ts) {
        Ok(t)  => t, Err(e) => { return Err(e); }
    };

    match ts.expect_keyword(KwSet) { Ok(_) => {}, Err(e) => { return Err(e); } }

    let mut assignments: List<UpdateAssignment> = List.new();
    loop {
        let col = match ts.expect_ident() {
            Ok(s)  => s, Err(e) => { return Err(e); }
        };
        if !ts.accept_op(OpEq) {
            return Err(parse_error("expected '=' in SET".clone(), ts.position()));
        }
        let value = match parse_expr(ts) {
            Ok(x)  => x, Err(err) => { return Err(err); }
        };
        assignments.push(UpdateAssignment { column: col, col_idx: -1, value: value });
        if !ts.accept_punct(PComma) { break; }
    }

    let mut where_clause: Maybe<Expr> = None;
    if ts.accept_keyword(KwWhere) {
        let e = match parse_expr(ts) {
            Ok(x)  => x, Err(err) => { return Err(err); }
        };
        where_clause = Some(e);
    }

    let returning = match parse_returning(ts) {
        Ok(v)  => v, Err(e) => { return Err(e); }
    };

    Ok(UpdateStmt {
        table: table,
        assignments: assignments,
        from: None,      // `UPDATE ... FROM ...` lands with subquery support
        where_clause: where_clause,
        on_conflict: conflict,
        returning: returning,
    })
}

// -----------------------------------------------------------------------------
// DELETE
// -----------------------------------------------------------------------------

public fn parse_delete(ts: &mut SqlTokenStream) -> Result<DeleteStmt, ParseError> {
    match ts.expect_keyword(KwDelete) { Ok(_) => {}, Err(e) => { return Err(e); } }
    match ts.expect_keyword(KwFrom) { Ok(_) => {}, Err(e) => { return Err(e); } }

    let table = match parse_qualified_name(ts) {
        Ok(t)  => t, Err(e) => { return Err(e); }
    };

    let mut where_clause: Maybe<Expr> = None;
    if ts.accept_keyword(KwWhere) {
        let e = match parse_expr(ts) {
            Ok(x)  => x, Err(err) => { return Err(err); }
        };
        where_clause = Some(e);
    }

    let returning = match parse_returning(ts) {
        Ok(v)  => v, Err(e) => { return Err(e); }
    };

    Ok(DeleteStmt {
        table: table,
        where_clause: where_clause,
        returning: returning,
    })
}

// -----------------------------------------------------------------------------
// Shared helpers
// -----------------------------------------------------------------------------

fn parse_conflict_action(ts: &mut SqlTokenStream) -> Result<OnConflict, ParseError> {
    if ts.accept_keyword(KwAbort)    { return Ok(OcAbort); }
    if ts.accept_keyword(KwFail)     { return Ok(OcFail); }
    if ts.accept_keyword(KwIgnore)   { return Ok(OcIgnore); }
    if ts.accept_keyword(KwReplace)  { return Ok(OcReplace); }
    if ts.accept_keyword(KwRollback) { return Ok(OcRollback); }
    Err(parse_error("expected conflict action".clone(), ts.position()))
}

fn parse_qualified_name(ts: &mut SqlTokenStream) -> Result<TableRef, ParseError> {
    let first = match ts.expect_ident() {
        Ok(s)  => s, Err(e) => { return Err(e); }
    };
    if ts.accept_punct(PDot) {
        let second = match ts.expect_ident() {
            Ok(s)  => s, Err(e) => { return Err(e); }
        };
        return Ok(TableRef { schema: first, name: second, alias: "".clone() });
    }
    Ok(TableRef { schema: "".clone(), name: first, alias: "".clone() })
}

fn parse_returning(ts: &mut SqlTokenStream) -> Result<List<ResultColumnItem>, ParseError> {
    let mut out: List<ResultColumnItem> = List.new();
    if !ts.accept_keyword(KwReturning) { return Ok(out); }
    loop {
        // Reuse the RcExpr form — `RETURNING *` / `RETURNING t.*` are
        // handled as expressions by the parser at this point; the
        // codegen normalises. For v1 we accept only expression-form.
        if ts.accept_punct(PStar) {
            out.push(RcStar);
        } else {
            let e = match parse_expr(ts) {
                Ok(x)  => x, Err(err) => { return Err(err); }
            };
            let alias = if ts.accept_keyword(KwAs) {
                match ts.expect_ident() {
                    Ok(s)  => s, Err(err) => { return Err(err); }
                }
            } else {
                "".clone()
            };
            out.push(RcExpr(e, alias));
        }
        if !ts.accept_punct(PComma) { break; }
    }
    Ok(out)
}
