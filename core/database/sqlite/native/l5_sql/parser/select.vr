@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.database.sqlite.native.l5_sql.parser.select;

// =============================================================================
// l5_sql/parser/select.vr — SELECT statement parser
// =============================================================================
// Layer: 5
// Spec: sqlite.org/lang_select.html, sqlite-native.md §12.2
//

// Grammar implemented:
//

//  select-stmt = simple-select { compound-op simple-select }
//  [ ORDER BY order-term {, order-term} ]
//  [ LIMIT expr [OFFSET expr] ]
//

//  simple-select = SELECT [DISTINCT|ALL] result-cols
//  [ FROM from-clause ]
//  [ WHERE expr ]
//  [ GROUP BY expr {, expr} ]
//  [ HAVING expr ]
//

//  compound-op = UNION | UNION ALL | INTERSECT | EXCEPT
//

//  result-cols = result-col {, result-col}
//  result-col = `*` | ident `.` `*` | expr [AS ident]
//

//  from-clause = from-item { join-clause }
//  from-item = table-ref [AS? alias]
//  join-clause = join-op from-item [ON expr | USING (cols)]
//  join-op = [NATURAL] [LEFT|RIGHT|FULL [OUTER]| INNER| CROSS] JOIN
//

//  order-term = expr [COLLATE ident] [ASC|DESC] [NULLS FIRST|LAST]
// =============================================================================

mount core.*;
mount collections.List;
mount base.{Result, Ok, Err, Text, Maybe};
mount core.database.sqlite.native.l5_sql.lexer.{
    SqlKeyword, Operator, Punct,
};
mount core.database.sqlite.native.l5_sql.ast.{
    SqlStatement, Expr, SelectStmt, SelectKind, SimpleSelect,
    ResultColumnItem, FromItem, JoinClause, SqlJoinKind,
    OrderTerm, OrderDirection, LimitClause,
    TableRef, CompoundOp,
};
mount core.database.sqlite.native.l5_sql.parser.token_stream.{
    SqlTokenStream, ParseError, parse_error,
};
mount core.database.sqlite.native.l5_sql.parser.expr.parse_expr;

// -----------------------------------------------------------------------------
// Entry point
// -----------------------------------------------------------------------------

public fn parse_select(ts: &mut SqlTokenStream) -> Result<SelectStmt, ParseError> {
    let first = match parse_simple(ts) {
        Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
    };

    // Compound chains: left-associative.
    let mut kind: SelectKind = SkSimple(first);
    loop {
        let op_opt = detect_compound_op(ts);
        match op_opt {
            Maybe.Some(op) => {
                let rhs = match parse_simple(ts) {
                    Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
                };
                let lhs_wrapped = SelectStmt { kind: kind, order_by: List.new(), limit: Maybe.None };
                let rhs_wrapped = SelectStmt { kind: SkSimple(rhs), order_by: List.new(), limit: Maybe.None };
                kind = SkCompound(op, Heap(lhs_wrapped), Heap(rhs_wrapped));
            }
            Maybe.None => break,
        }
    }

    // ORDER BY.
    let mut order_by: List<OrderTerm> = List.new();
    if ts.accept_keyword(KwOrder) {
        match ts.expect_keyword(KwBy) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        loop {
            let term = match parse_order_term(ts) {
                Result.Ok(t)  => t, Result.Err(e) => { return Result.Err(e); }
            };
            order_by.push(term);
            if !ts.accept_punct(PComma) { break; }
        }
    }

    // LIMIT.
    let mut limit: Maybe<LimitClause> = Maybe.None;
    if ts.accept_keyword(KwLimit) {
        let lim = match parse_expr(ts) {
            Result.Ok(e)  => e, Result.Err(e) => { return Result.Err(e); }
        };
        let off: Maybe<Expr> = if ts.accept_keyword(KwOffset) {
            let o = match parse_expr(ts) {
                Result.Ok(e)  => e, Result.Err(e) => { return Result.Err(e); }
            };
            Maybe.Some(o)
        } else {
            Maybe.None
        };
        limit = Maybe.Some(LimitClause { limit: lim, offset: off });
    }

    Result.Ok(SelectStmt { kind: kind, order_by: order_by, limit: limit })
}

// -----------------------------------------------------------------------------
// Simple SELECT
// -----------------------------------------------------------------------------

fn parse_simple(ts: &mut SqlTokenStream) -> Result<SimpleSelect, ParseError> {
    match ts.expect_keyword(KwSelect) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }

    let mut distinct = false;
    if ts.accept_keyword(KwDistinct) {
        distinct = true;
    } else {
        let _ = ts.accept_keyword(KwAll);
    }

    let result_columns = match parse_result_columns(ts) {
        Result.Ok(v)  => v, Result.Err(e) => { return Result.Err(e); }
    };

    let mut from: Maybe<FromItem> = Maybe.None;
    if ts.accept_keyword(KwFrom) {
        let fi = match parse_from_clause(ts) {
            Result.Ok(f)  => f, Result.Err(e) => { return Result.Err(e); }
        };
        from = Maybe.Some(fi);
    }

    let mut where_clause: Maybe<Expr> = Maybe.None;
    if ts.accept_keyword(KwWhere) {
        let e = match parse_expr(ts) {
            Result.Ok(x)  => x, Result.Err(err) => { return Result.Err(err); }
        };
        where_clause = Maybe.Some(e);
    }

    let mut group_by: List<Expr> = List.new();
    if ts.accept_keyword(KwGroup) {
        match ts.expect_keyword(KwBy) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        loop {
            let e = match parse_expr(ts) {
                Result.Ok(x)  => x, Result.Err(err) => { return Result.Err(err); }
            };
            group_by.push(e);
            if !ts.accept_punct(PComma) { break; }
        }
    }

    let mut having: Maybe<Expr> = Maybe.None;
    if ts.accept_keyword(KwHaving) {
        let e = match parse_expr(ts) {
            Result.Ok(x)  => x, Result.Err(err) => { return Result.Err(err); }
        };
        having = Maybe.Some(e);
    }

    Result.Ok(SimpleSelect {
        distinct: distinct,
        result_columns: result_columns,
        from: from,
        where_clause: where_clause,
        group_by: group_by,
        having: having,
    })
}

// -----------------------------------------------------------------------------
// Result columns
// -----------------------------------------------------------------------------

fn parse_result_columns(ts: &mut SqlTokenStream) -> Result<List<ResultColumnItem>, ParseError> {
    let mut out: List<ResultColumnItem> = List.new();
    loop {
        let item = match parse_result_column(ts) {
            Result.Ok(r)  => r, Result.Err(e) => { return Result.Err(e); }
        };
        out.push(item);
        if !ts.accept_punct(PComma) { break; }
    }
    Result.Ok(out)
}

fn parse_result_column(ts: &mut SqlTokenStream) -> Result<ResultColumnItem, ParseError> {
    // `*`
    if ts.accept_punct(PStar) {
        return Result.Ok(RcStar);
    }

    // `ident.*` lookahead — needs fork because the `ident` might be
    // part of a larger expression.
    let start = ts.position();
    match ts.peek() {
        TIdent(s) => {
            // Peek ahead for `. *`.
            match ts.peek_n(1) {
                TPunct(PDot) => {
                    match ts.peek_n(2) {
                        TPunct(PStar) => {
                            let _ = ts.advance();  // ident
                            let _ = ts.advance();  // .
                            let _ = ts.advance();  // *
                            return Result.Ok(RcTableStar(TableRef {
                                schema: "".clone(),
                                name: s,
                                alias: "".clone(),
                            }));
                        }
                        _ => {}
                    }
                }
                _ => {}
            }
            let _ = start;
        }
        _ => {}
    }

    // General expression with optional alias.
    let e = match parse_expr(ts) {
        Result.Ok(x)  => x, Result.Err(err) => { return Result.Err(err); }
    };
    let alias = parse_alias(ts);
    Result.Ok(RcExpr(e, alias))
}

/// Parse `AS ident` or a bare identifier as an alias. Returns "" for
/// none.
fn parse_alias(ts: &mut SqlTokenStream) -> Text {
    if ts.accept_keyword(KwAs) {
        match ts.expect_ident() {
            Result.Ok(s)  => s,
            Result.Err(_) => "".clone(),
        }
    } else {
        // Bare identifier only if the next token isn't a punct/keyword
        // that could continue the query (`,`, `FROM`, `WHERE`, etc.).
        // For safety we only take a bare ident as an alias if the
        // preceding expression parsed without consuming trailing
        // ambiguity. Conservatively: accept ident but back off if it's
        // one of the common continuation keywords.
        match ts.peek() {
            TIdent(_) => {
                let s = ts.accept_ident();
                match s { Maybe.Some(name) => name, Maybe.None => "".clone() }
            }
            _ => "".clone(),
        }
    }
}

// -----------------------------------------------------------------------------
// FROM clause
// -----------------------------------------------------------------------------

fn parse_from_clause(ts: &mut SqlTokenStream) -> Result<FromItem, ParseError> {
    let mut left = match parse_from_item(ts) {
        Result.Ok(fi) => fi, Result.Err(e) => { return Result.Err(e); }
    };

    loop {
        let join_opt = match try_parse_join_kind(ts) {
            Result.Ok(o)  => o, Result.Err(e) => { return Result.Err(e); }
        };
        match join_opt {
            Maybe.Some(jk) => {
                let right = match parse_from_item(ts) {
                    Result.Ok(fi) => fi, Result.Err(e) => { return Result.Err(e); }
                };
                let mut on: Maybe<Expr> = Maybe.None;
                let mut using_cols: List<Text> = List.new();
                if ts.accept_keyword(KwOn) {
                    let e = match parse_expr(ts) {
                        Result.Ok(x)  => x, Result.Err(err) => { return Result.Err(err); }
                    };
                    on = Maybe.Some(e);
                } else if ts.accept_keyword(KwUsing) {
                    match ts.expect_punct(PLParen) { Result.Ok(_) => {}, Result.Err(err) => { return Result.Err(err); } }
                    loop {
                        let col = match ts.expect_ident() {
                            Result.Ok(s)  => s, Result.Err(err) => { return Result.Err(err); }
                        };
                        using_cols.push(col);
                        if !ts.accept_punct(PComma) { break; }
                    }
                    match ts.expect_punct(PRParen) { Result.Ok(_) => {}, Result.Err(err) => { return Result.Err(err); } }
                }
                let jc = JoinClause {
                    kind: jk,
                    right: Heap(right),
                    on: on,
                    using_cols: using_cols,
                };
                left = FiJoin(Heap(left), jc);
            }
            Maybe.None => {
                // A comma-separated FROM list is parsed as a chain of
                // CROSS JOINs (SQLite behaviour).
                if ts.accept_punct(PComma) {
                    let right = match parse_from_item(ts) {
                        Result.Ok(fi) => fi, Result.Err(e) => { return Result.Err(e); }
                    };
                    let jc = JoinClause {
                        kind: JCross,
                        right: Heap(right),
                        on: Maybe.None,
                        using_cols: List.new(),
                    };
                    left = FiJoin(Heap(left), jc);
                    continue;
                }
                break;
            }
        }
    }
    Result.Ok(left)
}

fn parse_from_item(ts: &mut SqlTokenStream) -> Result<FromItem, ParseError> {
    // `(subquery) alias` not yet supported at L5.3 initial cut.
    let name = match ts.peek() {
        TIdent(_) => match ts.expect_ident() {
            Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
        },
        _ => { return Result.Err(parse_error("expected table name".clone(), ts.position())); }
    };

    // Qualified table name: `schema.name`.
    let (schema, table_name) = if ts.accept_punct(PDot) {
        let second = match ts.expect_ident() {
            Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
        };
        (name, second)
    } else {
        ("".clone(), name)
    };

    // Optional alias.
    let alias = parse_alias(ts);

    Result.Ok(FiTable(TableRef {
        schema: schema,
        name: table_name,
        alias: alias,
    }))
}

fn try_parse_join_kind(ts: &mut SqlTokenStream) -> Result<Maybe<SqlJoinKind>, ParseError> {
    let natural = ts.accept_keyword(KwNatural);
    let _ = natural;

    // LEFT / RIGHT / FULL / INNER / CROSS before JOIN.
    let kind = if ts.accept_keyword(KwLeft) {
        let _ = ts.accept_keyword(KwOuter);
        Maybe.Some(JLeftOuter)
    } else if ts.accept_keyword(KwRight) {
        let _ = ts.accept_keyword(KwOuter);
        Maybe.Some(JRightOuter)
    } else if ts.accept_keyword(KwFull) {
        let _ = ts.accept_keyword(KwOuter);
        Maybe.Some(JFullOuter)
    } else if ts.accept_keyword(KwInner) {
        Maybe.Some(JInner)
    } else if ts.accept_keyword(KwCross) {
        Maybe.Some(JCross)
    } else {
        Maybe.None
    };

    match kind {
        Maybe.Some(jk) => {
            match ts.expect_keyword(KwJoin) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
            Result.Ok(Maybe.Some(jk))
        }
        Maybe.None => {
            // Bare JOIN without prefix = INNER.
            if ts.accept_keyword(KwJoin) {
                Result.Ok(Maybe.Some(JInner))
            } else {
                Result.Ok(Maybe.None)
            }
        }
    }
}

// -----------------------------------------------------------------------------
// ORDER BY terms
// -----------------------------------------------------------------------------

fn parse_order_term(ts: &mut SqlTokenStream) -> Result<OrderTerm, ParseError> {
    let e = match parse_expr(ts) {
        Result.Ok(x)  => x, Result.Err(err) => { return Result.Err(err); }
    };
    let dir = if ts.accept_keyword(KwAsc) {
        OdAsc
    } else if ts.accept_keyword(KwDesc) {
        OdDesc
    } else {
        OdAsc
    };
    Result.Ok(OrderTerm {
        expr: e,
        direction: dir,
        nulls_first: Maybe.None,
    })
}

// -----------------------------------------------------------------------------
// Compound detection
// -----------------------------------------------------------------------------

fn detect_compound_op(ts: &mut SqlTokenStream) -> Maybe<CompoundOp> {
    if ts.accept_keyword(KwUnion) {
        if ts.accept_keyword(KwAll) {
            return Maybe.Some(CoUnionAll);
        }
        return Maybe.Some(CoUnion);
    }
    if ts.accept_keyword(KwIntersect) {
        return Maybe.Some(CoIntersect);
    }
    if ts.accept_keyword(KwExcept) {
        return Maybe.Some(CoExcept);
    }
    Maybe.None
}
