@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.database.sqlite.native.l5_sql.parser.misc;

// =============================================================================
// l5_sql/parser/misc.vr — PRAGMA / EXPLAIN / transaction / VACUUM / misc
// =============================================================================
// Layer: 5
// Spec: sqlite.org/pragma.html, lang_transaction.html, lang_explain.html
//

// Short, self-contained statements that don't deserve their own
// parser file:
//

//  pragma-stmt = PRAGMA [schema.] name [ '=' expr | '(' expr ')' ]
//  explain-stmt = EXPLAIN [QUERY PLAN] stmt
//  begin-stmt = BEGIN [DEFERRED|IMMEDIATE|EXCLUSIVE] [TRANSACTION]
//  commit-stmt = (COMMIT|END) [TRANSACTION]
//  rollback-stmt = ROLLBACK [TRANSACTION] [TO [SAVEPOINT] name]
//  savepoint-stmt = SAVEPOINT name
//  release-stmt = RELEASE [SAVEPOINT] name
//  vacuum-stmt = VACUUM [schema] [INTO string-lit]
//  reindex-stmt = REINDEX [collation | [schema.]name]
//  attach-stmt = ATTACH [DATABASE] expr AS expr
//  detach-stmt = DETACH [DATABASE] name
//  analyze-stmt = ANALYZE [schema[.name]]
// =============================================================================

mount core.*;
mount collections.List;
mount base.{Result, Ok, Err, Text, Maybe};
mount core.database.sqlite.native.l5_sql.lexer.{
    SqlKeyword, Operator, Punct,
};
mount core.database.sqlite.native.l5_sql.ast.{
    SqlStatement, Expr, TableRef,
};
mount core.database.sqlite.native.l5_sql.parser.token_stream.{
    SqlTokenStream, ParseError, parse_error,
};
mount core.database.sqlite.native.l5_sql.parser.expr.parse_expr;

// -----------------------------------------------------------------------------
// PRAGMA
// -----------------------------------------------------------------------------

public fn parse_pragma(ts: &mut SqlTokenStream) -> Result<SqlStatement, ParseError> {
    match ts.expect_keyword(KwPragma) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
    let name = match ts.expect_ident() {
        Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
    };
    // Optional schema-qualified form: `PRAGMA main.user_version`.
    let _qualified_name = if ts.accept_punct(PDot) {
        let second = match ts.expect_ident() {
            Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
        };
        // We fold schema.name into the pragma-name field as
        // "schema.name" until the full PRAGMA AST variant accepts a
        // TableRef — matches how SQLite stores it internally.
        name + ".".clone() + second
    } else {
        name
    };

    let mut value: Maybe<Expr> = Maybe.None;
    if ts.accept_op(OpEq) {
        let e = match parse_expr(ts) {
            Result.Ok(x)  => x, Result.Err(err) => { return Result.Err(err); }
        };
        value = Maybe.Some(e);
    } else if ts.accept_punct(PLParen) {
        let e = match parse_expr(ts) {
            Result.Ok(x)  => x, Result.Err(err) => { return Result.Err(err); }
        };
        match ts.expect_punct(PRParen) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        value = Maybe.Some(e);
    }

    Result.Ok(SPragma(_qualified_name, value))
}

// -----------------------------------------------------------------------------
// EXPLAIN
// -----------------------------------------------------------------------------

public fn parse_explain(
    ts: &mut SqlTokenStream,
    inner: fn(&mut SqlTokenStream) -> Result<SqlStatement, ParseError>,
) -> Result<SqlStatement, ParseError> {
    match ts.expect_keyword(KwExplain) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
    let query_plan = if ts.accept_keyword(KwQuery) {
        match ts.expect_keyword(KwPlan) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        true
    } else {
        false
    };
    let body = match inner(ts) {
        Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
    };
    Result.Ok(SExplain(Heap(body), query_plan))
}

// -----------------------------------------------------------------------------
// Transactions
// -----------------------------------------------------------------------------

public fn parse_begin(ts: &mut SqlTokenStream) -> Result<SqlStatement, ParseError> {
    match ts.expect_keyword(KwBegin) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
    // Optional transaction mode: DEFERRED / IMMEDIATE / EXCLUSIVE.
    let _ = ts.accept_keyword(KwDeferred);
    let _ = ts.accept_keyword(KwImmediate);
    // EXCLUSIVE isn't in our SqlKeyword set; accept as ident.
    match ts.peek() {
        TIdent(s) => {
            let lower = fold_text_ascii(&s);
            if lower == "exclusive".clone() {
                let _ = ts.advance();
            }
        }
        _ => {}
    }
    let _ = ts.accept_keyword(KwTransaction);
    Result.Ok(SBeginTransaction)
}

public fn parse_commit(ts: &mut SqlTokenStream) -> Result<SqlStatement, ParseError> {
    // `COMMIT [TRANSACTION]` or `END [TRANSACTION]`.
    if ts.accept_keyword(KwCommit) {
        let _ = ts.accept_keyword(KwTransaction);
        return Result.Ok(SCommit);
    }
    if ts.accept_keyword(KwEnd) {
        let _ = ts.accept_keyword(KwTransaction);
        return Result.Ok(SCommit);
    }
    Result.Err(parse_error("expected COMMIT / END".clone(), ts.position()))
}

public fn parse_rollback(ts: &mut SqlTokenStream) -> Result<SqlStatement, ParseError> {
    match ts.expect_keyword(KwRollback) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
    let _ = ts.accept_keyword(KwTransaction);
    if ts.accept_keyword(KwTo) {
        let _ = ts.accept_keyword(KwSavepoint);
        let name = match ts.expect_ident() {
            Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
        };
        return Result.Ok(SRollback(Maybe.Some(name)));
    }
    Result.Ok(SRollback(Maybe.None))
}

public fn parse_savepoint(ts: &mut SqlTokenStream) -> Result<SqlStatement, ParseError> {
    match ts.expect_keyword(KwSavepoint) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
    let name = match ts.expect_ident() {
        Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
    };
    Result.Ok(SSavepoint(name))
}

public fn parse_release(ts: &mut SqlTokenStream) -> Result<SqlStatement, ParseError> {
    match ts.expect_keyword(KwRelease) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
    let _ = ts.accept_keyword(KwSavepoint);
    let name = match ts.expect_ident() {
        Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
    };
    Result.Ok(SRelease(name))
}

// -----------------------------------------------------------------------------
// VACUUM / REINDEX / ATTACH / DETACH / ANALYZE
// -----------------------------------------------------------------------------

public fn parse_vacuum(ts: &mut SqlTokenStream) -> Result<SqlStatement, ParseError> {
    match ts.expect_keyword(KwVacuum) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
    // Optional schema name.
    let _schema: Maybe<Text> = match ts.peek() {
        TIdent(_) => {
            let s = match ts.expect_ident() {
                Result.Ok(s)  => s, Result.Err(_) => { return Result.Err(parse_error("ident".clone(), ts.position())); }
            };
            Maybe.Some(s)
        }
        _ => Maybe.None,
    };
    // Optional `INTO 'path'`.
    let into: Maybe<Text> = if ts.accept_keyword(KwInto) {
        match ts.peek() {
            TStringLit(s) => { let _ = ts.advance(); Maybe.Some(s) }
            _ => { return Result.Err(parse_error("expected string after INTO".clone(), ts.position())); }
        }
    } else {
        Maybe.None
    };
    Result.Ok(SVacuum(into))
}

public fn parse_reindex(ts: &mut SqlTokenStream) -> Result<SqlStatement, ParseError> {
    match ts.expect_keyword(KwReindex) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
    let target: Maybe<TableRef> = match ts.peek() {
        TIdent(_) => {
            let first = match ts.expect_ident() {
                Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
            };
            if ts.accept_punct(PDot) {
                let second = match ts.expect_ident() {
                    Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
                };
                Maybe.Some(TableRef { schema: first, name: second, alias: "".clone() })
            } else {
                Maybe.Some(TableRef { schema: "".clone(), name: first, alias: "".clone() })
            }
        }
        _ => Maybe.None,
    };
    Result.Ok(SReindex(target))
}

public fn parse_attach(ts: &mut SqlTokenStream) -> Result<SqlStatement, ParseError> {
    match ts.expect_keyword(KwAttach) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
    let _ = ts.accept_keyword(KwDatabase);
    let path = match parse_expr(ts) {
        Result.Ok(x)  => x, Result.Err(err) => { return Result.Err(err); }
    };
    match ts.expect_keyword(KwAs) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
    let name = match parse_expr(ts) {
        Result.Ok(x)  => x, Result.Err(err) => { return Result.Err(err); }
    };
    Result.Ok(SAttach(path, name))
}

public fn parse_detach(ts: &mut SqlTokenStream) -> Result<SqlStatement, ParseError> {
    match ts.expect_keyword(KwDetach) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
    let _ = ts.accept_keyword(KwDatabase);
    let name = match ts.expect_ident() {
        Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
    };
    Result.Ok(SDetach(name))
}

public fn parse_analyze(ts: &mut SqlTokenStream) -> Result<SqlStatement, ParseError> {
    match ts.expect_keyword(KwAnalyze) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
    let target: Maybe<TableRef> = match ts.peek() {
        TIdent(_) => {
            let first = match ts.expect_ident() {
                Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
            };
            if ts.accept_punct(PDot) {
                let second = match ts.expect_ident() {
                    Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
                };
                Maybe.Some(TableRef { schema: first, name: second, alias: "".clone() })
            } else {
                Maybe.Some(TableRef { schema: "".clone(), name: first, alias: "".clone() })
            }
        }
        _ => Maybe.None,
    };
    Result.Ok(SAnalyze(target))
}

// -----------------------------------------------------------------------------
// Local case-fold helper (avoids pulling `core.text.case_fold` which
// brings a larger dependency surface into the parser)
// -----------------------------------------------------------------------------

fn fold_text_ascii(t: &Text) -> Text {
    let raw = t.as_bytes();
    let mut out: List<Byte> = List.new();
    let mut i: Int = 0;
    while i < raw.len() {
        let mut b = raw[i];
        if b >= (0x41 as Byte) && b <= (0x5A as Byte) {
            b = b + (0x20 as Byte);
        }
        out.push(b);
        i = i + 1;
    }
    Text.from_bytes(&out).unwrap_or("".clone())
}
