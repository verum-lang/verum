@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.database.sqlite.native.l5_sql.parser.ddl;

// =============================================================================
// l5_sql/parser/ddl.vr — CREATE / DROP / ALTER
// =============================================================================
// Layer: 5
// Spec: sqlite.org/lang_{createtable,createindex,droptable,altertable}.html
//

// Grammar (subset — the v1 we can actually codegen):
//

//  create-table-stmt = CREATE [TEMP|TEMPORARY] TABLE [IF NOT EXISTS]
//  qname '(' column-def {, column-def | table-constraint} ')'
//  [WITHOUT ROWID] [STRICT]
//

//  column-def = ident [type-name] { column-constraint }
//  type-name = ident { ident | '(' INT [, INT] ')' }
//

//  column-constraint = PRIMARY KEY [ASC|DESC] [on-conflict] [AUTOINCREMENT]
//  | NOT NULL [on-conflict]
//  | UNIQUE [on-conflict]
//  | CHECK '(' expr ')'
//  | DEFAULT ( expr | signed-number | literal )
//  | COLLATE ident
//  | REFERENCES qname [ '(' ident {, ident} ')' ]
//

//  table-constraint = PRIMARY KEY '(' ident {, ident} ')' [on-conflict]
//  | UNIQUE '(' ident {, ident} ')' [on-conflict]
//  | CHECK '(' expr ')'
//  | FOREIGN KEY '(' ident {, ident} ')' REFERENCES ...
//

//  drop-stmt = DROP (TABLE|INDEX|VIEW|TRIGGER) [IF EXISTS] qname
//  create-index-stmt = CREATE [UNIQUE] INDEX [IF NOT EXISTS] qname ON
//  qname '(' ident {, ident} ')' -- stashed as
//  expression; v1 parses but discards the expr
//  detail until the planner consumes it.
// =============================================================================

mount core.*;
mount collections.List;
mount base.{Result, Ok, Err, Text, Maybe};
mount core.database.sqlite.native.l5_sql.lexer.{
    Token, SqlKeyword, Operator, Punct,
};
mount core.database.sqlite.native.l5_sql.ast.{
    SqlStatement, Expr, TableRef, SelectStmt,
    CreateTableStmt, ColumnDef, ColumnConstraint, TableConstraint,
    CreateIndexStmt, IndexedColumn, CreateViewStmt,
    OrderDirection,
    SqlOnConflict,
};
mount core.database.sqlite.native.l5_sql.parser.expr.parse_expr;
mount core.database.sqlite.native.l5_sql.parser.select.parse_select;
mount core.database.sqlite.native.l5_sql.parser.token_stream.{
    SqlTokenStream, ParseError, parse_error,
};
mount core.database.sqlite.native.l5_sql.parser.expr.parse_expr;

// -----------------------------------------------------------------------------
// CREATE
// -----------------------------------------------------------------------------

public fn parse_create(ts: &mut SqlTokenStream) -> Result<SqlStatement, ParseError> {
    match ts.expect_keyword(KwCreate) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }

    let temporary = ts.accept_keyword(KwTemp) || ts.accept_keyword(KwTemporary);
    let unique = ts.accept_keyword(KwUnique);
    let _ = unique;     // recorded only for INDEX form; TABLE doesn't take UNIQUE.

    if ts.accept_keyword(KwTable) {
        let stmt = match parse_create_table_rest(ts, temporary) {
            Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
        };
        return Result.Ok(SCreateTable(stmt));
    }

    if ts.accept_keyword(KwIndex) {
        let stmt = match parse_create_index_rest(ts, unique) {
            Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
        };
        return Result.Ok(SCreateIndex(stmt));
    }

    if ts.accept_keyword(KwView) {
        let stmt = match parse_create_view_rest(ts, temporary) {
            Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
        };
        return Result.Ok(SCreateView(stmt));
    }

    if ts.accept_keyword(KwTrigger) {
        return Result.Err(parse_error(
            "CREATE TRIGGER not yet supported in L5.5 initial cut".clone(),
            ts.position(),
        ));
    }

    Result.Err(parse_error("expected TABLE / INDEX / VIEW / TRIGGER after CREATE".clone(), ts.position()))
}

fn parse_create_table_rest(
    ts: &mut SqlTokenStream,
    temporary: Bool,
) -> Result<CreateTableStmt, ParseError> {
    let if_not_exists = if ts.accept_keyword(KwIf) {
        match ts.expect_keyword(KwNot) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        match ts.expect_keyword(KwExists) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        true
    } else {
        false
    };

    let table = match parse_qualified_name(ts) {
        Result.Ok(t)  => t, Result.Err(e) => { return Result.Err(e); }
    };

    match ts.expect_punct(PLParen) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }

    let mut columns: List<ColumnDef> = List.new();
    let mut constraints: List<TableConstraint> = List.new();
    let mut first = true;

    loop {
        if !first {
            if !ts.accept_punct(PComma) { break; }
        }
        first = false;

        // Table constraint vs column def — check the leading keyword.
        if is_table_constraint_start(ts) {
            let tc = match parse_table_constraint(ts) {
                Result.Ok(t)  => t, Result.Err(e) => { return Result.Err(e); }
            };
            constraints.push(tc);
        } else {
            let col = match parse_column_def(ts) {
                Result.Ok(c)  => c, Result.Err(e) => { return Result.Err(e); }
            };
            columns.push(col);
        }
    }

    match ts.expect_punct(PRParen) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }

    // Table options: WITHOUT ROWID, STRICT.
    let mut without_rowid = false;
    let mut strict = false;
    loop {
        if ts.accept_keyword(KwWithout) {
            match ts.expect_keyword(KwRowid) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
            without_rowid = true;
            // Comma-separated table options.
            if ts.accept_punct(PComma) { continue; }
            break;
        }
        // STRICT is not a full keyword in our lexer set — it falls
        // through as an identifier. Match on TIdent("strict"/"STRICT").
        match ts.peek() {
            TIdent(s) => {
                // ASCII-case-insensitive compare against "strict".
                if text_eq_ci(&s, "strict") {
                    let _ = ts.advance();
                    strict = true;
                    if ts.accept_punct(PComma) { continue; }
                    break;
                }
                break;
            }
            _ => break,
        }
    }

    Result.Ok(CreateTableStmt {
        if_not_exists: if_not_exists,
        temporary: temporary,
        table: table,
        columns: columns,
        constraints: constraints,
        strict: strict,
        without_rowid: without_rowid,
    })
}

// -----------------------------------------------------------------------------
// Column definition
// -----------------------------------------------------------------------------

fn parse_column_def(ts: &mut SqlTokenStream) -> Result<ColumnDef, ParseError> {
    let name = match ts.expect_ident() {
        Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
    };

    let declared_type = parse_type_name(ts);

    let mut constraints: List<ColumnConstraint> = List.new();
    loop {
        let cc_opt = match try_parse_column_constraint(ts) {
            Result.Ok(o)  => o, Result.Err(e) => { return Result.Err(e); }
        };
        match cc_opt {
            Maybe.Some(cc) => constraints.push(cc),
            Maybe.None     => break,
        }
    }

    Result.Ok(ColumnDef {
        name: name,
        declared_type: declared_type,
        constraints: constraints,
    })
}

/// Parse an optional type name after a column name. The grammar is
/// lax: `VARCHAR(255)`, `INTEGER`, `DOUBLE PRECISION`, etc. We absorb
/// any identifier(s) followed by an optional `(N [, M])` size spec.
fn parse_type_name(ts: &mut SqlTokenStream) -> Text {
    match ts.peek() {
        TIdent(_) => {},
        _ => return "".clone(),
    }

    let mut out: Text = "".clone();
    let mut first = true;

    loop {
        match ts.peek() {
            TIdent(s) => {
                if !first { out = out + " ".clone(); }
                first = false;
                out = out + s;
                let _ = ts.advance();
            }
            _ => break,
        }
    }

    // Optional size suffix — we skip through `(...)` without
    // recording it on the AST for v1.
    if ts.accept_punct(PLParen) {
        let _ = consume_through_rparen(ts);
    }

    out
}

fn consume_through_rparen(ts: &mut SqlTokenStream) -> Bool {
    let mut depth: Int = 1;
    while !ts.at_eof() {
        if ts.accept_punct(PLParen) { depth = depth + 1; continue; }
        if ts.accept_punct(PRParen) {
            depth = depth - 1;
            if depth == 0 { return true; }
            continue;
        }
        let _ = ts.advance();
    }
    false
}

// -----------------------------------------------------------------------------
// Column constraints
// -----------------------------------------------------------------------------

fn try_parse_column_constraint(ts: &mut SqlTokenStream) -> Result<Maybe<ColumnConstraint>, ParseError> {
    if ts.accept_keyword(KwPrimary) {
        match ts.expect_keyword(KwKey) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        // Optional ASC / DESC — ignored for v1.
        let _ = ts.accept_keyword(KwAsc);
        let _ = ts.accept_keyword(KwDesc);
        let on_conflict = match parse_optional_on_conflict(ts) {
            Result.Ok(o)  => o, Result.Err(e) => { return Result.Err(e); }
        };
        let autoincrement = ts.accept_keyword(KwAutoincrement);
        return Result.Ok(Maybe.Some(CcPrimaryKey(on_conflict, autoincrement)));
    }

    if ts.accept_keyword(KwNot) {
        match ts.expect_keyword(KwNull) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        let on_conflict = match parse_optional_on_conflict(ts) {
            Result.Ok(o)  => o, Result.Err(e) => { return Result.Err(e); }
        };
        return Result.Ok(Maybe.Some(CcNotNull(on_conflict)));
    }

    if ts.accept_keyword(KwUnique) {
        let on_conflict = match parse_optional_on_conflict(ts) {
            Result.Ok(o)  => o, Result.Err(e) => { return Result.Err(e); }
        };
        return Result.Ok(Maybe.Some(CcUnique(on_conflict)));
    }

    if ts.accept_keyword(KwCheck) {
        match ts.expect_punct(PLParen) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        let e = match parse_expr(ts) {
            Result.Ok(x)  => x, Result.Err(err) => { return Result.Err(err); }
        };
        match ts.expect_punct(PRParen) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        return Result.Ok(Maybe.Some(CcCheck(e)));
    }

    if ts.accept_keyword(KwDefault) {
        // DEFAULT can be an expression (parenthesised), a signed
        // number, or a simple literal. parse_expr handles all three.
        if ts.check_punct(PLParen) {
            let _ = ts.advance();
            let e = match parse_expr(ts) {
                Result.Ok(x)  => x, Result.Err(err) => { return Result.Err(err); }
            };
            match ts.expect_punct(PRParen) { Result.Ok(_) => {}, Result.Err(err) => { return Result.Err(err); } }
            return Result.Ok(Maybe.Some(CcDefault(e)));
        }
        let e = match parse_expr(ts) {
            Result.Ok(x)  => x, Result.Err(err) => { return Result.Err(err); }
        };
        return Result.Ok(Maybe.Some(CcDefault(e)));
    }

    if ts.accept_keyword(KwCollate) {
        let n = match ts.expect_ident() {
            Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
        };
        return Result.Ok(Maybe.Some(CcCollate(n)));
    }

    if ts.accept_keyword(KwReferences) {
        let qn = match parse_qualified_name(ts) {
            Result.Ok(t)  => t, Result.Err(e) => { return Result.Err(e); }
        };
        let mut cols: List<Text> = List.new();
        if ts.accept_punct(PLParen) {
            loop {
                let col = match ts.expect_ident() {
                    Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
                };
                cols.push(col);
                if !ts.accept_punct(PComma) { break; }
            }
            match ts.expect_punct(PRParen) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        }
        return Result.Ok(Maybe.Some(CcForeignKey(qn, cols)));
    }

    Result.Ok(Maybe.None)
}

// -----------------------------------------------------------------------------
// Table constraints
// -----------------------------------------------------------------------------

fn is_table_constraint_start(ts: &SqlTokenStream) -> Bool {
    match ts.peek() {
        TKeyword(KwPrimary) => true,
        TKeyword(KwUnique)  => true,
        TKeyword(KwCheck)   => true,
        TKeyword(KwForeign) => true,
        _ => false,
    }
}

fn parse_table_constraint(ts: &mut SqlTokenStream) -> Result<TableConstraint, ParseError> {
    if ts.accept_keyword(KwPrimary) {
        match ts.expect_keyword(KwKey) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        match ts.expect_punct(PLParen) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        let mut cols: List<Text> = List.new();
        loop {
            let c = match ts.expect_ident() {
                Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
            };
            cols.push(c);
            if !ts.accept_punct(PComma) { break; }
        }
        match ts.expect_punct(PRParen) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        let on_conflict = match parse_optional_on_conflict(ts) {
            Result.Ok(o)  => o, Result.Err(e) => { return Result.Err(e); }
        };
        let autoincrement = ts.accept_keyword(KwAutoincrement);
        return Result.Ok(TcPrimaryKey(cols, on_conflict, autoincrement));
    }

    if ts.accept_keyword(KwUnique) {
        match ts.expect_punct(PLParen) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        let mut cols: List<Text> = List.new();
        loop {
            let c = match ts.expect_ident() {
                Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
            };
            cols.push(c);
            if !ts.accept_punct(PComma) { break; }
        }
        match ts.expect_punct(PRParen) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        let on_conflict = match parse_optional_on_conflict(ts) {
            Result.Ok(o)  => o, Result.Err(e) => { return Result.Err(e); }
        };
        return Result.Ok(TcUnique(cols, on_conflict));
    }

    if ts.accept_keyword(KwCheck) {
        match ts.expect_punct(PLParen) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        let e = match parse_expr(ts) {
            Result.Ok(x)  => x, Result.Err(err) => { return Result.Err(err); }
        };
        match ts.expect_punct(PRParen) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        return Result.Ok(TcCheck(e));
    }

    if ts.accept_keyword(KwForeign) {
        match ts.expect_keyword(KwKey) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        match ts.expect_punct(PLParen) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        let mut local_cols: List<Text> = List.new();
        loop {
            let c = match ts.expect_ident() {
                Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
            };
            local_cols.push(c);
            if !ts.accept_punct(PComma) { break; }
        }
        match ts.expect_punct(PRParen) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        match ts.expect_keyword(KwReferences) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        let target = match parse_qualified_name(ts) {
            Result.Ok(t)  => t, Result.Err(e) => { return Result.Err(e); }
        };
        let mut fk_cols: List<Text> = List.new();
        if ts.accept_punct(PLParen) {
            loop {
                let c = match ts.expect_ident() {
                    Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
                };
                fk_cols.push(c);
                if !ts.accept_punct(PComma) { break; }
            }
            match ts.expect_punct(PRParen) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        }
        return Result.Ok(TcForeignKey(local_cols, target, fk_cols));
    }

    Result.Err(parse_error("expected table constraint".clone(), ts.position()))
}

fn parse_optional_on_conflict(ts: &mut SqlTokenStream) -> Result<Maybe<SqlOnConflict>, ParseError> {
    if !ts.accept_keyword(KwOn) { return Result.Ok(Maybe.None); }
    match ts.expect_keyword(KwConflict) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
    if ts.accept_keyword(KwAbort)    { return Result.Ok(Maybe.Some(OcAbort)); }
    if ts.accept_keyword(KwFail)     { return Result.Ok(Maybe.Some(OcFail)); }
    if ts.accept_keyword(KwIgnore)   { return Result.Ok(Maybe.Some(OcIgnore)); }
    if ts.accept_keyword(KwReplace)  { return Result.Ok(Maybe.Some(OcReplace)); }
    if ts.accept_keyword(KwRollback) { return Result.Ok(Maybe.Some(OcRollback)); }
    Result.Err(parse_error("expected conflict action after ON CONFLICT".clone(), ts.position()))
}

// -----------------------------------------------------------------------------
// DROP
// -----------------------------------------------------------------------------

public fn parse_drop(ts: &mut SqlTokenStream) -> Result<SqlStatement, ParseError> {
    match ts.expect_keyword(KwDrop) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }

    let kind_tag = if ts.accept_keyword(KwTable)   { 0 }
                   else if ts.accept_keyword(KwIndex)   { 1 }
                   else if ts.accept_keyword(KwView)    { 2 }
                   else if ts.accept_keyword(KwTrigger) { 3 }
                   else { -1 };
    if kind_tag < 0 {
        return Result.Err(parse_error("expected TABLE / INDEX / VIEW / TRIGGER".clone(), ts.position()));
    }

    let if_exists = if ts.accept_keyword(KwIf) {
        match ts.expect_keyword(KwExists) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        true
    } else {
        false
    };

    let qn = match parse_qualified_name(ts) {
        Result.Ok(t)  => t, Result.Err(e) => { return Result.Err(e); }
    };

    match kind_tag {
        0 => Result.Ok(SDropTable(if_exists, qn)),
        1 => Result.Ok(SDropIndex(if_exists, qn)),
        2 => Result.Ok(SDropView(if_exists, qn)),
        _ => Result.Ok(SDropTrigger(if_exists, qn)),
    }
}

// -----------------------------------------------------------------------------
// Helpers
// -----------------------------------------------------------------------------

fn parse_create_index_rest(
    ts: &mut SqlTokenStream,
    unique: Bool,
) -> Result<CreateIndexStmt, ParseError> {
    let if_not_exists = if ts.accept_keyword(KwIf) {
        match ts.expect_keyword(KwNot) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        match ts.expect_keyword(KwExists) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        true
    } else { false };

    let index_name = match parse_qualified_name(ts) {
        Result.Ok(t)  => t, Result.Err(e) => { return Result.Err(e); }
    };
    match ts.expect_keyword(KwOn) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
    let table = match parse_qualified_name(ts) {
        Result.Ok(t)  => t, Result.Err(e) => { return Result.Err(e); }
    };
    match ts.expect_punct(PLParen) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
    let mut cols: List<IndexedColumn> = List.new();
    loop {
        let name = match ts.expect_ident() {
            Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
        };
        let collation: Maybe<Text> = if ts.accept_keyword(KwCollate) {
            match ts.expect_ident() {
                Result.Ok(s)  => Maybe.Some(s), Result.Err(e) => { return Result.Err(e); }
            }
        } else { Maybe.None };
        let direction = if ts.accept_keyword(KwDesc) { OdDesc }
                        else { let _ = ts.accept_keyword(KwAsc); OdAsc };
        cols.push(IndexedColumn {
            expr: EColumn(TableRef { schema: "".clone(), name: "".clone(), alias: "".clone() }, name),
            collation: collation,
            direction: direction,
        });
        if !ts.accept_punct(PComma) { break; }
    }
    match ts.expect_punct(PRParen) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
    // Optional WHERE clause (partial indexes).
    let where_clause: Maybe<Expr> = if ts.accept_keyword(KwWhere) {
        match parse_expr(ts) {
            Result.Ok(e)  => Maybe.Some(e), Result.Err(err) => { return Result.Err(err); }
        }
    } else { Maybe.None };
    Result.Ok(CreateIndexStmt {
        if_not_exists: if_not_exists,
        unique: unique,
        index: index_name,
        table: table,
        columns: cols,
        where_clause: where_clause,
    })
}

fn parse_create_view_rest(
    ts: &mut SqlTokenStream,
    temporary: Bool,
) -> Result<CreateViewStmt, ParseError> {
    let if_not_exists = if ts.accept_keyword(KwIf) {
        match ts.expect_keyword(KwNot) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        match ts.expect_keyword(KwExists) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
        true
    } else { false };
    let view_name = match parse_qualified_name(ts) {
        Result.Ok(t)  => t, Result.Err(e) => { return Result.Err(e); }
    };
    let mut cols: List<Text> = List.new();
    if ts.accept_punct(PLParen) {
        loop {
            let c = match ts.expect_ident() {
                Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
            };
            cols.push(c);
            if !ts.accept_punct(PComma) { break; }
        }
        match ts.expect_punct(PRParen) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
    }
    match ts.expect_keyword(KwAs) { Result.Ok(_) => {}, Result.Err(e) => { return Result.Err(e); } }
    let query = match parse_select(ts) {
        Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
    };
    Result.Ok(CreateViewStmt {
        if_not_exists: if_not_exists,
        temporary: temporary,
        view: view_name,
        columns: cols,
        query: Heap(query),
    })
}

fn parse_qualified_name(ts: &mut SqlTokenStream) -> Result<TableRef, ParseError> {
    let first = match ts.expect_ident() {
        Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
    };
    if ts.accept_punct(PDot) {
        let second = match ts.expect_ident() {
            Result.Ok(s)  => s, Result.Err(e) => { return Result.Err(e); }
        };
        return Result.Ok(TableRef { schema: first, name: second, alias: "".clone() });
    }
    Result.Ok(TableRef { schema: "".clone(), name: first, alias: "".clone() })
}

fn text_eq_ci(a: &Text, lit: &str) -> Bool {
    let ab = a.as_bytes();
    let lb = lit.as_bytes();
    if ab.len() != lb.len() { return false; }
    let mut i: Int = 0;
    while i < ab.len() {
        let mut x = ab[i];
        if x >= (0x41 as Byte) && x <= (0x5A as Byte) {
            x = x + (0x20 as Byte);
        }
        if x != lb[i] { return false; }
        i = i + 1;
    }
    true
}
