module core.database.sqlite.native.l5_sql;

// =============================================================================
// core/database/sqlite/native/l5_sql/mod.vr — SQL compilation layer (L5)
// =============================================================================
// Layer: 5
// Dependencies: l4_vdbe, l3_btree, l2_record, l1_pager, l0_vfs
// =============================================================================
//
// The SQL compiler turns source SQL text into a compiled `VdbeProgram`:
//
//   source.sql
//        │
//        ├─> lexer     (Token stream)
//        ├─> parser    (AST)
//        ├─> resolver  (name resolution, CTE inlining)
//        ├─> planner   (index selection, join order)
//        ├─> codegen   (plan → VDBE)
//        └─> VdbeProgram
//
// This v1 ships the lexer + AST + a minimal parser for SELECT / INSERT /
// UPDATE / DELETE / basic DDL. Planner + codegen land in follow-on
// patches.
// =============================================================================

public module lexer;
public module ast;
public module parser;
public module planner;
public module resolver;
public module codegen;
public module compile;

public mount .lexer.{
    Token, SqlKeyword, Operator, Punct, VariableKind, LexError, LexerState,
    lex, lookup_keyword,
};

public mount .ast.{
    SqlStatement, Expr, SqlLiteral, BinOp, UnOp,
    SelectStmt, SelectKind, SimpleSelect, ResultColumnItem,
    FromItem, JoinClause, SqlJoinKind, CompoundOp,
    OrderTerm, OrderDirection, LimitClause,
    InsertStmt, InsertSource, SqlOnConflict,
    UpdateStmt, UpdateAssignment,
    DeleteStmt,
    CreateTableStmt, ColumnDef, TableConstraint,
    DropTargetKind,
    TableRef,
};

public mount .parser.{
    SqlTokenStream, ParseError,
    stream_new, parse_error,
    parse_expr, parse_select,
    parse_insert, parse_update, parse_delete,
    parse_create, parse_drop,
    parse_pragma, parse_begin, parse_commit, parse_rollback,
    parse_savepoint, parse_release, parse_vacuum, parse_reindex,
    parse_attach, parse_detach, parse_analyze,
    parse_statement, parse_batch, parse_one,
};

public mount .ast.{
    ColumnConstraint,
};

public mount .planner.{
    PlanNode, PlanColumn, PlanError, DropPlanKind, TxAction,
    plan_statement, plan_statement_with_schema, plan_error,
};

public mount .codegen.{
    CodegenError, CgState,
    codegen, emit_expr,
};

public mount .resolver.{
    ResolveError, ColumnScope,
    resolve_expr, build_single_table_scope, scope_from_table_meta,
};

public mount .compile.{
    CompileError, compile, compile_raw, compile_with_schema,
};
