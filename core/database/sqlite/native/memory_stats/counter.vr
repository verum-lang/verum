// =============================================================================
// memory_stats/counter.vr — bytes_used + highwater counter
// =============================================================================
// Spec: SQLite C API
//
// Minimal bookkeeping: running total + monotone highwater + hard/soft
// limits.  All fields are Int64 (bytes) to match sqlite3_*64 APIs.
// =============================================================================

module core.database.sqlite.native.memory_stats.counter;

mount core.*;
mount base.{Bool};

public type MemoryCounter is {
    bytes_used: Int64,
    highwater: Int64,
    /// Cap — allocations beyond this return OOM.  0 disables.
    hard_limit: Int64,
    /// Above this, the engine proactively triggers releases.  0 disables.
    soft_limit: Int64,
}

public fn new_counter() -> MemoryCounter {
    MemoryCounter {
        bytes_used: 0 as Int64,
        highwater: 0 as Int64,
        hard_limit: 0 as Int64,
        soft_limit: 0 as Int64,
    }
}

implement MemoryCounter {
    pub fn on_alloc(&mut self, n: Int64) {
        self.bytes_used = self.bytes_used + n;
        if self.bytes_used > self.highwater {
            self.highwater = self.bytes_used;
        }
    }

    pub fn on_free(&mut self, n: Int64) {
        if self.bytes_used >= n {
            self.bytes_used = self.bytes_used - n;
        } else {
            self.bytes_used = 0 as Int64;
        }
    }

    pub fn reset_highwater(&mut self) {
        self.highwater = self.bytes_used;
    }

    pub fn set_hard_limit(&mut self, n: Int64) -> Int64 {
        let prev = self.hard_limit;
        self.hard_limit = n;
        prev
    }

    pub fn set_soft_limit(&mut self, n: Int64) -> Int64 {
        let prev = self.soft_limit;
        self.soft_limit = n;
        prev
    }

    pub fn is_over_soft_limit(&self) -> Bool {
        self.soft_limit > (0 as Int64) && self.bytes_used > self.soft_limit
    }

    pub fn allocation_would_exceed_hard(&self, n: Int64) -> Bool {
        self.hard_limit > (0 as Int64) && (self.bytes_used + n) > self.hard_limit
    }
}
