// PRAGMA cache_size interpretation + page count computation.

module core.database.sqlite.native.page_cache_sizing_api.cache_size;

mount base.{Bool, Int64, Text};

// Default cache_size per §18.4: -2000 = 2000 KiB.
public fn default_value() -> Int { -2000 }

public type Interpretation is
    | InPages(Int)        // positive: literal page count
    | InKib(Int)          // negative: KiB budget
    ;

public fn classify(n: Int) -> Interpretation {
    if n >= 0 {
        InPages(n)
    } else {
        // Int.MIN-safe magnitude — `-n` for `n == Int.MIN` wraps back
        // to Int.MIN.  Saturate via the canonical bit-flip pattern;
        // 2^40 KiB is the sanity cap also enforced by
        // `effective_page_count`.
        let mag_u: UInt64 = ((!n) as UInt64) + 1_u64;
        let cap: UInt64 = 1099511627776_u64;
        let mag = if mag_u > cap { cap as Int } else { mag_u as Int };
        InKib(mag)
    }
}

public fn interp_name(i: &Interpretation) -> Text {
    match i {
        InPages(_) => "pages".clone(),
        InKib(_)   => "kib".clone(),
    }
}

// Effective page count given page_size (bytes).
//
// SOUNDNESS: pragma_value is a user-supplied PRAGMA argument.
// `(-pragma_value)` would wrap back to Int.MIN if pragma_value were
// Int.MIN, and `kib * 1024` would silently overflow Int64 on
// |pragma_value| > ~2^53 KiB.  Reject Int.MIN explicitly and cap |kib|
// at 2^40 (1 PiB of cache, comfortably beyond any production cache),
// so the multiply by 1024 cannot overflow Int64.
public fn effective_page_count(pragma_value: Int, page_size_bytes: Int) -> Int {
    if pragma_value >= 0 { return pragma_value; }
    if page_size_bytes <= 0 { return 0; }
    // Canonical Int.MIN-safe negation: `(!n) + 1` produces UInt64 magnitude
    // even when n is Int.MIN.  Same recipe as sqlite_version_fmt::int_to_text.
    let kib_u: UInt64 = ((!pragma_value) as UInt64) + 1_u64;
    if kib_u > 1099511627776_u64 {                 // 2^40 — sanity cap
        return 0;
    }
    let bytes_u: UInt64 = kib_u * 1024_u64;        // safe: kib_u ≤ 2^40 ⇒ ≤ 2^50
    let pages_u: UInt64 = bytes_u / (page_size_bytes as UInt64);
    pages_u as Int
}

public fn is_unlimited(pragma_value: Int) -> Bool {
    pragma_value == 0
}

// Minimum viable cache size per SQLite (10 pages).
public fn min_pages() -> Int { 10 }

public fn is_below_minimum(pragma_value: Int, page_size_bytes: Int) -> Bool {
    let n = effective_page_count(pragma_value, page_size_bytes);
    n > 0 && n < min_pages()
}
