module core.database.sqlite.native.l7_api;

// =============================================================================
// core/database/sqlite/native/l7_api/mod.vr — public API facade (L7)
// =============================================================================
// Layer: 7 — what user code imports.
// Dependencies: l6_session
// =============================================================================

public module database;
public module transaction;
public module backup;
public module hooks;
public module hook_registry;
public module pragma_api;
public module blob;
public module capability;
public module typed_connection;

public mount .database.{
    Database, SqliteApiDbError,
    open_memory_db, open_readonly, open_readwrite, open_admin,
    open_path, open_path_readonly, open_path_readwrite, open_path_admin,
    db_error_from_conn,
};

public mount .transaction.{
    Transaction, TxKind,
    TkDeferred, TkImmediate, TkExclusive,
};

public mount .backup.{
    BackupSession,
    backup_init_to_path, backup_init_into,
    backup_step, backup_finish, backup_abandon,
    backup_to_path_in_one_go,
};

public mount .hooks.{
    set_commit_hook, clear_commit_hook, has_commit_hook,
    set_rollback_hook, has_rollback_hook,
    set_update_hook, has_update_hook,
    set_pre_update_hook,
    set_authorizer, has_authorizer,
    set_busy_handler, set_progress_handler, set_trace_hook,
};

public mount .hook_registry.{
    HookKind, HkUpdate, HkPreUpdate, HkCommit, HkRollback,
    HkWal, HkBusy, HkProgress, HkAuthorizer, HkTrace,
    HookHandle, HookSlot, HookHandleRegistry,
    HsUpdate, HsPreUpdate, HsCommit, HsRollback, HsWal,
    HsBusy, HsProgress, HsAuthorizer, HsTrace,
    UpdateHookFn, CommitHookFn, RollbackHookFn, WalHookFn,
    BusyHandlerFn, ProgressHandlerFn, AuthorizerFn, TraceHookFn,
    hook_kind_name, hook_handle_invalid, hook_handle_is_valid,
    hook_handle_registry_new,
};

public mount .pragma_api.{
    PragmaValue, PvNull, PvInt, PvText, PvBool,
    pragma_get, pragma_set,
    pragma_get_int, pragma_set_int,
    pragma_get_text, pragma_set_text,
    pragma_get_bool, pragma_set_bool,
    pragma_kind_to_name,
};

public mount .blob.{
    blob_open, blob_bytes, blob_read, blob_write, blob_reopen, blob_close,
};

public mount .capability.{
    ReadCap, WriteCap, AdminCap,
    Capability, CanRead, CanWrite, CanDdl,
};

public mount .typed_connection.{
    TypedConnection,
    open_readonly as open_typed_readonly,
    open_readwrite as open_typed_readwrite,
    open_admin as open_typed_admin,
    open_memory_readonly, open_memory_readwrite, open_memory_admin,
};
