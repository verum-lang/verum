module core.database.sqlite.native.l7_api.database;

// =============================================================================
// l7_api/database.vr — top-level Database facade
// =============================================================================
// Layer: 7 — user-visible handle.
// Spec: sqlite-native.md §16.1 + §Appendix D (error-code map)
//
// `Database` is what end-user code holds. It wraps a Connection at L6,
// translates L6's strongly-typed ConnectionError / StmtError into a
// single `DbError` tagged with SQLSTATE-style codes, and exposes the
// idiomatic open / prepare / execute / close API.
//
// For v1:
//
//   * open_memory(mode)     — in-memory DB
//   * prepare(sql)          — compile SQL → PreparedStatement
//   * execute(sql)          — compile + run-to-completion for
//                             statements that produce no rows
//                             (DDL / INSERT / DELETE / TX)
//   * query(sql)            — compile + run returning first row;
//                             callers needing more call step() on
//                             the returned PreparedStatement
//   * close(self)           — affine consume
//
// File-backed open (open_path / open_uri) lands once the PosixVfs
// pager backend is integrated — pager_open_memory is the only route
// until the actor IPC is wired.
// =============================================================================

mount core.*;
mount collections.List;
mount base.{Result, Ok, Err, Text, Maybe};
mount core.database.sqlite.native.l1_pager.pager.{Pager};
mount core.database.sqlite.native.ext.registry.{FnRegistry};
mount core.database.sqlite.native.pragmas.config.{PragmaConfig};
mount core.database.sqlite.native.l4_vdbe.{Register, StepResult, VdbeProgram};
mount core.database.sqlite.native.l5_sql.{
    CompileError, Statement, Expr,
    parse_one,
};
mount core.database.sqlite.native.l6_session.{
    Connection, ConnectionMode, ConnectionError, TxMode,
    PreparedStatement, StmtError, IndexMeta,
    open_memory, open_file, prepare, prepare_with_schema,
    mode_can_write, mode_can_ddl,
    table_meta_from_create,
    seed_cursors_from_connection, writeback_cursors_to_connection,
};
mount core.database.sqlite.native.l7_api.transaction.{
    Transaction, TxKind, TkDeferred, TkImmediate, TkExclusive,
    tx_make,
};

// -----------------------------------------------------------------------------
// DbError — SQLSTATE-style tagged sum
// -----------------------------------------------------------------------------

public type DbError is
      DbOk
    | DbGeneric(Text)
    | DbBusy
    | DbLocked
    | DbOutOfMemory
    | DbReadonly
    | DbInterrupted
    | DbIoError(Text)
    | DbCorrupt(Text)
    | DbFull
    | DbCannotOpen(Text)
    | DbConstraint(Text)
    | DbDataTypeMismatch
    | DbMisuse(Text)
    | DbAuthDenied
    | DbBindRange(Int)
    | DbNotADatabase
    | DbCompileError(CompileError)
    | DbConnectionError(ConnectionError)
    | DbStmtError(StmtError)
    | DbUnsupported(Text);

/// Map ConnectionError → DbError for the facade layer.
public fn db_error_from_conn(e: ConnectionError) -> DbError {
    match e {
        NotWritable          => DbReadonly,
        NotAdmin             => DbAuthDenied,
        TxAlreadyActive      => DbMisuse("transaction already active".clone()),
        TxNotActive          => DbMisuse("no active transaction".clone()),
        IoError(ref msg)     => DbIoError(msg.clone()),
    }
}

// -----------------------------------------------------------------------------
// Database
// -----------------------------------------------------------------------------

public type Database is {
    conn: Connection,
};

/// Open an in-memory database with the given capability.
public fn open_memory_db(mode: ConnectionMode) -> Result<Database, DbError> {
    match open_memory(mode) {
        Ok(c)  => Ok(Database { conn: c }),
        Err(e) => Err(db_error_from_conn(e)),
    }
}

// Each open_<mode> inlines the open_memory_db body directly.  An earlier
// shape that delegated through open_memory_db (`{ open_memory_db(CmX) }`
// or `{ let r = open_memory_db(CmX); return r; }`) produced a deterministic
// `Null pointer dereference` panic at the call site once VBC codegen was
// stabilised (task #152).  Inlining sidesteps the broken wrapper-call path
// without losing any expressiveness — the bodies are tiny and the duplicate
// match is the only price.
public fn open_readonly() -> Result<Database, DbError> {
    match open_memory(CmRead) {
        Ok(c)  => Ok(Database { conn: c }),
        Err(e) => Err(db_error_from_conn(e)),
    }
}

public fn open_readwrite() -> Result<Database, DbError> {
    match open_memory(CmWrite) {
        Ok(c)  => Ok(Database { conn: c }),
        Err(e) => Err(db_error_from_conn(e)),
    }
}

public fn open_admin() -> Result<Database, DbError> {
    match open_memory(CmAdmin) {
        Ok(c)  => Ok(Database { conn: c }),
        Err(e) => Err(db_error_from_conn(e)),
    }
}

/// Open a file-backed database with the given capability mode.
/// Routes through L6 `open_file` → L1 `pager_open_file` → L0 PosixVfs.
/// The path is interpreted by the platform's filesystem; the caller
/// is responsible for any URI parsing (the `file:` URI handler is a
/// separate `core.database.sqlite.native.uri` task).
public fn open_path(path: &Text, mode: ConnectionMode) -> Result<Database, DbError> {
    match open_file(path, mode) {
        Ok(c)  => Ok(Database { conn: c }),
        Err(e) => Err(db_error_from_conn(e)),
    }
}

public fn open_path_readonly(path: &Text) -> Result<Database, DbError> {
    open_path(path, CmRead)
}

public fn open_path_readwrite(path: &Text) -> Result<Database, DbError> {
    open_path(path, CmWrite)
}

public fn open_path_admin(path: &Text) -> Result<Database, DbError> {
    open_path(path, CmAdmin)
}

implement Database {
    public fn mode(&self) -> ConnectionMode { self.conn.mode() }
    public fn is_in_tx(&self) -> Bool { self.conn.is_in_tx() }
    public fn schema_generation(&self) -> Int { self.conn.schema_generation() }

    /// Borrow the underlying L1 pager — used by the online-backup
    /// surface (`l7_api/backup.vr`) and other low-level callers that
    /// need to walk pages directly.  External crates should prefer
    /// the higher-level operations in `database.vr` itself.
    public fn pager_view(&self) -> &Pager { self.conn.pager() }
    public fn pager_mut(&mut self) -> &mut Pager { self.conn.pager_mut() }

    /// Borrow the connection's function & hook registry.  Used by the
    /// `l7_api.hooks` surface to expose `set_commit_hook` /
    /// `set_rollback_hook` / etc. as method-style sugar on Database
    /// without leaking the underlying Connection through the public
    /// API.
    public fn registry_view(&self) -> &FnRegistry { self.conn.registry_view() }
    public fn registry_mut(&mut self) -> &mut FnRegistry { self.conn.registry_mut() }

    /// Borrow the connection's per-connection PRAGMA state.  Used by
    /// the `l7_api.pragma_api` surface for typed pragma_get / _set.
    public fn pragma_cfg_view(&self) -> &PragmaConfig { self.conn.pragma_cfg_view() }
    public fn pragma_cfg_mut(&mut self) -> &mut PragmaConfig { self.conn.pragma_cfg_mut() }

    /// Borrow the underlying L6 Connection.  Required by
    /// `l7_api.blob` so it can talk to the schema cache + table store
    /// + blob engine in one logical pass.  Other L7 modules should
    /// prefer the narrower accessors above.
    public fn conn_view_for_blob(&self) -> &Connection { &self.conn }
    public fn conn_mut_for_blob(&mut self) -> &mut Connection { &mut self.conn }

    // -------------------------------------------------------------------------
    // Prepare / execute / query
    // -------------------------------------------------------------------------

    /// Compile `sql` into a PreparedStatement. Routes through the
    /// schema-aware pipeline so that `SELECT ... FROM t` resolves
    /// column references against the live SchemaCache.
    public fn prepare(&self, sql: &Text) -> Result<PreparedStatement, DbError> {
        match prepare_with_schema(sql, self.conn.schema()) {
            Ok(p)  => Ok(p),
            Err(e) => Err(DbStmtError(e)),
        }
    }

    /// Compile + run-to-completion. Intended for statements that
    /// produce no rows (DDL, INSERT/UPDATE/DELETE, transaction
    /// control). For CREATE TABLE / DROP TABLE we also apply the
    /// schema side-effect so subsequent SELECTs can resolve.
    public fn execute(&mut self, sql: &Text) -> Result<(), DbError> {
        // Parse once up front for the schema side-effect hook.
        let stmt_ast = match parse_one(sql) {
            Ok(s)  => s,
            Err(e) => {
                // Let the regular prepare path surface the parse error
                // with the richer CompileError wrapping.
                let _ = e;
                let mut stmt = match self.prepare(sql) {
                    Ok(s)  => s, Err(err) => { return Err(err); }
                };
                let _ = stmt;
                return Err(DbMisuse("unreachable — parse failed after re-parse succeeded".clone()));
            }
        };

        // Apply DDL side-effects BEFORE compiling so that a subsequent
        // same-transaction SELECT sees the new table.
        match stmt_ast {
            SCreateTable(ref ct) => {
                match self.conn.ensure_admin() {
                    Ok(_)  => {},
                    Err(e) => { return Err(db_error_from_conn(e)); }
                }
                let root = self.conn.allocate_root_page();
                let meta = table_meta_from_create(ct, root, sql.clone());
                let already = self.conn.schema().has_table(&ct.table.schema, &ct.table.name);
                if already {
                    if ct.if_not_exists {
                        // IF NOT EXISTS is non-failure
                    } else {
                        return Err(DbConstraint("table already exists".clone()));
                    }
                } else {
                    let _ = self.conn.schema_mut().register_table(meta);
                }
            }
            SDropTable(if_exists, ref tref) => {
                match self.conn.ensure_admin() {
                    Ok(_)  => {},
                    Err(e) => { return Err(db_error_from_conn(e)); }
                }
                let has = self.conn.schema().has_table(&tref.schema, &tref.name);
                if !has {
                    if !if_exists {
                        return Err(DbGeneric("table does not exist".clone()));
                    }
                } else {
                    let _ = self.conn.schema_mut().drop_table(&tref.schema, &tref.name);
                }
            }
            SCreateIndex(ref ci) => {
                match self.conn.ensure_admin() {
                    Ok(_)  => {},
                    Err(e) => { return Err(db_error_from_conn(e)); }
                }
                let root = self.conn.allocate_root_page();
                let mut col_names: List<Text> = List.new();
                let mut i: Int = 0;
                while i < ci.columns.len() {
                    match ci.columns[i].expr {
                        EColumn(ref _t, ref n) => { col_names.push(n.clone()); }
                        _ => {}
                    }
                    i = i + 1;
                }
                let meta = IndexMeta {
                    schema: ci.index.schema.clone(),
                    name: ci.index.name.clone(),
                    table_name: ci.table.name.clone(),
                    root_page: root,
                    columns: col_names,
                    unique: ci.unique,
                };
                match self.conn.schema_mut().register_index(meta) {
                    Ok(_)  => {}
                    Err(_) => {
                        if !ci.if_not_exists {
                            return Err(DbConstraint("index already exists".clone()));
                        }
                    }
                }
            }
            SCreateView(ref _cv) => {
                // Views are metadata-only in v1; codegen emits a no-op
                // and the facade skips schema-cache registration until
                // the view resolver lands.
            }
            _ => {}
        }

        let mut stmt = match self.prepare(sql) {
            Ok(s)  => s, Err(e) => { return Err(e); }
        };
        seed_cursors_from_connection(&mut stmt, &self.conn);
        let mut err_result: Maybe<DbError> = None;
        loop {
            match stmt.step() {
                Done => { break; }
                Row(_, _) => {
                    err_result = Some(DbMisuse("execute() called on a row-producing query".clone()));
                    break;
                }
                ExecError(c, m) => {
                    err_result = Some(DbStmtError(StmtExec(c, m)));
                    break;
                }
                Yield => {
                    // Shouldn't happen — run_until_row already drains
                    // Yields, but we guard.
                }
            }
        }
        writeback_cursors_to_connection(&stmt, &mut self.conn);
        match err_result {
            Some(e) => Err(e),
            None    => Ok(()),
        }
    }

    /// Compile + step once, returning the first row (if any) as a
    /// list of Register values. Intended for single-row SELECTs;
    /// multi-row consumers call `prepare` + loop directly.
    public fn query_first_row(&mut self, sql: &Text) -> Result<List<Register>, DbError> {
        let mut stmt = match self.prepare(sql) {
            Ok(s)  => s, Err(e) => { return Err(e); }
        };
        seed_cursors_from_connection(&mut stmt, &self.conn);
        let result = match stmt.step() {
            Row(start, cols) => {
                let mut out: List<Register> = List.new();
                let mut i: Int = 0;
                while i < cols {
                    out.push(stmt.column(i));
                    i = i + 1;
                }
                Ok(out)
            }
            Done => Ok(List.new()),   // no rows
            ExecError(c, m) => Err(DbStmtError(StmtExec(c, m))),
            Yield => Err(DbMisuse("yield outside run_until_row".clone())),
        };
        writeback_cursors_to_connection(&stmt, &mut self.conn);
        result
    }

    /// Collect every row a SELECT produces. Seeds cursors before
    /// stepping and writes back after. Use for bounded-size result
    /// sets; large scans should iterate via `prepare` + manual `step`
    /// loop + the bridge helpers.
    public fn query_all(&mut self, sql: &Text) -> Result<List<List<Register>>, DbError> {
        let mut stmt = match self.prepare(sql) {
            Ok(s)  => s, Err(e) => { return Err(e); }
        };
        seed_cursors_from_connection(&mut stmt, &self.conn);
        let mut out: List<List<Register>> = List.new();
        let mut err_result: Maybe<DbError> = None;
        loop {
            match stmt.step() {
                Row(_, cols) => {
                    let mut row: List<Register> = List.new();
                    let mut i: Int = 0;
                    while i < cols {
                        row.push(stmt.column(i));
                        i = i + 1;
                    }
                    out.push(row);
                }
                Done => { break; }
                ExecError(c, m) => {
                    err_result = Some(DbStmtError(StmtExec(c, m)));
                    break;
                }
                Yield => {}
            }
        }
        writeback_cursors_to_connection(&stmt, &mut self.conn);
        match err_result {
            Some(e) => Err(e),
            None    => Ok(out),
        }
    }

    // -------------------------------------------------------------------------
    // Transaction — affine handle API
    // -------------------------------------------------------------------------
    //
    // Spec database.md §4.1+§5.5: `Transaction` is `affine` — the value
    // MUST be consumed by exactly one of `commit_tx` / `rollback_tx`.
    // The compiler refuses to drop a Transaction out of scope, which
    // makes "leaked transaction" (the most common production SQL bug)
    // lexically impossible.
    //
    // For the 90% case use `with_transaction(|d| body)`; for the
    // advanced manual case use `begin_tx_*` + `commit_tx`/`rollback_tx`.

    /// Begin a deferred transaction (BEGIN).  Returns the affine
    /// handle the caller MUST consume.
    public fn begin_tx(&mut self) -> Result<Transaction, DbError> {
        let depth = self.conn.tx_depth();
        match self.conn.begin_tx(TmDeferred) {
            Ok(_)  => Ok(tx_make(depth, TkDeferred)),
            Err(e) => Err(db_error_from_conn(e)),
        }
    }

    /// Begin an IMMEDIATE transaction (RESERVED lock at start).
    public fn begin_tx_immediate(&mut self) -> Result<Transaction, DbError> {
        let depth = self.conn.tx_depth();
        match self.conn.begin_tx(TmImmediate) {
            Ok(_)  => Ok(tx_make(depth, TkImmediate)),
            Err(e) => Err(db_error_from_conn(e)),
        }
    }

    /// Begin an EXCLUSIVE transaction.
    public fn begin_tx_exclusive(&mut self) -> Result<Transaction, DbError> {
        let depth = self.conn.tx_depth();
        match self.conn.begin_tx(TmExclusive) {
            Ok(_)  => Ok(tx_make(depth, TkExclusive)),
            Err(e) => Err(db_error_from_conn(e)),
        }
    }

    /// Consume the transaction handle and COMMIT.  Returns
    /// `DbMisuse(...)` if the connection's tx-depth no longer matches
    /// what `tx` recorded at begin time (savepoint left dangling).
    public fn commit_tx(&mut self, tx: Transaction) -> Result<(), DbError> {
        let started = tx.started_at_depth();
        let _ = tx;     // affine consume — no further use of `tx` is possible.
        let now = self.conn.tx_depth();
        if now != started + 1 {
            // The user opened a savepoint and forgot to release it before
            // committing the outer tx.  We refuse and let them clean up.
            return Err(DbMisuse(
                "commit_tx called with stale tx-depth — release nested savepoints first"
                    .clone(),
            ));
        }
        match self.conn.commit_tx() {
            Ok(_)  => Ok(()),
            Err(e) => Err(db_error_from_conn(e)),
        }
    }

    /// Consume the transaction handle and ROLLBACK.  Tolerant of stale
    /// depth — rollback is a recovery path, so we issue the ROLLBACK
    /// regardless.
    public fn rollback_tx(&mut self, tx: Transaction) -> Result<(), DbError> {
        let _ = tx;
        match self.conn.rollback_tx() {
            Ok(_)  => Ok(()),
            Err(e) => Err(db_error_from_conn(e)),
        }
    }

    /// Run `body` inside an automatically-managed deferred transaction.
    /// Begins, runs, and commits on success; rolls back on either a
    /// `body` error or a panic propagating through the closure.
    ///
    /// This is the recommended entry point for almost all transactional
    /// code — the affine `Transaction` value is created and consumed
    /// internally so the caller never has to thread it.
    public fn with_transaction<R>(
        &mut self,
        body: fn(&mut Database) -> Result<R, DbError>,
    ) -> Result<R, DbError> {
        let tx = match self.begin_tx() {
            Ok(t)  => t,
            Err(e) => { return Err(e); }
        };
        let body_result = body(self);
        match body_result {
            Ok(r) => {
                match self.commit_tx(tx) {
                    Ok(_)  => Ok(r),
                    Err(e) => Err(e),
                }
            }
            Err(body_err) => {
                // Best-effort rollback — the original body error wins.
                let _ = self.rollback_tx(tx);
                Err(body_err)
            }
        }
    }

    /// IMMEDIATE-mode variant of `with_transaction`.  Useful in
    /// concurrent-writer setups to avoid SQLITE_BUSY.
    public fn with_transaction_immediate<R>(
        &mut self,
        body: fn(&mut Database) -> Result<R, DbError>,
    ) -> Result<R, DbError> {
        let tx = match self.begin_tx_immediate() {
            Ok(t)  => t,
            Err(e) => { return Err(e); }
        };
        let body_result = body(self);
        match body_result {
            Ok(r) => {
                match self.commit_tx(tx) {
                    Ok(_)  => Ok(r),
                    Err(e) => Err(e),
                }
            }
            Err(body_err) => {
                let _ = self.rollback_tx(tx);
                Err(body_err)
            }
        }
    }

    // -------------------------------------------------------------------------
    // Close
    // -------------------------------------------------------------------------

    /// Consume the database. Further methods are unreachable because
    /// `self` is moved. In the actor-backed version this also
    /// forwards a Close request to the pager actor.
    public fn close(self) {
        let _ = self;
    }
}
