// PRAGMA legacy_file_format handler.

module core.database.sqlite.native.legacy_file_format_pragma.gate;

mount base.{Bool, Text};

public type LegacyFileFormatMode is
    | FfModern       // 0 — default; format-4 layout (3.3.0+)
    | FfLegacy       // 1 — format-1 layout (3.0.0 wire-compat)
    ;

public fn default_mode() -> LegacyFileFormatMode { FfModern }

public fn from_pragma_value(n: Int) -> LegacyFileFormatMode {
    if n == 0 { FfModern } else { FfLegacy }
}

public fn to_pragma_value(m: &LegacyFileFormatMode) -> Int {
    match m { FfModern => 0, FfLegacy => 1 }
}

public fn mode_name(m: &LegacyFileFormatMode) -> Text {
    match m { FfModern => "modern".clone(), FfLegacy => "legacy".clone() }
}

// Header-byte values for "schema format" stored at offset 44 in the db header.
public fn write_format_for(m: &LegacyFileFormatMode) -> Int {
    match m { FfModern => 4, FfLegacy => 1 }
}

public fn read_format_min_for(m: &LegacyFileFormatMode) -> Int {
    match m { FfModern => 1, FfLegacy => 1 }
}

public fn read_format_max_for(m: &LegacyFileFormatMode) -> Int {
    match m { FfModern => 4, FfLegacy => 4 }
}

public fn supports_descending_index(m: &LegacyFileFormatMode) -> Bool {
    match m { FfModern => true, FfLegacy => false }
}

// Pragma is deprecated since 3.35.0 but still parsed.
public fn is_deprecated(_m: &LegacyFileFormatMode) -> Bool { true }
