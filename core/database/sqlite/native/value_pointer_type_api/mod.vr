// sqlite3_value_pointer(value, type) — added 3.20. Returns the opaque pointer
// stashed by sqlite3_bind_pointer / sqlite3_result_pointer if and only if the
// type-tag string matches. Otherwise returns NULL — engine never coerces
// or reinterprets the pointer. Spec App E.V.
// =============================================================================

