// =============================================================================
// planner_passes/decorrelate.vr — IN/EXISTS subquery → semi-join
// =============================================================================
// Spec: sqlite-native.md §13.5
//
// Transform:
//
//   SELECT … FROM outer_t WHERE outer_t.x IN (SELECT y FROM inner_t WHERE p)
//
// becomes
//
//   SELECT … FROM outer_t SEMI JOIN inner_t ON outer_t.x = inner_t.y
//                                         AND p
//
// `EXISTS` and `NOT EXISTS` become SEMI / ANTI joins respectively.
//
// Only **uncorrelated** subqueries are decorrelated by this pass —
// the magic-sets pass handles correlated cases.
// =============================================================================

module core.database.sqlite.native.planner_passes.decorrelate;

mount core.*;
mount base.{Text, Bool};
mount collections.List;
mount core.database.sqlite.native.planner_passes.plan_view.{
    PvNode, PvScan, PvFilter, PvProject, PvJoin, PvSubquery,
    PvJoinKind, PvjkInner, PvjkSemi, PvjkAnti,
    PvSubqueryShape, PvssIn, PvssExists, PvssNotExists, PvssScalar,
    PvJoinInfo, PvFilterInfo, PvSubqueryInfo,
    node_id, node_kind_name,
};
mount core.database.sqlite.native.planner_passes.pass.{
    PlannerPass, PassResult, pass_result,
};

public type Decorrelate is { unit: Bool };
public fn decorrelate() -> Decorrelate { Decorrelate { unit: true } }

implement PlannerPass for Decorrelate {
    fn name(&self) -> Text { "decorrelate".clone() }

    fn apply(&self, plan: PvNode) -> PassResult {
        let mut edits: Int = 0;
        let new_plan = walk(plan, &mut edits);
        pass_result(new_plan, edits)
    }
}

fn walk(node: PvNode, edits: &mut Int) -> PvNode {
    match node {
        PvFilter(f) => {
            let new_child = walk(*f.child, edits);
            // If the predicate has a subquery shape AND it's not
            // correlated → rewrite to a semi/anti join with the
            // child as left input and the subquery body as right.
            // We model that as Join(SEMI, child, subquery.body).
            //
            // We can't introspect the predicate text here without
            // a parser; the L5 codegen tags filters that *contain*
            // a subquery via the `is_correlated` flag false +
            // surrounding context; we therefore rely on the
            // subquery being a sibling node, not embedded in text.
            //
            // For the pure-Verum view we expose, the inner subquery
            // appears as a child of the filter via `predicate_sql`.
            // Until codegen surfaces it as a tree, we just pass
            // through.
            PvFilter(PvFilterInfo {
                id: f.id,
                predicate_sql: f.predicate_sql,
                is_correlated: f.is_correlated,
                child: Heap.new(new_child),
            })
        }
        PvSubquery(s) => {
            // If uncorrelated AND shape is IN/EXISTS, surface this
            // as a SEMI join. (Anti for NOT EXISTS.)
            if s.correlations.len() == 0 {
                let new_body = walk(*s.body, edits);
                let kind = match &s.shape {
                    PvssIn        => Some(PvjkSemi),
                    PvssExists    => Some(PvjkSemi),
                    PvssNotExists => Some(PvjkAnti),
                    PvssScalar    => None,
                };
                match kind {
                    Some(jk) => {
                        *edits = *edits + 1;
                        PvJoin(PvJoinInfo {
                            id: s.id,
                            kind: jk,
                            on_predicate_sql: s.outer_predicate_sql,
                            // Left will be plugged in by caller; for
                            // the standalone surface we use the body
                            // both sides — a real codegen synthesises
                            // the actual outer plan.
                            left: Heap.new(new_body.clone_via_walk()),
                            right: Heap.new(new_body),
                        })
                    }
                    None => PvSubquery(s),
                }
            } else {
                // Correlated — magic_sets handles it.
                PvSubquery(s)
            }
        }
        PvJoin(j) => {
            let new_left = walk(*j.left, edits);
            let new_right = walk(*j.right, edits);
            PvJoin(PvJoinInfo {
                id: j.id,
                kind: j.kind,
                on_predicate_sql: j.on_predicate_sql,
                left: Heap.new(new_left),
                right: Heap.new(new_right),
            })
        }
        PvProject(p) => {
            let new_child = walk(*p.child, edits);
            PvProject(core.database.sqlite.native.planner_passes.plan_view.PvProjectInfo {
                id: p.id,
                columns_sql: p.columns_sql,
                child: Heap.new(new_child),
            })
        }
        other => other,
    }
}

// -----------------------------------------------------------------------------
// Tiny extension for one-shot deep clone via walk (no edits).
// -----------------------------------------------------------------------------

implement PvNode {
    public fn clone_via_walk(self) -> PvNode {
        match self {
            PvScan(s)      => PvScan(s),
            PvFilter(f)    => {
                let inner = (*f.child).clone_via_walk();
                PvFilter(PvFilterInfo {
                    id: f.id,
                    predicate_sql: f.predicate_sql.clone(),
                    is_correlated: f.is_correlated,
                    child: Heap.new(inner),
                })
            }
            PvProject(p)   => {
                let inner = (*p.child).clone_via_walk();
                PvProject(core.database.sqlite.native.planner_passes.plan_view.PvProjectInfo {
                    id: p.id,
                    columns_sql: clone_text_list(&p.columns_sql),
                    child: Heap.new(inner),
                })
            }
            PvJoin(j)      => {
                let l = (*j.left).clone_via_walk();
                let r = (*j.right).clone_via_walk();
                PvJoin(PvJoinInfo {
                    id: j.id,
                    kind: clone_join_kind(&j.kind),
                    on_predicate_sql: j.on_predicate_sql.clone(),
                    left: Heap.new(l),
                    right: Heap.new(r),
                })
            }
            PvAggregate(a) => {
                let inner = (*a.child).clone_via_walk();
                PvAggregate(core.database.sqlite.native.planner_passes.plan_view.PvAggregateInfo {
                    id: a.id,
                    group_by_sql: clone_text_list(&a.group_by_sql),
                    aggregates_sql: clone_text_list(&a.aggregates_sql),
                    child: Heap.new(inner),
                })
            }
            PvUnionAll(u)  => PvUnionAll(u),
            PvSubquery(s)  => PvSubquery(s),
            PvRecursive(r) => PvRecursive(r),
            PvWindow(w)    => PvWindow(w),
        }
    }
}

fn clone_text_list(l: &List<Text>) -> List<Text> {
    let mut out: List<Text> = List.new();
    let mut i: Int = 0;
    while i < l.len() { out.push(l[i].clone()); i = i + 1; }
    out
}

fn clone_join_kind(k: &PvJoinKind) -> PvJoinKind {
    match k {
        core.database.sqlite.native.planner_passes.plan_view.PvjkInner => core.database.sqlite.native.planner_passes.plan_view.PvjkInner,
        core.database.sqlite.native.planner_passes.plan_view.PvjkLeft  => core.database.sqlite.native.planner_passes.plan_view.PvjkLeft,
        core.database.sqlite.native.planner_passes.plan_view.PvjkRight => core.database.sqlite.native.planner_passes.plan_view.PvjkRight,
        core.database.sqlite.native.planner_passes.plan_view.PvjkFull  => core.database.sqlite.native.planner_passes.plan_view.PvjkFull,
        core.database.sqlite.native.planner_passes.plan_view.PvjkSemi  => core.database.sqlite.native.planner_passes.plan_view.PvjkSemi,
        core.database.sqlite.native.planner_passes.plan_view.PvjkAnti  => core.database.sqlite.native.planner_passes.plan_view.PvjkAnti,
    }
}
