@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.database.sqlite.native.l4_vdbe.cursor_btree_bridge;

// =============================================================================
// l4_vdbe/cursor_btree_bridge.vr — L4 cursor opcode → L3 btree_ops bridge
// =============================================================================
// Layer: 4 (interpreter side) → 3 (btree side)
// Spec: sqlite-native.md §11.2 (cursor opcodes) + §10.3 (btree cursor)
//
// Pre-fix: L4 interpreter's cursor-touching opcodes (Column / Next /
// SeekGE / Insert) were stubs because the L3 btree had no cursor
// seek/next/insert (#140).  Now that #140 ships the foundation
// (`cursor_seek`, `cursor_next`, `btree_insert_at_cursor`), this
// module bridges the two layers.
//
// Per cursor opcode, this module exposes a function the interpreter
// calls.  Each function takes:
//   * the L4-side `CursorSlot` (carries the L3 `BtreeCursor`)
//   * a `PageStore` / `&mut PageStore` (production: WalPager adapter)
//   * the opcode-specific arguments (column index, target rowid, etc.)
// and returns the result the opcode expects.
//
// This is a thin adapter — no business logic here, just shape
// translation.  The actual work happens in `cursor_seek.vr`,
// `btree_ops.vr`, etc.
// =============================================================================

mount core.*;
mount collections.{List, Map};
mount base.{Result, Ok, Err, Text, Maybe};
mount core.database.sqlite.native.l3_btree.cursor.{
    BtreeCursor,
    // Alias `cursor_new` as `btree_cursor_new` to disambiguate from
    // the 0-arg `cursor_new` siblings in
    // `core/database/sqlite/native/vtabs/{dbstat,generate_series,
    // json_each}.vr`.  Pre-fix the AOT vbc_lowering's first-suffix-
    // wins `lookup_function` picked one of those 0-arg variants and
    // rejected `cursor_new(&tree)` with "wrong number of arguments
    // for cursor_new: expected 0, found 1".  Same root class as
    // task #17/#39 mount-scope-aware lookup.
    cursor_new,
    cursor_root, cursor_is_valid, cursor_is_at_end,
    cursor_current_page, cursor_current_cell,
};
mount core.database.sqlite.native.l3_btree.btree.{
    Btree, BtreeError, BtreeKind, TableBtree, IndexBtree,
    btree_new,
    InvalidRootPage,
};
mount core.database.sqlite.native.l3_btree.cursor_seek.{
    PageStore, page_store_new,
    SeekOutcome, SoExactMatch, SoFoundLarger, SoFoundSmaller, SoEmpty, SoPastEnd,
    cursor_seek, cursor_next, cursor_prev,
    cursor_first as bt_cursor_first, cursor_last as bt_cursor_last,
};
mount core.database.sqlite.native.l3_btree.comparator.{
    SeekKey, SkRowId, SkRecord,
};
mount core.database.sqlite.native.btree_seek_op_codes.op.{
    SeekOp, SoEq, SoGe, SoLe, SoGt, SoLt,
};
mount core.database.sqlite.native.l3_btree.btree_ops.{
    btree_seek, btree_insert_at_cursor, btree_delete_at_cursor,
    RebalanceLog,
};
mount core.database.sqlite.native.l3_btree.balance.{
    BalanceContext, balance_context_new,
};
mount core.database.sqlite.native.l3_btree.page_layout.{
    PageKind, parse_page_header, parse_cell_pointer_array, parse_cell,
    CellParts, TableLeafCell, TableInteriorCell, IndexLeafCell, IndexInteriorCell,
};
mount core.database.sqlite.native.l2_record.record.{
    SerialType, StNull, StInt8, StInt16, StInt24, StInt32, StInt48, StInt64,
    StReal, StZero, StOne, StBlob, StText,
    decode_record_header, serial_type_payload_size,
};
mount core.database.sqlite.native.l2_record.varint;
mount core.database.sqlite.native.l4_vdbe.register.{
    Register, RNull, RInt, RReal, RText, RBlob, RRowId,
};
mount core.database.sqlite.native.l4_vdbe.cursor_table.{
    CursorSlot, CursorTable, CursorTableError,
};

// -----------------------------------------------------------------------------
// CursorBridgeError — composed error type for opcode dispatch
// -----------------------------------------------------------------------------

public type CursorBridgeError is
      BeBtree(BtreeError)
    | BeInvalidCursor(Text)
    | BePageNotFound(Int)
    | BeCellOutOfRange(Int)
    | BeUnsupportedOp(Text);

implement Display for CursorBridgeError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            BeBtree(e)         => f.write_str(f"cursor bridge: btree error {e}".as_str()),
            BeInvalidCursor(r) => f.write_str(f"cursor bridge: invalid cursor ({r})".as_str()),
            BePageNotFound(p)  => f.write_str(f"cursor bridge: page {p} not found".as_str()),
            BeCellOutOfRange(i)=> f.write_str(f"cursor bridge: cell {i} out of range".as_str()),
            BeUnsupportedOp(o) => f.write_str(f"cursor bridge: unsupported op {o}".as_str()),
        }
    }
}

// -----------------------------------------------------------------------------
// OpenRead / OpenWrite — instantiate a cursor
// -----------------------------------------------------------------------------

/// Mirror of L4 `OpenRead(cursor_id, root_page, n_cols)` opcode.
/// Returns a fresh `BtreeCursor` seated at the root of `root_page`.
/// Caller installs the cursor into the cursor table at `cursor_id`.
public fn op_open_read(
    root_page: Int,
    page_size: Int,
    reserved_bytes: Int,
) -> Result<BtreeCursor, CursorBridgeError> {
    let tree = match btree_new(TableBtree, root_page, page_size, reserved_bytes) {
        Ok(t)  => t,
        Err(e) => return Err(BeBtree(e)),
    };
    let mut c = core.database.sqlite.native.l3_btree.cursor.cursor_new(&tree);
    match cursor_root(&mut c) {
        Ok(_)  => Ok(c),
        Err(e) => Err(BeBtree(e)),
    }
}

// -----------------------------------------------------------------------------
// Column — read column `col_idx` from the row at the cursor
// -----------------------------------------------------------------------------

/// Mirror of L4 `Column(cursor_id, col_idx, reg_dst)` opcode.
/// Returns the column value as a `Register`; caller stores it into
/// the destination register.  Schema-typed columns return their
/// declared type; SkAny columns return based on the cell's payload
/// kind (foundation: returns RBlob with the local payload bytes).
public fn op_column(
    c: &BtreeCursor,
    pages: &PageStore,
    col_idx: Int,
) -> Result<Register, CursorBridgeError> {
    if !cursor_is_valid(c) {
        return Err(BeInvalidCursor("Column: cursor not valid".clone()));
    }
    let page_no = cursor_current_page(c);
    let cell_idx = cursor_current_cell(c);
    let bytes = match pages.fetch(page_no) {
        Some(b) => b,
        None    => return Err(BePageNotFound(page_no)),
    };
    let hdr_off = if page_no == c.root_page && page_no == 1 { 100 } else { 0 };
    let (hdr, _) = match parse_page_header(&bytes, hdr_off) {
        Ok(p)  => p,
        Err(_) => return Err(BeBtree(InvalidRootPage(page_no))),
    };
    if cell_idx < 0 || cell_idx >= hdr.cell_count {
        return Err(BeCellOutOfRange(cell_idx));
    }
    let pointers = match parse_cell_pointer_array(&bytes, &hdr.cell_pointer_offset, hdr.cell_count) {
        Ok(p)  => p,
        Err(_) => return Err(BeBtree(InvalidRootPage(page_no))),
    };
    let cell_off = pointers[cell_idx];
    let local_max: Int = 100;
    let parts = match parse_cell(&bytes, cell_off, hdr.kind.clone(), local_max) {
        Ok(p)  => p,
        Err(_) => return Err(BeBtree(InvalidRootPage(page_no))),
    };
    extract_column_register(&bytes, cell_off, &parts, col_idx)
}

/// Decode column `col_idx` from a parsed cell.  Walks the SQLite
/// record header (varint serial-type stream) to find the column's
/// SerialType + payload offset, then decodes the value into a
/// typed `Register`.
///
/// Algorithm (matches SQLite's `sqlite3VdbeMemFromBtree`):
///   1. Locate the record's header start within the cell payload.
///   2. `decode_record_header` returns the serial-type list +
///      header_consumed bytes.
///   3. Skip serial types 0..col_idx-1; sum their payload sizes
///      to find the body offset of column col_idx.
///   4. Read `col_idx`'s SerialType from `serial_type_payload_size`
///      to get its byte length and decode into a Register.
fn extract_column_register(
    bytes: &List<Byte>,
    cell_off: Int,
    cell: &CellParts,
    col_idx: Int,
) -> Result<Register, CursorBridgeError> {
    if col_idx < 0 {
        return Err(BeUnsupportedOp("Column: negative col_idx".clone()));
    }
    match cell {
        TableLeafCell(_payload_len, rowid, local_end, _overflow) => {
            // Special case: SQLite treats column 0 of an INTEGER
            // PRIMARY KEY table as the rowid.  For other columns,
            // walk the record header.
            if col_idx == 0 {
                // Heuristic: if the record decodes to StNull at
                // column 0 (the typical INTEGER PRIMARY KEY row
                // shape), the rowid is the user-visible value.
                let payload_start = compute_payload_start(bytes, cell_off, true);
                match decode_record_column(bytes, payload_start, local_end, 0) {
                    Ok(reg) => match &reg {
                        RNull => Ok(RRowId(rowid)),
                        _     => Ok(reg),
                    }
                    Err(_) => Ok(RRowId(rowid)),
                }
            } else {
                let payload_start = compute_payload_start(bytes, cell_off, true);
                match decode_record_column(bytes, payload_start, local_end, col_idx) {
                    Ok(reg) => Ok(reg),
                    Err(e) => Err(e),
                }
            }
        }
        TableInteriorCell(_, rowid) => {
            // Interior cells carry only the rowid + left-child pointer.
            if col_idx == 0 { Ok(RRowId(rowid)) } else { Ok(RNull) }
        }
        IndexLeafCell(_payload_len, local_end, _overflow) => {
            let payload_start = compute_payload_start(bytes, cell_off, false);
            decode_record_column(bytes, payload_start, local_end, col_idx)
        }
        IndexInteriorCell(_left, _payload_len, local_end, _overflow) => {
            // Skip the 4-byte left_child pointer; payload starts after
            // the payload-length varint.
            let payload_start = compute_payload_start_index_interior(bytes, cell_off);
            decode_record_column(bytes, payload_start, local_end, col_idx)
        }
    }
}

/// Re-decode the cell's payload-start offset.  `is_table_leaf` =
/// true → cell layout `[payload_len_varint][rowid_varint][payload]`;
/// false → index leaf layout `[payload_len_varint][payload]`.
fn compute_payload_start(bytes: &List<Byte>, cell_off: Int, is_table_leaf: Bool) -> Int {
    let (_payload_len, a) = match varint.decode(bytes, cell_off) {
        Ok(r)  => r,
        Err(_) => return cell_off,
    };
    if !is_table_leaf {
        return cell_off + a;
    }
    let (_rowid, b) = match varint.decode(bytes, cell_off + a) {
        Ok(r)  => r,
        Err(_) => return cell_off + a,
    };
    cell_off + a + b
}

fn compute_payload_start_index_interior(bytes: &List<Byte>, cell_off: Int) -> Int {
    // 4-byte left_child + payload_len varint + payload.
    let after_child = cell_off + 4;
    let (_payload_len, a) = match varint.decode(bytes, after_child) {
        Ok(r)  => r,
        Err(_) => return after_child,
    };
    after_child + a
}

/// Decode column `col_idx` from a record at `payload_start..payload_end`.
/// Walks the header serial-type stream + per-column payload offsets.
fn decode_record_column(
    bytes: &List<Byte>,
    payload_start: Int,
    payload_end: Int,
    col_idx: Int,
) -> Result<Register, CursorBridgeError> {
    if payload_start >= bytes.len() || payload_start >= payload_end {
        return Ok(RNull);
    }
    let (types, header_consumed) = match decode_record_header(bytes, payload_start) {
        Ok(r)  => r,
        Err(_) => return Ok(RNull),
    };
    if col_idx >= types.len() {
        return Ok(RNull);
    }

    // Body starts immediately after the header.  Walk per-column
    // payload sizes until we reach col_idx.
    let mut body_offset = payload_start + header_consumed;
    let mut i: Int = 0;
    while i < col_idx {
        let sz = serial_type_payload_size(types[i]);
        body_offset = body_offset + sz;
        i = i + 1;
    }

    // Decode the value at body_offset per its serial type.
    decode_serial_value(bytes, body_offset, payload_end, &types[col_idx])
}

/// Decode one serial-type value into a Register.
fn decode_serial_value(
    bytes: &List<Byte>,
    offset: Int,
    payload_end: Int,
    st: &SerialType,
) -> Result<Register, CursorBridgeError> {
    match st {
        StNull   => Ok(RNull),
        StInt8   => Ok(RInt(read_int_be(bytes, offset, 1, payload_end))),
        StInt16  => Ok(RInt(read_int_be(bytes, offset, 2, payload_end))),
        StInt24  => Ok(RInt(read_int_be(bytes, offset, 3, payload_end))),
        StInt32  => Ok(RInt(read_int_be(bytes, offset, 4, payload_end))),
        StInt48  => Ok(RInt(read_int_be(bytes, offset, 6, payload_end))),
        StInt64  => Ok(RInt(read_int_be(bytes, offset, 8, payload_end))),
        StReal   => {
            // IEEE 754 big-endian — decode as i64 bits then reinterpret.
            let bits = read_int_be(bytes, offset, 8, payload_end);
            // Verum reinterpret: caller-supplied conversion intrinsic.
            // Foundation: store the raw bits as RInt; Real value
            // reinterpretation is wired via core.intrinsics.float_bits.
            Ok(RInt(bits))
        }
        StZero   => Ok(RInt(0_i64)),
        StOne    => Ok(RInt(1_i64)),
        StBlob(n) => {
            let mut blob: List<Byte> = List.new();
            let mut k: Int = 0;
            while k < n && offset + k < payload_end && offset + k < bytes.len() {
                blob.push(bytes[offset + k]);
                k = k + 1;
            }
            Ok(RBlob(blob))
        }
        StText(n) => {
            // Foundation: build Text from the byte slice.  Real
            // implementation respects the database text encoding
            // (UTF-8 / UTF-16 LE / UTF-16 BE) — currently UTF-8 only.
            let mut buf: List<Byte> = List.new();
            let mut k: Int = 0;
            while k < n && offset + k < payload_end && offset + k < bytes.len() {
                buf.push(bytes[offset + k]);
                k = k + 1;
            }
            Ok(RText(bytes_to_utf8_text(&buf)))
        }
    }
}

/// Read a big-endian signed integer of `n_bytes` bytes from `buf`
/// at `offset`.  Returns 0 on out-of-range (defensive).
fn read_int_be(buf: &List<Byte>, offset: Int, n_bytes: Int, payload_end: Int) -> Int64 {
    let mut acc: Int64 = 0_i64;
    let mut i: Int = 0;
    while i < n_bytes {
        let pos = offset + i;
        if pos >= buf.len() || pos >= payload_end { return acc; }
        acc = (acc << 8_i64) | ((buf[pos] as Int64) & 0xFF_i64);
        i = i + 1;
    }
    // Sign-extend: if the top bit of the leading byte is set,
    // extend the upper bits.
    if n_bytes < 8 && offset < buf.len() {
        let top = buf[offset] as Int;
        if (top & 0x80) != 0 {
            let shift: Int64 = 8_i64 * (8 - n_bytes) as Int64;
            let mask: Int64 = -1_i64 << ((8_i64 * n_bytes as Int64) as Int64);
            acc = acc | mask;
            let _ = shift;
        }
    }
    acc
}

/// Wrap a UTF-8 byte buffer into Text via `Text.from_utf8_unchecked`.
/// SQLite stores TEXT serial-type payloads as raw bytes in the
/// database's text encoding (UTF-8 by default per
/// PRAGMA encoding); the caller is the database file, which has
/// already validated the encoding when the row was inserted, so
/// the unchecked path is safe.
fn bytes_to_utf8_text(buf: &List<Byte>) -> Text {
    if buf.len() == 0 { return "".clone(); }
    Text.from_utf8_unchecked(&buf[..buf.len()])
}

// -----------------------------------------------------------------------------
// Next / Prev — advance the cursor
// -----------------------------------------------------------------------------

/// Mirror of L4 `Next(cursor_id, jump_target)` opcode.  Returns
/// `Ok(true)` if advancing succeeded (cursor now on a fresh row);
/// `Ok(false)` if the cursor fell off the end (the interpreter
/// then jumps to `jump_target`).
public fn op_next(c: &mut BtreeCursor, pages: &PageStore) -> Result<Bool, CursorBridgeError> {
    match core.database.sqlite.native.l3_btree.cursor_seek.cursor_next(c, pages) {
        Ok(b)  => Ok(b),
        Err(e) => Err(BeBtree(e)),
    }
}

public fn op_prev(c: &mut BtreeCursor, pages: &PageStore) -> Result<Bool, CursorBridgeError> {
    match core.database.sqlite.native.l3_btree.cursor_seek.cursor_prev(c, pages) {
        Ok(b)  => Ok(b),
        Err(e) => Err(BeBtree(e)),
    }
}

public fn op_rewind(c: &mut BtreeCursor, pages: &PageStore) -> Result<Bool, CursorBridgeError> {
    match bt_cursor_first(c, pages) {
        Ok(b)  => Ok(b),
        Err(e) => Err(BeBtree(e)),
    }
}

public fn op_last(c: &mut BtreeCursor, pages: &PageStore) -> Result<Bool, CursorBridgeError> {
    match bt_cursor_last(c, pages) {
        Ok(b)  => Ok(b),
        Err(e) => Err(BeBtree(e)),
    }
}

// -----------------------------------------------------------------------------
// SeekGE / SeekGT / SeekLE / SeekLT / SeekEQ
// -----------------------------------------------------------------------------

/// Generic seek dispatch.  Mirror of L4 `SeekGE / SeekGT / SeekLE /
/// SeekLT` opcodes — converted to a single function with the
/// `SeekOp` enum because the dispatch is identical apart from the op.
public fn op_seek(
    c: &mut BtreeCursor,
    pages: &PageStore,
    target: &SeekKey,
    op: SeekOp,
) -> Result<SeekOutcome, CursorBridgeError> {
    match cursor_seek(c, pages, target, op) {
        Ok(o)  => Ok(o),
        Err(e) => Err(BeBtree(e)),
    }
}

// -----------------------------------------------------------------------------
// Insert / Delete
// -----------------------------------------------------------------------------

/// Mirror of L4 `Insert(cursor_id, data_reg, key_reg, flags)` opcode.
/// Caller has already encoded the cell payload (header + key + data)
/// per `l2_record::encode_cell`.  This bridge function then drives
/// `btree_insert_at_cursor` which handles the full ripple.
public fn op_insert(
    c: &mut BtreeCursor,
    pages: &mut PageStore,
    page_size: Int,
    reserved_bytes: Int,
    cell_bytes: &List<Byte>,
) -> Result<RebalanceLog, CursorBridgeError> {
    let ctx = balance_context_new(page_size, reserved_bytes);
    match btree_insert_at_cursor(c, pages, &ctx, cell_bytes) {
        Ok(log) => Ok(log),
        Err(e)  => Err(BeBtree(e)),
    }
}

/// Mirror of L4 `Delete(cursor_id)` opcode.
public fn op_delete(
    c: &mut BtreeCursor,
    pages: &mut PageStore,
    page_size: Int,
    reserved_bytes: Int,
) -> Result<RebalanceLog, CursorBridgeError> {
    let ctx = balance_context_new(page_size, reserved_bytes);
    match btree_delete_at_cursor(c, pages, &ctx) {
        Ok(log) => Ok(log),
        Err(e)  => Err(BeBtree(e)),
    }
}

// -----------------------------------------------------------------------------
// RowId — read the rowid of the current cell
// -----------------------------------------------------------------------------

/// Mirror of L4 `RowIdOp(cursor_id, reg_dst)`.  Returns the rowid
/// of the current cell as `Int64`.  Only valid for table-btree
/// cursors; index cursors return `Err(BeUnsupportedOp)`.
public fn op_rowid(
    c: &BtreeCursor,
    pages: &PageStore,
) -> Result<Int64, CursorBridgeError> {
    if !cursor_is_valid(c) {
        return Err(BeInvalidCursor("RowId: cursor not valid".clone()));
    }
    let page_no = cursor_current_page(c);
    let cell_idx = cursor_current_cell(c);
    let bytes = match pages.fetch(page_no) {
        Some(b) => b,
        None    => return Err(BePageNotFound(page_no)),
    };
    let hdr_off = if page_no == c.root_page && page_no == 1 { 100 } else { 0 };
    let (hdr, _) = match parse_page_header(&bytes, hdr_off) {
        Ok(p)  => p,
        Err(_) => return Err(BeBtree(InvalidRootPage(page_no))),
    };
    if cell_idx < 0 || cell_idx >= hdr.cell_count {
        return Err(BeCellOutOfRange(cell_idx));
    }
    let pointers = match parse_cell_pointer_array(&bytes, &hdr.cell_pointer_offset, hdr.cell_count) {
        Ok(p)  => p,
        Err(_) => return Err(BeBtree(InvalidRootPage(page_no))),
    };
    let cell_off = pointers[cell_idx];
    match parse_cell(&bytes, cell_off, hdr.kind.clone(), 100) {
        Ok(TableLeafCell(_, rowid, _, _))     => Ok(rowid),
        Ok(TableInteriorCell(_, rowid))        => Ok(rowid),
        _ => Err(BeUnsupportedOp("RowId on non-table-btree cell".clone())),
    }
}
