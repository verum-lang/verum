module core.database.sqlite.native.l4_vdbe.program;

// =============================================================================
// l4_vdbe/program.vr — Compiled VDBE program + builder
// =============================================================================
// Layer: 4
// Spec: sqlite-native.md §11.1
//
// A `VdbeProgram` is the compiled output of the SQL planner + codegen.
// It is immutable once built; a single program is shared by many
// prepared-statement instances (each owning its own `RegisterFile`
// and cursor table).
//
// Shape:
//
//   * `instructions`    — Vec<Opcode>
//   * `constants`       — shared pool for large Int64 / Float64 / Text / Blob
//                          literals referenced by opcodes (keeps Opcode small)
//   * `result_columns`  — for SELECT: names + expected types per column
//   * `num_registers`   — RegisterFile size
//   * `num_cursors`     — cursor-table size
//   * `sub_programs`    — child programs for triggers (indexed by Gosub id)
//
// `affine` so a program, once handed to an executor, cannot be aliased
// — SQLite explicitly forbids running two `sqlite3_step` loops on the
// same prepared statement concurrently.
// =============================================================================

mount core.*;
mount collections.List;
mount base.{Text, Maybe};
mount core.database.sqlite.native.l4_vdbe.opcode.Opcode;

// -----------------------------------------------------------------------------
// Constant pool
// -----------------------------------------------------------------------------

public type ConstantEntry is
      KInt(Int64)
    | KReal(Float64)
    | KText(Text)
    | KBlob(List<Byte>)
    | KAffinityStr(Text);

public type ConstantPool is {
    entries: List<ConstantEntry>,
};

public fn constant_pool_new() -> ConstantPool {
    ConstantPool { entries: List.new() }
}

implement ConstantPool {
    public fn len(&self) -> Int { self.entries.len() }

    /// Append a constant and return its index (used as `*_const_idx`
    /// in opcode operands). Does not deduplicate — the optimizer can
    /// run a later dedup pass.
    public fn add(&mut self, entry: ConstantEntry) -> Int {
        let idx = self.entries.len();
        self.entries.push(entry);
        idx
    }

    /// Retrieve by index; returns a synthetic zero on out-of-bounds to
    /// match the interpreter's defensive posture.
    public fn get(&self, idx: Int) -> ConstantEntry {
        if idx < 0 || idx >= self.entries.len() {
            return KInt(0 as Int64);
        }
        // Manual clone branch — keeps the inner `Text`/`List<Byte>`
        // deep-copied so subsequent pool mutations don't alias.
        match self.entries[idx] {
            KInt(i)  => KInt(i),
            KReal(x) => KReal(x),
            KText(s) => KText(s.clone()),
            KBlob(b) => {
                let mut out: List<Byte> = List.new();
                let mut i: Int = 0;
                while i < b.len() {
                    out.push(b[i]);
                    i = i + 1;
                }
                KBlob(out)
            }
            KAffinityStr(s) => KAffinityStr(s.clone()),
        }
    }
}

// -----------------------------------------------------------------------------
// Result-column metadata
// -----------------------------------------------------------------------------

/// Description of one output column exposed by a SELECT program.
/// `declared_type` is the SQL-level type text (e.g. "INTEGER", "TEXT")
/// if the planner could determine it; empty when the column is an
/// expression without a matching declared type.
public type ResultColumn is {
    name: Text,
    declared_type: Text,
};

// -----------------------------------------------------------------------------
// Cursor declaration
// -----------------------------------------------------------------------------

public type CursorKind is CkTable | CkIndex | CkEphemeral | CkSorter;

public type CursorDecl is {
    cursor_id: Int,
    kind: CursorKind,
    root_page: Int,
    n_cols: Int,
};

// -----------------------------------------------------------------------------
// Program
// -----------------------------------------------------------------------------

public type affine VdbeProgram is {
    instructions: List<Opcode>,
    constants: ConstantPool,
    result_columns: List<ResultColumn>,
    cursors: List<CursorDecl>,
    num_registers: Int,
    sub_programs: List<VdbeProgram>,
    sql: Text,                    // original SQL for EXPLAIN / trace
};

/// Fresh empty program.
public fn program_new(sql: Text, num_registers: Int) -> VdbeProgram {
    VdbeProgram {
        instructions: List.new(),
        constants: constant_pool_new(),
        result_columns: List.new(),
        cursors: List.new(),
        num_registers: num_registers,
        sub_programs: List.new(),
        sql: sql,
    }
}

implement VdbeProgram {
    public fn sql_text(&self) -> &Text { &self.sql }
    public fn instruction_count(&self) -> Int { self.instructions.len() }
    public fn register_count(&self) -> Int { self.num_registers }
    public fn cursor_count(&self) -> Int { self.cursors.len() }

    /// Look up a cursor declaration by cursor_id. Returns None when
    /// out of range; used by L6 bridge to seed row-stores.
    public fn get_cursor_decl(&self, i: Int) -> Maybe<CursorDecl> {
        if i < 0 || i >= self.cursors.len() { return None; }
        let d = &self.cursors[i];
        Some(CursorDecl {
            cursor_id: d.cursor_id,
            kind: d.kind,
            root_page: d.root_page,
            n_cols: d.n_cols,
        })
    }
    public fn result_column_count(&self) -> Int { self.result_columns.len() }

    /// Append an opcode; returns its instruction index (useful for
    /// back-patching `jump_target` operands after emission).
    public fn emit(&mut self, op: Opcode) -> Int {
        let idx = self.instructions.len();
        self.instructions.push(op);
        idx
    }

    /// Replace the instruction at `idx`. Used during jump-patching /
    /// peephole optimisations.
    public fn replace(&mut self, idx: Int, op: Opcode) {
        if idx < 0 || idx >= self.instructions.len() {
            return;
        }
        self.instructions[idx] = op;
    }

    /// Register a cursor declaration. Returns the assigned cursor_id.
    public fn declare_cursor(&mut self, kind: CursorKind, root_page: Int, n_cols: Int) -> Int {
        let id = self.cursors.len();
        self.cursors.push(CursorDecl {
            cursor_id: id,
            kind: kind,
            root_page: root_page,
            n_cols: n_cols,
        });
        id
    }

    /// Declare a result column. Call once per column of a SELECT in
    /// left-to-right order.
    public fn declare_result_column(&mut self, name: Text, declared_type: Text) {
        self.result_columns.push(ResultColumn {
            name: name,
            declared_type: declared_type,
        });
    }

    /// Attach a sub-program (trigger body). Returns its sub-program
    /// index; `Gosub` operand values reference this index.
    public fn attach_subprogram(&mut self, sub: VdbeProgram) -> Int {
        let id = self.sub_programs.len();
        self.sub_programs.push(sub);
        id
    }

    public fn get_opcode(&self, idx: Int) -> Maybe<Opcode> {
        if idx < 0 || idx >= self.instructions.len() {
            return None;
        }
        // Return a copy via match on the variant.
        Some(clone_opcode(&self.instructions[idx]))
    }
}

fn clone_opcode(op: &Opcode) -> Opcode {
    match op {
        Init(t)           => Init(t),
        Halt(c, m)        => Halt(c, m),
        Goto(t)           => Goto(t),
        Gosub(r, t)       => Gosub(r, t),
        Return(r)         => Return(r),
        Once(t)           => Once(t),
        Noop              => Noop,
        Integer(v, d)     => Integer(v, d),
        Int64(c, d)       => Int64(c, d),
        Real(c, d)        => Real(c, d),
        String8(c, d)     => String8(c, d),
        BlobLit(c, d)     => BlobLit(c, d),
        Null(s, e)        => Null(s, e),
        SoftNull(d)       => SoftNull(d),
        Move(s, d, c)     => Move(s, d, c),
        Copy(s, d, c)     => Copy(s, d, c),
        SCopy(s, d)       => SCopy(s, d),
        Add(a, b, d)      => Add(a, b, d),
        Subtract(a, b, d) => Subtract(a, b, d),
        Multiply(a, b, d) => Multiply(a, b, d),
        Divide(a, b, d)   => Divide(a, b, d),
        Remainder(a, b, d)=> Remainder(a, b, d),
        BitAnd(a, b, d)   => BitAnd(a, b, d),
        BitOr(a, b, d)    => BitOr(a, b, d),
        ShiftLeft(a, b, d)=> ShiftLeft(a, b, d),
        ShiftRight(a, b, d)=> ShiftRight(a, b, d),
        BitNot(s, d)      => BitNot(s, d),
        Eq(a, b, t) => Eq(a, b, t),
        Ne(a, b, t) => Ne(a, b, t),
        Lt(a, b, t) => Lt(a, b, t),
        Le(a, b, t) => Le(a, b, t),
        Gt(a, b, t) => Gt(a, b, t),
        Ge(a, b, t) => Ge(a, b, t),
        If(r, t)    => If(r, t),
        IfNot(r, t) => IfNot(r, t),
        IfNull(r, t)=> IfNull(r, t),
        NotNull(r, t)=> NotNull(r, t),
        OpenRead(c, r, n)  => OpenRead(c, r, n),
        OpenWrite(c, r, n) => OpenWrite(c, r, n),
        Close(c)           => Close(c),
        Rewind(c, t)       => Rewind(c, t),
        Last(c, t)         => Last(c, t),
        Next(c, t)         => Next(c, t),
        Prev(c, t)         => Prev(c, t),
        Column(c, i, d)    => Column(c, i, d),
        RowIdOp(c, d)      => RowIdOp(c, d),
        SeekGE(c, k, n, t) => SeekGE(c, k, n, t),
        SeekGT(c, k, n, t) => SeekGT(c, k, n, t),
        SeekLE(c, k, n, t) => SeekLE(c, k, n, t),
        SeekLT(c, k, n, t) => SeekLT(c, k, n, t),
        Found(c, t, k, n)    => Found(c, t, k, n),
        NotFound(c, t, k, n) => NotFound(c, t, k, n),
        Insert(c, d, k, f) => Insert(c, d, k, f),
        Delete(c)          => Delete(c),
        NewRowid(c, d)     => NewRowid(c, d),
        MakeRecord(s, n, d, a) => MakeRecord(s, n, d, a),
        OpenEphemeral(c, n) => OpenEphemeral(c, n),
        OpenAutoindex(c, n) => OpenAutoindex(c, n),
        SorterOpen(c)       => SorterOpen(c),
        SorterInsert(c, r)  => SorterInsert(c, r),
        SorterSort(c)       => SorterSort(c),
        SorterData(c, d)    => SorterData(c, d),
        SorterNext(c, t)    => SorterNext(c, t),
        Transaction(w) => Transaction(w),
        Commit         => Commit,
        RollbackOp(n)  => RollbackOp(n),
        SavepointOp(n) => SavepointOp(n),
        AutoCommit(d, r) => AutoCommit(d, r),
        ReadCookie(c, d)  => ReadCookie(c, d),
        WriteCookie(c, s) => WriteCookie(c, s),
        Function(n, a, d, f) => Function(n, a, d, f),
        AggStep(f, n, a, c)  => AggStep(f, n, a, c),
        AggFinal(f, c)       => AggFinal(f, c),
        ResultRow(s, n) => ResultRow(s, n),
    }
}
