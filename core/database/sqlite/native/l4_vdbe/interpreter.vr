module core.database.sqlite.native.l4_vdbe.interpreter;

// =============================================================================
// l4_vdbe/interpreter.vr — VDBE interpreter (step-based)
// =============================================================================
// Layer: 4
// Spec: sqlite-native.md §11.3
//
// The interpreter is deliberately *step-based* rather than batched —
// SQLite's sqlite3_step() returns one row at a time and the caller
// controls iteration. Our `step(&mut VdbeState)` returns a `StepResult`:
//
//   * `Row(reg_start, n_cols)` — caller should emit a result row
//   * `Done`                    — Halt(0) reached, program complete
//   * `Error(code, msg)`        — Halt(nonzero) or runtime error
//   * `Yield`                   — no visible effect; call step() again
//
// This module implements the subset of opcodes that don't require
// cursor I/O (arithmetic, control flow, register moves, comparisons).
// Cursor-touching opcodes — Column, Next, SeekGE, Insert — are stubbed
// to `Yield` until the actor IPC integration lands.
// =============================================================================

mount core.*;
mount collections.List;
mount base.{Result, Ok, Err, Text, Maybe};
mount core.database.sqlite.native.l4_vdbe.opcode.Opcode;
mount core.database.sqlite.native.l4_vdbe.register.{
    Register, RegisterFile, register_file_new, register_is_truthy, register_clone,
};
mount core.database.sqlite.native.l4_vdbe.program.{
    VdbeProgram, ConstantEntry, ConstantPool, CursorKind,
};
mount core.database.sqlite.native.l4_vdbe.cursor_table.{
    CursorTable, cursor_table_new,
};
mount core.database.sqlite.native.l3_btree.BtreeKind;

// -----------------------------------------------------------------------------
// State / result
// -----------------------------------------------------------------------------

public type StepResult is
      Row(reg_start: Int, n_cols: Int)
    | Done
    | Yield
    | ExecError(code: Int, msg: Text);

/// Row-mutation kind — layer-neutral dual of `ext.hooks.ExtUpdateOp`.
/// Kept here so L4 (interpreter) doesn't have to pull in L7's hook
/// surface; the L6 writeback bridge converts to `ExtUpdateOp` when it
/// fires user-visible update_hook callbacks.
public type RowMutationKind is RmkInsert | RmkUpdate | RmkDelete;

/// One row-level mutation observed during a single VDBE program run.
/// The bridge replays these in original order, resolves
/// `cursor_id` → `(schema, table)` via `Connection.schema`, and
/// invokes the per-connection `update_hook` (when set).
public type RowMutation is {
    kind: RowMutationKind,
    cursor_id: Int,
    rowid: Int64,
};

/// Mutable interpreter state held across calls to `step`.
public type affine VdbeState is {
    pc: Int,
    regs: RegisterFile,
    return_stack: List<Int>,     // for Gosub/Return
    once_fired: List<Int>,       // instruction indices of Once ops that fired
    halted: Bool,
    cursors: CursorTable,        // live cursor pipeline (opened lazily)
    /// Mutation log — captured by Insert/Delete/UpdateRow opcodes,
    /// drained by the L6 writeback bridge to fire update_hook
    /// callbacks.  Empty for read-only programs.
    mutations: List<RowMutation>,
};

public fn vdbe_state_new(program: &VdbeProgram) -> VdbeState {
    VdbeState {
        pc: 0,
        regs: register_file_new(program.register_count()),
        return_stack: List.new(),
        once_fired: List.new(),
        halted: false,
        cursors: cursor_table_new(program.cursor_count(), 4096, 0),
        mutations: List.new(),
    }
}

implement VdbeState {
    public fn program_counter(&self) -> Int { self.pc }
    public fn is_halted(&self) -> Bool { self.halted }
    public fn reg(&self, i: Int) -> Register { self.regs.get(i) }
    public fn set_reg(&mut self, i: Int, v: Register) { self.regs.set(i, v); }
    public fn cursor_table_mut(&mut self) -> &mut CursorTable { &mut self.cursors }
    public fn cursor_table_ref(&self) -> &CursorTable { &self.cursors }
    /// Borrow the mutation log — bridge consumers call this to fire
    /// update_hooks.
    public fn mutations_ref(&self) -> &List<RowMutation> { &self.mutations }
    /// Drain the mutation log.  Bridge calls this to consume + fire
    /// hooks, leaving the state ready for a fresh program (re-run on
    /// the same statement).
    public fn drain_mutations(&mut self) -> List<RowMutation> {
        let out = self.mutations.clone();
        self.mutations = List.new();
        out
    }
}

// -----------------------------------------------------------------------------
// Helpers — arithmetic + comparison lowering
// -----------------------------------------------------------------------------

fn to_int64(r: &Register) -> Int64 {
    match r {
        RInt(i)   => i,
        RRowId(i) => i,
        RReal(x)  => x as Int64,
        _         => 0 as Int64,
    }
}

fn to_real(r: &Register) -> Float64 {
    match r {
        RInt(i)   => i as Float64,
        RRowId(i) => i as Float64,
        RReal(x)  => x,
        _         => 0.0,
    }
}

fn arith_add(a: &Register, b: &Register) -> Register {
    match (a, b) {
        (RReal(_), _) | (_, RReal(_)) => RReal(to_real(a) + to_real(b)),
        _                             => RInt(to_int64(a) + to_int64(b)),
    }
}

fn arith_sub(a: &Register, b: &Register) -> Register {
    match (a, b) {
        (RReal(_), _) | (_, RReal(_)) => RReal(to_real(a) - to_real(b)),
        _                             => RInt(to_int64(a) - to_int64(b)),
    }
}

fn arith_mul(a: &Register, b: &Register) -> Register {
    match (a, b) {
        (RReal(_), _) | (_, RReal(_)) => RReal(to_real(a) * to_real(b)),
        _                             => RInt(to_int64(a) * to_int64(b)),
    }
}

fn arith_div(a: &Register, b: &Register) -> Register {
    // SQLite divides as REAL for REAL operands, INT otherwise with 0
    // protection (0 / 0 = NULL).
    match (a, b) {
        (RReal(_), _) | (_, RReal(_)) => {
            let bx = to_real(b);
            if bx == 0.0 { RNull } else { RReal(to_real(a) / bx) }
        }
        _ => {
            let bi = to_int64(b);
            if bi == 0_i64 { RNull } else { RInt(to_int64(a) / bi) }
        }
    }
}

fn cmp_lt(a: &Register, b: &Register) -> Bool {
    match (a, b) {
        (RReal(_), _) | (_, RReal(_)) => to_real(a) < to_real(b),
        (RText(x), RText(y)) => x < y,
        _ => to_int64(a) < to_int64(b),
    }
}

fn cmp_eq(a: &Register, b: &Register) -> Bool {
    match (a, b) {
        (RNull, RNull) => false,     // SQLite NULL != NULL in comparisons
        (RReal(_), _) | (_, RReal(_)) => to_real(a) == to_real(b),
        (RText(x), RText(y)) => x == y,
        _ => to_int64(a) == to_int64(b),
    }
}

// -----------------------------------------------------------------------------
// Step
// -----------------------------------------------------------------------------

/// Execute one opcode. Advances `pc` to the next instruction unless the
/// opcode jumps. Returns the step outcome for the caller to dispatch on.
///
/// Cursor-bound opcodes return `Yield` (still a no-op) until the pager
/// actor IPC is wired; callers can special-case by inspecting the
/// current opcode via `program.get_opcode(state.pc)`.
public fn step(state: &mut VdbeState, program: &VdbeProgram) -> StepResult {
    if state.halted {
        return Done;
    }
    let op_maybe = program.get_opcode(state.pc);
    let op = match op_maybe {
        Some(o) => o,
        None    => { state.halted = true; return Done; }
    };

    match op {
        Init(t) => { state.pc = t; Yield }

        Halt(code, _msg_idx) => {
            state.halted = true;
            if code == 0 { Done } else { ExecError(code, "Halt with error".clone()) }
        }

        Goto(t) => { state.pc = t; Yield }

        Gosub(r, t) => {
            state.return_stack.push(state.pc + 1);
            state.regs.set(r, RInt(state.pc as Int64));
            state.pc = t;
            Yield
        }

        Return(r) => {
            let v = state.regs.get(r);
            let _ = v;
            if state.return_stack.len() > 0 {
                let ret = state.return_stack.pop();
                state.pc = ret;
            } else {
                state.halted = true;
                return ExecError(1, "Return with empty stack".clone());
            }
            Yield
        }

        Once(jump_if_done) => {
            let fired = state.once_fired;
            let idx = state.pc;
            let mut already = false;
            let mut k: Int = 0;
            while k < fired.len() {
                if fired[k] == idx { already = true; break; }
                k = k + 1;
            }
            if already {
                state.pc = jump_if_done;
            } else {
                state.once_fired.push(idx);
                state.pc = state.pc + 1;
            }
            Yield
        }

        Noop => { state.pc = state.pc + 1; Yield }

        Integer(v, d) => {
            state.regs.set(d, RInt(v as Int64));
            state.pc = state.pc + 1;
            Yield
        }

        Int64(const_idx, d) => {
            match program.constants.get(const_idx) {
                KInt(i) => state.regs.set(d, RInt(i)),
                _       => state.regs.set(d, RNull),
            }
            state.pc = state.pc + 1;
            Yield
        }

        Real(const_idx, d) => {
            match program.constants.get(const_idx) {
                KReal(x) => state.regs.set(d, RReal(x)),
                _        => state.regs.set(d, RNull),
            }
            state.pc = state.pc + 1;
            Yield
        }

        String8(const_idx, d) => {
            match program.constants.get(const_idx) {
                KText(s) => state.regs.set(d, RText(s)),
                _        => state.regs.set(d, RNull),
            }
            state.pc = state.pc + 1;
            Yield
        }

        Null(start, end_inclusive) => {
            state.regs.clear_range(start, end_inclusive);
            state.pc = state.pc + 1;
            Yield
        }

        SoftNull(d) => {
            state.regs.set(d, RNull);
            state.pc = state.pc + 1;
            Yield
        }

        Move(src, dst, count) => {
            state.regs.move_range(src, dst, count);
            state.pc = state.pc + 1;
            Yield
        }

        Copy(src, dst, count) => {
            state.regs.copy_range(src, dst, count);
            state.pc = state.pc + 1;
            Yield
        }

        SCopy(src, dst) => {
            let v = state.regs.get(src);
            state.regs.set(dst, v);
            state.pc = state.pc + 1;
            Yield
        }

        Add(a, b, d) => {
            let va = state.regs.get(a);
            let vb = state.regs.get(b);
            state.regs.set(d, arith_add(&va, &vb));
            state.pc = state.pc + 1;
            Yield
        }

        Subtract(a, b, d) => {
            let va = state.regs.get(a);
            let vb = state.regs.get(b);
            state.regs.set(d, arith_sub(&va, &vb));
            state.pc = state.pc + 1;
            Yield
        }

        Multiply(a, b, d) => {
            let va = state.regs.get(a);
            let vb = state.regs.get(b);
            state.regs.set(d, arith_mul(&va, &vb));
            state.pc = state.pc + 1;
            Yield
        }

        Divide(a, b, d) => {
            let va = state.regs.get(a);
            let vb = state.regs.get(b);
            state.regs.set(d, arith_div(&va, &vb));
            state.pc = state.pc + 1;
            Yield
        }

        Eq(a, b, t) => {
            let va = state.regs.get(a);
            let vb = state.regs.get(b);
            if cmp_eq(&va, &vb) { state.pc = t; } else { state.pc = state.pc + 1; }
            Yield
        }

        Ne(a, b, t) => {
            let va = state.regs.get(a);
            let vb = state.regs.get(b);
            if !cmp_eq(&va, &vb) { state.pc = t; } else { state.pc = state.pc + 1; }
            Yield
        }

        Lt(a, b, t) => {
            let va = state.regs.get(a);
            let vb = state.regs.get(b);
            if cmp_lt(&va, &vb) { state.pc = t; } else { state.pc = state.pc + 1; }
            Yield
        }

        Le(a, b, t) => {
            let va = state.regs.get(a);
            let vb = state.regs.get(b);
            if cmp_lt(&va, &vb) || cmp_eq(&va, &vb) { state.pc = t; } else { state.pc = state.pc + 1; }
            Yield
        }

        Gt(a, b, t) => {
            let va = state.regs.get(a);
            let vb = state.regs.get(b);
            if cmp_lt(&vb, &va) { state.pc = t; } else { state.pc = state.pc + 1; }
            Yield
        }

        Ge(a, b, t) => {
            let va = state.regs.get(a);
            let vb = state.regs.get(b);
            if cmp_lt(&vb, &va) || cmp_eq(&va, &vb) { state.pc = t; } else { state.pc = state.pc + 1; }
            Yield
        }

        If(r, t) => {
            let v = state.regs.get(r);
            if register_is_truthy(&v) { state.pc = t; } else { state.pc = state.pc + 1; }
            Yield
        }

        IfNot(r, t) => {
            let v = state.regs.get(r);
            if !register_is_truthy(&v) { state.pc = t; } else { state.pc = state.pc + 1; }
            Yield
        }

        IfNull(r, t) => {
            let v = state.regs.get(r);
            match v {
                RNull => { state.pc = t; },
                _     => { state.pc = state.pc + 1; }
            }
            Yield
        }

        NotNull(r, t) => {
            let v = state.regs.get(r);
            match v {
                RNull => { state.pc = state.pc + 1; },
                _     => { state.pc = t; }
            }
            Yield
        }

        ResultRow(start, n) => {
            // Row emission — interpreter yields a row; caller re-enters
            // step() on the same pc → but ResultRow advances so the
            // next call moves past it.
            state.pc = state.pc + 1;
            Row(start, n)
        }

        // -------------------------------------------------------------
        // Cursor pipeline — backed by CursorTable's in-memory row store.
        // Real pager-backed cursors plug in transparently once the
        // actor IPC adapter fills `rows` one at a time.
        // -------------------------------------------------------------

        OpenRead(cursor_id, root_page, n_cols) => {
            let _ = state.cursors.open_read(cursor_id, root_page, n_cols, TableBtree);
            state.pc = state.pc + 1;
            Yield
        }

        OpenWrite(cursor_id, root_page, n_cols) => {
            let _ = state.cursors.open_write(cursor_id, root_page, n_cols, TableBtree);
            state.pc = state.pc + 1;
            Yield
        }

        OpenEphemeral(cursor_id, n_cols) => {
            let _ = state.cursors.open_ephemeral(cursor_id, n_cols);
            state.pc = state.pc + 1;
            Yield
        }

        Close(cursor_id) => {
            let _ = state.cursors.close(cursor_id);
            state.pc = state.pc + 1;
            Yield
        }

        Rewind(cursor_id, jump_if_empty) => {
            let _ = state.cursors.rewind(cursor_id);
            if !state.cursors.has_more(cursor_id) {
                state.pc = jump_if_empty;
            } else {
                state.pc = state.pc + 1;
            }
            Yield
        }

        Next(cursor_id, jump_if_more) => {
            let still_has = state.cursors.advance(cursor_id);
            if still_has {
                state.pc = jump_if_more;
            } else {
                state.pc = state.pc + 1;
            }
            Yield
        }

        Column(cursor_id, col_idx, dst) => {
            let v = state.cursors.peek_cell(cursor_id, col_idx);
            state.regs.set(dst, v);
            state.pc = state.pc + 1;
            Yield
        }

        RowIdOp(cursor_id, dst) => {
            let rid = state.cursors.current_rowid(cursor_id);
            state.regs.set(dst, RRowId(rid));
            state.pc = state.pc + 1;
            Yield
        }

        NewRowid(cursor_id, dst) => {
            let rid = state.cursors.peek_next_rowid(cursor_id);
            state.regs.set(dst, RRowId(rid));
            state.pc = state.pc + 1;
            Yield
        }

        Insert(cursor_id, data_reg, key_reg, _flags) => {
            // Data register holds a prepared MakeRecord result; for our
            // v1 row-store path we reconstruct the row from the
            // originating register range. Until MakeRecord lowering
            // lands in the interpreter, the simpler path is: the
            // preceding Column-like setup wrote n_cols registers
            // starting at `data_reg`; we read them all. This matches
            // what the current codegen emits for PnValues INSERT.
            // The `key_reg` carries the rowid the row will receive
            // (autoincrement or user-supplied) — used to populate the
            // update_hook payload.
            let slot_kind = state.cursors.kind(cursor_id);
            match slot_kind {
                CskClosed => { state.pc = state.pc + 1; return Yield; }
                _ => {}
            }
            let n_cols = state.cursors.n_cols_of(cursor_id);
            let mut row: List<Register> = List.new();
            let mut i: Int = 0;
            while i < n_cols {
                row.push(state.regs.get(data_reg + i));
                i = i + 1;
            }
            let _ = state.cursors.append_row(cursor_id, row);
            // Record the mutation for the update_hook.  rowid
            // resolution: prefer the `key_reg` content if it's an
            // RInt/RRowId; fall back to the cursor's most-recent
            // assigned rowid (1-based — matches NewRowid emission).
            let rowid: Int64 = match state.regs.get(key_reg) {
                RInt(n)   => n,
                RRowId(n) => n,
                _         => state.cursors.peek_next_rowid(cursor_id) - 1_i64,
            };
            state.mutations.push(RowMutation {
                kind: RmkInsert,
                cursor_id: cursor_id,
                rowid: rowid,
            });
            state.pc = state.pc + 1;
            Yield
        }

        Delete(cursor_id) => {
            // Capture rowid BEFORE delete so the update_hook payload
            // points at the row that just disappeared.
            let rowid = state.cursors.current_rowid(cursor_id);
            let _ = state.cursors.delete_current(cursor_id);
            state.mutations.push(RowMutation {
                kind: RmkDelete,
                cursor_id: cursor_id,
                rowid: rowid,
            });
            state.pc = state.pc + 1;
            Yield
        }

        UpdateRow(cursor_id, data_reg) => {
            // Read n_cols registers starting at data_reg, overwrite
            // the row at current pos. Mirrors the Insert pattern but
            // replaces instead of appending.
            let rowid = state.cursors.current_rowid(cursor_id);
            let n_cols = state.cursors.n_cols_of(cursor_id);
            let mut row: List<Register> = List.new();
            let mut i: Int = 0;
            while i < n_cols {
                row.push(state.regs.get(data_reg + i));
                i = i + 1;
            }
            let _ = state.cursors.replace_current_row(cursor_id, row);
            state.mutations.push(RowMutation {
                kind: RmkUpdate,
                cursor_id: cursor_id,
                rowid: rowid,
            });
            state.pc = state.pc + 1;
            Yield
        }

        SortRowStore(cursor_id, n_keys, dir_bits) => {
            let _ = state.cursors.sort_by_prefix(cursor_id, n_keys, dir_bits);
            state.pc = state.pc + 1;
            Yield
        }

        DedupRowStore(cursor_id, n_cells) => {
            let _ = state.cursors.dedup_adjacent(cursor_id, n_cells);
            state.pc = state.pc + 1;
            Yield
        }

        AggStep(agg_kind, n_args, first_arg_reg, acc_reg) => {
            match agg_kind {
                0 => {
                    // COUNT. For COUNT(*), n_args = 0 → unconditional increment.
                    // For COUNT(expr), skip if the arg is NULL.
                    if n_args > 0 {
                        match state.regs.get(first_arg_reg) {
                            RNull => { state.pc = state.pc + 1; return Yield; }
                            _     => {}
                        }
                    }
                    let cur: Int64 = match state.regs.get(acc_reg) {
                        RInt(v) => v,
                        _       => 0_i64,
                    };
                    state.regs.set(acc_reg, RInt(cur + 1_i64));
                }
                1 => {
                    // SUM — NULL-skip; keep RReal if either side is real.
                    let v = state.regs.get(first_arg_reg);
                    let is_null = match v { RNull => true, _ => false };
                    if !is_null {
                        let cur = state.regs.get(acc_reg);
                        let new_val = agg_add(&cur, &v);
                        state.regs.set(acc_reg, new_val);
                    }
                }
                2 => {
                    // MIN — first non-null value wins, then min of subsequent.
                    let v = state.regs.get(first_arg_reg);
                    let is_null = match v { RNull => true, _ => false };
                    if !is_null {
                        let cur = state.regs.get(acc_reg);
                        let cur_null = match cur { RNull => true, _ => false };
                        if cur_null {
                            state.regs.set(acc_reg, v);
                        } else {
                            let keep_cur = agg_less(&cur, &v);
                            if !keep_cur { state.regs.set(acc_reg, v); }
                        }
                    }
                }
                3 => {
                    // MAX — symmetric to MIN.
                    let v = state.regs.get(first_arg_reg);
                    let is_null = match v { RNull => true, _ => false };
                    if !is_null {
                        let cur = state.regs.get(acc_reg);
                        let cur_null = match cur { RNull => true, _ => false };
                        if cur_null {
                            state.regs.set(acc_reg, v);
                        } else {
                            let keep_cur = agg_less(&v, &cur);
                            if !keep_cur { state.regs.set(acc_reg, v); }
                        }
                    }
                }
                _ => {}
            }
            state.pc = state.pc + 1;
            Yield
        }

        AggFinal(_agg_kind, _acc_reg) => {
            // COUNT / SUM / MIN / MAX all hold their final value in
            // acc_reg already. AVG uses the dedicated AggFinalAvg path.
            state.pc = state.pc + 1;
            Yield
        }

        AggStepAvg(n_args, first_arg_reg, sum_reg, count_reg) => {
            // AVG(x): NULL-skip; otherwise sum += x and count += 1.
            // Supports AVG(*) form (n_args = 0) too by treating every
            // row as "not null".
            let skip = if n_args > 0 {
                match state.regs.get(first_arg_reg) {
                    RNull => true,
                    _     => false,
                }
            } else {
                false
            };
            if !skip {
                if n_args > 0 {
                    let v = state.regs.get(first_arg_reg);
                    let cur = state.regs.get(sum_reg);
                    state.regs.set(sum_reg, agg_add(&cur, &v));
                }
                let cur_count: Int64 = match state.regs.get(count_reg) {
                    RInt(x) => x,
                    _       => 0_i64,
                };
                state.regs.set(count_reg, RInt(cur_count + 1_i64));
            }
            state.pc = state.pc + 1;
            Yield
        }

        CastVal(src_reg, target_kind, dst) => {
            let v = state.regs.get(src_reg);
            let out: Register = match target_kind {
                0 => match v {
                    RInt(x)  => RInt(x),
                    RReal(x) => RInt(x as Int64),
                    RText(ref s) => match parse_int_text(s) {
                        Some(i) => RInt(i),
                        None    => RInt(0_i64),
                    },
                    RNull => RNull,
                    _ => RInt(0_i64),
                },
                1 => match v {
                    RInt(x)  => RReal(x as Float64),
                    RReal(x) => RReal(x),
                    RText(ref s) => match parse_real_text(s) {
                        Some(f) => RReal(f),
                        None    => RReal(0.0),
                    },
                    RNull => RNull,
                    _ => RReal(0.0),
                },
                2 => match v {
                    RInt(x)  => RText(int_to_text(x)),
                    RReal(x) => RText(real_to_text(x)),
                    RText(ref s) => RText(s.clone()),
                    RNull => RNull,
                    RBlob(ref b) => RText(bytes_to_text(b)),
                    _ => RText("".clone()),
                },
                3 => match v {
                    RBlob(ref b) => RBlob(b.clone()),
                    RText(ref s) => RBlob(text_to_bytes(s)),
                    RNull => RNull,
                    _ => RBlob(List.new()),
                },
                4 => {
                    // NUMERIC affinity: prefer int if lossless else real.
                    match v {
                        RInt(x)  => RInt(x),
                        RReal(x) => RReal(x),
                        RText(ref s) => match parse_int_text(s) {
                            Some(i) => RInt(i),
                            None    => match parse_real_text(s) {
                                Some(f) => RReal(f),
                                None    => RText(s.clone()),
                            }
                        },
                        RNull => RNull,
                        _ => v,
                    }
                }
                _ => v,
            };
            state.regs.set(dst, out);
            state.pc = state.pc + 1;
            Yield
        }

        ScalarFn(kind, n_args, first_arg_reg, dst) => {
            let result: Register = match kind {
                0 => {
                    // LENGTH(x) — byte length for text/blob, NULL otherwise.
                    if n_args < 1 {
                        RNull
                    } else {
                        match state.regs.get(first_arg_reg) {
                            RText(ref s) => RInt(s.len() as Int64),
                            RBlob(ref b) => RInt(b.len() as Int64),
                            RNull        => RNull,
                            _            => RNull,
                        }
                    }
                }
                1 => {
                    // ABS(x) — numeric absolute value; NULL otherwise.
                    if n_args < 1 {
                        RNull
                    } else {
                        match state.regs.get(first_arg_reg) {
                            RInt(x)  => { if x < 0_i64 { RInt(-x) } else { RInt(x) } }
                            RReal(x) => { if x < 0.0 { RReal(-x) } else { RReal(x) } }
                            RNull    => RNull,
                            _        => RNull,
                        }
                    }
                }
                2 => {
                    // LOWER(text) — ASCII lowercase.
                    if n_args < 1 {
                        RNull
                    } else {
                        match state.regs.get(first_arg_reg) {
                            RText(ref s) => RText(ascii_fold_case(s, false)),
                            RNull        => RNull,
                            _            => RNull,
                        }
                    }
                }
                3 => {
                    // UPPER(text) — ASCII uppercase.
                    if n_args < 1 {
                        RNull
                    } else {
                        match state.regs.get(first_arg_reg) {
                            RText(ref s) => RText(ascii_fold_case(s, true)),
                            RNull        => RNull,
                            _            => RNull,
                        }
                    }
                }
                4 => {
                    // COALESCE(a, b, ...) — first non-null.
                    let mut i: Int = 0;
                    let mut out: Register = RNull;
                    while i < n_args {
                        let v = state.regs.get(first_arg_reg + i);
                        let is_null = match v { RNull => true, _ => false };
                        if !is_null { out = v; break; }
                        i = i + 1;
                    }
                    out
                }
                5 => {
                    // IFNULL(a, b) — a if non-null else b.
                    if n_args < 2 {
                        state.regs.get(first_arg_reg)
                    } else {
                        let a = state.regs.get(first_arg_reg);
                        let is_null = match a { RNull => true, _ => false };
                        if is_null { state.regs.get(first_arg_reg + 1) } else { a }
                    }
                }
                6 => {
                    // NULLIF(a, b) — NULL if a == b else a.
                    if n_args < 2 {
                        state.regs.get(first_arg_reg)
                    } else {
                        let a = state.regs.get(first_arg_reg);
                        let b = state.regs.get(first_arg_reg + 1);
                        let eq = match a {
                            RInt(x)  => match b { RInt(y)  => x == y, _ => false },
                            RReal(x) => match b { RReal(y) => x == y, _ => false },
                            RText(ref xs) => match b { RText(ref ys) => xs == ys, _ => false },
                            _ => false,
                        };
                        if eq { RNull } else { a }
                    }
                }
                10 => {
                    // LIKE: arg0 target text, arg1 pattern.
                    if n_args < 2 {
                        RInt(0_i64)
                    } else {
                        let tv = state.regs.get(first_arg_reg);
                        let pv = state.regs.get(first_arg_reg + 1);
                        match tv {
                            RText(ref t) => match pv {
                                RText(ref p) => {
                                    if like_match(t, p) { RInt(1_i64) } else { RInt(0_i64) }
                                }
                                _ => RInt(0_i64),
                            },
                            _ => RInt(0_i64),
                        }
                    }
                }
                12 => {
                    // Concat two texts.
                    if n_args < 2 {
                        RNull
                    } else {
                        let a = state.regs.get(first_arg_reg);
                        let b = state.regs.get(first_arg_reg + 1);
                        match a {
                            RText(ref as_s) => match b {
                                RText(ref bs_s) => {
                                    let mut out = Text.new();
                                    let abytes = as_s.as_bytes();
                                    let bbytes = bs_s.as_bytes();
                                    let mut i: Int = 0;
                                    while i < abytes.len() { out.push_byte(abytes[i]); i = i + 1; }
                                    i = 0;
                                    while i < bbytes.len() { out.push_byte(bbytes[i]); i = i + 1; }
                                    RText(out)
                                }
                                RNull => RNull,
                                _ => RNull,
                            },
                            RNull => RNull,
                            _ => RNull,
                        }
                    }
                }
                13 => {
                    // SUBSTR(s, start, [length]) — 1-indexed, SQLite style.
                    if n_args < 2 {
                        RNull
                    } else {
                        let s_reg = state.regs.get(first_arg_reg);
                        let start_reg = state.regs.get(first_arg_reg + 1);
                        let start_i: Int = match start_reg {
                            RInt(x) => x as Int,
                            _       => 1,
                        };
                        let length_opt: Maybe<Int> = if n_args >= 3 {
                            match state.regs.get(first_arg_reg + 2) {
                                RInt(x) => Some(x as Int),
                                _       => None,
                            }
                        } else {
                            None
                        };
                        match s_reg {
                            RText(ref s) => {
                                let bs = s.as_bytes();
                                let n = bs.len();
                                // SQLite: start=0 treated as 1; negative counts from end.
                                let mut begin: Int = start_i;
                                if begin < 0 { begin = n + begin + 1; }
                                if begin < 1 { begin = 1; }
                                let end: Int = match length_opt {
                                    Some(l) => begin + l - 1,
                                    None    => n,
                                };
                                let mut out = Text.new();
                                let mut i: Int = begin;
                                while i <= end && i <= n {
                                    if i >= 1 { out.push_byte(bs[i - 1]); }
                                    i = i + 1;
                                }
                                RText(out)
                            }
                            RNull => RNull,
                            _ => RNull,
                        }
                    }
                }
                14 => {
                    // TRIM(s) / TRIM(s, chars) — ASCII whitespace by
                    // default; otherwise trim any byte in `chars`
                    // (treated as a SET) from both ends.
                    if n_args < 1 {
                        RNull
                    } else if n_args >= 2 {
                        let s_v = state.regs.get(first_arg_reg);
                        let c_v = state.regs.get(first_arg_reg + 1);
                        match s_v {
                            RText(ref s) => match c_v {
                                RText(ref c) => RText(trim_with_chars(s, c, true, true)),
                                RNull => RNull,
                                _ => RNull,
                            },
                            RNull => RNull,
                            _ => RNull,
                        }
                    } else {
                        match state.regs.get(first_arg_reg) {
                            RText(ref s) => RText(trim_ascii(s, true, true)),
                            RNull => RNull,
                            _ => RNull,
                        }
                    }
                }
                15 => {
                    // LTRIM(s) / LTRIM(s, chars) — leading-only.
                    if n_args < 1 {
                        RNull
                    } else if n_args >= 2 {
                        let s_v = state.regs.get(first_arg_reg);
                        let c_v = state.regs.get(first_arg_reg + 1);
                        match s_v {
                            RText(ref s) => match c_v {
                                RText(ref c) => RText(trim_with_chars(s, c, true, false)),
                                RNull => RNull,
                                _ => RNull,
                            },
                            RNull => RNull,
                            _ => RNull,
                        }
                    } else {
                        match state.regs.get(first_arg_reg) {
                            RText(ref s) => RText(trim_ascii(s, true, false)),
                            RNull => RNull,
                            _ => RNull,
                        }
                    }
                }
                16 => {
                    // RTRIM(s) / RTRIM(s, chars) — trailing-only.
                    if n_args < 1 {
                        RNull
                    } else if n_args >= 2 {
                        let s_v = state.regs.get(first_arg_reg);
                        let c_v = state.regs.get(first_arg_reg + 1);
                        match s_v {
                            RText(ref s) => match c_v {
                                RText(ref c) => RText(trim_with_chars(s, c, false, true)),
                                RNull => RNull,
                                _ => RNull,
                            },
                            RNull => RNull,
                            _ => RNull,
                        }
                    } else {
                        match state.regs.get(first_arg_reg) {
                            RText(ref s) => RText(trim_ascii(s, false, true)),
                            RNull => RNull,
                            _ => RNull,
                        }
                    }
                }
                17 => {
                    // REPLACE(s, find, replacement).
                    if n_args < 3 {
                        RNull
                    } else {
                        let s_v = state.regs.get(first_arg_reg);
                        let f_v = state.regs.get(first_arg_reg + 1);
                        let r_v = state.regs.get(first_arg_reg + 2);
                        match s_v {
                            RText(ref s) => match f_v {
                                RText(ref f) => match r_v {
                                    RText(ref r) => RText(replace_all_bytes(s, f, r)),
                                    _ => RNull,
                                },
                                _ => RNull,
                            },
                            _ => RNull,
                        }
                    }
                }
                18 => {
                    // INSTR(haystack, needle) → 1-based index of first match, else 0.
                    if n_args < 2 {
                        RNull
                    } else {
                        let hv = state.regs.get(first_arg_reg);
                        let nv = state.regs.get(first_arg_reg + 1);
                        match hv {
                            RText(ref h) => match nv {
                                RText(ref n) => RInt(instr_bytes(h, n) as Int64),
                                _ => RNull,
                            },
                            _ => RNull,
                        }
                    }
                }
                19 => {
                    // ROUND(x [, digits]) — rounds to `digits` decimal places.
                    if n_args < 1 {
                        RNull
                    } else {
                        let v = state.regs.get(first_arg_reg);
                        let digits: Int = if n_args >= 2 {
                            match state.regs.get(first_arg_reg + 1) {
                                RInt(x) => x as Int,
                                _ => 0,
                            }
                        } else { 0 };
                        match v {
                            RInt(x) => RInt(x),
                            RReal(x) => RReal(round_to_digits(x, digits)),
                            RNull    => RNull,
                            _        => RNull,
                        }
                    }
                }
                20 => {
                    // MIN(a, b, ...) as scalar — smallest of any non-null arg.
                    let mut i: Int = 0;
                    let mut best: Register = RNull;
                    while i < n_args {
                        let v = state.regs.get(first_arg_reg + i);
                        let is_null = match v { RNull => true, _ => false };
                        if !is_null {
                            match best {
                                RNull => { best = v; }
                                _ => {
                                    if agg_less(&v, &best) { best = v; }
                                }
                            }
                        }
                        i = i + 1;
                    }
                    best
                }
                21 => {
                    // MAX(a, b, ...) as scalar.
                    let mut i: Int = 0;
                    let mut best: Register = RNull;
                    while i < n_args {
                        let v = state.regs.get(first_arg_reg + i);
                        let is_null = match v { RNull => true, _ => false };
                        if !is_null {
                            match best {
                                RNull => { best = v; }
                                _ => {
                                    if agg_less(&best, &v) { best = v; }
                                }
                            }
                        }
                        i = i + 1;
                    }
                    best
                }
                22 => {
                    // HEX(blob) — hex-encode bytes.
                    if n_args < 1 {
                        RNull
                    } else {
                        match state.regs.get(first_arg_reg) {
                            RBlob(ref b) => RText(hex_encode(b)),
                            RText(ref s) => RText(hex_encode_text(s)),
                            RNull => RNull,
                            _ => RNull,
                        }
                    }
                }
                23 => {
                    // TYPEOF(x) — dynamic type name as text.
                    if n_args < 1 {
                        RNull
                    } else {
                        let v = state.regs.get(first_arg_reg);
                        let name: Text = match v {
                            RNull     => "null".clone(),
                            RInt(_)   => "integer".clone(),
                            RRowId(_) => "integer".clone(),
                            RReal(_)  => "real".clone(),
                            RText(_)  => "text".clone(),
                            RBlob(_)  => "blob".clone(),
                        };
                        RText(name)
                    }
                }
                24 => {
                    // IIF(cond, a, b) — ternary helper (SQLite 3.32+).
                    if n_args < 3 {
                        RNull
                    } else {
                        let c = state.regs.get(first_arg_reg);
                        let cond_true = match c {
                            RInt(x)  => x != 0_i64,
                            RReal(x) => x != 0.0,
                            RText(ref s) => s.len() > 0,
                            RBlob(ref b) => b.len() > 0,
                            _ => false,
                        };
                        if cond_true {
                            state.regs.get(first_arg_reg + 1)
                        } else {
                            state.regs.get(first_arg_reg + 2)
                        }
                    }
                }
                25 => {
                    // UNICODE(s) — codepoint of first byte (ASCII subset).
                    if n_args < 1 {
                        RNull
                    } else {
                        match state.regs.get(first_arg_reg) {
                            RText(ref s) => {
                                let bs = s.as_bytes();
                                if bs.len() == 0 { RNull } else { RInt(bs[0] as Int64) }
                            }
                            RNull => RNull,
                            _ => RNull,
                        }
                    }
                }
                26 => {
                    // CHAR(n) — single-char text from ASCII codepoint.
                    if n_args < 1 {
                        RNull
                    } else {
                        match state.regs.get(first_arg_reg) {
                            RInt(x) => {
                                let mut out = Text.new();
                                let b: Byte = (x as Int) as Byte;
                                out.push_byte(b);
                                RText(out)
                            }
                            _ => RNull,
                        }
                    }
                }
                27 => {
                    // SIGN(x) — -1/0/1 for numeric, NULL for others.
                    if n_args < 1 {
                        RNull
                    } else {
                        match state.regs.get(first_arg_reg) {
                            RInt(x)  => {
                                if x > 0_i64 { RInt(1_i64) }
                                else if x < 0_i64 { RInt(-1_i64) }
                                else { RInt(0_i64) }
                            }
                            RReal(x) => {
                                if x > 0.0 { RInt(1_i64) }
                                else if x < 0.0 { RInt(-1_i64) }
                                else { RInt(0_i64) }
                            }
                            RNull => RNull,
                            _ => RNull,
                        }
                    }
                }
                11 => {
                    // NOT LIKE — inverse of LIKE.
                    if n_args < 2 {
                        RInt(1_i64)
                    } else {
                        let tv = state.regs.get(first_arg_reg);
                        let pv = state.regs.get(first_arg_reg + 1);
                        match tv {
                            RText(ref t) => match pv {
                                RText(ref p) => {
                                    if like_match(t, p) { RInt(0_i64) } else { RInt(1_i64) }
                                }
                                _ => RInt(1_i64),
                            },
                            _ => RInt(1_i64),
                        }
                    }
                }
                _ => RNull,
            };
            state.regs.set(dst, result);
            state.pc = state.pc + 1;
            Yield
        }

        AggFinalAvg(sum_reg, count_reg, dst_reg) => {
            let cnt: Int64 = match state.regs.get(count_reg) {
                RInt(x) => x,
                _       => 0_i64,
            };
            if cnt == 0_i64 {
                state.regs.set(dst_reg, RNull);
            } else {
                let sum = state.regs.get(sum_reg);
                let cnt_f: Float64 = (cnt as Float64);
                match sum {
                    RInt(s) => {
                        let sf: Float64 = (s as Float64);
                        state.regs.set(dst_reg, RReal(sf / cnt_f));
                    }
                    RReal(s) => {
                        state.regs.set(dst_reg, RReal(s / cnt_f));
                    }
                    _ => {
                        state.regs.set(dst_reg, RNull);
                    }
                }
            }
            state.pc = state.pc + 1;
            Yield
        }

        Transaction(_) => { state.pc = state.pc + 1; Yield }
        Commit         => { state.pc = state.pc + 1; Yield }
        RollbackOp(_)  => { state.pc = state.pc + 1; Yield }
        SavepointOp(_) => { state.pc = state.pc + 1; Yield }

        // Anything else still a no-op.
        _ => {
            state.pc = state.pc + 1;
            Yield
        }
    }
}


// -----------------------------------------------------------------------------
// Cast helpers
// -----------------------------------------------------------------------------

fn parse_int_text(s: &Text) -> Maybe<Int64> {
    let bs = s.as_bytes();
    if bs.len() == 0 { return None; }
    let mut i: Int = 0;
    let mut sign: Int64 = 1 as Int64;
    if bs[0] == (45 as Byte) { sign = -1 as Int64; i = 1; }
    else if bs[0] == (43 as Byte) { i = 1; }
    if i >= bs.len() { return None; }
    let mut acc: Int64 = 0 as Int64;
    while i < bs.len() {
        let b = bs[i];
        if b < (48 as Byte) || b > (57 as Byte) { return None; }
        let d: Int64 = ((b - (48 as Byte)) as Int64);
        acc = acc * 10_i64 + d;
        i = i + 1;
    }
    Some(acc * sign)
}

fn parse_real_text(s: &Text) -> Maybe<Float64> {
    // Very minimal: tries integer first, falls back to NaN-guard.
    match parse_int_text(s) {
        Some(i) => Some(i as Float64),
        None    => None,
    }
}

fn int_to_text(x: Int64) -> Text {
    // Manual base-10 render (SQLite cheat: allocate small buffer).
    if x == 0_i64 { return "0".clone(); }
    let mut n: Int64 = x;
    let mut neg: Bool = false;
    if n < 0_i64 { neg = true; n = -n; }
    let mut digits: List<Byte> = List.new();
    while n > 0_i64 {
        let d: Byte = ((n as Int) % 10) as Byte;
        digits.push(d + (48 as Byte));
        n = n / 10_i64;
    }
    let mut out = Text.new();
    if neg { out.push_byte(45 as Byte); }
    let mut i: Int = digits.len() - 1;
    while i >= 0 {
        out.push_byte(digits[i]);
        i = i - 1;
    }
    out
}

fn real_to_text(x: Float64) -> Text {
    // Quick-and-dirty: render integral part only. Full IEEE rendering
    // lives in a dedicated helper outside the interpreter hot path.
    let i = x as Int64;
    int_to_text(i)
}

fn bytes_to_text(b: &List<Byte>) -> Text {
    let mut out = Text.new();
    let mut i: Int = 0;
    while i < b.len() {
        out.push_byte(b[i]);
        i = i + 1;
    }
    out
}

fn text_to_bytes(s: &Text) -> List<Byte> {
    let mut out: List<Byte> = List.new();
    let bs = s.as_bytes();
    let mut i: Int = 0;
    while i < bs.len() {
        out.push(bs[i]);
        i = i + 1;
    }
    out
}

// -----------------------------------------------------------------------------
// Scalar-function helpers
// -----------------------------------------------------------------------------

fn is_ws(b: Byte) -> Bool {
    b == (32 as Byte) || b == (9 as Byte) || b == (10 as Byte) || b == (13 as Byte)
}

fn trim_ascii(s: &Text, left: Bool, right: Bool) -> Text {
    let bs = s.as_bytes();
    let n = bs.len();
    let mut i: Int = 0;
    if left {
        while i < n && is_ws(bs[i]) { i = i + 1; }
    }
    let mut j: Int = n;
    if right {
        while j > i && is_ws(bs[j - 1]) { j = j - 1; }
    }
    let mut out = Text.new();
    let mut k: Int = i;
    while k < j { out.push_byte(bs[k]); k = k + 1; }
    out
}

/// SQL TRIM(s, chars) / LTRIM(s, chars) / RTRIM(s, chars) — trim
/// any characters in `chars` (treated as a SET, not a substring) from
/// the requested ends of `s`.
///
/// Per SQL spec: `TRIM('xyhelloy', 'xy')` returns `"hello"` because
/// the SET {x, y} is stripped from both ends.  Empty `chars` is a
/// no-op (matches SQLite behaviour).
///
/// ASCII-only — multi-byte chars in `chars` are matched byte-by-byte,
/// which is correct for ASCII trim sets and matches SQLite's behaviour
/// (SQLite's `TRIM` is byte-oriented, not codepoint-oriented).
fn trim_with_chars(s: &Text, chars: &Text, left: Bool, right: Bool) -> Text {
    let cb = chars.as_bytes();
    if cb.len() == 0 { return s.clone(); }
    let bs = s.as_bytes();
    let n = bs.len();
    let mut i: Int = 0;
    if left {
        while i < n && byte_in_set(bs[i], cb) { i = i + 1; }
    }
    let mut j: Int = n;
    if right {
        while j > i && byte_in_set(bs[j - 1], cb) { j = j - 1; }
    }
    let mut out = Text.new();
    let mut k: Int = i;
    while k < j { out.push_byte(bs[k]); k = k + 1; }
    out
}

/// Linear search through the trim-char set.  At typical SQL trim
/// set sizes (≤ 16 chars) this beats a HashSet by avoiding the
/// hash + allocation cost.
fn byte_in_set(b: Byte, set: &List<Byte>) -> Bool {
    let mut i: Int = 0;
    while i < set.len() {
        if set[i] == b { return true; }
        i = i + 1;
    }
    false
}

fn bytes_equal_at(h: &List<Byte>, at: Int, n: &List<Byte>) -> Bool {
    if at + n.len() > h.len() { return false; }
    let mut i: Int = 0;
    while i < n.len() {
        if h[at + i] != n[i] { return false; }
        i = i + 1;
    }
    true
}

fn replace_all_bytes(s: &Text, find: &Text, repl: &Text) -> Text {
    let sb = s.as_bytes();
    let fb = find.as_bytes();
    let rb = repl.as_bytes();
    let mut out = Text.new();
    if fb.len() == 0 {
        let mut i: Int = 0;
        while i < sb.len() { out.push_byte(sb[i]); i = i + 1; }
        return out;
    }
    let mut i: Int = 0;
    while i < sb.len() {
        if i + fb.len() <= sb.len() && bytes_equal_at(sb, i, fb) {
            let mut k: Int = 0;
            while k < rb.len() { out.push_byte(rb[k]); k = k + 1; }
            i = i + fb.len();
        } else {
            out.push_byte(sb[i]);
            i = i + 1;
        }
    }
    out
}

fn instr_bytes(h: &Text, n: &Text) -> Int {
    let hb = h.as_bytes();
    let nb = n.as_bytes();
    if nb.len() == 0 { return 0; }
    let mut i: Int = 0;
    while i + nb.len() <= hb.len() {
        if bytes_equal_at(hb, i, nb) { return i + 1; }
        i = i + 1;
    }
    0
}

fn round_to_digits(x: Float64, digits: Int) -> Float64 {
    let mut scale: Float64 = 1.0;
    let mut k: Int = 0;
    while k < digits { scale = scale * 10.0; k = k + 1; }
    let mut n_neg: Int = 0;
    while n_neg > digits { scale = scale / 10.0; n_neg = n_neg - 1; }
    let scaled = x * scale;
    let rounded: Int64 = if scaled >= 0.0 {
        (scaled + 0.5) as Int64
    } else {
        (scaled - 0.5) as Int64
    };
    (rounded as Float64) / scale
}

fn hex_nibble(b: Byte) -> Byte {
    if b < (10 as Byte) { (b + (48 as Byte)) } else { (b + (55 as Byte)) }
}

fn hex_encode(b: &List<Byte>) -> Text {
    let mut out = Text.new();
    let mut i: Int = 0;
    while i < b.len() {
        let c = b[i];
        out.push_byte(hex_nibble((c >> 4) & (15 as Byte)));
        out.push_byte(hex_nibble(c & (15 as Byte)));
        i = i + 1;
    }
    out
}

fn hex_encode_text(s: &Text) -> Text {
    let bs = s.as_bytes();
    let mut out = Text.new();
    let mut i: Int = 0;
    while i < bs.len() {
        let c = bs[i];
        out.push_byte(hex_nibble((c >> 4) & (15 as Byte)));
        out.push_byte(hex_nibble(c & (15 as Byte)));
        i = i + 1;
    }
    out
}

/// SQLite LIKE semantics — case-insensitive ASCII, '%' matches any
/// sequence of zero or more chars, '_' matches any single char.
/// Escape character support omitted in v1.
fn like_match(target: &Text, pattern: &Text) -> Bool {
    let t = ascii_fold_case(target, false);
    let p = ascii_fold_case(pattern, false);
    let tb = t.as_bytes();
    let pb = p.as_bytes();
    like_rec(tb, 0, pb, 0)
}

fn like_rec(tb: &List<Byte>, ti: Int, pb: &List<Byte>, pi: Int) -> Bool {
    if pi >= pb.len() { return ti >= tb.len(); }
    let pc = pb[pi];
    if pc == (37 as Byte) {
        // '%' — try matching rest of pattern against every suffix.
        if pi + 1 >= pb.len() { return true; }
        let mut i: Int = ti;
        while i <= tb.len() {
            if like_rec(tb, i, pb, pi + 1) { return true; }
            i = i + 1;
        }
        return false;
    }
    if pc == (95 as Byte) {
        // '_' — any single char.
        if ti >= tb.len() { return false; }
        return like_rec(tb, ti + 1, pb, pi + 1);
    }
    // Literal byte match.
    if ti >= tb.len() { return false; }
    if tb[ti] != pc { return false; }
    like_rec(tb, ti + 1, pb, pi + 1)
}

fn ascii_fold_case(s: &Text, to_upper: Bool) -> Text {
    let mut out = Text.new();
    let bs = s.as_bytes();
    let mut i: Int = 0;
    while i < bs.len() {
        let b = bs[i];
        let folded: Byte = if to_upper {
            if b >= (97 as Byte) && b <= (122 as Byte) { b - (32 as Byte) } else { b }
        } else {
            if b >= (65 as Byte) && b <= (90 as Byte) { b + (32 as Byte) } else { b }
        };
        out.push_byte(folded);
        i = i + 1;
    }
    out
}

// -----------------------------------------------------------------------------
// Aggregate helpers
// -----------------------------------------------------------------------------

/// Add two register values, preserving real-ness. NULLs are treated as
/// 0 when the *other* side is non-null (matches SQLite's SUM behaviour
/// for pre-initialized accumulators).
fn agg_add(a: &Register, b: &Register) -> Register {
    match a {
        RNull => match b {
            RNull => RNull,
            _     => {
                // a null, b real/int → return b's value (seed the sum).
                match b {
                    RInt(y)  => RInt(y),
                    RReal(y) => RReal(y),
                    _        => RNull,
                }
            }
        },
        RInt(x) => match b {
            RNull    => RInt(x),
            RInt(y)  => RInt(x + y),
            RReal(y) => {
                let xf: Float64 = (x as Float64);
                RReal(xf + y)
            }
            _        => RInt(x),
        },
        RReal(x) => match b {
            RNull    => RReal(x),
            RInt(y)  => {
                let yf: Float64 = (y as Float64);
                RReal(x + yf)
            }
            RReal(y) => RReal(x + y),
            _        => RReal(x),
        },
        _ => RNull,
    }
}

/// Returns true when `a < b` for aggregate comparison purposes.
fn agg_less(a: &Register, b: &Register) -> Bool {
    match a {
        RInt(x) => match b {
            RInt(y)  => x < y,
            RReal(y) => (x as Float64) < y,
            _        => false,
        },
        RReal(x) => match b {
            RInt(y)  => x < (y as Float64),
            RReal(y) => x < y,
            _        => false,
        },
        RText(ref xs) => match b {
            RText(ref ys) => xs < ys,
            _ => false,
        },
        _ => false,
    }
}


/// Run the program until it yields a row, reports Done, or errors out.
/// Returns after at most `budget` steps to give the caller back
/// control. `-1` disables the limit.
public fn run_until_row(
    state: &mut VdbeState,
    program: &VdbeProgram,
    budget: Int,
) -> StepResult {
    let mut steps: Int = 0;
    while budget < 0 || steps < budget {
        match step(state, program) {
            Row(s, n)        => { return Row(s, n); }
            Done             => { return Done; }
            ExecError(c, m)  => { return ExecError(c, m); }
            Yield            => { steps = steps + 1; }
        }
    }
    Yield
}
