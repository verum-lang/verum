module core.database.sqlite.native.l4_vdbe.interpreter;

// =============================================================================
// l4_vdbe/interpreter.vr — VDBE interpreter (step-based)
// =============================================================================
// Layer: 4
// Spec: sqlite-native.md §11.3
//
// The interpreter is deliberately *step-based* rather than batched —
// SQLite's sqlite3_step() returns one row at a time and the caller
// controls iteration. Our `step(&mut VdbeState)` returns a `StepResult`:
//
//   * `Row(reg_start, n_cols)` — caller should emit a result row
//   * `Done`                    — Halt(0) reached, program complete
//   * `Error(code, msg)`        — Halt(nonzero) or runtime error
//   * `Yield`                   — no visible effect; call step() again
//
// This module implements the subset of opcodes that don't require
// cursor I/O (arithmetic, control flow, register moves, comparisons).
// Cursor-touching opcodes — Column, Next, SeekGE, Insert — are stubbed
// to `Yield` until the actor IPC integration lands.
// =============================================================================

mount core.*;
mount collections.List;
mount base.{Result, Ok, Err, Text, Maybe};
mount core.database.sqlite.native.l4_vdbe.opcode.Opcode;
mount core.database.sqlite.native.l4_vdbe.register.{
    Register, RegisterFile, register_file_new, register_is_truthy, register_clone,
};
mount core.database.sqlite.native.l4_vdbe.program.{
    VdbeProgram, ConstantEntry, ConstantPool, CursorKind,
};
mount core.database.sqlite.native.l4_vdbe.cursor_table.{
    CursorTable, cursor_table_new,
};
mount core.database.sqlite.native.l3_btree.BtreeKind;

// -----------------------------------------------------------------------------
// State / result
// -----------------------------------------------------------------------------

public type StepResult is
      Row(reg_start: Int, n_cols: Int)
    | Done
    | Yield
    | ExecError(code: Int, msg: Text);

/// Mutable interpreter state held across calls to `step`.
public type affine VdbeState is {
    pc: Int,
    regs: RegisterFile,
    return_stack: List<Int>,     // for Gosub/Return
    once_fired: List<Int>,       // instruction indices of Once ops that fired
    halted: Bool,
    cursors: CursorTable,        // live cursor pipeline (opened lazily)
};

public fn vdbe_state_new(program: &VdbeProgram) -> VdbeState {
    VdbeState {
        pc: 0,
        regs: register_file_new(program.register_count()),
        return_stack: List.new(),
        once_fired: List.new(),
        halted: false,
        cursors: cursor_table_new(program.cursor_count(), 4096, 0),
    }
}

implement VdbeState {
    public fn program_counter(&self) -> Int { self.pc }
    public fn is_halted(&self) -> Bool { self.halted }
    public fn reg(&self, i: Int) -> Register { self.regs.get(i) }
    public fn set_reg(&mut self, i: Int, v: Register) { self.regs.set(i, v); }
    public fn cursor_table_mut(&mut self) -> &mut CursorTable { &mut self.cursors }
    public fn cursor_table_ref(&self) -> &CursorTable { &self.cursors }
}

// -----------------------------------------------------------------------------
// Helpers — arithmetic + comparison lowering
// -----------------------------------------------------------------------------

fn to_int64(r: &Register) -> Int64 {
    match r {
        RInt(i)   => i,
        RRowId(i) => i,
        RReal(x)  => x as Int64,
        _         => 0 as Int64,
    }
}

fn to_real(r: &Register) -> Float64 {
    match r {
        RInt(i)   => i as Float64,
        RRowId(i) => i as Float64,
        RReal(x)  => x,
        _         => 0.0,
    }
}

fn arith_add(a: &Register, b: &Register) -> Register {
    match (a, b) {
        (RReal(_), _) | (_, RReal(_)) => RReal(to_real(a) + to_real(b)),
        _                             => RInt(to_int64(a) + to_int64(b)),
    }
}

fn arith_sub(a: &Register, b: &Register) -> Register {
    match (a, b) {
        (RReal(_), _) | (_, RReal(_)) => RReal(to_real(a) - to_real(b)),
        _                             => RInt(to_int64(a) - to_int64(b)),
    }
}

fn arith_mul(a: &Register, b: &Register) -> Register {
    match (a, b) {
        (RReal(_), _) | (_, RReal(_)) => RReal(to_real(a) * to_real(b)),
        _                             => RInt(to_int64(a) * to_int64(b)),
    }
}

fn arith_div(a: &Register, b: &Register) -> Register {
    // SQLite divides as REAL for REAL operands, INT otherwise with 0
    // protection (0 / 0 = NULL).
    match (a, b) {
        (RReal(_), _) | (_, RReal(_)) => {
            let bx = to_real(b);
            if bx == 0.0 { RNull } else { RReal(to_real(a) / bx) }
        }
        _ => {
            let bi = to_int64(b);
            if bi == (0 as Int64) { RNull } else { RInt(to_int64(a) / bi) }
        }
    }
}

fn cmp_lt(a: &Register, b: &Register) -> Bool {
    match (a, b) {
        (RReal(_), _) | (_, RReal(_)) => to_real(a) < to_real(b),
        (RText(x), RText(y)) => x < y,
        _ => to_int64(a) < to_int64(b),
    }
}

fn cmp_eq(a: &Register, b: &Register) -> Bool {
    match (a, b) {
        (RNull, RNull) => false,     // SQLite NULL != NULL in comparisons
        (RReal(_), _) | (_, RReal(_)) => to_real(a) == to_real(b),
        (RText(x), RText(y)) => x == y,
        _ => to_int64(a) == to_int64(b),
    }
}

// -----------------------------------------------------------------------------
// Step
// -----------------------------------------------------------------------------

/// Execute one opcode. Advances `pc` to the next instruction unless the
/// opcode jumps. Returns the step outcome for the caller to dispatch on.
///
/// Cursor-bound opcodes return `Yield` (still a no-op) until the pager
/// actor IPC is wired; callers can special-case by inspecting the
/// current opcode via `program.get_opcode(state.pc)`.
public fn step(state: &mut VdbeState, program: &VdbeProgram) -> StepResult {
    if state.halted {
        return Done;
    }
    let op_maybe = program.get_opcode(state.pc);
    let op = match op_maybe {
        Some(o) => o,
        None    => { state.halted = true; return Done; }
    };

    match op {
        Init(t) => { state.pc = t; Yield }

        Halt(code, _msg_idx) => {
            state.halted = true;
            if code == 0 { Done } else { ExecError(code, "Halt with error".clone()) }
        }

        Goto(t) => { state.pc = t; Yield }

        Gosub(r, t) => {
            state.return_stack.push(state.pc + 1);
            state.regs.set(r, RInt(state.pc as Int64));
            state.pc = t;
            Yield
        }

        Return(r) => {
            let v = state.regs.get(r);
            let _ = v;
            if state.return_stack.len() > 0 {
                let ret = state.return_stack.pop();
                state.pc = ret;
            } else {
                state.halted = true;
                return ExecError(1, "Return with empty stack".clone());
            }
            Yield
        }

        Once(jump_if_done) => {
            let fired = state.once_fired;
            let idx = state.pc;
            let mut already = false;
            let mut k: Int = 0;
            while k < fired.len() {
                if fired[k] == idx { already = true; break; }
                k = k + 1;
            }
            if already {
                state.pc = jump_if_done;
            } else {
                state.once_fired.push(idx);
                state.pc = state.pc + 1;
            }
            Yield
        }

        Noop => { state.pc = state.pc + 1; Yield }

        Integer(v, d) => {
            state.regs.set(d, RInt(v as Int64));
            state.pc = state.pc + 1;
            Yield
        }

        Int64(const_idx, d) => {
            match program.constants.get(const_idx) {
                KInt(i) => state.regs.set(d, RInt(i)),
                _       => state.regs.set(d, RNull),
            }
            state.pc = state.pc + 1;
            Yield
        }

        Real(const_idx, d) => {
            match program.constants.get(const_idx) {
                KReal(x) => state.regs.set(d, RReal(x)),
                _        => state.regs.set(d, RNull),
            }
            state.pc = state.pc + 1;
            Yield
        }

        String8(const_idx, d) => {
            match program.constants.get(const_idx) {
                KText(s) => state.regs.set(d, RText(s)),
                _        => state.regs.set(d, RNull),
            }
            state.pc = state.pc + 1;
            Yield
        }

        Null(start, end_inclusive) => {
            state.regs.clear_range(start, end_inclusive);
            state.pc = state.pc + 1;
            Yield
        }

        SoftNull(d) => {
            state.regs.set(d, RNull);
            state.pc = state.pc + 1;
            Yield
        }

        Move(src, dst, count) => {
            state.regs.move_range(src, dst, count);
            state.pc = state.pc + 1;
            Yield
        }

        Copy(src, dst, count) => {
            state.regs.copy_range(src, dst, count);
            state.pc = state.pc + 1;
            Yield
        }

        SCopy(src, dst) => {
            let v = state.regs.get(src);
            state.regs.set(dst, v);
            state.pc = state.pc + 1;
            Yield
        }

        Add(a, b, d) => {
            let va = state.regs.get(a);
            let vb = state.regs.get(b);
            state.regs.set(d, arith_add(&va, &vb));
            state.pc = state.pc + 1;
            Yield
        }

        Subtract(a, b, d) => {
            let va = state.regs.get(a);
            let vb = state.regs.get(b);
            state.regs.set(d, arith_sub(&va, &vb));
            state.pc = state.pc + 1;
            Yield
        }

        Multiply(a, b, d) => {
            let va = state.regs.get(a);
            let vb = state.regs.get(b);
            state.regs.set(d, arith_mul(&va, &vb));
            state.pc = state.pc + 1;
            Yield
        }

        Divide(a, b, d) => {
            let va = state.regs.get(a);
            let vb = state.regs.get(b);
            state.regs.set(d, arith_div(&va, &vb));
            state.pc = state.pc + 1;
            Yield
        }

        Eq(a, b, t) => {
            let va = state.regs.get(a);
            let vb = state.regs.get(b);
            if cmp_eq(&va, &vb) { state.pc = t; } else { state.pc = state.pc + 1; }
            Yield
        }

        Ne(a, b, t) => {
            let va = state.regs.get(a);
            let vb = state.regs.get(b);
            if !cmp_eq(&va, &vb) { state.pc = t; } else { state.pc = state.pc + 1; }
            Yield
        }

        Lt(a, b, t) => {
            let va = state.regs.get(a);
            let vb = state.regs.get(b);
            if cmp_lt(&va, &vb) { state.pc = t; } else { state.pc = state.pc + 1; }
            Yield
        }

        Le(a, b, t) => {
            let va = state.regs.get(a);
            let vb = state.regs.get(b);
            if cmp_lt(&va, &vb) || cmp_eq(&va, &vb) { state.pc = t; } else { state.pc = state.pc + 1; }
            Yield
        }

        Gt(a, b, t) => {
            let va = state.regs.get(a);
            let vb = state.regs.get(b);
            if cmp_lt(&vb, &va) { state.pc = t; } else { state.pc = state.pc + 1; }
            Yield
        }

        Ge(a, b, t) => {
            let va = state.regs.get(a);
            let vb = state.regs.get(b);
            if cmp_lt(&vb, &va) || cmp_eq(&va, &vb) { state.pc = t; } else { state.pc = state.pc + 1; }
            Yield
        }

        If(r, t) => {
            let v = state.regs.get(r);
            if register_is_truthy(&v) { state.pc = t; } else { state.pc = state.pc + 1; }
            Yield
        }

        IfNot(r, t) => {
            let v = state.regs.get(r);
            if !register_is_truthy(&v) { state.pc = t; } else { state.pc = state.pc + 1; }
            Yield
        }

        IfNull(r, t) => {
            let v = state.regs.get(r);
            match v {
                RNull => { state.pc = t; },
                _     => { state.pc = state.pc + 1; }
            }
            Yield
        }

        NotNull(r, t) => {
            let v = state.regs.get(r);
            match v {
                RNull => { state.pc = state.pc + 1; },
                _     => { state.pc = t; }
            }
            Yield
        }

        ResultRow(start, n) => {
            // Row emission — interpreter yields a row; caller re-enters
            // step() on the same pc → but ResultRow advances so the
            // next call moves past it.
            state.pc = state.pc + 1;
            Row(start, n)
        }

        // -------------------------------------------------------------
        // Cursor pipeline — backed by CursorTable's in-memory row store.
        // Real pager-backed cursors plug in transparently once the
        // actor IPC adapter fills `rows` one at a time.
        // -------------------------------------------------------------

        OpenRead(cursor_id, root_page, n_cols) => {
            let _ = state.cursors.open_read(cursor_id, root_page, n_cols, TableBtree);
            state.pc = state.pc + 1;
            Yield
        }

        OpenWrite(cursor_id, root_page, n_cols) => {
            let _ = state.cursors.open_write(cursor_id, root_page, n_cols, TableBtree);
            state.pc = state.pc + 1;
            Yield
        }

        OpenEphemeral(cursor_id, n_cols) => {
            let _ = state.cursors.open_ephemeral(cursor_id, n_cols);
            state.pc = state.pc + 1;
            Yield
        }

        Close(cursor_id) => {
            let _ = state.cursors.close(cursor_id);
            state.pc = state.pc + 1;
            Yield
        }

        Rewind(cursor_id, jump_if_empty) => {
            let _ = state.cursors.rewind(cursor_id);
            if !state.cursors.has_more(cursor_id) {
                state.pc = jump_if_empty;
            } else {
                state.pc = state.pc + 1;
            }
            Yield
        }

        Next(cursor_id, jump_if_more) => {
            let still_has = state.cursors.advance(cursor_id);
            if still_has {
                state.pc = jump_if_more;
            } else {
                state.pc = state.pc + 1;
            }
            Yield
        }

        Column(cursor_id, col_idx, dst) => {
            let v = state.cursors.peek_cell(cursor_id, col_idx);
            state.regs.set(dst, v);
            state.pc = state.pc + 1;
            Yield
        }

        RowIdOp(cursor_id, dst) => {
            let rid = state.cursors.current_rowid(cursor_id);
            state.regs.set(dst, RRowId(rid));
            state.pc = state.pc + 1;
            Yield
        }

        NewRowid(cursor_id, dst) => {
            let rid = state.cursors.peek_next_rowid(cursor_id);
            state.regs.set(dst, RRowId(rid));
            state.pc = state.pc + 1;
            Yield
        }

        Insert(cursor_id, data_reg, key_reg, _flags) => {
            // Data register holds a prepared MakeRecord result; for our
            // v1 row-store path we reconstruct the row from the
            // originating register range. Until MakeRecord lowering
            // lands in the interpreter, the simpler path is: the
            // preceding Column-like setup wrote n_cols registers
            // starting at `data_reg`; we read them all. This matches
            // what the current codegen emits for PnValues INSERT.
            let _ = key_reg;
            // Snapshot n_cols from the cursor metadata at open time.
            let slot_kind = state.cursors.kind(cursor_id);
            match slot_kind {
                CskClosed => { state.pc = state.pc + 1; return Yield; }
                _ => {}
            }
            // Pull n_cols from the slot.
            let n_cols = state.cursors.n_cols_of(cursor_id);
            let mut row: List<Register> = List.new();
            let mut i: Int = 0;
            while i < n_cols {
                row.push(state.regs.get(data_reg + i));
                i = i + 1;
            }
            let _ = state.cursors.append_row(cursor_id, row);
            state.pc = state.pc + 1;
            Yield
        }

        Delete(cursor_id) => {
            let _ = state.cursors.delete_current(cursor_id);
            state.pc = state.pc + 1;
            Yield
        }

        UpdateRow(cursor_id, data_reg) => {
            // Read n_cols registers starting at data_reg, overwrite
            // the row at current pos. Mirrors the Insert pattern but
            // replaces instead of appending.
            let n_cols = state.cursors.n_cols_of(cursor_id);
            let mut row: List<Register> = List.new();
            let mut i: Int = 0;
            while i < n_cols {
                row.push(state.regs.get(data_reg + i));
                i = i + 1;
            }
            let _ = state.cursors.replace_current_row(cursor_id, row);
            state.pc = state.pc + 1;
            Yield
        }

        SortRowStore(cursor_id, n_keys, dir_bits) => {
            let _ = state.cursors.sort_by_prefix(cursor_id, n_keys, dir_bits);
            state.pc = state.pc + 1;
            Yield
        }

        DedupRowStore(cursor_id, n_cells) => {
            let _ = state.cursors.dedup_adjacent(cursor_id, n_cells);
            state.pc = state.pc + 1;
            Yield
        }

        AggStep(agg_kind, n_args, first_arg_reg, acc_reg) => {
            match agg_kind {
                0 => {
                    // COUNT. For COUNT(*), n_args = 0 → unconditional increment.
                    // For COUNT(expr), skip if the arg is NULL.
                    if n_args > 0 {
                        match state.regs.get(first_arg_reg) {
                            RNull => { state.pc = state.pc + 1; return Yield; }
                            _     => {}
                        }
                    }
                    let cur: Int64 = match state.regs.get(acc_reg) {
                        RInt(v) => v,
                        _       => (0 as Int64),
                    };
                    state.regs.set(acc_reg, RInt(cur + (1 as Int64)));
                }
                1 => {
                    // SUM — NULL-skip; keep RReal if either side is real.
                    let v = state.regs.get(first_arg_reg);
                    let is_null = match v { RNull => true, _ => false };
                    if !is_null {
                        let cur = state.regs.get(acc_reg);
                        let new_val = agg_add(&cur, &v);
                        state.regs.set(acc_reg, new_val);
                    }
                }
                2 => {
                    // MIN — first non-null value wins, then min of subsequent.
                    let v = state.regs.get(first_arg_reg);
                    let is_null = match v { RNull => true, _ => false };
                    if !is_null {
                        let cur = state.regs.get(acc_reg);
                        let cur_null = match cur { RNull => true, _ => false };
                        if cur_null {
                            state.regs.set(acc_reg, v);
                        } else {
                            let keep_cur = agg_less(&cur, &v);
                            if !keep_cur { state.regs.set(acc_reg, v); }
                        }
                    }
                }
                3 => {
                    // MAX — symmetric to MIN.
                    let v = state.regs.get(first_arg_reg);
                    let is_null = match v { RNull => true, _ => false };
                    if !is_null {
                        let cur = state.regs.get(acc_reg);
                        let cur_null = match cur { RNull => true, _ => false };
                        if cur_null {
                            state.regs.set(acc_reg, v);
                        } else {
                            let keep_cur = agg_less(&v, &cur);
                            if !keep_cur { state.regs.set(acc_reg, v); }
                        }
                    }
                }
                _ => {}
            }
            state.pc = state.pc + 1;
            Yield
        }

        AggFinal(_agg_kind, _acc_reg) => {
            // COUNT / SUM / MIN / MAX all hold their final value in
            // acc_reg already. AVG uses the dedicated AggFinalAvg path.
            state.pc = state.pc + 1;
            Yield
        }

        AggStepAvg(n_args, first_arg_reg, sum_reg, count_reg) => {
            // AVG(x): NULL-skip; otherwise sum += x and count += 1.
            // Supports AVG(*) form (n_args = 0) too by treating every
            // row as "not null".
            let skip = if n_args > 0 {
                match state.regs.get(first_arg_reg) {
                    RNull => true,
                    _     => false,
                }
            } else {
                false
            };
            if !skip {
                if n_args > 0 {
                    let v = state.regs.get(first_arg_reg);
                    let cur = state.regs.get(sum_reg);
                    state.regs.set(sum_reg, agg_add(&cur, &v));
                }
                let cur_count: Int64 = match state.regs.get(count_reg) {
                    RInt(x) => x,
                    _       => (0 as Int64),
                };
                state.regs.set(count_reg, RInt(cur_count + (1 as Int64)));
            }
            state.pc = state.pc + 1;
            Yield
        }

        AggFinalAvg(sum_reg, count_reg, dst_reg) => {
            let cnt: Int64 = match state.regs.get(count_reg) {
                RInt(x) => x,
                _       => (0 as Int64),
            };
            if cnt == (0 as Int64) {
                state.regs.set(dst_reg, RNull);
            } else {
                let sum = state.regs.get(sum_reg);
                let cnt_f: Float64 = (cnt as Float64);
                match sum {
                    RInt(s) => {
                        let sf: Float64 = (s as Float64);
                        state.regs.set(dst_reg, RReal(sf / cnt_f));
                    }
                    RReal(s) => {
                        state.regs.set(dst_reg, RReal(s / cnt_f));
                    }
                    _ => {
                        state.regs.set(dst_reg, RNull);
                    }
                }
            }
            state.pc = state.pc + 1;
            Yield
        }

        Transaction(_) => { state.pc = state.pc + 1; Yield }
        Commit         => { state.pc = state.pc + 1; Yield }
        RollbackOp(_)  => { state.pc = state.pc + 1; Yield }
        SavepointOp(_) => { state.pc = state.pc + 1; Yield }

        // Anything else still a no-op.
        _ => {
            state.pc = state.pc + 1;
            Yield
        }
    }
}


// -----------------------------------------------------------------------------
// Aggregate helpers
// -----------------------------------------------------------------------------

/// Add two register values, preserving real-ness. NULLs are treated as
/// 0 when the *other* side is non-null (matches SQLite's SUM behaviour
/// for pre-initialized accumulators).
fn agg_add(a: &Register, b: &Register) -> Register {
    match a {
        RNull => match b {
            RNull => RNull,
            _     => {
                // a null, b real/int → return b's value (seed the sum).
                match b {
                    RInt(y)  => RInt(y),
                    RReal(y) => RReal(y),
                    _        => RNull,
                }
            }
        },
        RInt(x) => match b {
            RNull    => RInt(x),
            RInt(y)  => RInt(x + y),
            RReal(y) => {
                let xf: Float64 = (x as Float64);
                RReal(xf + y)
            }
            _        => RInt(x),
        },
        RReal(x) => match b {
            RNull    => RReal(x),
            RInt(y)  => {
                let yf: Float64 = (y as Float64);
                RReal(x + yf)
            }
            RReal(y) => RReal(x + y),
            _        => RReal(x),
        },
        _ => RNull,
    }
}

/// Returns true when `a < b` for aggregate comparison purposes.
fn agg_less(a: &Register, b: &Register) -> Bool {
    match a {
        RInt(x) => match b {
            RInt(y)  => x < y,
            RReal(y) => (x as Float64) < y,
            _        => false,
        },
        RReal(x) => match b {
            RInt(y)  => x < (y as Float64),
            RReal(y) => x < y,
            _        => false,
        },
        RText(ref xs) => match b {
            RText(ref ys) => xs < ys,
            _ => false,
        },
        _ => false,
    }
}


/// Run the program until it yields a row, reports Done, or errors out.
/// Returns after at most `budget` steps to give the caller back
/// control. `-1` disables the limit.
public fn run_until_row(
    state: &mut VdbeState,
    program: &VdbeProgram,
    budget: Int,
) -> StepResult {
    let mut steps: Int = 0;
    while budget < 0 || steps < budget {
        match step(state, program) {
            Row(s, n)        => { return Row(s, n); }
            Done             => { return Done; }
            ExecError(c, m)  => { return ExecError(c, m); }
            Yield            => { steps = steps + 1; }
        }
    }
    Yield
}
