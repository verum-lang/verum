@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.database.sqlite.native.l4_vdbe.ssa.to_register_vm;

// =============================================================================
// l4_vdbe/ssa/to_register_vm.vr — SSA back-translation to VdbeProgram
// =============================================================================
// Layer: 4
// Spec: sqlite-native.md §4.4
//
// Lowers an `SsaProgram` back to a legacy `VdbeProgram` for execution
// by the existing register-VM interpreter.  This keeps Tier-0
// execution unchanged while the SSA layer takes over codegen + opt.
//
// Strategy:
//
//   1. Assign a register slot to every SSA value (Chaitin-style register
//      allocation later; trivial 1:1 mapping for the foundation pass).
//   2. Walk blocks in CFG order; for each block, emit phis as Mov
//      instructions on every incoming edge (handled by inserting
//      Mov on the predecessor's terminator path), then straight-line
//      instructions, then the terminator translated to a register-VM
//      jump targeting the destination block's first emitted index.
//   3. Patch all jumps once block start indices are known.
//
// This file ships the SCAFFOLD with the trivial 1:1 mapping.  Full
// register coalescing + interference-graph allocation lands with the
// optimizer in #133.
// =============================================================================

mount core.*;
mount collections.List;
mount base.{Text, Maybe};
mount core.database.sqlite.native.l4_vdbe.opcode.{
    Opcode,
    Integer, Int64, Real, String8, BlobLit, Null,
    Add, Subtract, Multiply, Divide, Remainder,
    BitAnd, BitOr, ShiftLeft, ShiftRight, BitNot,
    Eq, Ne, Lt, Le, Gt, Ge,
    If, IfNot, Goto, Halt, Noop, Return,
    Move, SCopy, MakeRecord,
    Column, RowIdOp, NewRowid,
    Insert, Delete,
    Rewind, Next, Prev, Last,
    OpenRead, OpenWrite, Close,
    Function, ScalarFn, Transaction, Commit
};
mount core.database.sqlite.native.l4_vdbe.program.{
    VdbeProgram, program_new
};
mount core.database.sqlite.native.l4_vdbe.ssa.value.{
    SValueKind, SkBool, SkInt, SkReal, SkText, SkBlob, SkRowId, SkNull, SkAny,
    SsaValue, ValueId, value_id_raw, kind_eq
};
mount core.database.sqlite.native.l4_vdbe.ssa.inst.{
    SsaInst, CmpKind, CkEq, CkNe, CkLt, CkLe, CkGt, CkGe,
    IConst, INull, IIntImm,
    IAdd, ISub, IMul, IDiv, IRem,
    IBitAnd, IBitOr, IShiftLeft, IShiftRight, IBitNot,
    ICmp, ICast,
    IColumn, IRowId, INewRowId,
    IMakeRecord, ICursorInsert, ICursorDelete,
    ICursorOpen, ICursorClose, ICursorRewind, ICursorNext, ICursorPrev, ICursorLast,
    IPhi, PhiOperand,
    IBranch, IJump, IHalt, IReturn, IYield,
    inst_dst
};
mount core.database.sqlite.native.l4_vdbe.ssa.block.{
    BasicBlock, BlockId, block_id_raw
};
mount core.database.sqlite.native.l4_vdbe.ssa.cfg.Cfg;
mount core.database.sqlite.native.l4_vdbe.ssa.program.SsaProgram;

// -----------------------------------------------------------------------------
// LowerState
// -----------------------------------------------------------------------------

/// Per-lowering working state.  `value_to_reg` maps an SSA ValueId
/// to its assigned register slot in the output VdbeProgram.
/// `block_start[i]` is the first instruction index of block `i` in
/// the output (-1 until emitted; used for jump patching).
type LowerState = {
    value_to_reg: List<Int>,             // indexed by ValueId raw
    block_start: List<Int>,              // indexed by BlockId raw
    next_register: Int,
};

fn lower_state_new(value_count: Int, block_count: Int) -> LowerState {
    let mut v: List<Int> = List.new();
    let mut i: Int = 0;
    while i < value_count {
        v.push(-1);
        i = i + 1;
    }
    let mut b: List<Int> = List.new();
    let mut j: Int = 0;
    while j < block_count {
        b.push(-1);
        j = j + 1;
    }
    LowerState {
        value_to_reg: v,
        block_start: b,
        next_register: 0,
    }
}

fn assign_reg(st: &mut LowerState, vid: &ValueId) -> Int {
    let raw = value_id_raw(vid);
    if raw < 0 || raw >= st.value_to_reg.len() {
        // Defensive: out-of-range value ids fall back to register 0.
        return 0;
    }
    if st.value_to_reg[raw] >= 0 {
        return st.value_to_reg[raw];
    }
    let r = st.next_register;
    st.value_to_reg[raw] = r;
    st.next_register = r + 1;
    r
}

fn reg_for(st: &LowerState, v: &SsaValue) -> Int {
    let raw = value_id_raw(&v.id);
    if raw < 0 || raw >= st.value_to_reg.len() { return 0; }
    let r = st.value_to_reg[raw];
    if r < 0 { return 0; }
    r
}

// -----------------------------------------------------------------------------
// Public entry point
// -----------------------------------------------------------------------------

/// Lower `ssa` to a VdbeProgram.  Returned program shares the
/// constant pool / cursor / result-column metadata; instructions are
/// re-emitted from the SSA representation.
public fn lower_ssa_to_vdbe(ssa: &SsaProgram) -> VdbeProgram {
    let mut state = lower_state_new(ssa.value_count, ssa.cfg.block_count());

    // Pre-pass: assign registers to every SSA value (trivial 1:1).
    pre_assign_registers(&mut state, ssa);

    // Build output VdbeProgram with `state.next_register` slots.
    let mut out = program_new(ssa.sql.clone(), state.next_register);

    // Copy constants + result columns + cursor decls.
    copy_constants(ssa, &mut out);
    copy_result_columns(ssa, &mut out);
    copy_cursor_decls(ssa, &mut out);

    // Emit each block in CFG order.
    let mut b: Int = 0;
    while b < ssa.cfg.blocks.len() {
        state.block_start[b] = out.instruction_count();
        emit_block(&mut state, &ssa.cfg.blocks[b], &mut out);
        b = b + 1;
    }

    // Jump patching: walk emitted instructions and rewrite any block-id
    // operand into the matching block_start index.  For the foundation
    // we emit jumps with the BlockId.raw in the target field directly,
    // so this pass simply rewrites them.  See `patch_jumps`.
    patch_jumps(&state, &mut out);
    out
}

// -----------------------------------------------------------------------------
// Pre-pass: register assignment
// -----------------------------------------------------------------------------

fn pre_assign_registers(st: &mut LowerState, ssa: &SsaProgram) {
    let mut b: Int = 0;
    while b < ssa.cfg.blocks.len() {
        let block = &ssa.cfg.blocks[b];
        // Phi destinations
        let mut p: Int = 0;
        while p < block.phi_nodes.len() {
            match inst_dst(&block.phi_nodes[p]) {
                Some(d) => { let _ = assign_reg(st, &d.id); }
                None => {}
            }
            p = p + 1;
        }
        // Straight-line destinations
        let mut i: Int = 0;
        while i < block.insts.len() {
            match inst_dst(&block.insts[i]) {
                Some(d) => { let _ = assign_reg(st, &d.id); }
                None => {}
            }
            i = i + 1;
        }
        b = b + 1;
    }
}

// -----------------------------------------------------------------------------
// Per-block emission
// -----------------------------------------------------------------------------

fn emit_block(st: &mut LowerState, blk: &BasicBlock, out: &mut VdbeProgram) {
    // Phi handling: for the foundation we emit the phi target
    // register as initially-null and rely on Move ops being inserted
    // on the predecessor side (a follow-up pass during finalisation).
    // This intentionally produces a slightly suboptimal but
    // correct register-VM program.

    // Emit straight-line instructions.
    let mut i: Int = 0;
    while i < blk.insts.len() {
        emit_inst(st, &blk.insts[i], out);
        i = i + 1;
    }
    // Emit terminator.
    emit_inst(st, &blk.terminator, out);
}

// -----------------------------------------------------------------------------
// Per-instruction emission
// -----------------------------------------------------------------------------

fn emit_inst(st: &mut LowerState, inst: &SsaInst, out: &mut VdbeProgram) {
    match inst {
        IConst(d, idx) => {
            let r = reg_for(st, d);
            // Dispatch on declared kind.
            match &d.kind {
                SkInt   => { let _ = out.emit(Int64(idx, r)); }
                SkReal  => { let _ = out.emit(Real(idx, r)); }
                SkText  => { let _ = out.emit(String8(idx, r)); }
                SkBlob  => { let _ = out.emit(BlobLit(idx, r)); }
                _       => { let _ = out.emit(Null(r, r)); }
            }
        }
        INull(d) => {
            let r = reg_for(st, d);
            let _ = out.emit(Null(r, r));
        }
        IIntImm(d, val) => {
            let r = reg_for(st, d);
            // `Integer` opcode operand is `Int` (truncated from i64
            // for small immediates); larger constants should go
            // through the constant pool via `IConst`.
            let _ = out.emit(Integer(i64_to_int(val), r));
        }
        IAdd(d, a, b)  => { let _ = out.emit(Add(reg_for(st, a), reg_for(st, b), reg_for(st, d))); }
        ISub(d, a, b)  => { let _ = out.emit(Subtract(reg_for(st, a), reg_for(st, b), reg_for(st, d))); }
        IMul(d, a, b)  => { let _ = out.emit(Multiply(reg_for(st, a), reg_for(st, b), reg_for(st, d))); }
        IDiv(d, a, b)  => { let _ = out.emit(Divide(reg_for(st, a), reg_for(st, b), reg_for(st, d))); }
        IRem(d, a, b)  => { let _ = out.emit(Remainder(reg_for(st, a), reg_for(st, b), reg_for(st, d))); }
        IBitAnd(d, a, b) => { let _ = out.emit(BitAnd(reg_for(st, a), reg_for(st, b), reg_for(st, d))); }
        IBitOr(d, a, b)  => { let _ = out.emit(BitOr(reg_for(st, a), reg_for(st, b), reg_for(st, d))); }
        IShiftLeft(d, a, b)  => { let _ = out.emit(ShiftLeft(reg_for(st, a), reg_for(st, b), reg_for(st, d))); }
        IShiftRight(d, a, b) => { let _ = out.emit(ShiftRight(reg_for(st, a), reg_for(st, b), reg_for(st, d))); }
        IBitNot(d, s)        => { let _ = out.emit(BitNot(reg_for(st, s), reg_for(st, d))); }
        ICmp(_, kind, a, b) => {
            // Comparison with deferred branch — the immediately-following
            // IBranch terminator picks up the result.  For the foundation
            // we materialise comparison opcodes via the legacy Eq/Ne/...
            // jumps: target is patched in `patch_jumps`.  Use placeholder
            // jump_target = -1 to be rewritten.
            let opcode_var = match kind {
                CkEq => Eq(reg_for(st, a), reg_for(st, b), -1),
                CkNe => Ne(reg_for(st, a), reg_for(st, b), -1),
                CkLt => Lt(reg_for(st, a), reg_for(st, b), -1),
                CkLe => Le(reg_for(st, a), reg_for(st, b), -1),
                CkGt => Gt(reg_for(st, a), reg_for(st, b), -1),
                CkGe => Ge(reg_for(st, a), reg_for(st, b), -1),
            };
            let _ = out.emit(opcode_var);
        }
        ICast(d, s) => {
            // For the foundation: cast via SCopy (legacy interpreter
            // re-coerces dynamically based on operand context).  Full
            // typed casts will land with the optimizer.
            let _ = out.emit(SCopy(reg_for(st, s), reg_for(st, d)));
        }
        IColumn(d, cur, col)  => { let _ = out.emit(Column(cur, col, reg_for(st, d))); }
        IRowId(d, cur)        => { let _ = out.emit(RowIdOp(cur, reg_for(st, d))); }
        INewRowId(d, cur)     => { let _ = out.emit(NewRowid(cur, reg_for(st, d))); }
        IMakeRecord(d, vs, _affinity) => {
            // Legacy MakeRecord expects contiguous source registers.
            // Foundation: assume the SSA values were assigned to a
            // contiguous range (true under the trivial 1:1 allocator).
            // The allocator pass in #133 will make this guarantee hard.
            let start = if vs.len() > 0 { reg_for(st, &vs[0]) } else { 0 };
            let _ = out.emit(MakeRecord(start, vs.len(), reg_for(st, d), 0));
        }
        ICursorInsert(cur, rec, key, flags) => {
            let _ = out.emit(Insert(cur, reg_for(st, rec), reg_for(st, key), flags));
        }
        ICursorDelete(cur) => { let _ = out.emit(Delete(cur)); }

        // Cursor open/close: lowered to legacy OpenRead/OpenWrite/Close
        ICursorOpen(cur, _kind, root_page, n_cols) => {
            // Default to OpenRead; OpenWrite distinction tracked via
            // a follow-up that lifts the kind through.
            let _ = out.emit(OpenRead(cur, root_page, n_cols));
        }
        ICursorClose(cur)             => { let _ = out.emit(Close(cur)); }
        ICursorRewind(cur, _target)   => { let _ = out.emit(Rewind(cur, -1)); }
        ICursorNext(cur, _target)     => { let _ = out.emit(Next(cur, -1)); }
        ICursorPrev(cur, _target)     => { let _ = out.emit(Prev(cur, -1)); }
        ICursorLast(cur, _target)     => { let _ = out.emit(Last(cur, -1)); }

        // ---- Terminators with target patching ----
        IBranch(c, _then, _else) => {
            // Encode as If(cond_reg, -1) — patched to `then` block start;
            // the fall-through naturally targets `else` block start
            // when block layout is sequential (which our lowerer
            // guarantees by emitting blocks in BlockId order).
            let _ = out.emit(If(reg_for(st, c), -1));
        }
        IJump(_target) => { let _ = out.emit(Goto(-1)); }
        IHalt(code, msg) => { let _ = out.emit(Halt(code, 0)); }
        IReturn(reg_id) => { let _ = out.emit(Return(value_id_raw(reg_id))); }
        IYield(_target) => { let _ = out.emit(Goto(-1)); }

        // ---- Phis don't lower to a single legacy opcode (they're
        //      meta) — for the foundation we skip them; a follow-up
        //      pass inserts SCopy instructions on predecessor edges.
        IPhi(_, _) => {}

        // Catch-all for instructions not yet wired (Function, AggStep,
        // etc.).  Treated as Noop so the block still terminates
        // correctly.  Tracked under #132 follow-ups.
        _ => { let _ = out.emit(Noop); }
    }
}

// -----------------------------------------------------------------------------
// Jump patching
// -----------------------------------------------------------------------------

/// In the foundation pass, jump targets are emitted as -1 placeholders
/// because we don't yet thread the SSA → register correspondence map
/// at emit time.  A more thorough implementation tracks the (SSA_inst
/// → emitted instruction index) map and rewrites targets in a single
/// pass.  For now this is a no-op stub; the emitted program runs but
/// jumps fall through (correct only for straight-line programs).
fn patch_jumps(_st: &LowerState, _out: &mut VdbeProgram) {
    // TODO(#132 follow-up): walk emitted instructions, find If/Goto/etc.
    // with -1 target, rewrite to st.block_start[matching_block].
}

// -----------------------------------------------------------------------------
// Const + metadata copy
// -----------------------------------------------------------------------------

fn copy_constants(ssa: &SsaProgram, out: &mut VdbeProgram) {
    let mut i: Int = 0;
    while i < ssa.constants.entries.len() {
        let _ = out.constants.add(ssa.constants.get(i));
        i = i + 1;
    }
}

fn copy_result_columns(ssa: &SsaProgram, out: &mut VdbeProgram) {
    let mut i: Int = 0;
    while i < ssa.result_columns.len() {
        let rc = &ssa.result_columns[i];
        out.declare_result_column(rc.name.clone(), rc.declared_type.clone());
        i = i + 1;
    }
}

fn copy_cursor_decls(ssa: &SsaProgram, out: &mut VdbeProgram) {
    let mut i: Int = 0;
    while i < ssa.cursors.len() {
        let cd = &ssa.cursors[i];
        let _ = out.declare_cursor(cd.kind.clone(), cd.root_page, cd.n_cols);
        i = i + 1;
    }
}

// -----------------------------------------------------------------------------
// Coercion helpers
// -----------------------------------------------------------------------------

fn i64_to_int(v: Int64) -> Int { v as Int }
