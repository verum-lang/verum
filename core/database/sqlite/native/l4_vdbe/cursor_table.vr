module core.database.sqlite.native.l4_vdbe.cursor_table;

// =============================================================================
// l4_vdbe/cursor_table.vr — per-program cursor registry
// =============================================================================
// Layer: 4
// Spec: sqlite-native.md §11.3
//
// Each VDBE program declares its cursors at build time (via
// `VdbeProgram.declare_cursor`) and the interpreter opens real
// L3 BtreeCursors lazily when it encounters an `OpenRead` / `OpenWrite`
// / `OpenEphemeral` / `SorterOpen` opcode. The `CursorTable` is the
// slot array the interpreter consults on every cursor-bound opcode
// (`Column`, `Next`, `SeekGE`, …).
//
// Ownership:
//
//   * The program owns the cursor *declarations* (metadata — root
//     page, n_cols, kind).
//   * The interpreter owns the cursor *instances* — live L3
//     BtreeCursors, ephemeral in-memory B-trees, sorter state.
//
// Cursor slots are typed via a small sum so the interpreter can
// dispatch without looking up the declaration again. Ephemeral and
// sorter slots lazily construct their backing store on first use.
// =============================================================================

mount core.*;
mount collections.{List, Map};
mount base.{Result, Ok, Err, Text, Maybe};
mount core.database.sqlite.native.l3_btree.{
    Btree, BtreeCursor, BtreeKind,
    btree_new, cursor_new, cursor_root,
};
mount core.database.sqlite.native.l4_vdbe.register.Register;

// -----------------------------------------------------------------------------
// Types
// -----------------------------------------------------------------------------

public type CursorSlotKind is
      CskClosed
    | CskBtree                      // real B-tree cursor backed by the pager
    | CskEphemeral                  // in-memory temp B-tree (OpenEphemeral)
    | CskSorter;                    // sort-only ephemeral

public type CursorSlot is {
    kind: CursorSlotKind,
    cursor_id: Int,
    root_page: Int,
    n_cols: Int,
    // Backing tree — only set when kind is CskBtree / CskEphemeral.
    // Sorter stores nothing here; its state lives in SorterTable below.
    btree: Maybe<Btree>,
    // Active cursor position. None until the cursor is Rewound / Seek'd.
    position: Maybe<BtreeCursor>,
    // Whether this cursor was opened for writing. OpenWrite sets this;
    // OpenRead leaves it false. Used to reject Insert/Delete on
    // read-only cursors.
    writable: Bool,
    // In-memory row store — filled by OpenEphemeral / test harnesses
    // or by cursor-backed reads from the pager once IPC is wired. The
    // interpreter's Column / Next / Rewind opcodes consult `rows` +
    // `pos` directly; for CskBtree slots the pager will drive these
    // via a streaming adapter that materialises one row at a time.
    rows: List<List<Register>>,
    pos: Int,             // 0 ≤ pos ≤ rows.len(); pos == rows.len() → at end
    // Next rowid to issue — used by NewRowid for INSERT paths. Starts
    // at 1; bumps on every Insert.
    next_rowid: Int64,
};

// -----------------------------------------------------------------------------
// Row comparison helpers (used by sort_by_prefix)
// -----------------------------------------------------------------------------

/// Three-way compare of two registers. Returns -1 / 0 / 1.
/// Rules follow SQLite's type-affinity rough order:
///   NULL  < numeric < text < blob
/// Within numeric, ints and reals compare via Float64 widening.
fn cmp_register(a: &Register, b: &Register) -> Int {
    // Dispatch on both tags.
    match a {
        RNull => match b {
            RNull => 0,
            _     => -1,
        },
        RInt(x) => match b {
            RNull     => 1,
            RInt(y)   => if x < y { -1 } else if x > y { 1 } else { 0 },
            RRowId(y) => if x < y { -1 } else if x > y { 1 } else { 0 },
            RReal(y)  => {
                let xf: Float64 = (x as Float64);
                if xf < y { -1 } else if xf > y { 1 } else { 0 }
            }
            RText(_)  => -1,
            RBlob(_)  => -1,
        },
        RRowId(x) => match b {
            RNull     => 1,
            RInt(y)   => if x < y { -1 } else if x > y { 1 } else { 0 },
            RRowId(y) => if x < y { -1 } else if x > y { 1 } else { 0 },
            RReal(y)  => {
                let xf: Float64 = (x as Float64);
                if xf < y { -1 } else if xf > y { 1 } else { 0 }
            }
            RText(_)  => -1,
            RBlob(_)  => -1,
        },
        RReal(x) => match b {
            RNull     => 1,
            RInt(y)   => {
                let yf: Float64 = (y as Float64);
                if x < yf { -1 } else if x > yf { 1 } else { 0 }
            }
            RRowId(y) => {
                let yf: Float64 = (y as Float64);
                if x < yf { -1 } else if x > yf { 1 } else { 0 }
            }
            RReal(y)  => if x < y { -1 } else if x > y { 1 } else { 0 },
            RText(_)  => -1,
            RBlob(_)  => -1,
        },
        RText(ref xs) => match b {
            RNull     => 1,
            RInt(_) | RReal(_) | RRowId(_) => 1,
            RText(ref ys) => {
                if xs < ys { -1 } else if xs > ys { 1 } else { 0 }
            }
            RBlob(_) => -1,
        },
        RBlob(ref xs) => match b {
            RNull => 1,
            RInt(_) | RReal(_) | RRowId(_) | RText(_) => 1,
            RBlob(ref ys) => {
                // Byte-wise compare.
                let na = xs.len();
                let nb = ys.len();
                let mut i: Int = 0;
                let mn = if na < nb { na } else { nb };
                while i < mn {
                    let xi = xs[i] as Int;
                    let yi = ys[i] as Int;
                    if xi < yi { return -1; }
                    if xi > yi { return 1; }
                    i = i + 1;
                }
                if na < nb { -1 } else if na > nb { 1 } else { 0 }
            }
        },
    }
}

/// Compare two rows using the first `n_keys` cells as sort keys.
/// `dir_bits` bitmask: bit k set → key k is DESC.
fn compare_rows_prefix(
    a: &List<Register>,
    b: &List<Register>,
    n_keys: Int,
    dir_bits: Int,
) -> Int {
    let mut k: Int = 0;
    while k < n_keys {
        if k >= a.len() || k >= b.len() { return 0; }
        let c = cmp_register(&a[k], &b[k]);
        if c != 0 {
            let desc = ((dir_bits >> k) & 1) == 1;
            if desc { return -c; } else { return c; }
        }
        k = k + 1;
    }
    0
}

fn cursor_slot_empty(cursor_id: Int) -> CursorSlot {
    CursorSlot {
        kind: CskClosed,
        cursor_id: cursor_id,
        root_page: 0,
        n_cols: 0,
        btree: None,
        position: None,
        writable: false,
        rows: List.new(),
        pos: 0,
        next_rowid: 1 as Int64,
    }
}

public type CursorTableError is
      NoSuchSlot(cursor_id: Int)
    | AlreadyOpen(cursor_id: Int)
    | WrongKind(cursor_id: Int, expected: Text)
    | WriteOnReadOnly(cursor_id: Int);

// -----------------------------------------------------------------------------
// Cursor table
// -----------------------------------------------------------------------------

public type CursorTable is {
    slots: List<CursorSlot>,
    page_size: Int,
    reserved_bytes: Int,
};

/// Build a fresh table sized for `n` cursors; each slot is CskClosed.
public fn cursor_table_new(n: Int, page_size: Int, reserved_bytes: Int) -> CursorTable {
    let mut slots: List<CursorSlot> = List.new();
    let mut i: Int = 0;
    while i < n {
        slots.push(cursor_slot_empty(i));
        i = i + 1;
    }
    CursorTable {
        slots: slots,
        page_size: page_size,
        reserved_bytes: reserved_bytes,
    }
}

implement CursorTable {
    public fn size(&self) -> Int { self.slots.len() }

    // -------------------------------------------------------------------------
    // OpenRead / OpenWrite
    // -------------------------------------------------------------------------

    public fn open_read(
        &mut self,
        cursor_id: Int,
        root_page: Int,
        n_cols: Int,
        kind: BtreeKind,
    ) -> Result<(), CursorTableError> {
        self.open_btree(cursor_id, root_page, n_cols, kind, false)
    }

    public fn open_write(
        &mut self,
        cursor_id: Int,
        root_page: Int,
        n_cols: Int,
        kind: BtreeKind,
    ) -> Result<(), CursorTableError> {
        self.open_btree(cursor_id, root_page, n_cols, kind, true)
    }

    fn open_btree(
        &mut self,
        cursor_id: Int,
        root_page: Int,
        n_cols: Int,
        kind: BtreeKind,
        writable: Bool,
    ) -> Result<(), CursorTableError> {
        if cursor_id < 0 || cursor_id >= self.slots.len() {
            return Err(NoSuchSlot(cursor_id));
        }
        let existing = self.slots[cursor_id].kind;
        match existing {
            CskClosed => {}
            _         => { return Err(AlreadyOpen(cursor_id)); }
        }
        let tree = match btree_new(kind, root_page, self.page_size, self.reserved_bytes) {
            Ok(t)  => t,
            Err(_) => { return Err(WrongKind(cursor_id, "btree_new".clone())); }
        };
        self.slots[cursor_id] = CursorSlot {
            kind: CskBtree,
            cursor_id: cursor_id,
            root_page: root_page,
            n_cols: n_cols,
            btree: Some(tree),
            position: None,
            writable: writable,
            rows: List.new(),
            pos: 0,
            next_rowid: 1 as Int64,
        };
        Ok(())
    }

    // -------------------------------------------------------------------------
    // OpenEphemeral / SorterOpen
    // -------------------------------------------------------------------------

    public fn open_ephemeral(&mut self, cursor_id: Int, n_cols: Int) -> Result<(), CursorTableError> {
        if cursor_id < 0 || cursor_id >= self.slots.len() {
            return Err(NoSuchSlot(cursor_id));
        }
        // Ephemeral tables are backed by a fresh in-memory btree at
        // synthetic root_page 0 (the cursor table notes the
        // specialness via CskEphemeral; a real allocator lives in
        // L1 pager's temp-store path).
        self.slots[cursor_id] = CursorSlot {
            kind: CskEphemeral,
            cursor_id: cursor_id,
            root_page: 0,
            n_cols: n_cols,
            btree: None,
            position: None,
            writable: true,
            rows: List.new(),
            pos: 0,
            next_rowid: 1 as Int64,
        };
        Ok(())
    }

    public fn open_sorter(&mut self, cursor_id: Int) -> Result<(), CursorTableError> {
        if cursor_id < 0 || cursor_id >= self.slots.len() {
            return Err(NoSuchSlot(cursor_id));
        }
        self.slots[cursor_id] = CursorSlot {
            kind: CskSorter,
            cursor_id: cursor_id,
            root_page: 0,
            n_cols: 0,
            btree: None,
            position: None,
            writable: true,
            rows: List.new(),
            pos: 0,
            next_rowid: 1 as Int64,
        };
        Ok(())
    }

    // -------------------------------------------------------------------------
    // Close / inspect
    // -------------------------------------------------------------------------

    public fn close(&mut self, cursor_id: Int) -> Result<(), CursorTableError> {
        if cursor_id < 0 || cursor_id >= self.slots.len() {
            return Err(NoSuchSlot(cursor_id));
        }
        self.slots[cursor_id] = cursor_slot_empty(cursor_id);
        Ok(())
    }

    public fn kind(&self, cursor_id: Int) -> CursorSlotKind {
        if cursor_id < 0 || cursor_id >= self.slots.len() {
            return CskClosed;
        }
        self.slots[cursor_id].kind
    }

    public fn is_writable(&self, cursor_id: Int) -> Bool {
        if cursor_id < 0 || cursor_id >= self.slots.len() {
            return false;
        }
        self.slots[cursor_id].writable
    }

    // -------------------------------------------------------------------------
    // Positioning
    // -------------------------------------------------------------------------

    public fn rewind(&mut self, cursor_id: Int) -> Result<(), CursorTableError> {
        if cursor_id < 0 || cursor_id >= self.slots.len() {
            return Err(NoSuchSlot(cursor_id));
        }
        self.slots[cursor_id].pos = 0;
        // For CskBtree we *also* seat the B-tree cursor at the root
        // so page-backed streams can begin iteration. The row-store
        // path (CskEphemeral + v1 test harness) only needs pos=0.
        match self.slots[cursor_id].kind {
            CskBtree => {
                let btree_opt = self.slots[cursor_id].btree;
                match btree_opt {
                    Some(ref tree) => {
                        let mut cur = cursor_new(tree);
                        let _ = cursor_root(&mut cur);
                        self.slots[cursor_id].position = Some(cur);
                    }
                    None => {}
                }
            }
            _ => {}
        }
        Ok(())
    }

    /// Reject a write attempt on a read-only cursor. The interpreter
    /// calls this before any Insert / Delete opcode.
    public fn ensure_writable(&self, cursor_id: Int) -> Result<(), CursorTableError> {
        if cursor_id < 0 || cursor_id >= self.slots.len() {
            return Err(NoSuchSlot(cursor_id));
        }
        if !self.slots[cursor_id].writable {
            return Err(WriteOnReadOnly(cursor_id));
        }
        Ok(())
    }

    // -------------------------------------------------------------------------
    // Row-store operations (in-memory cursor pipeline)
    // -------------------------------------------------------------------------

    /// Append a row to the cursor's row store. Used by INSERT
    /// opcodes AND by test harnesses that pre-populate ephemeral
    /// tables. Auto-issues the next rowid and returns it.
    public fn append_row(&mut self, cursor_id: Int, row: List<Register>) -> Result<Int64, CursorTableError> {
        if cursor_id < 0 || cursor_id >= self.slots.len() {
            return Err(NoSuchSlot(cursor_id));
        }
        self.slots[cursor_id].rows.push(row);
        let rid = self.slots[cursor_id].next_rowid;
        self.slots[cursor_id].next_rowid = rid + (1 as Int64);
        Ok(rid)
    }

    /// Bulk-install a row list. Used by the test harness and by the
    /// future pager streaming adapter.
    public fn install_rows(&mut self, cursor_id: Int, rows: List<List<Register>>) -> Result<(), CursorTableError> {
        if cursor_id < 0 || cursor_id >= self.slots.len() {
            return Err(NoSuchSlot(cursor_id));
        }
        self.slots[cursor_id].rows = rows;
        self.slots[cursor_id].pos = 0;
        Ok(())
    }

    /// Has the cursor still got rows to emit? Used by the interpreter
    /// to decide whether Rewind/Next should fall through or jump.
    public fn has_more(&self, cursor_id: Int) -> Bool {
        if cursor_id < 0 || cursor_id >= self.slots.len() { return false; }
        let s = &self.slots[cursor_id];
        s.pos < s.rows.len()
    }

    /// Advance the cursor. Returns true if a row is now current;
    /// false if the cursor has exhausted the store.
    public fn advance(&mut self, cursor_id: Int) -> Bool {
        if cursor_id < 0 || cursor_id >= self.slots.len() { return false; }
        let s = &mut self.slots[cursor_id];
        s.pos = s.pos + 1;
        s.pos < s.rows.len()
    }

    /// Read column `col` of the current row. Returns RNull if the
    /// cursor is past the end or col is out of range.
    public fn peek_cell(&self, cursor_id: Int, col: Int) -> Register {
        if cursor_id < 0 || cursor_id >= self.slots.len() { return RNull; }
        let s = &self.slots[cursor_id];
        if s.pos >= s.rows.len() { return RNull; }
        let row = &s.rows[s.pos];
        if col < 0 || col >= row.len() { return RNull; }
        row[col]
    }

    /// Clone the current row into a fresh List<Register>. Used by
    /// the ResultRow emission path that wants to hand the caller an
    /// owned row rather than a register-file slice.
    public fn peek_row(&self, cursor_id: Int) -> List<Register> {
        let mut out: List<Register> = List.new();
        if cursor_id < 0 || cursor_id >= self.slots.len() { return out; }
        let s = &self.slots[cursor_id];
        if s.pos >= s.rows.len() { return out; }
        let row = &s.rows[s.pos];
        let mut i: Int = 0;
        while i < row.len() {
            out.push(row[i]);
            i = i + 1;
        }
        out
    }

    /// The rowid that would be assigned to the next appended row.
    /// NewRowid opcode reads this.
    public fn peek_next_rowid(&self, cursor_id: Int) -> Int64 {
        if cursor_id < 0 || cursor_id >= self.slots.len() { return 0 as Int64; }
        self.slots[cursor_id].next_rowid
    }

    /// The rowid of the current row — pos is 1-based for rowid
    /// assignment convention (pos == rowid - 1 after append_row).
    public fn current_rowid(&self, cursor_id: Int) -> Int64 {
        if cursor_id < 0 || cursor_id >= self.slots.len() { return 0 as Int64; }
        let s = &self.slots[cursor_id];
        if s.pos >= s.rows.len() { return 0 as Int64; }
        (s.pos as Int64) + (1 as Int64)
    }

    /// Remove the current row. Used by Delete opcode. Leaves pos
    /// unchanged so Next lands on the successor.
    public fn delete_current(&mut self, cursor_id: Int) -> Bool {
        if cursor_id < 0 || cursor_id >= self.slots.len() { return false; }
        let s = &mut self.slots[cursor_id];
        if s.pos >= s.rows.len() { return false; }
        let _ = s.rows.remove(s.pos);
        true
    }

    /// Overwrite the row at the current `pos` with `row`. Used by
    /// UPDATE codegen: evaluate per-column assignments into
    /// contiguous registers, then call this to commit.
    public fn replace_current_row(&mut self, cursor_id: Int, row: List<Register>) -> Bool {
        if cursor_id < 0 || cursor_id >= self.slots.len() { return false; }
        let s = &mut self.slots[cursor_id];
        if s.pos >= s.rows.len() { return false; }
        s.rows[s.pos] = row;
        true
    }

    /// Total rows currently in the store.
    public fn row_count(&self, cursor_id: Int) -> Int {
        if cursor_id < 0 || cursor_id >= self.slots.len() { return 0; }
        self.slots[cursor_id].rows.len()
    }

    public fn current_position(&self, cursor_id: Int) -> Int {
        if cursor_id < 0 || cursor_id >= self.slots.len() { return -1; }
        self.slots[cursor_id].pos
    }

    /// Number of columns declared at open time. Interpreter reads
    /// this to know how many registers an Insert's data_reg range
    /// covers.
    public fn n_cols_of(&self, cursor_id: Int) -> Int {
        if cursor_id < 0 || cursor_id >= self.slots.len() { return 0; }
        self.slots[cursor_id].n_cols
    }

    /// Read a specific cell at an explicit position. Does NOT touch
    /// the cursor's current `pos`; used by the L6 writeback bridge
    /// to extract all rows back to the connection's table_store.
    public fn peek_cell_at(&self, cursor_id: Int, pos: Int, col: Int) -> Register {
        if cursor_id < 0 || cursor_id >= self.slots.len() { return RNull; }
        let s = &self.slots[cursor_id];
        if pos < 0 || pos >= s.rows.len() { return RNull; }
        let row = &s.rows[pos];
        if col < 0 || col >= row.len() { return RNull; }
        row[col]
    }

    /// Clone the entire row at `pos`.
    public fn peek_row_at(&self, cursor_id: Int, pos: Int) -> List<Register> {
        let mut out: List<Register> = List.new();
        if cursor_id < 0 || cursor_id >= self.slots.len() { return out; }
        let s = &self.slots[cursor_id];
        if pos < 0 || pos >= s.rows.len() { return out; }
        let row = &s.rows[pos];
        let mut i: Int = 0;
        while i < row.len() {
            out.push(row[i]);
            i = i + 1;
        }
        out
    }

    /// Remove adjacent rows that agree on the first `n_cells` cells.
    /// Intended to follow `sort_by_prefix` for SELECT DISTINCT paths.
    public fn dedup_adjacent(&mut self, cursor_id: Int, n_cells: Int) -> Bool {
        if cursor_id < 0 || cursor_id >= self.slots.len() { return false; }
        if n_cells <= 0 { return true; }
        let s = &mut self.slots[cursor_id];
        let mut kept: List<List<Register>> = List.new();
        let mut i: Int = 0;
        while i < s.rows.len() {
            let push_it = if kept.len() == 0 {
                true
            } else {
                let prev = &kept[kept.len() - 1];
                compare_rows_prefix(prev, &s.rows[i], n_cells, 0) != 0
            };
            if push_it { kept.push(s.rows[i].clone()); }
            i = i + 1;
        }
        s.rows = kept;
        s.pos = 0;
        true
    }

    /// In-place stable sort of the row-store by the first `n_keys`
    /// cells of each row. `dir_bits` is a bitmask: bit k set → key k
    /// is DESC. Used by the SortRowStore opcode backing ORDER BY.
    public fn sort_by_prefix(&mut self, cursor_id: Int, n_keys: Int, dir_bits: Int) -> Bool {
        if cursor_id < 0 || cursor_id >= self.slots.len() { return false; }
        if n_keys <= 0 { return true; }
        let s = &mut self.slots[cursor_id];
        // Stable insertion sort — v1 row counts are bounded by the
        // test-harness row-store; real pager streams will back a
        // merge-based sorter later.
        let n = s.rows.len();
        let mut i: Int = 1;
        while i < n {
            let mut j: Int = i;
            while j > 0 {
                let cmp = compare_rows_prefix(&s.rows[j - 1], &s.rows[j], n_keys, dir_bits);
                if cmp <= 0 { break; }
                let tmp = s.rows[j - 1].clone();
                s.rows[j - 1] = s.rows[j].clone();
                s.rows[j] = tmp;
                j = j - 1;
            }
            i = i + 1;
        }
        true
    }

    /// Snapshot every row into a fresh List<List<Register>>. Used by
    /// the bridge to write back to the connection's table_store
    /// after a prepared statement finishes.
    public fn snapshot_rows(&self, cursor_id: Int) -> List<List<Register>> {
        let mut out: List<List<Register>> = List.new();
        if cursor_id < 0 || cursor_id >= self.slots.len() { return out; }
        let row_total = self.slots[cursor_id].rows.len();
        let mut i: Int = 0;
        while i < row_total {
            out.push(self.peek_row_at(cursor_id, i));
            i = i + 1;
        }
        out
    }
}
