// =============================================================================
// busy_timeout/timeout.vr — sqlite3_busy_timeout request
// =============================================================================
// Spec: SQLite C API
//
// sqlite3_busy_timeout(db, ms) installs a built-in handler that
// retries with exponential-ish back-off up to the requested total
// wall-clock budget.  Passing ms == 0 (or negative) removes the
// handler entirely.
// =============================================================================

module core.database.sqlite.native.busy_timeout.timeout;

mount core.*;
mount base.{Bool};
mount core.database.sqlite.native.busy_timeout.handler.{
    BusyHandlerKind, BhNone, BhTimeout,
};

public type TimeoutRequest is {
    milliseconds: Int,
}

public fn new_request(milliseconds: Int) -> TimeoutRequest {
    TimeoutRequest { milliseconds: milliseconds }
}

/// Compose the resulting handler kind from the request.
public fn derive_handler(r: &TimeoutRequest) -> BusyHandlerKind {
    if r.milliseconds <= 0 { BhNone } else { BhTimeout(r.milliseconds) }
}

/// Matches SQLite's internal back-off table: the first few retries
/// are very short (1, 2, 5, 10, 15, 20, 25 ms); above that the
/// handler settles into 50 ms increments up to the timeout.
public fn sleep_ns_for_attempt(r: &TimeoutRequest, attempt: Int) -> Int64 {
    if r.milliseconds <= 0 { return 0 as Int64; }
    let step_ms = if attempt <= 0 { 1 }
                  else if attempt == 1 { 2 }
                  else if attempt == 2 { 5 }
                  else if attempt == 3 { 10 }
                  else if attempt == 4 { 15 }
                  else if attempt == 5 { 20 }
                  else if attempt == 6 { 25 }
                  else { 50 };
    (step_ms as Int64) * 1_000_000_i64
}
