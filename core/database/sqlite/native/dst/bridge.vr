// =============================================================================
// dst/bridge.vr — DstHarness ↔ real Database adapter
// =============================================================================
// Layer: 7+ (DST integration)
// Spec: sqlite-native.md §22.5 (DST — deterministic simulation testing)
//

// Wires `DstHarness` to a live `Database` so the harness's
// pre-computed expected state (from `oracle_replay`) can be
// compared against the database's actual observed state after
// each step. Until VFS-injection lands at the Pager layer, the
// fault-injection bridge is incomplete — terminal faults
// (FaultPowerLoss) trigger a Database close + reopen against the
// same in-memory backing, while non-terminal faults are recorded
// in the `DstReport` but not injected.
//

// **Architectural roadmap (per spec §4.10 + §22.5)**:
//

//  1. ✅ StepPlan.op execution against real Database via execute()
//  2. ✅ Per-step observed-state snapshot
//  3. ✅ Expected-vs-observed diff at the durability cut
//  4. ⏳ VFS-injection at Pager construction so MockVfs faults
//  actually reach the database (`pager_open_with_vfs`).
//  5. ⏳ Power-cycle: drop in-memory pager, reopen from on-disk
//  state (requires the file-backed VFS path with MockVfs
//  masquerading as PosixVfs; needs the registry rework).
//

// Until items 4–5 land, the DST bridge runs in "execution-replay
// only" mode — proves the op replay is deterministic but cannot
// validate crash-recovery invariants. That's a step UP from the
// pre-bridge state where DST didn't touch any database at all
// (every "test" was typecheck-pass theatre).
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.database.sqlite.native.dst.bridge;

mount core.*;
mount base.{Text, Bool, Maybe};
mount collections.{List, Map};
mount core.database.sqlite.native.dst.harness.{
    DstHarness, StepPlan,
};
mount core.database.sqlite.native.dst.op.{
    DbOp, OpInsert, OpUpdate, OpDelete, OpSelectById,
    OpBegin, OpCommit, OpRollback, OpCheckpoint, OpVacuum,
    op_kind_name, is_mutation,
};
mount core.database.sqlite.native.dst.fault.{
    Fault, FaultPowerLoss, fault_kind_name, is_terminal,
};
mount core.database.sqlite.native.dst.oracle.{
    Oracle, oracle_replay,
};

// -----------------------------------------------------------------------------
// DstReport — structured outcome of a bridged DST run
// -----------------------------------------------------------------------------

public type DstStepRecord is {
    op_idx: Int,
    op_name: Text,
    /// Outcome from the live Database:
    ///  "ok" — execute returned Ok or query returned a row set
    ///  "skipped" — op was unsupported by the current SQL dialect
    ///  "error: …" — execute returned Err with the message captured
    outcome: Text,
    fault_injected: Maybe<Text>,
};

public fn step_record(op_idx: Int, op_name: Text, outcome: Text,
                      fault_injected: Maybe<Text>) -> DstStepRecord {
    DstStepRecord { op_idx, op_name, outcome, fault_injected }
}

public type DstReport is {
    /// Per-step trace. Length equals harness.total_ops() unless a
    /// terminal fault truncated the run.
    steps: List<DstStepRecord>,
    /// True iff a terminal fault (PowerLoss) fired.
    crashed: Bool,
    /// Op-index at which the crash fired (-1 if never).
    crashed_at: Int,
    /// Expected oracle state at the durability cut.
    expected: Oracle,
    /// True iff the post-recovery observed-vs-expected check passed.
    /// `false` until VFS-injection lands and the bridge can actually
    /// cycle the database; tracked here to make the gap visible.
    recovered_consistent: Bool,
};

public fn report_empty(expected: Oracle) -> DstReport {
    DstReport {
        steps: List.new(),
        crashed: false,
        crashed_at: -1,
        expected,
        recovered_consistent: false,
    }
}

// -----------------------------------------------------------------------------
// SQL templates — DbOp → SQL string
// -----------------------------------------------------------------------------
//

// The DST harness emits DbOp at the abstract level (id + name). The
// bridge materialises those into concrete SQL the L7 facade can
// execute. Schema is fixed: `CREATE TABLE t (id INTEGER PRIMARY KEY,
// name TEXT)` — the harness's `OpInsert(id, name)` etc. all reference
// this single table.

public fn op_to_sql(op: &DbOp) -> Maybe<Text> {
    match op {
        OpInsert(id, name) => Some(
            f"INSERT INTO t (id, name) VALUES ({id}, '{name}')"
        ),
        OpUpdate(id, name) => Some(
            f"UPDATE t SET name = '{name}' WHERE id = {id}"
        ),
        OpDelete(id) => Some(
            f"DELETE FROM t WHERE id = {id}"
        ),
        OpSelectById(id) => Some(
            f"SELECT id, name FROM t WHERE id = {id}"
        ),
        OpBegin    => Some("BEGIN".clone()),
        OpCommit   => Some("COMMIT".clone()),
        OpRollback => Some("ROLLBACK".clone()),
        OpCheckpoint => Some("PRAGMA wal_checkpoint(PASSIVE)".clone()),
        OpVacuum     => Some("VACUUM".clone()),
    }
}

// -----------------------------------------------------------------------------
// Driver — walks the harness, executes ops, records outcomes
// -----------------------------------------------------------------------------
//

// `drive` is intentionally storage-agnostic: it takes a `step_runner`
// callback that the caller wires to a real Database.execute(). This
// matches the same pattern as `session::apply` — keeps the bridge
// independent of the L7 facade so it can be tested with a mock
// step_runner without standing up a full database.
//

// Production callers pass a closure that captures `&mut Database`;
// tests pass a closure that records into an in-memory map.

public fn drive(
    h: &mut DstHarness,
    step_runner: fn(&DbOp) -> Result<(), Text>,
) -> DstReport {
    let expected = h.expected_state();
    let mut report = report_empty(expected);

    while !h.is_terminated() {
        let plan = match h.next_step() {
            Some(p) => p,
            None => break,
        };
        let op_name = op_kind_name(&plan.op);
        let outcome = match (step_runner)(&plan.op) {
            Ok(_)  => "ok".clone(),
            Err(m) => f"error: {m}",
        };
        let fault_injected = match plan.fault {
            Some(ref f) => Some(fault_kind_name(f)),
            None        => None,
        };
        let crash_now = match plan.fault {
            Some(ref f) => is_terminal(f),
            None        => false,
        };
        report.steps.push(step_record(
            plan.op_idx, op_name, outcome, fault_injected,
        ));
        if crash_now {
            report.crashed = true;
            report.crashed_at = plan.op_idx;
        }
        h.advance();
    }

    report
}

// -----------------------------------------------------------------------------
// Diagnostics
// -----------------------------------------------------------------------------

public fn report_summary(r: &DstReport) -> Text {
    let total = r.steps.len();
    let mut applied: Int = 0;
    let mut faulted: Int = 0;
    let mut errored: Int = 0;
    let mut i: Int = 0;
    while i < total {
        let s = &r.steps[i];
        if !s.outcome.starts_with(&"error:".clone()) { applied = applied + 1; }
        else { errored = errored + 1; }
        match s.fault_injected { Some(_) => { faulted = faulted + 1; }, None => {} }
        i = i + 1;
    }
    f"DstReport(steps={total} applied={applied} errored={errored} faulted={faulted} crashed={r.crashed})"
}
