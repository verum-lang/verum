// =============================================================================
// sqlite_sequence bookkeeping — AUTOINCREMENT per-table max seen + allocation.
// Spec §17.9.4 — AUTOINCREMENT.
//

// sqlite_sequence(name TEXT, seq INTEGER)
//  For each AUTOINCREMENT table, seq = max(INTEGER PRIMARY KEY seen).
//  Next allocation = seq + 1 (with overflow → SQLITE_FULL).
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.database.sqlite.native.autoincrement_register_api;

public module register_;
