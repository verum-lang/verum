// octet_length(X) — bytes-on-disk projection.

module core.database.sqlite.native.octet_length_fn.fn_;

mount base.{Bool, Int64, Text};

public type ValueKind is
    | VkNull
    | VkInt(Int64)        // serial type 1..6 — actual byte count varies
    | VkFloat             // always 8 bytes (serial type 7)
    | VkText(Int)         // text byte count (UTF-8 / UTF-16 depending on encoding)
    | VkBlob(Int)         // blob byte count
    ;

public type Result is
    | RNull
    | RBytes(Int)
    ;

public fn result_is_null(r: &Result) -> Bool {
    match r { RNull => true, _ => false }
}

public fn result_bytes(r: &Result) -> Int {
    match r { RBytes(n) => n.clone(), RNull => 0 }
}

// Serial-type widths (§3.0 record format).  Mirrors serial_type_api but kept
// inline for self-containment.
public fn integer_serial_width(n: Int64) -> Int {
    let zero = 0 as Int64;
    let one  = 1 as Int64;
    let v = if n < zero { zero - n } else { n };
    if v == zero { return 0; }                // serial type 8 / 9 (0/1)
    if v <= (127 as Int64) { return 1; }      // 1-byte integer
    if v <= (32767 as Int64) { return 2; }
    if v <= (8388607 as Int64) { return 3; }
    if v <= (2147483647 as Int64) { return 4; }
    if v <= (140737488355327 as Int64) { return 6; }
    8
}

public fn evaluate(v: &ValueKind) -> Result {
    match v {
        VkNull       => RNull,
        VkInt(n)     => RBytes(integer_serial_width(n.clone())),
        VkFloat      => RBytes(8),
        VkText(n)    => RBytes(n.clone()),
        VkBlob(n)    => RBytes(n.clone()),
    }
}

// length() vs octet_length() differ for TEXT — length() returns the
// character count, octet_length() returns the byte count.  This helper
// projects the difference for documentation/test parity.
public fn length_minus_octet_length_text(byte_count: Int, char_count: Int) -> Int {
    byte_count - char_count
}

public fn arity_is_well_known(n: Int) -> Bool { n == 1 }
