// =============================================================================
// core/database/sqlite/native/verify/mod.vr
// =============================================================================
// Layer: cross-cutting (V axis from §21)
// Spec: sqlite-native.md §21
//
// Loom-side `@verify`-annotated invariants. Each module here states
// the invariant, the operations after which it must re-hold, and a
// reference proof sketch. The actual Z3 obligations are emitted by
// `verum_smt`; this directory is the authoritative source of what
// loom guarantees, in Verum syntax (so the obligations stay in sync
// with the implementation).
//
// Strata:
//   * file_format_invariants — DatabaseHeader, page-layout
//     refinements (mostly type-encoded, listed for documentation).
//   * btree_invariants       — sorted, balanced, parent_pointers,
//     no_orphans, no_overflow_loops.
//   * wal_invariants         — wal_consistent, checkpoint_idempotent,
//     recovery_preserves_commits.
//   * vdbe_register_consistency — register-type SSA-form consistency.
//   * sql_semantics          — join cardinality bounds, filter
//     monotonicity, result-shape match.
// =============================================================================

module core.database.sqlite.native.verify;

public module file_format_invariants;
public module btree_invariants;
public module wal_invariants;
public module vdbe_register_consistency;
public module sql_semantics;
