// =============================================================================
// client_data/registry.vr — per-connection slot list
// =============================================================================
// Spec: SQLite C API
// =============================================================================

module core.database.sqlite.native.client_data.registry;

mount core.*;
mount base.{Bool, Maybe, Text};
mount collections.List;
mount core.database.sqlite.native.client_data.slot.{
    Slot, new_slot, is_unset,
};

public type ClientDataRegistry is {
    slots: List<Slot>,
    /// Total destructor calls (fires when a slot is replaced / cleared).
    destructors_invoked: Int64,
}

public fn new_registry() -> ClientDataRegistry {
    ClientDataRegistry {
        slots: List.new(),
        destructors_invoked: 0 as Int64,
    }
}

implement ClientDataRegistry {
    fn find(&self, name: &Text) -> Int {
        let mut i: Int = 0;
        while i < self.slots.len() {
            if self.slots.get(i).name == *name { return i; }
            i = i + 1;
        }
        -1
    }

    /// Install (or overwrite) the slot.  If a previous entry existed
    /// and it had a destructor, bump the destructor counter.
    pub fn sqlite3_set_clientdata(&mut self, name: Text, handle: Int64, has_destructor: Bool) {
        let idx = self.find(&name);
        if idx >= 0 {
            if self.slots.get(idx).has_destructor {
                self.destructors_invoked = self.destructors_invoked + (1 as Int64);
            }
            self.slots.get_mut(idx).handle = handle;
            self.slots.get_mut(idx).has_destructor = has_destructor;
            return;
        }
        self.slots.push(new_slot(name, handle, has_destructor));
    }

    pub fn sqlite3_get_clientdata(&self, name: &Text) -> Int64 {
        let idx = self.find(name);
        if idx < 0 { return 0 as Int64; }
        self.slots.get(idx).handle
    }

    /// Clear a slot (equivalent to set with handle==NULL + no destructor).
    pub fn clear(&mut self, name: &Text) -> Bool {
        let idx = self.find(name);
        if idx < 0 { return false; }
        if self.slots.get(idx).has_destructor {
            self.destructors_invoked = self.destructors_invoked + (1 as Int64);
        }
        let _ = self.slots.remove(idx);
        true
    }

    /// Connection-close path — fire every remaining destructor and
    /// drop all slots.
    pub fn close(&mut self) {
        let mut fired: Int64 = 0 as Int64;
        let mut i: Int = 0;
        while i < self.slots.len() {
            if self.slots.get(i).has_destructor { fired = fired + (1 as Int64); }
            i = i + 1;
        }
        self.destructors_invoked = self.destructors_invoked + fired;
        self.slots = List.new();
    }

    pub fn len(&self) -> Int { self.slots.len() }
}
