// =============================================================================
// core/database/sqlite/native/optimizer/mod.vr
// =============================================================================
// Layer: 4-5 (between codegen + interpreter)
// Spec: sqlite-native.md ¬ß11.5
//
// Pre-emission optimisation passes operating on a `List<Opcode>` view.
// Each pass implements the `OptimizationPass` protocol; passes are
// composed into a deterministic `PassPipeline` that's idempotent on
// already-canonicalised input.
//
// Submodules:
//
//   * `opstream`       ‚Äî opaque opcode-stream view + edit primitives
//   * `pass`           ‚Äî `OptimizationPass` protocol + Pipeline runner
//   * `noop_elim`      ‚Äî drop `Noop` instructions, retarget jumps
//   * `jump_threading` ‚Äî `Goto a; a: Goto b` ‚Üí `Goto b`
//   * `dead_code`      ‚Äî drop unreachable instructions after `Halt`/
//                        `Goto` whose target lies outside the program
//   * `const_fold`     ‚Äî fold `Integer + Integer` etc. when both
//                        operands are statically known
//   * `move_chain`     ‚Äî `Move r1‚Üír2; Move r2‚Üír3` ‚Üí `Move r1‚Üír3`
// =============================================================================

module core.database.sqlite.native.optimizer;

public module opstream;
public module pass;
public module noop_elim;
public module jump_threading;
public module dead_code;
public module const_fold;
public module move_chain;
