// sqlite3_vtab_in_first / _in_next — IN-list streaming iteration.

module core.database.sqlite.native.vtab_in_first_next_api.iter;

mount base.{Bool, Int64, Text};
mount core.collections.list.{List};

// Position state.
public type Position is
    | PFresh             // before any call
    | PAtRow(Int)         // 0-based index of the current value
    | PExhausted          // past the last value
    ;

public fn position_name(p: &Position) -> Text {
    match p {
        PFresh       => "fresh".clone(),
        PAtRow(_)    => "at_row".clone(),
        PExhausted   => "exhausted".clone(),
    }
}

// Outcome of one xVtab_in_{first,next} call.
public type Outcome is
    | OkRow             // result-value populated
    | OkDone            // SQLITE_DONE — no more values
    | OkErrNotInList    // SQLITE_ERROR — not an IN constraint
    ;

public fn outcome_name(o: &Outcome) -> Text {
    match o {
        OkRow         => "row".clone(),
        OkDone        => "done".clone(),
        OkErrNotInList => "err_not_in_list".clone(),
    }
}

public fn returned_row(o: &Outcome) -> Bool {
    match o { OkRow => true, _ => false }
}

// Step result combines new position + outcome.  Use a record (tuple returns
// remain unsupported in Verum).
public type StepResult is { pos: Position, outcome: Outcome };

public fn first_call(values: &List<Int64>, is_in_constraint: Bool) -> StepResult {
    if !is_in_constraint {
        return StepResult { pos: PFresh, outcome: OkErrNotInList };
    }
    if (values.len() as Int) == 0 {
        return StepResult { pos: PExhausted, outcome: OkDone };
    }
    StepResult { pos: PAtRow(0), outcome: OkRow }
}

public fn next_call(p: &Position, values: &List<Int64>) -> StepResult {
    let n = values.len() as Int;
    match p {
        PFresh        => StepResult { pos: PFresh,      outcome: OkErrNotInList },
        PExhausted    => StepResult { pos: PExhausted,  outcome: OkDone },
        PAtRow(i)     => {
            let next_idx = i.clone() + 1;
            if next_idx >= n {
                StepResult { pos: PExhausted, outcome: OkDone }
            } else {
                StepResult { pos: PAtRow(next_idx), outcome: OkRow }
            }
        },
    }
}

public fn current_value(p: &Position, values: &List<Int64>) -> Int64 {
    match p {
        PAtRow(i)   => values.get(i.clone()),
        _ => 0 as Int64,
    }
}

// Memory / scan tradeoff: streaming wins for large IN-lists.
public fn is_streaming_beneficial(values_count: Int) -> Bool {
    values_count >= 16
}
