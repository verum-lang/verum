// =============================================================================
// core/database/sqlite/native/session_attach_api/mod.vr
// =============================================================================
// sqlite3session_attach — selects which tables are recorded into a session.
// Spec §22 — session extension.
//

// attach(session, NULL) → every rowid table is attached
// attach(session, "tbl") → only "tbl" is attached
// attach_filter(session, fn) → callback decides per-table
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.database.sqlite.native.session_attach_api;

public module mode;
public module session;
