// =============================================================================
// session/patch.vr — PatchSet (compact form of ChangeSet)
// =============================================================================
// Spec: sqlite-native.md §22 (CDC) — sqlite3session_patchset
//
// `SessionPatch` is the compact analogue of `Change`: only the modified
// columns are present, with NULL standing for "unchanged" in the
// `new_row`. Used when the consumer doesn't need OLD row values
// and bandwidth matters (replication over WAN).
//
// Conversion `ChangeSet → PatchSet` is lossy in two ways:
//   * OLD row is dropped except for primary-key columns
//   * NEW row drops cells that match OLD
//
// Reverse `PatchSet → ChangeSet` is impossible without the target
// database state (which the applier already has).
// =============================================================================

module core.database.sqlite.native.session.patch;

mount core.*;
mount base.{Bool, Maybe};
mount collections.List;
mount core.database.sqlite.native.l4_vdbe.register.{
    Register, RNull, RInt, RReal, RText, RBlob, RRowId,
};
mount core.database.sqlite.native.session.change.{
    Change, SessionChangeOp, ChangeSet, OpInsert, OpUpdate, OpDelete,
    change_op_name,
};

// -----------------------------------------------------------------------------
// PatchCell — Some(value) means "set", None means "unchanged"
// -----------------------------------------------------------------------------

public type PatchCell is { value: Maybe<Register> };

// -----------------------------------------------------------------------------
// SessionPatch
// -----------------------------------------------------------------------------

public type SessionPatch is {
    op: SessionChangeOp,
    table: base.Text,
    pk_columns: List<Bool>,
    /// PK column values (used to locate the target row).
    pk_values: List<Register>,
    /// New value per column; None for cells unchanged from OLD.
    new_cells: List<PatchCell>,
}

// -----------------------------------------------------------------------------
// PatchSet
// -----------------------------------------------------------------------------

public type PatchSet is { patches: List<SessionPatch> }

public fn patchset_empty() -> PatchSet { PatchSet { patches: List.new() } }

implement PatchSet {
    public fn len(&self) -> Int { self.patches.len() }

    public fn record(&mut self, p: SessionPatch) {
        self.patches.push(p);
    }
}

// -----------------------------------------------------------------------------
// Conversion: ChangeSet → PatchSet
// -----------------------------------------------------------------------------

public fn from_changeset(cs: &ChangeSet) -> PatchSet {
    let mut out = patchset_empty();
    let changes = cs.iter();
    let mut i: Int = 0;
    while i < changes.len() {
        out.record(patch_from_change(&changes[i]));
        i = i + 1;
    }
    out
}

fn patch_from_change(c: &Change) -> SessionPatch {
    let mut pk_values: List<Register> = List.new();
    let mut k: Int = 0;
    while k < c.pk_columns.len() {
        if c.pk_columns[k] {
            // PK is read from old_row for UPDATE/DELETE, new_row for INSERT.
            let src = match c.op {
                OpInsert => &c.new_row,
                _        => &c.old_row,
            };
            if k < src.len() { pk_values.push(clone_register(&src[k])); }
        }
        k = k + 1;
    }
    let mut new_cells: List<PatchCell> = List.new();
    match c.op {
        OpInsert => {
            // Every cell present.
            let mut i: Int = 0;
            while i < c.new_row.len() {
                new_cells.push(PatchCell { value: Some(clone_register(&c.new_row[i])) });
                i = i + 1;
            }
        }
        OpUpdate => {
            // None for cells that didn't change.
            let mut i: Int = 0;
            while i < c.new_row.len() {
                let unchanged: Bool = if i < c.old_row.len() {
                    registers_equal(&c.old_row[i], &c.new_row[i])
                } else { false };
                if unchanged {
                    new_cells.push(PatchCell { value: None });
                } else {
                    new_cells.push(PatchCell { value: Some(clone_register(&c.new_row[i])) });
                }
                i = i + 1;
            }
        }
        OpDelete => {
            // No new values for delete.
        }
    }
    SessionPatch {
        op: clone_op(&c.op),
        table: c.table.clone(),
        pk_columns: clone_bools(&c.pk_columns),
        pk_values: pk_values,
        new_cells: new_cells,
    }
}

// -----------------------------------------------------------------------------
// Helpers
// -----------------------------------------------------------------------------

fn clone_register(r: &Register) -> Register {
    match r {
        RNull     => RNull,
        RInt(x)   => RInt(x),
        RReal(x)  => RReal(x),
        RText(s)  => RText(s.clone()),
        RBlob(b)  => {
            let mut out: List<Byte> = List.new();
            let mut i: Int = 0;
            while i < b.len() { out.push(b[i]); i = i + 1; }
            RBlob(out)
        }
        RRowId(x) => RRowId(x),
    }
}

fn clone_op(o: &SessionChangeOp) -> SessionChangeOp {
    match o { OpInsert => OpInsert, OpUpdate => OpUpdate, OpDelete => OpDelete }
}

fn clone_bools(b: &List<Bool>) -> List<Bool> {
    let mut out: List<Bool> = List.new();
    let mut i: Int = 0;
    while i < b.len() { out.push(b[i]); i = i + 1; }
    out
}

fn registers_equal(a: &Register, b: &Register) -> Bool {
    match a {
        RNull => match b { RNull => true, _ => false },
        RInt(x) => match b {
            RInt(y) => x == y,
            RRowId(y) => x == y,
            _ => false,
        },
        RReal(x) => match b {
            RReal(y) => x == y,
            _ => false,
        },
        RText(xs) => match b { RText(ys) => xs == ys, _ => false },
        RBlob(xb) => match b {
            RBlob(yb) => {
                if xb.len() != yb.len() { return false; }
                let mut i: Int = 0;
                while i < xb.len() {
                    if xb[i] != yb[i] { return false; }
                    i = i + 1;
                }
                true
            }
            _ => false,
        },
        RRowId(x) => match b { RRowId(y) => x == y, _ => false },
    }
}
