// PRAGMA foreign_keys handler.

module core.database.sqlite.native.foreign_keys_pragma.gate;

mount base.{Bool, Text};

public type Mode is
    | FkOff      // 0 — default; FK clauses parsed but not enforced
    | FkOn       // 1 — enforced
    ;

public fn default_mode() -> Mode { FkOff }

public fn from_pragma_value(n: Int) -> Mode {
    if n == 0 { FkOff } else { FkOn }
}

public fn to_pragma_value(m: &Mode) -> Int {
    match m { FkOff => 0, FkOn => 1 }
}

public fn mode_name(m: &Mode) -> Text {
    match m { FkOff => "off".clone(), FkOn => "on".clone() }
}

public fn enforces(m: &Mode) -> Bool {
    match m { FkOff => false, FkOn => true }
}

// Outcome of a SET attempt depending on whether a transaction is open.
public type SetOutcome is
    | SoApplied
    | SoIgnoredInsideTxn      // SQLite silently ignores changes during a txn
    ;

public fn try_apply(in_txn: Bool) -> SetOutcome {
    if in_txn { SoIgnoredInsideTxn } else { SoApplied }
}

public fn outcome_name(o: &SetOutcome) -> Text {
    match o {
        SoApplied            => "applied".clone(),
        SoIgnoredInsideTxn   => "ignored_inside_txn".clone(),
    }
}

public fn was_applied(o: &SetOutcome) -> Bool {
    match o { SoApplied => true, _ => false }
}

// Whether changing the mode requires the engine to re-prepare cached stmts
// (it does — FK gate affects codegen of write statements).
public fn invalidates_prepared_stmts(o: &SetOutcome) -> Bool {
    was_applied(o)
}
