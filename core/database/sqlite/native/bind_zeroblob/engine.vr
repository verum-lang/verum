// =============================================================================
// bind_zeroblob/engine.vr — per-stmt zeroblob-bind slot
// =============================================================================
// Spec: SQLite C API
// =============================================================================

module core.database.sqlite.native.bind_zeroblob.engine;

mount core.*;
mount base.{Bool, Maybe};
mount collections.List;
mount core.database.sqlite.native.bind_zeroblob.spec.{
    ZeroBlobSpec, is_valid,
};

public type ZeroBlobSlot is {
    index: Int,
    spec: Maybe<ZeroBlobSpec>,
}

public fn empty_slot(index: Int) -> ZeroBlobSlot {
    ZeroBlobSlot { index: index, spec: Maybe.None }
}

public type ZeroBlobBindEngine is {
    slots: List<ZeroBlobSlot>,
    rejections: Int64,
}

public fn new_engine(n_params: Int) -> ZeroBlobBindEngine {
    let mut slots: List<ZeroBlobSlot> = List.new();
    let mut i: Int = 0;
    while i <= n_params { slots.push(empty_slot(i)); i = i + 1; }
    ZeroBlobBindEngine { slots: slots, rejections: 0 as Int64 }
}

implement ZeroBlobBindEngine {
    /// Returns sqlite3 code: 0 (OK), 18 (SQLITE_TOOBIG) if spec is
    /// invalid, 25 (SQLITE_RANGE) if index is out of range.
    pub fn sqlite3_bind_zeroblob(&mut self, index: Int, spec: ZeroBlobSpec) -> Int {
        if index <= 0 || index >= self.slots.len() {
            self.rejections = self.rejections + (1 as Int64);
            return 25;
        }
        if !is_valid(&spec) {
            self.rejections = self.rejections + (1 as Int64);
            return 18;
        }
        self.slots.get_mut(index).spec = Maybe.Some(spec);
        0
    }

    pub fn clear(&mut self, index: Int) -> Bool {
        if index <= 0 || index >= self.slots.len() { return false; }
        self.slots.get_mut(index).spec = Maybe.None;
        true
    }

    pub fn slot_size(&self, index: Int) -> Int64 {
        if index <= 0 || index >= self.slots.len() { return 0 as Int64; }
        match &self.slots.get(index).spec {
            Maybe.Some(s) => s.size_bytes,
            Maybe.None => 0 as Int64,
        }
    }
}
