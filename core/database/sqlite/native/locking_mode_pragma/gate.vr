// PRAGMA locking_mode handler.

module core.database.sqlite.native.locking_mode_pragma.gate;

mount base.{Bool, Text};

public type Mode is
    | LmNormal       // default
    | LmExclusive
    ;

public fn default_mode() -> Mode { LmNormal }

public fn from_text(t: Text) -> Mode {
    if t == "exclusive".clone() { return LmExclusive; }
    LmNormal
}

public fn mode_name(m: &Mode) -> Text {
    match m {
        LmNormal    => "normal".clone(),
        LmExclusive => "exclusive".clone(),
    }
}

public fn retains_locks_across_txns(m: &Mode) -> Bool {
    match m { LmExclusive => true, _ => false }
}

// Whether WAL mode can skip writing the -shm file.
public fn allows_walwithout_shm(m: &Mode) -> Bool {
    retains_locks_across_txns(m)
}

// Switch back to NORMAL is allowed any time; switch from NORMAL to EXCLUSIVE
// is processed lazily on the next transaction (so SQLite reports success
// but the actual exclusive locks aren't taken until the next txn).
public type SwitchEffect is
    | SeImmediate
    | SeLazy
    ;

public fn effect_of_switch(prev: &Mode, next: &Mode) -> SwitchEffect {
    match prev {
        LmExclusive => match next {
            LmExclusive => SeImmediate,    // no-op
            LmNormal    => SeImmediate,    // releases on next-txn boundary
        },
        LmNormal => match next {
            LmExclusive => SeLazy,
            LmNormal    => SeImmediate,    // no-op
        },
    }
}

public fn effect_name(e: &SwitchEffect) -> Text {
    match e {
        SeImmediate => "immediate".clone(),
        SeLazy      => "lazy".clone(),
    }
}

public fn is_immediate(e: &SwitchEffect) -> Bool {
    match e { SeImmediate => true, _ => false }
}
