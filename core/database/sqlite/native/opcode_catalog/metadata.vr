// -----------------------------------------------------------------------------
// Name → opcode lookup
// -----------------------------------------------------------------------------

public fn opcode_from_name(name: &Text) -> Maybe<OpcodeKind> {
    let all = list_all();
    let mut i: Int = 0;
    while i < all.len() {
        if opcode_name(&all[i]) == name {
            return Some(clone_opcode(&all[i]));
        }
        i = i + 1;
    }
    None
}

public fn opcode_count() -> Int { list_all().len() }

fn clone_opcode(o: &OpcodeKind) -> OpcodeKind {
    // Match every variant explicitly so missing cases are caught.
    let code = opcode_wire(o);
    let _ = code;
    // Reproduce the variant exactly.
    match o {
        OpInit => OpInit, OpHalt => OpHalt, OpHaltIfNull => OpHaltIfNull,
        OpGoto => OpGoto, OpGosub => OpGosub, OpReturn => OpReturn,
        OpOnce => OpOnce, OpNoop => OpNoop, OpJump => OpJump,
        OpExpire => OpExpire, OpAbortable => OpAbortable,
        OpReleaseReg => OpReleaseReg, OpYield => OpYield,
        OpInteger32 => OpInteger32, OpResult => OpResult,
        OpInteger => OpInteger, OpInt64 => OpInt64, OpReal => OpReal,
        OpString8 => OpString8, OpBlob => OpBlob, OpNull => OpNull,
        OpSoftNull => OpSoftNull, OpMove => OpMove, OpCopy => OpCopy,
        OpSCopy => OpSCopy, OpZeroOrNull => OpZeroOrNull,
        OpVariable => OpVariable, OpString => OpString, OpClear => OpClear,
        OpResetCount => OpResetCount, OpEphemeralAbs => OpEphemeralAbs,
        OpAdd => OpAdd, OpSubtract => OpSubtract, OpMultiply => OpMultiply,
        OpDivide => OpDivide, OpRemainder => OpRemainder, OpAddImm => OpAddImm,
        OpRealAffinity => OpRealAffinity, OpBitAnd => OpBitAnd,
        OpBitOr => OpBitOr, OpShiftLeft => OpShiftLeft,
        OpShiftRight => OpShiftRight, OpBitNot => OpBitNot,
        OpConcat => OpConcat, OpCast => OpCast, OpMustBeInt => OpMustBeInt,
        OpAffinity => OpAffinity,
        OpCompare => OpCompare, OpEq => OpEq, OpNe => OpNe,
        OpLt => OpLt, OpLe => OpLe, OpGt => OpGt, OpGe => OpGe,
        OpIf => OpIf, OpIfNot => OpIfNot, OpIfNull => OpIfNull,
        OpNotNull => OpNotNull, OpIfPos => OpIfPos, OpIfNeg => OpIfNeg,
        OpIfZero => OpIfZero, OpAnd => OpAnd, OpOr => OpOr,
        OpOpenRead => OpOpenRead, OpOpenWrite => OpOpenWrite,
        OpOpenAutoindex => OpOpenAutoindex, OpOpenEphemeral => OpOpenEphemeral,
        OpClose => OpClose, OpRewind => OpRewind, OpLast => OpLast,
        OpNext => OpNext, OpPrev => OpPrev, OpColumn => OpColumn,
        OpRowId => OpRowId, OpRowKey => OpRowKey, OpRowData => OpRowData,
        OpInsert => OpInsert, OpDelete => OpDelete, OpUpdateRow => OpUpdateRow,
        OpFound => OpFound, OpNotFound => OpNotFound,
        OpSeekGT => OpSeekGT, OpSeekLT => OpSeekLT,
        OpSeekGE => OpSeekGE, OpSeekLE => OpSeekLE,
        OpSeekRowId => OpSeekRowId, OpSeekScan => OpSeekScan,
        OpResetCursor => OpResetCursor, OpIdxInsert => OpIdxInsert,
        OpIdxDelete => OpIdxDelete, OpIdxRowid => OpIdxRowid,
        OpIdxLT => OpIdxLT, OpIdxLE => OpIdxLE,
        OpIdxGE => OpIdxGE, OpIdxGT => OpIdxGT,
        OpAggStep => OpAggStep, OpAggFinal => OpAggFinal,
        OpAggValue => OpAggValue, OpAggInverse => OpAggInverse,
        OpAggFinalAvg => OpAggFinalAvg,
        OpSorterOpen => OpSorterOpen, OpSorterInsert => OpSorterInsert,
        OpSorterRewind => OpSorterRewind, OpSorterNext => OpSorterNext,
        OpSorterData => OpSorterData, OpSorterCompare => OpSorterCompare,
        OpSorterDistinct => OpSorterDistinct,
        OpDistinct => OpDistinct, OpScalarFn => OpScalarFn,
        OpFunction => OpFunction, OpAggregateContext => OpAggregateContext,
        OpTransaction => OpTransaction, OpCommit => OpCommit,
        OpRollbackOp => OpRollbackOp, OpSavepointOp => OpSavepointOp,
        OpAutoCommit => OpAutoCommit, OpReadCookie => OpReadCookie,
        OpSetCookie => OpSetCookie, OpVacuum => OpVacuum,
        OpVNew => OpVNew, OpVOpen => OpVOpen, OpVDestroy => OpVDestroy,
        OpVRename => OpVRename, OpVColumn => OpVColumn,
        OpVNext => OpVNext, OpVUpdate => OpVUpdate, OpVFilter => OpVFilter,
        OpCollSeq => OpCollSeq, OpExpiredSchema => OpExpiredSchema,
        OpInitCoroutine => OpInitCoroutine, OpEndCoroutine => OpEndCoroutine,
        OpYieldCoroutine => OpYieldCoroutine, OpDecrJumpZero => OpDecrJumpZero,
        OpIncrLoad => OpIncrLoad, OpResetSorter => OpResetSorter,
        OpAddCheckpoint => OpAddCheckpoint, OpJournalMode => OpJournalMode,
        OpPragma => OpPragma, OpAnalyze => OpAnalyze,
        OpReleaseSavepoint => OpReleaseSavepoint, OpDestroy => OpDestroy,
        OpCreateIndex => OpCreateIndex, OpCreateTable => OpCreateTable,
        OpFkCounter => OpFkCounter, OpFkIfZero => OpFkIfZero,
        OpFkCheck => OpFkCheck, OpDeferredFk => OpDeferredFk,
        OpTriggerEnter => OpTriggerEnter, OpTriggerLeave => OpTriggerLeave,
        OpTriggerProgram => OpTriggerProgram, OpFkViolation => OpFkViolation,
        OpFunctionInvoke => OpFunctionInvoke, OpRowSetTest => OpRowSetTest,
        OpRowSetAdd => OpRowSetAdd, OpRowSetRead => OpRowSetRead,
        OpProgram => OpProgram, OpParam => OpParam,
        OpProgramReturn => OpProgramReturn, OpJumpIfNotZero => OpJumpIfNotZero,
        OpVerify => OpVerify, OpExplain => OpExplain,
        OpExplainQueryPlan => OpExplainQueryPlan, OpDebug => OpDebug,
        OpTrace => OpTrace, OpProfile => OpProfile,
        OpProgressTick => OpProgressTick, OpDeleteAll => OpDeleteAll,
        OpDeleteUntilZero => OpDeleteUntilZero,
        OpJournalCheckpoint => OpJournalCheckpoint, OpPagerWrite => OpPagerWrite,
        OpFinish => OpFinish, OpReset => OpReset,
        OpBindParam => OpBindParam, OpHaltUserError => OpHaltUserError,
        OpSqlReset => OpSqlReset,
    }
}

fn list_all() -> List<OpcodeKind> {
    let mut out: List<OpcodeKind> = List.new();
    out.push(OpInit); out.push(OpHalt); out.push(OpHaltIfNull); out.push(OpGoto);
    out.push(OpGosub); out.push(OpReturn); out.push(OpOnce); out.push(OpNoop);
    out.push(OpJump); out.push(OpExpire); out.push(OpAbortable); out.push(OpReleaseReg);
    out.push(OpYield); out.push(OpInteger32); out.push(OpResult);
    out.push(OpInteger); out.push(OpInt64); out.push(OpReal); out.push(OpString8);
    out.push(OpBlob); out.push(OpNull); out.push(OpSoftNull); out.push(OpMove);
    out.push(OpCopy); out.push(OpSCopy); out.push(OpZeroOrNull); out.push(OpVariable);
    out.push(OpString); out.push(OpClear); out.push(OpResetCount); out.push(OpEphemeralAbs);
    out.push(OpAdd); out.push(OpSubtract); out.push(OpMultiply); out.push(OpDivide);
    out.push(OpRemainder); out.push(OpAddImm); out.push(OpRealAffinity); out.push(OpBitAnd);
    out.push(OpBitOr); out.push(OpShiftLeft); out.push(OpShiftRight); out.push(OpBitNot);
    out.push(OpConcat); out.push(OpCast); out.push(OpMustBeInt); out.push(OpAffinity);
    out.push(OpCompare); out.push(OpEq); out.push(OpNe); out.push(OpLt);
    out.push(OpLe); out.push(OpGt); out.push(OpGe); out.push(OpIf);
    out.push(OpIfNot); out.push(OpIfNull); out.push(OpNotNull); out.push(OpIfPos);
    out.push(OpIfNeg); out.push(OpIfZero); out.push(OpAnd); out.push(OpOr);
    out.push(OpOpenRead); out.push(OpOpenWrite); out.push(OpOpenAutoindex); out.push(OpOpenEphemeral);
    out.push(OpClose); out.push(OpRewind); out.push(OpLast); out.push(OpNext);
    out.push(OpPrev); out.push(OpColumn); out.push(OpRowId); out.push(OpRowKey);
    out.push(OpRowData); out.push(OpInsert); out.push(OpDelete); out.push(OpUpdateRow);
    out.push(OpFound); out.push(OpNotFound); out.push(OpSeekGT); out.push(OpSeekLT);
    out.push(OpSeekGE); out.push(OpSeekLE); out.push(OpSeekRowId); out.push(OpSeekScan);
    out.push(OpResetCursor); out.push(OpIdxInsert); out.push(OpIdxDelete); out.push(OpIdxRowid);
    out.push(OpIdxLT); out.push(OpIdxLE); out.push(OpIdxGE); out.push(OpIdxGT);
    out.push(OpAggStep); out.push(OpAggFinal); out.push(OpAggValue); out.push(OpAggInverse);
    out.push(OpAggFinalAvg);
    out.push(OpSorterOpen); out.push(OpSorterInsert); out.push(OpSorterRewind); out.push(OpSorterNext);
    out.push(OpSorterData); out.push(OpSorterCompare); out.push(OpSorterDistinct);
    out.push(OpDistinct); out.push(OpScalarFn); out.push(OpFunction); out.push(OpAggregateContext);
    out.push(OpTransaction); out.push(OpCommit); out.push(OpRollbackOp); out.push(OpSavepointOp);
    out.push(OpAutoCommit); out.push(OpReadCookie); out.push(OpSetCookie); out.push(OpVacuum);
    out.push(OpVNew); out.push(OpVOpen); out.push(OpVDestroy); out.push(OpVRename);
