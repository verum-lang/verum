// =============================================================================
// opcode_catalog/metadata.vr — VDBE opcode → name + wire-code table
// =============================================================================
// Spec: sqlite-native.md §11.2, Appendix C
//
// Approximately 180 SQLite VDBE opcodes are catalogued here. Wire
// codes are stable — they are the values the interpreter (and any
// VDBE bytecode persisted to disk) references. Names are the SQLite
// canonical identifiers (matches `sqlite3_opcode_name`).
//
// We use a single `OpcodeKind` enum over the entire catalogue so the
// optimiser, fuzz mutator, and EXPLAIN serialiser can pattern-match
// exhaustively. Adding a new opcode here is a one-line insertion;
// the existing wire codes are frozen forever.
// =============================================================================

module core.database.sqlite.native.opcode_catalog.metadata;

mount core.*;
mount base.{Text, Maybe};
mount collections.List;

// -----------------------------------------------------------------------------
// OpcodeKind — every VDBE opcode loom can encode
// -----------------------------------------------------------------------------

public type OpcodeKind is
    // 0-15 : program control
      OpInit
    | OpHalt
    | OpHaltIfNull
    | OpGoto
    | OpGosub
    | OpReturn
    | OpOnce
    | OpNoop
    | OpJump
    | OpExpire
    | OpAbortable
    | OpReleaseReg
    | OpYield
    | OpInteger32
    | OpResult

    // 16-31 : register moves & literals
    | OpInteger
    | OpInt64
    | OpReal
    | OpString8
    | OpBlob
    | OpNull
    | OpSoftNull
    | OpMove
    | OpCopy
    | OpSCopy
    | OpZeroOrNull
    | OpVariable
    | OpString
    | OpClear
    | OpResetCount
    | OpEphemeralAbs

    // 32-47 : arithmetic + bitwise
    | OpAdd
    | OpSubtract
    | OpMultiply
    | OpDivide
    | OpRemainder
    | OpAddImm
    | OpRealAffinity
    | OpBitAnd
    | OpBitOr
    | OpShiftLeft
    | OpShiftRight
    | OpBitNot
    | OpConcat
    | OpCast
    | OpMustBeInt
    | OpAffinity

    // 48-63 : comparisons & boolean
    | OpCompare
    | OpEq
    | OpNe
    | OpLt
    | OpLe
    | OpGt
    | OpGe
    | OpIf
    | OpIfNot
    | OpIfNull
    | OpNotNull
    | OpIfPos
    | OpIfNeg
    | OpIfZero
    | OpAnd
    | OpOr

    // 64-95 : cursor & table operations
    | OpOpenRead
    | OpOpenWrite
    | OpOpenAutoindex
    | OpOpenEphemeral
    | OpClose
    | OpRewind
    | OpLast
    | OpNext
    | OpPrev
    | OpColumn
    | OpRowId
    | OpRowKey
    | OpRowData
    | OpInsert
    | OpDelete
    | OpUpdateRow
    | OpFound
    | OpNotFound
    | OpSeekGT
    | OpSeekLT
    | OpSeekGE
    | OpSeekLE
    | OpSeekRowId
    | OpSeekScan
    | OpResetCursor
    | OpIdxInsert
    | OpIdxDelete
    | OpIdxRowid
    | OpIdxLT
    | OpIdxLE
    | OpIdxGE
    | OpIdxGT

    // 96-111 : aggregate / sort
    | OpAggStep
    | OpAggFinal
    | OpAggValue
    | OpAggInverse
    | OpAggFinalAvg
    | OpSorterOpen
    | OpSorterInsert
    | OpSorterRewind
    | OpSorterNext
    | OpSorterData
    | OpSorterCompare
    | OpSorterDistinct
    | OpDistinct
    | OpScalarFn
    | OpFunction
    | OpAggregateContext

    // 112-127 : transaction & schema
    | OpTransaction
    | OpCommit
    | OpRollbackOp
    | OpSavepointOp
    | OpAutoCommit
    | OpReadCookie
    | OpSetCookie
    | OpVacuum
    | OpVNew
    | OpVOpen
    | OpVDestroy
    | OpVRename
    | OpVColumn
    | OpVNext
    | OpVUpdate
    | OpVFilter

    // 128-143 : indexing helpers / collation
    | OpCollSeq
    | OpExpiredSchema
    | OpInitCoroutine
    | OpEndCoroutine
    | OpYieldCoroutine
    | OpDecrJumpZero
    | OpIncrLoad
    | OpResetSorter
    | OpAddCheckpoint
    | OpJournalMode
    | OpPragma
    | OpAnalyze
    | OpReleaseSavepoint
    | OpDestroy
    | OpCreateIndex
    | OpCreateTable

    // 144-159 : foreign keys & triggers
    | OpFkCounter
    | OpFkIfZero
    | OpFkCheck
    | OpDeferredFk
    | OpTriggerEnter
    | OpTriggerLeave
    | OpTriggerProgram
    | OpFkViolation
    | OpFunctionInvoke
    | OpRowSetTest
    | OpRowSetAdd
    | OpRowSetRead
    | OpProgram
    | OpParam
    | OpProgramReturn
    | OpJumpIfNotZero

    // 160-175 : misc / debug
    | OpVerify
    | OpExplain
    | OpExplainQueryPlan
    | OpDebug
    | OpTrace
    | OpProfile
    | OpProgressTick
    | OpDeleteAll
    | OpDeleteUntilZero
    | OpJournalCheckpoint
    | OpPagerWrite
    | OpFinish
    | OpReset
    | OpBindParam
    | OpHaltUserError
    | OpSqlReset;

// -----------------------------------------------------------------------------
// Wire codes
// -----------------------------------------------------------------------------

public fn opcode_wire(o: &OpcodeKind) -> Int {
    match o {
        // 0-15 — program control
        OpInit => 0, OpHalt => 1, OpHaltIfNull => 2, OpGoto => 3,
        OpGosub => 4, OpReturn => 5, OpOnce => 6, OpNoop => 7,
        OpJump => 8, OpExpire => 9, OpAbortable => 10, OpReleaseReg => 11,
        OpYield => 12, OpInteger32 => 13, OpResult => 14,
        // 16-31 — register moves
        OpInteger => 16, OpInt64 => 17, OpReal => 18, OpString8 => 19,
        OpBlob => 20, OpNull => 21, OpSoftNull => 22, OpMove => 23,
        OpCopy => 24, OpSCopy => 25, OpZeroOrNull => 26, OpVariable => 27,
        OpString => 28, OpClear => 29, OpResetCount => 30, OpEphemeralAbs => 31,
        // 32-47 — arithmetic
        OpAdd => 32, OpSubtract => 33, OpMultiply => 34, OpDivide => 35,
        OpRemainder => 36, OpAddImm => 37, OpRealAffinity => 38, OpBitAnd => 39,
        OpBitOr => 40, OpShiftLeft => 41, OpShiftRight => 42, OpBitNot => 43,
        OpConcat => 44, OpCast => 45, OpMustBeInt => 46, OpAffinity => 47,
        // 48-63 — comparisons
        OpCompare => 48, OpEq => 49, OpNe => 50, OpLt => 51,
        OpLe => 52, OpGt => 53, OpGe => 54, OpIf => 55,
        OpIfNot => 56, OpIfNull => 57, OpNotNull => 58, OpIfPos => 59,
        OpIfNeg => 60, OpIfZero => 61, OpAnd => 62, OpOr => 63,
        // 64-95 — cursor / table
        OpOpenRead => 64, OpOpenWrite => 65, OpOpenAutoindex => 66, OpOpenEphemeral => 67,
        OpClose => 68, OpRewind => 69, OpLast => 70, OpNext => 71,
        OpPrev => 72, OpColumn => 73, OpRowId => 74, OpRowKey => 75,
        OpRowData => 76, OpInsert => 77, OpDelete => 78, OpUpdateRow => 79,
        OpFound => 80, OpNotFound => 81, OpSeekGT => 82, OpSeekLT => 83,
        OpSeekGE => 84, OpSeekLE => 85, OpSeekRowId => 86, OpSeekScan => 87,
        OpResetCursor => 88, OpIdxInsert => 89, OpIdxDelete => 90, OpIdxRowid => 91,
        OpIdxLT => 92, OpIdxLE => 93, OpIdxGE => 94, OpIdxGT => 95,
        // 96-111 — aggregates / sort
        OpAggStep => 96, OpAggFinal => 97, OpAggValue => 98, OpAggInverse => 99,
        OpAggFinalAvg => 100, OpSorterOpen => 101, OpSorterInsert => 102, OpSorterRewind => 103,
        OpSorterNext => 104, OpSorterData => 105, OpSorterCompare => 106, OpSorterDistinct => 107,
        OpDistinct => 108, OpScalarFn => 109, OpFunction => 110, OpAggregateContext => 111,
        // 112-127 — transaction / schema
        OpTransaction => 112, OpCommit => 113, OpRollbackOp => 114, OpSavepointOp => 115,
        OpAutoCommit => 116, OpReadCookie => 117, OpSetCookie => 118, OpVacuum => 119,
        OpVNew => 120, OpVOpen => 121, OpVDestroy => 122, OpVRename => 123,
        OpVColumn => 124, OpVNext => 125, OpVUpdate => 126, OpVFilter => 127,
        // 128-143 — collation / coroutines
        OpCollSeq => 128, OpExpiredSchema => 129, OpInitCoroutine => 130, OpEndCoroutine => 131,
        OpYieldCoroutine => 132, OpDecrJumpZero => 133, OpIncrLoad => 134, OpResetSorter => 135,
        OpAddCheckpoint => 136, OpJournalMode => 137, OpPragma => 138, OpAnalyze => 139,
        OpReleaseSavepoint => 140, OpDestroy => 141, OpCreateIndex => 142, OpCreateTable => 143,
        // 144-159 — foreign keys / triggers
        OpFkCounter => 144, OpFkIfZero => 145, OpFkCheck => 146, OpDeferredFk => 147,
        OpTriggerEnter => 148, OpTriggerLeave => 149, OpTriggerProgram => 150, OpFkViolation => 151,
        OpFunctionInvoke => 152, OpRowSetTest => 153, OpRowSetAdd => 154, OpRowSetRead => 155,
        OpProgram => 156, OpParam => 157, OpProgramReturn => 158, OpJumpIfNotZero => 159,
        // 160-175 — misc
        OpVerify => 160, OpExplain => 161, OpExplainQueryPlan => 162, OpDebug => 163,
        OpTrace => 164, OpProfile => 165, OpProgressTick => 166, OpDeleteAll => 167,
        OpDeleteUntilZero => 168, OpJournalCheckpoint => 169, OpPagerWrite => 170, OpFinish => 171,
        OpReset => 172, OpBindParam => 173, OpHaltUserError => 174, OpSqlReset => 175,
    }
}

