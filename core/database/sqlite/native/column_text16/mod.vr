// Layer: 7 (façade — sqlite3_column_text16 / _bytes16)
// Spec: SQLite C API
//
//   const void *sqlite3_column_text16(stmt, col) → UTF-16 bytes
//   int         sqlite3_column_bytes16(stmt, col) → byte count (not code units)
