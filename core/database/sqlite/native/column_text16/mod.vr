// The engine auto-converts from the stored representation when needed.
//
// Submodules:
//   * `view`     — per-column U16 view w/ byte-order
//   * `engine`   — _column_text16 / _column_bytes16
// =============================================================================

module core.database.sqlite.native.column_text16;

public module view;
public module engine;
