// =============================================================================
// os_init_api/phase.vr — OsPhase
// =============================================================================
// Spec: SQLite C API
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.database.sqlite.native.os_init_api.phase;

mount core.*;
mount base.{Bool, Text};

public type OsPhase is
      OsFresh
    | OsInitialised
    | OsTornDown;

public fn phase_name(p: &OsPhase) -> Text {
    match p {
        OsFresh        => "fresh".clone(),
        OsInitialised  => "initialised".clone(),
        OsTornDown     => "torn-down".clone(),
    }
}

public fn is_live(p: &OsPhase) -> Bool {
    match p {
        OsInitialised => true,
        _ => false,
    }
}
