// PRAGMA recursive_triggers gate.
//
// When OFF (default): a trigger cannot fire another trigger.  The DML inside
// a trigger body executes with trigger-firing temporarily suppressed.
// When ON: triggers may cascade up to SQLITE_LIMIT_TRIGGER_DEPTH levels.

module core.database.sqlite.native.recursive_trigger_pragma.gate;

mount base.{Bool, Text};

public type Mode is
    | MoOff
    | MoOn
    ;

public fn default_mode() -> Mode { MoOff }

public fn from_pragma_value(n: Int) -> Mode {
    if n == 0 { MoOff } else { MoOn }
}

public fn to_pragma_value(m: &Mode) -> Int {
    match m { MoOff => 0, MoOn => 1 }
}

public fn mode_name(m: &Mode) -> Text {
    match m { MoOff => "off".clone(), MoOn => "on".clone() }
}

public fn cascades(m: &Mode) -> Bool {
    match m { MoOff => false, MoOn => true }
}

// Decide whether a new trigger may fire when we are already inside `depth`
// trigger bodies.  Off-mode forbids any nesting; on-mode forbids recursion
// only after exceeding the configured limit (handled separately).
public fn allows_fire(m: &Mode, current_depth: Int) -> Bool {
    match m {
        MoOff => current_depth == 0,
        MoOn  => true,
    }
}

// Boolean view used by stmt-prep (matches `recursive_triggers` field of
// db config flags).
public fn as_flag(m: &Mode) -> Bool { cascades(m) }

public fn from_flag(b: Bool) -> Mode {
    if b { MoOn } else { MoOff }
}
