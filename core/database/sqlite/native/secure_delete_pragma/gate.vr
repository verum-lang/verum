// PRAGMA secure_delete — zero-fill freed storage.

module core.database.sqlite.native.secure_delete_pragma.gate;

mount base.{Bool, Text};

public type Mode is
    | SdOff       // 0 — default; do not overwrite
    | SdOn        // 1 — overwrite freed bytes with zeros immediately
    | SdFast      // 2 — overwrite only while page is in the freelist (3.31+)
    ;

public fn default_mode() -> Mode { SdOff }

public fn from_pragma_value(n: Int) -> Mode {
    if n <= 0 { return SdOff; }
    if n == 1 { return SdOn; }
    SdFast
}

public fn to_pragma_value(m: &Mode) -> Int {
    match m {
        SdOff  => 0,
        SdOn   => 1,
        SdFast => 2,
    }
}

public fn mode_name(m: &Mode) -> Text {
    match m {
        SdOff  => "off".clone(),
        SdOn   => "on".clone(),
        SdFast => "fast".clone(),
    }
}

public fn zeros_freed_pages(m: &Mode) -> Bool {
    match m { SdOff => false, _ => true }
}

public fn zeros_immediately(m: &Mode) -> Bool {
    match m { SdOn => true, _ => false }
}

public fn zeros_only_in_freelist(m: &Mode) -> Bool {
    match m { SdFast => true, _ => false }
}

// Increases write-amplification when not OFF.
public fn increases_write_amp(m: &Mode) -> Bool {
    zeros_freed_pages(m)
}
