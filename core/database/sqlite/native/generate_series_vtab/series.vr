// generate_series() vtab — filter args + step iterator.

module core.database.sqlite.native.generate_series_vtab.series;

mount base.{Bool, Int64, Text};

// Effective filter arguments after applying defaults.
public type Args is {
    start: Int64,
    stop: Int64,
    step: Int64,
};

public fn default_start() -> Int64 { 0 as Int64 }
public fn default_stop()  -> Int64 { 9_223_372_036_854_775_806 as Int64 }
public fn default_step()  -> Int64 { 1 as Int64 }

public fn defaults() -> Args {
    Args { start: default_start(), stop: default_stop(), step: default_step() }
}

// xFilter validation — step=0 is rejected.
public type FilterCheck is
    | FcOk
    | FcZeroStep
    ;

public fn check(args: &Args) -> FilterCheck {
    if args.step == (0 as Int64) { return FcZeroStep; }
    FcOk
}

public fn check_name(c: &FilterCheck) -> Text {
    match c { FcOk => "ok".clone(), FcZeroStep => "zero_step".clone() }
}

public fn is_ok(c: &FilterCheck) -> Bool {
    match c { FcOk => true, _ => false }
}

// SeriesDirection.
public type SeriesDirection is
    | DirAscending
    | DirDescending
    ;

public fn direction_for(args: &Args) -> SeriesDirection {
    if args.step > (0 as Int64) { DirAscending } else { DirDescending }
}

public fn direction_name(d: &SeriesDirection) -> Text {
    match d {
        DirAscending  => "ascending".clone(),
        DirDescending => "descending".clone(),
    }
}

// Number of rows produced.  For ascending: floor((stop-start)/step)+1 if
// start <= stop, else 0.  For descending: mirror.
public fn row_count(args: &Args) -> Int64 {
    let zero = 0 as Int64;
    if args.step == zero { return zero; }
    if args.step > zero {
        if args.start > args.stop { return zero; }
        return (args.stop - args.start) / args.step + (1 as Int64);
    }
    // step < 0
    if args.start < args.stop { return zero; }
    let neg_step = zero - args.step;
    (args.start - args.stop) / neg_step + (1 as Int64)
}

// Generate the value at the given 0-based row index.
public fn value_at(args: &Args, row: Int64) -> Int64 {
    args.start + args.step * row
}

// Termination check used by xNext.
public fn at_end(args: &Args, current: Int64) -> Bool {
    let zero = 0 as Int64;
    if args.step > zero { return current > args.stop; }
    current < args.stop
}

// Column index taxonomy: value (0), start (1), stop (2), step (3).
public fn well_known_column_count() -> Int { 4 }

public fn column_name(idx: Int) -> Text {
    if idx == 0 { return "value".clone(); }
    if idx == 1 { return "start".clone(); }
    if idx == 2 { return "stop".clone(); }
    if idx == 3 { return "step".clone(); }
    "".clone()
}
