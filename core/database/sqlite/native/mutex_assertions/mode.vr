// =============================================================================
// mutex_assertions/mode.vr — BuildMode
// =============================================================================
// Spec: SQLite C API
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.database.sqlite.native.mutex_assertions.mode;

mount core.*;
mount base.{Bool, Text};

public type BuildMode is
      BmDebug
    | BmRelease;

public fn mode_name(m: &BuildMode) -> Text {
    match m {
        BmDebug   => "debug".clone(),
        BmRelease => "release".clone(),
    }
}

/// Release-mode versions of held / notheld always return 1.
public fn always_true_in_release(m: &BuildMode) -> Bool {
    match m {
        BmRelease => true,
        _ => false,
    }
}
