// Function-overload request + outcome.

module core.database.sqlite.native.vtab_overload_function_api.request;

mount base.{Bool, Text, Int64};

public type OverloadRequest is {
    function_name: Text,
    arity: Int,                  // -1 means variadic
    vtab_name: Text,
};

public fn new(function_name: Text, arity: Int, vtab_name: Text) -> OverloadRequest {
    OverloadRequest { function_name: function_name, arity: arity, vtab_name: vtab_name }
}

public fn is_variadic(r: &OverloadRequest) -> Bool {
    r.arity < 0
}

public type VtabOverloadOutcome is
    | OoInstalled          // overload registered successfully
    | OoAlreadyNative      // SQLite already has this fn; overload not used
    | OoOutOfMemory        // SQLITE_NOMEM
    | OoNotSupported       // vtab doesn't support xFindFunction
    ;

public fn outcome_name(o: &VtabOverloadOutcome) -> Text {
    match o {
        OoInstalled      => "installed".clone(),
        OoAlreadyNative  => "already_native".clone(),
        OoOutOfMemory    => "out_of_memory".clone(),
        OoNotSupported   => "not_supported".clone(),
    }
}

public fn is_success(o: &VtabOverloadOutcome) -> Bool {
    match o { OoInstalled => true, _ => false }
}

public fn is_retryable(o: &VtabOverloadOutcome) -> Bool {
    match o { OoOutOfMemory => true, _ => false }
}

// Classifier: given vtab's capabilities + SQLite's view of the fn.
public fn classify(
    vtab_has_xfindfunction: Bool,
    sqlite_has_native_impl: Bool,
    allocation_succeeded: Bool,
) -> VtabOverloadOutcome {
    if !vtab_has_xfindfunction { return OoNotSupported; }
    if sqlite_has_native_impl { return OoAlreadyNative; }
    if !allocation_succeeded { return OoOutOfMemory; }
    OoInstalled
}
