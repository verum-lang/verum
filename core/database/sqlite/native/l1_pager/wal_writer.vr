module core.database.sqlite.native.l1_pager.wal_writer;

// =============================================================================
// l1_pager/wal_writer.vr — Append-only WAL file writer
// =============================================================================
// Layer: 1
// Spec: sqlite-native.md §8.1 .. §8.3
//
// Owns the WAL file (one per pager) and the in-memory `WalState`.
// Single-writer by construction (the type is `affine`, mirroring
// `PagerActor`).  All disk I/O goes through the `SqliteFile`
// protocol so the same writer works on Posix, MemDb, and any
// future backend that implements the protocol.
//
// Operations:
//
//   * `wal_writer_create(backend, page_size, salts)` — create a
//     fresh WAL file, write the file header, return the writer.
//   * `wal_writer_open(backend)` — open an existing WAL file,
//     decode the header, and return a writer.  The caller must
//     run `wal_reader::recover_state` afterward to rebuild the
//     `frame_index` from the on-disk frame stream.
//   * `wal_writer_append_frame(self, page_no, page_data,
//                              commit_db_size)` — encode a frame
//     header + payload, append to the file, update `WalState`.
//   * `wal_writer_commit(self, sync_flags)` — fsync the WAL file
//     after the last commit frame of a transaction.
//   * `wal_writer_reset(self, new_salts)` — overwrite the file
//     header with rotated salts; mx_frame and n_backfill go to 0.
//   * `wal_writer_truncate(self)` — reset + truncate the file to
//     `file_header_size()`.
//
// Encoding follows the SQLite WAL on-disk format (sqlite-native.md
// §6.4 / SQLite §wal-file-format):
//
//   * File header  — 32 bytes (8 × u32 big-endian)
//   * Frame header — 24 bytes (6 × u32 big-endian)
//   * Frame payload — `page_size` bytes verbatim
//
// Endianness: SQLite uses big-endian for both headers regardless of
// host endianness.  We encode/decode via explicit byte shifts so
// the same code runs on any target.
// =============================================================================

mount core.*;
mount collections.{List, Map};
mount base.{Result, Ok, Err, Text, Maybe};
mount core.database.sqlite.native.l0_vfs.posix_vfs.PosixFile;
mount core.database.sqlite.native.l0_vfs.memdb_vfs.MemDbFile;
mount core.database.sqlite.native.l0_vfs.vfs_protocol.{
    VfsError, SyncFlags, sync_default, sync_full,
};
mount core.database.sqlite.native.wal_frame_layout.constants.{
    file_header_size, frame_header_size, magic_little, current_format_version,
};
mount core.database.sqlite.native.wal_frame_layout.file_header.{
    WalFileHeader, new as new_file_header,
};
mount core.database.sqlite.native.wal_frame_layout.frame_header.{
    WalFrameHeader, new as new_frame_header,
};
mount core.database.sqlite.native.l1_pager.wal_state.{
    WalState, wal_state_new,
};
mount core.database.sqlite.native.l1_pager.pager.{PagerError, PagerErrorKind};
mount core.database.sqlite.native.l1_pager.journal.wal.{
    WalChecksum, wal_running_checksum,
};
mount core.database.sqlite.native.l0_vfs.vfs_protocol.SqliteVfs;
mount core.database.sqlite.native.l1_pager.wal_index.{
    WalIndex, wal_index_new,
};

// -----------------------------------------------------------------------------
// WalBackend — sum type mirroring `PagerBackend` for consistency
// -----------------------------------------------------------------------------

/// One WAL file.  Posix-backed for real WAL files; MemDb for tests.
/// A future addition (Sqlite-3 RBU custom VFS) will land as a third
/// variant rather than a `dyn` parameter — same dispatch pattern as
/// `PagerBackend`.
public type WalBackend is
      WbFile(PosixFile)
    | WbMem(MemDbFile);

// -----------------------------------------------------------------------------
// WalWriter — append-only writer
// -----------------------------------------------------------------------------

public type affine WalWriter is {
    backend: WalBackend,
    state: WalState,
    /// Last byte offset written.  Equals `file_header_size() +
    /// mx_frame * (frame_header_size() + page_size)`.  Cached so
    /// each append doesn't re-multiply.
    write_cursor: Int,
    /// Rolling Fossil-checksum state (#149).  Seeded from the file
    /// header's checksum1/2 at create/open time and advanced on every
    /// frame append.  The (s1, s2) pair after the per-frame advance
    /// becomes the frame header's checksum1/2 fields — that's how
    /// readers verify frame integrity in lockstep without scanning
    /// the whole WAL.  See `wal_running_checksum` in journal/wal.vr.
    running: WalChecksum,
    /// In-memory WAL-index (#150 + #163).  Updated atomically with
    /// every `wal_writer_append_frame` so concurrent readers see
    /// the new frame via `WalIndex.find_frame` without walking the
    /// WAL file.  `wal_writer_commit` publishes the new mx_frame
    /// via `WalIndex.commit_header`; `wal_writer_reset` calls
    /// `WalIndex.reset_after_checkpoint`.  Pre-#163: the WalIndex
    /// data structure shipped (#150) but no caller updated it —
    /// readers had to fall back to walking the WAL from byte 0.
    /// Post-#163: the writer + index are kept in lockstep so the
    /// .shm protocol actually delivers its multi-reader payoff.
    index: WalIndex,
};

// -----------------------------------------------------------------------------
// Construction
// -----------------------------------------------------------------------------

/// Create a fresh WAL file.  Writes the file header at offset 0
/// with the supplied salts + page_size.  Caller is responsible for
/// providing salts from the Vfs PRNG; for tests, deterministic
/// salts are fine.
///
/// `page_size` must be a power of two in [512, 65536] OR the
/// sentinel 1 (which encodes 65536 in u16).  Returns
/// `PagerError::InvalidPageSize` otherwise.
public fn wal_writer_create(
    backend: WalBackend,
    page_size: Int,
    salt1: u32,
    salt2: u32,
) -> Result<WalWriter, PagerError> {
    if !is_power_of_two_or_sentinel(page_size) {
        return Err(PagerError {
            kind: InvalidPageSize,
            message: "WAL page size must be 512..65536 power-of-two or sentinel 1",
        });
    }

    // Build the file header (#149): compute the rolling-checksum
    // initial value over the first 24 bytes (magic .. salt2) and
    // store it in the header's checksum1/2 fields.  The same pair
    // seeds the per-frame rolling state.
    let hdr_no_cksum = new_file_header(
        magic_little(),
        current_format_version(),
        page_size,
        0 as u32,           // checkpoint_seq starts at 0
        salt1,
        salt2,
        0 as u32,
        0 as u32,
    );
    let prefix_bytes = encode_file_header_prefix_24(&hdr_no_cksum);
    let initial_cksum = wal_running_checksum(
        WalChecksum { s1: 0 as u32, s2: 0 as u32 },
        prefix_bytes.as_slice(),
    );
    let hdr = new_file_header(
        magic_little(),
        current_format_version(),
        page_size,
        0 as u32,
        salt1,
        salt2,
        initial_cksum.s1,
        initial_cksum.s2,
    );

    let mut backend = backend;
    let header_bytes = encode_file_header(&hdr);
    match backend_write(&mut backend, &header_bytes, 0) {
        Ok(_) => {}
        Err(e) => return Err(io_error("wal create header write failed", e)),
    }

    let mut state = wal_state_new(page_size);
    state.salt1 = salt1;
    state.salt2 = salt2;

    // Initialise the WAL-index (#163).  Fresh WAL ⇒ fresh index;
    // header isn't committed yet (`is_init = false`) — first
    // wal_writer_commit will flip the bit + publish the mx_frame.
    let index = wal_index_new(page_size);

    Ok(WalWriter {
        backend: backend,
        state: state,
        write_cursor: file_header_size(),
        running: initial_cksum,
        index: index,
    })
}

/// Convenience: construct a fresh WAL with salts pulled from the
/// platform Vfs PRNG (#153).  Caller's `vfs.random_bytes(8)` returns
/// 8 cryptographic-grade bytes which split into (salt1, salt2) as
/// big-endian u32 pairs.  Returns the underlying `VfsError` if
/// entropy harvesting fails — never silently falls back to
/// deterministic salts (that would re-introduce the
/// reused-salts-after-crash hazard the rotation policy exists to
/// prevent).
public fn wal_writer_create_with_random<V>(
    backend: WalBackend,
    page_size: Int,
    vfs: &V,
) -> Result<WalWriter, PagerError>
where V: SqliteVfs
{
    let bytes = match vfs.random_bytes(8) {
        Ok(b)  => b,
        Err(e) => return Err(io_error("wal create: random_bytes failed", e)),
    };
    if bytes.len() < 8 {
        return Err(PagerError {
            kind: CorruptHeader,
            message: "WAL create: vfs.random_bytes returned < 8 bytes",
        });
    }
    let salt1 = bytes_to_u32_be(&bytes, 0);
    let salt2 = bytes_to_u32_be(&bytes, 4);
    wal_writer_create(backend, page_size, salt1, salt2)
}

fn bytes_to_u32_be(b: &List<Byte>, off: Int) -> u32 {
    let b0: Int = b[off]     as Int;
    let b1: Int = b[off + 1] as Int;
    let b2: Int = b[off + 2] as Int;
    let b3: Int = b[off + 3] as Int;
    (((b0 << 24) | (b1 << 16) | (b2 << 8) | b3) as u32)
}

/// Open an existing WAL file.  Reads + decodes the header but does
/// NOT walk the frame stream — the caller (typically
/// `wal_reader::recover_state`) follows up to rebuild the
/// `frame_index` from disk and update `mx_frame` / `n_backfill` to
/// the actual on-disk reality.
public fn wal_writer_open(
    backend: WalBackend,
) -> Result<WalWriter, PagerError> {
    let mut backend = backend;
    let mut buf: List<Byte> = List.new();
    let mut i: Int = 0;
    while i < file_header_size() {
        buf.push(0 as Byte);
        i = i + 1;
    }
    match backend_read(&mut backend, &mut buf, 0) {
        Ok(_) => {}
        Err(e) => return Err(io_error("wal open header read failed", e)),
    }
    let hdr = decode_file_header(&buf);
    if hdr.magic != magic_little() {
        return Err(PagerError {
            kind: CorruptHeader,
            message: "WAL file magic mismatch",
        });
    }
    let mut state = wal_state_new(hdr.page_size);
    state.salt1 = hdr.salt1;
    state.salt2 = hdr.salt2;
    state.checkpoint_seq = hdr.checkpoint_seq;
    // Seed the rolling-checksum from the file header's stored
    // checksum1/2 (#149).  After recovery walks the frame stream
    // and validates the rolling chain frame-by-frame, the writer's
    // `running` field will hold the post-last-frame state — but
    // `wal_writer_open` itself doesn't walk frames; the `recover`
    // entry in wal_reader.vr does that and updates `running` via
    // `wal_writer_set_running` before any append is attempted.
    //
    // The WalIndex (#163) starts uninitialised; recovery populates
    // it via `wal_writer_index_replay` (called from wal_reader's
    // recover_state path) so readers don't have to re-walk the
    // WAL on every reopen.
    let index = wal_index_new(hdr.page_size);
    Ok(WalWriter {
        backend: backend,
        state: state,
        write_cursor: file_header_size(),
        running: WalChecksum { s1: hdr.checksum1, s2: hdr.checksum2 },
        index: index,
    })
}

implement WalWriter {
    public fn page_size(&self) -> Int { self.state.page_size }
    public fn mx_frame(&self) -> Int { self.state.mx_frame }
    public fn n_backfill(&self) -> Int { self.state.n_backfill }
    public fn pending_frames(&self) -> Int { self.state.pending_frame_count() }
    public fn salts(&self) -> (u32, u32) { (self.state.salt1, self.state.salt2) }
    public fn checkpoint_seq(&self) -> u32 { self.state.checkpoint_seq }

    /// Borrow the state for read access (no mutation).  Used by
    /// the snapshot machinery and the pager's read fast path.
    public fn state(&self) -> &WalState { &self.state }

    /// Borrow the WAL-index for read access (#163).  Concurrent
    /// readers (single-process for now; cross-process arrives
    /// when the WsbMmap backend lands) call `find_frame` /
    /// `try_acquire_reader_mark` against this.
    public fn index(&self) -> &WalIndex { &self.index }
}

/// Recovery seam (#163) — overwrite the writer's in-memory
/// WalIndex with one rebuilt from the on-disk frame stream.
/// Used by `wal_reader::recover_state` after walking the WAL
/// file end-to-end so the post-reopen writer state matches
/// the pre-crash invariant: every appended frame is in the
/// index, the header reflects the last-commit mx_frame.
pub fn wal_writer_set_index(w: &mut WalWriter, index: WalIndex) {
    w.index = index;
}

/// Append-frame seam for recovery: re-publish a single frame
/// to the WalIndex without touching the WAL file or rolling
/// checksum.  Used by `recover_state` to repopulate the index
/// frame-by-frame as it walks the WAL during crash recovery.
pub fn wal_writer_index_publish_frame(
    w: &mut WalWriter,
    page_no: Int,
    frame_no: Int,
) {
    w.index.append_frame(page_no, frame_no);
}

// -----------------------------------------------------------------------------
// Frame append
// -----------------------------------------------------------------------------

/// Append one frame to the WAL.  `commit_db_size` is non-zero for
/// the LAST frame of a transaction (the commit marker) — it
/// records the new database page count after the txn.  All other
/// frames pass `0`.
///
/// Caller MUST `wal_writer_commit` after the commit-marker frame
/// to durably persist the txn.  Without the fsync the appended
/// frames are visible to in-process readers but a crash will lose
/// them.
public fn wal_writer_append_frame(
    w: &mut WalWriter,
    page_no: Int,
    page_data: &[Byte],
    commit_db_size: Int,
) -> Result<(), PagerError> {
    if page_data.len() != w.state.page_size {
        return Err(PagerError {
            kind: InvalidPageSize,
            message: "WAL append: page_data length must equal page_size",
        });
    }
    let is_commit = commit_db_size > 0;
    // Compute the rolling Fossil checksum (#149) over the 8-byte
    // frame-header prefix (page_no + db_size_after_commit) followed
    // by the page payload.  The prefix bytes are the FIRST 8 of the
    // frame header — salt1/salt2 are NOT fed into the rolling
    // accumulator (they're just identity tags for the WAL session).
    // This matches `journal/writer.vr::append` and the SQLite
    // walformat.html spec §6.4.
    let prefix = encode_frame_prefix_8(page_no as u32, commit_db_size as u32);
    let after_prefix = wal_running_checksum(w.running.clone(), prefix.as_slice());
    let after_body = wal_running_checksum(after_prefix, page_data);

    let frame_hdr = new_frame_header(
        page_no as u32,
        commit_db_size as u32,
        w.state.salt1,
        w.state.salt2,
        after_body.s1,
        after_body.s2,
    );
    let hdr_bytes = encode_frame_header(&frame_hdr);

    // Write header at the current cursor.
    match backend_write(&mut w.backend, &hdr_bytes, w.write_cursor) {
        Ok(_) => {}
        Err(e) => return Err(io_error("wal append: frame header write failed", e)),
    }
    // Write payload immediately after the header.
    let payload_offset = w.write_cursor + frame_header_size();
    match backend_write(&mut w.backend, page_data, payload_offset) {
        Ok(_) => {}
        Err(e) => return Err(io_error("wal append: frame payload write failed", e)),
    }
    w.write_cursor = w.write_cursor + frame_header_size() + w.state.page_size;
    w.state.record_appended_frame(page_no, is_commit, commit_db_size);
    // Persist the post-frame rolling state for the next append.
    w.running = after_body;
    // Publish the new frame to the in-memory WAL-index (#163) so
    // concurrent readers can find it via `WalIndex.find_frame`
    // without walking the WAL file.  `mx_frame` was just bumped
    // by `record_appended_frame`, so we use the post-bump value
    // as the new frame number.
    w.index.append_frame(page_no, w.state.mx_frame);
    Ok(())
}

/// fsync the WAL file.  Call after the last frame of a transaction.
/// `full=true` uses F_FULLFSYNC on Darwin (slower, true-durable);
/// the default `sync_default()` uses fdatasync on Linux which is
/// ~5-20× faster on rotational + datacenter SSDs.
public fn wal_writer_commit(
    w: &mut WalWriter,
    flags: SyncFlags,
) -> Result<(), PagerError> {
    // fsync FIRST — durability before observability.  If the
    // sync fails, the WalIndex header is NOT bumped, so readers
    // continue to see the old mx_frame and don't observe data
    // that hasn't reached durable storage.
    match backend_sync(&w.backend, flags) {
        Ok(_)  => {},
        Err(e) => return Err(io_error("wal commit: fsync failed", e)),
    }
    // Publish the new mx_frame + n_page to the WalIndex (#163).
    // Concurrent readers' next snapshot will see the post-commit
    // state via WalIndex.commit_header — no WAL-walk needed.
    let mx = w.state.mx_frame;
    let n_pg = w.state.last_commit_db_size as u32;
    let s1 = w.state.salt1;
    let s2 = w.state.salt2;
    w.index.commit_header(mx, n_pg, s1, s2);
    Ok(())
}

/// Reset the WAL: rotate salts, rewrite the file header, drop the
/// frame index.  Used by Restart and Truncate checkpoints AFTER
/// the frames have been drained to the main DB.
public fn wal_writer_reset(
    w: &mut WalWriter,
    new_salt1: u32,
    new_salt2: u32,
) -> Result<(), PagerError> {
    w.state.reset_for_restart(new_salt1, new_salt2);
    // Recompute the file-header rolling checksum over the new
    // prefix (#149).  The new running state seeds future appends —
    // the salt rotation also rotates the checksum chain origin so
    // a torn write straddling the rotation can't be confused for a
    // valid frame in the new chain.
    let hdr_no_cksum = new_file_header(
        magic_little(),
        current_format_version(),
        w.state.page_size,
        w.state.checkpoint_seq,
        new_salt1,
        new_salt2,
        0 as u32,
        0 as u32,
    );
    let prefix_bytes = encode_file_header_prefix_24(&hdr_no_cksum);
    let initial_cksum = wal_running_checksum(
        WalChecksum { s1: 0 as u32, s2: 0 as u32 },
        prefix_bytes.as_slice(),
    );
    let hdr = new_file_header(
        magic_little(),
        current_format_version(),
        w.state.page_size,
        w.state.checkpoint_seq,
        new_salt1,
        new_salt2,
        initial_cksum.s1,
        initial_cksum.s2,
    );
    let header_bytes = encode_file_header(&hdr);
    match backend_write(&mut w.backend, &header_bytes, 0) {
        Ok(_) => {}
        Err(e) => return Err(io_error("wal reset: header write failed", e)),
    }
    w.write_cursor = file_header_size();
    w.running = initial_cksum;
    // Reset the WAL-index too (#163): drop hash sections, zero
    // mx_frame, install new salts, bump change_count so any
    // in-flight reader detects the salt rotation on its next
    // snapshot probe.
    w.index.reset_after_checkpoint(new_salt1, new_salt2);
    Ok(())
}

/// Convenience: rotate WAL salts using fresh entropy from the
/// platform Vfs (#153).  Same `vfs.random_bytes(8)` contract as
/// `wal_writer_create_with_random` — surfaces VfsError on failure
/// and never falls back to deterministic salts.
public fn wal_writer_reset_with_random<V>(
    w: &mut WalWriter,
    vfs: &V,
) -> Result<(), PagerError>
where V: SqliteVfs
{
    let bytes = match vfs.random_bytes(8) {
        Ok(b)  => b,
        Err(e) => return Err(io_error("wal reset: random_bytes failed", e)),
    };
    if bytes.len() < 8 {
        return Err(PagerError {
            kind: CorruptHeader,
            message: "WAL reset: vfs.random_bytes returned < 8 bytes",
        });
    }
    let salt1 = bytes_to_u32_be(&bytes, 0);
    let salt2 = bytes_to_u32_be(&bytes, 4);
    wal_writer_reset(w, salt1, salt2)
}

/// Override the rolling-checksum state after recovery.  Used by
/// `wal_reader::recover_state` once it has walked the on-disk frame
/// stream and verified each frame's checksum chain end-to-end.
/// Without this seam the writer would re-start the chain from the
/// file-header initial value — breaking integrity on the very next
/// append after a reopen.
public fn wal_writer_set_running(w: &mut WalWriter, running: WalChecksum) {
    w.running = running;
}

/// Read-only view of the current rolling-checksum state.  Useful
/// for testing + observability.
public fn wal_writer_running(w: &WalWriter) -> WalChecksum {
    w.running.clone()
}

/// Truncate the WAL file to just the file header.  Used by
/// Truncate checkpoint mode after `wal_writer_reset`.
public fn wal_writer_truncate(w: &mut WalWriter) -> Result<(), PagerError> {
    match backend_truncate(&mut w.backend, file_header_size()) {
        Ok(_) => Ok(()),
        Err(e) => Err(io_error("wal truncate: ftruncate failed", e)),
    }
}

// -----------------------------------------------------------------------------
// Backend dispatch — sum-type pattern matching the PagerBackend shape
// -----------------------------------------------------------------------------

fn backend_write(b: &mut WalBackend, buf: &[Byte], offset: Int) -> Result<(), VfsError> {
    match b {
        WbFile(f) => f.write(buf, offset),
        WbMem(f)  => f.write(buf, offset),
    }
}

fn backend_read(b: &mut WalBackend, buf: &mut List<Byte>, offset: Int) -> Result<(), VfsError> {
    match b {
        WbFile(f) => f.read(buf, offset),
        WbMem(f)  => f.read(buf, offset),
    }
}

fn backend_sync(b: &WalBackend, flags: SyncFlags) -> Result<(), VfsError> {
    match b {
        WbFile(f) => f.sync(flags),
        WbMem(f)  => f.sync(flags),
    }
}

fn backend_truncate(b: &mut WalBackend, size: Int) -> Result<(), VfsError> {
    match b {
        WbFile(f) => f.truncate(size),
        WbMem(f)  => f.truncate(size),
    }
}

// -----------------------------------------------------------------------------
// Binary encoding — big-endian u32 (SQLite WAL convention)
// -----------------------------------------------------------------------------

fn encode_u32_be(value: u32, dst: &mut List<Byte>) {
    let v: Int = value as Int;
    dst.push(((v >> 24) & 0xFF) as Byte);
    dst.push(((v >> 16) & 0xFF) as Byte);
    dst.push(((v >> 8)  & 0xFF) as Byte);
    dst.push((v         & 0xFF) as Byte);
}

fn decode_u32_be(buf: &[Byte], offset: Int) -> u32 {
    let b0: Int = buf[offset]     as Int;
    let b1: Int = buf[offset + 1] as Int;
    let b2: Int = buf[offset + 2] as Int;
    let b3: Int = buf[offset + 3] as Int;
    (((b0 << 24) | (b1 << 16) | (b2 << 8) | b3) as u32)
}

fn encode_file_header(h: &WalFileHeader) -> List<Byte> {
    let mut out: List<Byte> = List.new();
    encode_u32_be(h.magic,           &mut out);
    encode_u32_be(h.format_version,  &mut out);
    // page_size is i32 in our type; cast to u32 for encoding.
    // Per spec, value 1 in the file header sentinels for 65536.
    encode_u32_be(h.page_size as u32, &mut out);
    encode_u32_be(h.checkpoint_seq,  &mut out);
    encode_u32_be(h.salt1,           &mut out);
    encode_u32_be(h.salt2,           &mut out);
    encode_u32_be(h.checksum1,       &mut out);
    encode_u32_be(h.checksum2,       &mut out);
    out
}

/// First 24 bytes of the file header (everything except checksum1/2).
/// Fed to `wal_running_checksum` to compute the file-header checksum
/// per SQLite's WAL spec §6.4.
fn encode_file_header_prefix_24(h: &WalFileHeader) -> List<Byte> {
    let mut out: List<Byte> = List.new();
    encode_u32_be(h.magic,           &mut out);
    encode_u32_be(h.format_version,  &mut out);
    encode_u32_be(h.page_size as u32, &mut out);
    encode_u32_be(h.checkpoint_seq,  &mut out);
    encode_u32_be(h.salt1,           &mut out);
    encode_u32_be(h.salt2,           &mut out);
    out
}

/// 8-byte frame header prefix (page_no + db_size_after_commit).
/// Fed to the rolling checksum BEFORE the page payload — the
/// (s1, s2) pair after both advances is the frame's checksum1/2.
fn encode_frame_prefix_8(page_no: u32, commit_db_size: u32) -> List<Byte> {
    let mut out: List<Byte> = List.new();
    encode_u32_be(page_no, &mut out);
    encode_u32_be(commit_db_size, &mut out);
    out
}

fn decode_file_header(buf: &List<Byte>) -> WalFileHeader {
    new_file_header(
        decode_u32_be(buf, 0),
        decode_u32_be(buf, 4),
        decode_u32_be(buf, 8) as Int,
        decode_u32_be(buf, 12),
        decode_u32_be(buf, 16),
        decode_u32_be(buf, 20),
        decode_u32_be(buf, 24),
        decode_u32_be(buf, 28),
    )
}

fn encode_frame_header(h: &WalFrameHeader) -> List<Byte> {
    let mut out: List<Byte> = List.new();
    encode_u32_be(h.page_number, &mut out);
    encode_u32_be(h.commit_size, &mut out);
    encode_u32_be(h.salt1,       &mut out);
    encode_u32_be(h.salt2,       &mut out);
    encode_u32_be(h.checksum1,   &mut out);
    encode_u32_be(h.checksum2,   &mut out);
    out
}

public fn decode_frame_header(buf: &List<Byte>, offset: Int) -> WalFrameHeader {
    let mut tmp: List<Byte> = List.new();
    let mut i: Int = 0;
    while i < frame_header_size() {
        tmp.push(buf[offset + i]);
        i = i + 1;
    }
    new_frame_header(
        decode_u32_be(&tmp, 0),
        decode_u32_be(&tmp, 4),
        decode_u32_be(&tmp, 8),
        decode_u32_be(&tmp, 12),
        decode_u32_be(&tmp, 16),
        decode_u32_be(&tmp, 20),
    )
}

// -----------------------------------------------------------------------------
// Helpers
// -----------------------------------------------------------------------------

fn is_power_of_two_or_sentinel(n: Int) -> Bool {
    if n == 1 { return true; }   // sentinel for 65536
    if n < 512 { return false; }
    if n > 65536 { return false; }
    let mut x = n;
    while x > 1 {
        if (x % 2) != 0 { return false; }
        x = x / 2;
    }
    true
}

fn io_error(context: &str, e: VfsError) -> PagerError {
    let _ = e;
    PagerError {
        kind: IoError,
        message: context.to_owned(),
    }
}
