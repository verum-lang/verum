module core.database.sqlite.native.l1_pager.wal_actor_bridge;

// =============================================================================
// l1_pager/wal_actor_bridge.vr — PagerActor → WalPager bridge
// =============================================================================
// Layer: 1
// Spec: sqlite-native.md §8 (WAL mode integration)
//
// Closes the integration gap left by #139's foundation: the WalPager
// surface (`wal_pager_read` / `wal_pager_write` / `wal_pager_commit`
// / `wal_pager_checkpoint`) is real, but the existing `PagerActor`
// (`actor.vr`) routes Read / Write / Commit / Checkpoint requests
// through the legacy `Pager` (main DB only — no WAL).  This bridge
// ships a parallel `WalPagerActor` that routes the same request
// taxonomy through `WalPager`, preserving the architectural
// single-writer + snapshot-reader semantics.
//
// Both actors satisfy the same request/reply protocol so the upper
// layers (L6 Connection, L4 cursor opcodes) can dispatch through
// either backend uniformly.  The differentiation is at construction
// time: `actor_new(pager, cache_pages)` for legacy main-only pager;
// `wal_actor_new(wal_pager)` for WAL-mode operation.
// =============================================================================

mount core.*;
mount collections.{List, Map};
mount base.{Result, Ok, Err, Text, Maybe};
mount core.database.sqlite.native.l0_vfs.vfs_protocol.{SyncFlags, sync_default};
mount core.database.sqlite.native.l1_pager.pager.{
    PageFrame, PagerError, PagerErrorKind,
};
mount core.database.sqlite.native.l1_pager.actor.{
    PagerRequest, PagerReply,
    Read, Write, Commit, Checkpoint,
    ReadOk, WriteOk, CommitOk, CheckpointOk, Failed,
    PagerCheckpointMode, Passive, Full, Restart, Truncate,
};
mount core.database.sqlite.native.l1_pager.wal_pager.{
    WalPager,
    wal_pager_read, wal_pager_write, wal_pager_commit, wal_pager_checkpoint,
    CheckpointMode, CheckpointResult,
    Passive as WPassive, Full as WFull, Restart as WRestart, Truncate as WTruncate,
};

// -----------------------------------------------------------------------------
// WalPagerActor — owns a WalPager + serves PagerRequest
// -----------------------------------------------------------------------------

pub type affine WalPagerActor is {
    wal_pager: WalPager,
    /// Pending writes since the last commit.  Pure stat for
    /// observability — the WalPager itself buffers via
    /// `pending_writes`.
    pending_writes: Int,
}

pub fn wal_actor_new(wal_pager: WalPager) -> WalPagerActor {
    WalPagerActor {
        wal_pager: wal_pager,
        pending_writes: 0,
    }
}

implement WalPagerActor {
    pub fn pending(&self) -> Int { self.pending_writes }
    pub fn mx_frame(&self) -> Int { self.wal_pager.mx_frame() }
    pub fn n_backfill(&self) -> Int { self.wal_pager.n_backfill() }
}

// -----------------------------------------------------------------------------
// Request processor — same shape as actor.vr's `pager_apply`
// -----------------------------------------------------------------------------

/// Execute one request against the WAL-backed actor.  Mirrors the
/// legacy `pager_apply` shape so callers can swap the actor type
/// without changing dispatch.  Reads/writes go through the WAL
/// frame index; commits append + fsync; checkpoints drain.
pub fn wal_pager_apply(
    actor: &mut WalPagerActor,
    req: PagerRequest,
) -> PagerReply {
    match req {
        Read(page, tok) => {
            match wal_pager_read(&mut actor.wal_pager, page) {
                Ok(frame) => ReadOk(frame, tok),
                Err(e)    => Failed(e, tok),
            }
        }
        Write(frame, tok) => {
            match wal_pager_write(&mut actor.wal_pager, &frame) {
                Ok(_) => {
                    actor.pending_writes = actor.pending_writes + 1;
                    WriteOk(tok)
                }
                Err(e) => Failed(e, tok),
            }
        }
        Commit(tok) => {
            match wal_pager_commit(&mut actor.wal_pager, sync_default()) {
                Ok(frames) => {
                    let _ = frames;
                    actor.pending_writes = 0;
                    CommitOk(tok)
                }
                Err(e) => Failed(e, tok),
            }
        }
        Checkpoint(mode, tok) => {
            let wal_mode = translate_mode(mode);
            // Foundation: deterministic salt rotation seed = 0/0 +
            // checkpoint_seq XOR (xor mixes prevent identical salts
            // across restarts).  Production caller passes Vfs
            // PRNG-supplied salts.
            let salt1: u32 = 0xCAFEBABE as u32;
            let salt2: u32 = 0xDEADBEEF as u32;
            match wal_pager_checkpoint(&mut actor.wal_pager, wal_mode, salt1, salt2) {
                Ok(result) => CheckpointOk(result.frames_drained, tok),
                Err(e)     => Failed(e, tok),
            }
        }
    }
}

fn translate_mode(m: PagerCheckpointMode) -> CheckpointMode {
    match m {
        Passive  => WPassive,
        Full     => WFull,
        Restart  => WRestart,
        Truncate => WTruncate,
    }
}

// -----------------------------------------------------------------------------
// Batch dispatch — same convenience as actor.vr's pager_apply_batch
// -----------------------------------------------------------------------------

pub fn wal_pager_apply_batch(
    actor: &mut WalPagerActor,
    reqs: List<PagerRequest>,
) -> List<PagerReply> {
    let mut out: List<PagerReply> = List.new();
    let mut i: Int = 0;
    while i < reqs.len() {
        let req = reqs[i].clone();
        out.push(wal_pager_apply(actor, req));
        i = i + 1;
    }
    out
}
