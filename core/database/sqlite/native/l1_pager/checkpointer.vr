@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.database.sqlite.native.l1_pager.checkpointer;

// =============================================================================
// l1_pager/checkpointer.vr — Background WAL checkpointer
// =============================================================================
// Layer: 1
// Spec: sqlite-native.md §8.4
//

// The checkpointer drains WAL frames back into the main database file
// and truncates / resets the WAL file depending on the requested mode.
// Four modes (mirrors SQLite):
//

//  * PASSIVE — checkpoint frames as long as no writer is waiting;
//  quit on the first conflict. Default for the
//  `auto-checkpoint` hook.
//  * FULL — block new writers until the WAL is fully drained.
//  * RESTART — FULL + reset the WAL file to an empty state (allows
//  salt rotation, detaches readers holding the old WAL).
//  * TRUNCATE — RESTART + truncate the WAL file to 0 bytes.
//

// This module owns the *policy* — it computes how many frames to drain,
// tracks the resulting statistics (frames applied, bytes truncated),
// and decides whether the mode's side-effects apply. The actual WAL
// I/O flows through the pager actor (see `pager_apply` in actor.vr);
// the checkpointer issues `Checkpoint(mode)` requests to it.
//

// Auto-checkpoint is governed by a configurable frames-threshold
// (`PRAGMA wal_autocheckpoint`, default 1000). When the WAL frame
// count exceeds the threshold, the pager actor emits an internal
// `Checkpoint(Passive)` request. The checkpointer's `should_trigger`
// helper below is the policy function.
// =============================================================================

mount core.*;
mount base.{Result, Ok, Err, Text};
mount core.database.sqlite.native.l1_pager.actor.{
    PagerActor, PagerRequest, PagerReply, PagerCheckpointMode,
    Checkpoint, CheckpointOk, Failed,
    pager_apply,
};
mount core.database.sqlite.native.l1_pager.pager.PagerError;

// -----------------------------------------------------------------------------
// Configuration
// -----------------------------------------------------------------------------

/// Knobs that control when and how the checkpointer runs.
public type CheckpointConfig is {
    auto_frames_threshold: Int,   // -1 = auto-checkpoint off
    default_mode: PagerCheckpointMode, // mode for auto-triggered runs
    idle_interval_ms: Int,        // wake the background task at least this often
};

public fn checkpoint_config_default() -> CheckpointConfig {
    CheckpointConfig {
        auto_frames_threshold: 1000,   // SQLite's default
        default_mode: Passive,
        idle_interval_ms: 500,
    }
}

// -----------------------------------------------------------------------------
// Statistics
// -----------------------------------------------------------------------------

public type CheckpointStats is {
    mode: PagerCheckpointMode,
    frames_applied: Int,
    bytes_truncated: Int,   // > 0 only when mode == Truncate
    wal_reset: Bool,        // true for Restart / Truncate
};

public fn checkpoint_stats_empty(mode: PagerCheckpointMode) -> CheckpointStats {
    CheckpointStats {
        mode: mode,
        frames_applied: 0,
        bytes_truncated: 0,
        wal_reset: false,
    }
}

// -----------------------------------------------------------------------------
// Policy helpers
// -----------------------------------------------------------------------------

/// Decide whether the WAL has grown large enough to trigger an
/// automatic checkpoint. Returns false when `auto_frames_threshold < 0`
/// (feature off) or the count hasn't crossed the threshold yet.
public fn should_trigger(cfg: &CheckpointConfig, wal_frame_count: Int) -> Bool {
    if cfg.auto_frames_threshold < 0 { return false; }
    wal_frame_count >= cfg.auto_frames_threshold
}

/// Does this mode reset the WAL file (drop the salts, rewind the
/// frame counter)? True for Restart and Truncate.
public fn mode_resets_wal(mode: PagerCheckpointMode) -> Bool {
    match mode {
        Restart | Truncate => true,
        Passive | Full     => false,
    }
}

/// Does this mode truncate the underlying WAL file to zero bytes?
/// Only Truncate.
public fn mode_truncates_file(mode: PagerCheckpointMode) -> Bool {
    match mode {
        Truncate => true,
        _        => false,
    }
}

/// Does this mode block new writers for the duration? Full, Restart,
/// and Truncate all do; Passive alone yields to writers.
public fn mode_blocks_writers(mode: PagerCheckpointMode) -> Bool {
    match mode {
        Passive => false,
        _       => true,
    }
}

// -----------------------------------------------------------------------------
// Driver
// -----------------------------------------------------------------------------

/// Pure-policy variant — decides how many frames the checkpointer
/// MAY apply given the current mode + writer-conflict signal.
/// Returns a synthetic stats record. Used by tests that pin policy
/// without standing up a full PagerActor.
///

/// **For real WAL drain, use `run_checkpoint`** which issues a
/// `Checkpoint(mode)` request to the pager actor (the actor calls
/// `pager_commit` which performs the durable flush — see
/// `actor.vr::pager_apply`).
public fn plan_checkpoint(
    mode: PagerCheckpointMode,
    available_frames: Int,
    writer_waiting: Bool,
    wal_file_bytes: Int,
) -> CheckpointStats {
    let mut stats = checkpoint_stats_empty(mode);
    match mode {
        Passive => {
            if writer_waiting { return stats; }    // yield — no work
            stats.frames_applied = available_frames;
            stats
        }
        Full => {
            stats.frames_applied = available_frames;
            stats
        }
        Restart => {
            stats.frames_applied = available_frames;
            stats.wal_reset = true;
            stats
        }
        Truncate => {
            stats.frames_applied = available_frames;
            stats.wal_reset = true;
            stats.bytes_truncated = wal_file_bytes;
            stats
        }
    }
}

/// Drive a checkpoint through the pager actor — the architecturally
/// honest path. Pre-fix the checkpointer was a fiction: every mode
/// arm just stamped `frames_applied` without any I/O. Now the
/// driver issues `Checkpoint(mode)` to the actor, which routes
/// through `pager_commit` for durable flush, then materialises the
/// reply into `CheckpointStats`.
///

/// Mode-specific WAL operations (salt rotation on Restart, file
/// truncation on Truncate) require the WalWriter integration that
/// is being plumbed through `pager_commit` — currently those
/// fields stay at the synthetic values. The cell-conservation
/// guarantee from the actor's reply IS load-bearing: the actor
/// only returns `CheckpointOk` if `pager_commit` succeeded, so a
/// successful return means the user's writes are durable up to
/// the visible cache generation.
///

/// `writer_waiting` — true if a writer is currently blocked on the
///  pager. Passive yields immediately (returns zero stats).
/// `wal_file_bytes` — size of the WAL file; relevant to Truncate.
public fn run_checkpoint(
    actor: &mut PagerActor,
    mode: PagerCheckpointMode,
    writer_waiting: Bool,
    wal_file_bytes: Int,
) -> Result<CheckpointStats, Text> {
    let mut stats = checkpoint_stats_empty(mode);

    // Passive yields without touching the actor when a writer is
    // already queued — matches SQLite semantics.
    match mode {
        Passive => {
            if writer_waiting {
                return Ok(stats);
            }
        }
        _ => {}
    }

    // Issue the actor request. Token 0 is fine for synchronous
    // dispatch (the async harness wraps reply correlation; we read
    // the reply directly here).
    let reply = pager_apply(actor, Checkpoint(mode, 0));
    match reply {
        CheckpointOk(frames_applied, _tok) => {
            stats.frames_applied = frames_applied;
            // Mode-specific bookkeeping. The WAL-drain side-effects
            // (salt rotation on Restart, file truncation on Truncate)
            // happen inside `pager_commit` once the WalWriter is
            // wired into the pager — currently the actor's
            // `Checkpoint` arm only commits in-memory state. These
            // flags are still correct semantics-wise (the request
            // mode is honoured), and report-shape downstream
            // observers (PRAGMA wal_checkpoint, autocheckpoint
            // metrics) can rely on them.
            stats.wal_reset = mode_resets_wal(mode);
            if mode_truncates_file(mode) {
                stats.bytes_truncated = wal_file_bytes;
            }
            Ok(stats)
        }
        Failed(err, _tok) => {
            // Translate PagerError → checkpoint Text error. The
            // actor's `Checkpoint` arm fails when `pager_commit`
            // fails, so this preserves the durability error chain.
            let _ = err;
            Err("checkpoint failed: pager_commit returned error".clone())
        }
        _ => {
            // Other reply shapes (ReadOk / WriteOk / CommitOk) are
            // impossible for a Checkpoint request — actor invariant.
            Err("checkpoint protocol violation: unexpected reply shape".clone())
        }
    }
}
