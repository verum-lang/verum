module core.database.sqlite.native.l1_pager.recovery;

// =============================================================================
// l1_pager/recovery.vr — WAL recovery protocol
// =============================================================================
// Layer: 1
// Spec: sqlite-native.md §8.5
//
// When a database opens, the pager scans `<db>-wal` for valid frames
// and returns the set of `(page_no → latest_frame_offset)` mappings it
// should use for satisfying reads. Invalid or torn frames past the last
// valid commit record are discarded — matching C-SQLite's behaviour of
// treating post-crash partial writes as "never happened".
//
// Correctness invariant (Z3-checkable, §21.4):
//
//     forall crash_point k,
//         recover(truncate(wal, k))
//             == recover_up_to_last_commit_before(wal, k)
//
// This module implements the *pure* side of recovery: given a byte
// stream, return the decision. The actual file-I/O loop (read header,
// iterate frames, apply to page cache) is driven by the pager actor.
// =============================================================================

mount core.*;
mount collections.{List, Map};
mount base.{Result, Ok, Err, Text, Maybe};
mount core.database.sqlite.native.l1_pager.journal.wal.{
    WalHeader, WalFrameHeader, WalChecksum,
    WAL_HEADER_SIZE, WAL_FRAME_HEADER_SIZE,
    wal_header_parse, wal_frame_header_parse, wal_running_checksum,
};

// -----------------------------------------------------------------------------
// Recovery result
// -----------------------------------------------------------------------------

/// Summary of a successful WAL scan.
public type RecoveryPlan is {
    /// How many frames we considered valid (contiguous prefix of the WAL).
    valid_frame_count: Int,
    /// Index of the last commit marker (frames[i].db_size_after_commit > 0).
    /// -1 if no commit found — the WAL has no recoverable content.
    last_commit_index: Int,
    /// Resulting DB size (in pages) after the last valid commit.
    /// 0 if no commit.
    db_size_after: Int,
    /// For every page number that appears in the recovered prefix, the
    /// byte-offset (within the WAL file) of the most recent frame for
    /// that page. Readers satisfy `page_no` lookups from here first,
    /// falling through to the main DB file on miss.
    page_map: Map<Int, Int>,
};

/// Errors distinguishable from "empty WAL, do nothing".
public type RecoveryError is
      ShortFile(Int /* bytes_available */)
    | BadMagic
    | ZeroPageSize;

implement Display for RecoveryError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            ShortFile(n)  => f.write_str(f"sqlite recovery: short file ({n} bytes available)".as_str()),
            BadMagic      => f.write_str("sqlite recovery: bad magic number"),
            ZeroPageSize  => f.write_str("sqlite recovery: zero page size"),
        }
    }
}

implement Debug for RecoveryError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            ShortFile(n)  => f.write_str(f"ShortFile({n})".as_str()),
            BadMagic      => f.write_str("BadMagic"),
            ZeroPageSize  => f.write_str("ZeroPageSize"),
        }
    }
}

implement Eq for RecoveryError {
    fn eq(&self, other: &RecoveryError) -> Bool {
        match (self, other) {
            (ShortFile(a), ShortFile(b)) => a == b,
            (BadMagic,     BadMagic)     => true,
            (ZeroPageSize, ZeroPageSize) => true,
            _ => false,
        }
    }
}

// -----------------------------------------------------------------------------
// Main entry point
// -----------------------------------------------------------------------------

/// Analyse a byte stream representing a `<db>-wal` file. Returns a
/// `RecoveryPlan` describing which prefix of frames is trustworthy.
///
/// Algorithm (§8.5):
///
///   1. Parse the 32-byte header. If short / bad magic → error.
///   2. Initialise a running checksum over the header-seed bytes.
///   3. For each frame:
///        a. Parse its 24-byte header and extract the expected
///           (checksum_1, checksum_2).
///        b. Compute the running checksum across (frame_header[0..8]
///           + frame_payload).
///        c. If salt or checksum mismatches, STOP — every frame past
///           this point is invalid.
///        d. Otherwise, this frame is valid. If it's a commit marker,
///           remember the index and DB size. Record page_no → offset.
///   4. Truncate the plan at the last commit marker — frames after it
///      are "uncommitted" (valid checksums but no commit quorum).
public fn wal_scan(
    wal_bytes: &[Byte],
    page_size: Int,
) -> Result<RecoveryPlan, RecoveryError> {
    if page_size <= 0 {
        return Err(ZeroPageSize);
    }
    if wal_bytes.len() < WAL_HEADER_SIZE {
        return Err(ShortFile(wal_bytes.len()));
    }

    let header = match wal_header_parse(wal_bytes) {
        Ok(h)  => h,
        Err(_) => { return Err(BadMagic); }
    };

    // Seed the running checksum over the header's pre-checksum bytes
    // (first 24 bytes). Identical to `wal_header_serialize_seed` in
    // `wal.vr`; the function is private there so we replicate the
    // slice here (cheap — 24 bytes).
    let mut seed: List<Byte> = List.new();
    let mut i: Int = 0;
    while i < 24 {
        seed.push(wal_bytes[i]);
        i = i + 1;
    }
    let mut running = wal_running_checksum(
        WalChecksum { s1: 0_u32, s2: 0_u32 },
        seed.as_slice(),
    );

    // Validate the header's own checksum-of-self. A header whose stored
    // (cksum_1, cksum_2) doesn't match the running state we just
    // computed is corrupted at rest — refuse the entire WAL rather
    // than silently recovering against a tampered salt/page_size pair
    // (which would mis-classify every subsequent frame's salt
    // comparison and could allow an attacker to swap salts to bypass
    // the torn-tail invariant).
    if running.s1 != header.checksum_1 || running.s2 != header.checksum_2 {
        return Err(BadMagic);
    }

    let frame_stride = WAL_FRAME_HEADER_SIZE + page_size;
    let mut offset: Int = WAL_HEADER_SIZE;
    let mut valid_count: Int = 0;
    let mut last_commit_idx: Int = -1;
    let mut db_size_after: Int = 0;
    let mut page_map: Map<Int, Int> = Map.new();

    while offset + frame_stride <= wal_bytes.len() {
        // Parse the frame header.
        let mut fh_slice: List<Byte> = List.new();
        let mut j: Int = 0;
        while j < WAL_FRAME_HEADER_SIZE {
            fh_slice.push(wal_bytes[offset + j]);
            j = j + 1;
        }
        let fh = match wal_frame_header_parse(&fh_slice) {
            Ok(h)  => h,
            Err(_) => break,
        };

        // Salt mismatch → invalid; every subsequent frame is also invalid.
        if fh.salt_1 != header.salt_1 || fh.salt_2 != header.salt_2 {
            break;
        }

        // Running-checksum the first 8 bytes of the frame header
        // (page_number + db_size_after_commit), then the page payload.
        let mut chk_bytes: List<Byte> = List.new();
        let mut k: Int = 0;
        while k < 8 {
            chk_bytes.push(wal_bytes[offset + k]);
            k = k + 1;
        }
        let payload_start = offset + WAL_FRAME_HEADER_SIZE;
        let mut p: Int = 0;
        while p < page_size {
            chk_bytes.push(wal_bytes[payload_start + p]);
            p = p + 1;
        }
        let new_running = wal_running_checksum(
            WalChecksum { s1: running.s1, s2: running.s2 },
            chk_bytes.as_slice(),
        );

        if new_running.s1 != fh.checksum_1 || new_running.s2 != fh.checksum_2 {
            break;
        }

        running = new_running;

        // Frame is valid — record its position.
        let _ = page_map.insert(fh.page_number as Int, offset);
        if fh.db_size_after_commit != 0_u32 {
            last_commit_idx = valid_count;
            db_size_after = fh.db_size_after_commit as Int;
        }
        valid_count = valid_count + 1;
        offset = offset + frame_stride;
    }

    // If there was no commit, the page map must be empty — the body of
    // any prefix without a commit is logically absent.
    let final_page_map: Map<Int, Int> = if last_commit_idx < 0 {
        Map.new()
    } else {
        // Keep only entries whose frame index is ≤ last_commit_idx.
        let keys = page_map.keys_list();
        let mut out: Map<Int, Int> = Map.new();
        let mut ii: Int = 0;
        while ii < keys.len() {
            let k2 = keys[ii];
            let off = page_map.get(k2);
            // Frame index = (off - WAL_HEADER_SIZE) / frame_stride
            let idx = (off - WAL_HEADER_SIZE) / frame_stride;
            if idx <= last_commit_idx {
                let _ = out.insert(k2, off);
            }
            ii = ii + 1;
        }
        out
    };

    Ok(RecoveryPlan {
        valid_frame_count: valid_count,
        last_commit_index: last_commit_idx,
        db_size_after: db_size_after,
        page_map: final_page_map,
    })
}

/// Convenience: did the scan find a usable commit?
public fn plan_has_recoverable_commit(plan: &RecoveryPlan) -> Bool {
    plan.last_commit_index >= 0
}
