// Synchronous-mode taxonomy.

module core.database.sqlite.native.pragma_synchronous_mode.mode;

mount base.{Bool, Text, Maybe};

public type SyncMode is
    | SmOff        // 0
    | SmNormal     // 1
    | SmFull       // 2
    | SmExtra      // 3
    ;

public fn code(m: &SyncMode) -> Int {
    match m {
        SmOff    => 0,
        SmNormal => 1,
        SmFull   => 2,
        SmExtra  => 3,
    }
}

public fn from_code(c: Int) -> Maybe<SyncMode> {
    if c == 0 { return Maybe.Some(SmOff); }
    if c == 1 { return Maybe.Some(SmNormal); }
    if c == 2 { return Maybe.Some(SmFull); }
    if c == 3 { return Maybe.Some(SmExtra); }
    Maybe.None
}

public fn mode_name(m: &SyncMode) -> Text {
    match m {
        SmOff    => "OFF".clone(),
        SmNormal => "NORMAL".clone(),
        SmFull   => "FULL".clone(),
        SmExtra  => "EXTRA".clone(),
    }
}

public fn fsyncs_per_commit(m: &SyncMode) -> Bool {
    match m {
        SmOff    => false,
        SmNormal => false,    // NORMAL uses SYNC_FULL only at critical moments
        SmFull   => true,
        SmExtra  => true,
    }
}

public fn fsyncs_master_journal(m: &SyncMode) -> Bool {
    match m { SmExtra => true, _ => false }
}

// Recommended default per journal mode:
//   Rollback journal  →  FULL
//   WAL               →  NORMAL
public fn recommended_default_wal() -> SyncMode { SmNormal }
public fn recommended_default_rollback() -> SyncMode { SmFull }

public fn is_safe_on_power_loss(m: &SyncMode) -> Bool {
    match m { SmOff => false, _ => true }
}

public fn ordering_rank(m: &SyncMode) -> Int {
    code(m)
}

public fn is_stricter_than(a: &SyncMode, b: &SyncMode) -> Bool {
    ordering_rank(a) > ordering_rank(b)
}
