// =============================================================================
// filename_api/filename.vr — FilenameHandle
// =============================================================================
// Spec: SQLite C API
// =============================================================================

module core.database.sqlite.native.filename_api.filename;

mount core.*;
mount base.{Text};

public type FilenameHandle is {
    database: Text,
    journal: Text,
    wal: Text,
    super_journal: Text,
}

public fn new_handle(database: Text) -> FilenameHandle {
    let journal = concat(&database, &"-journal".clone());
    let wal = concat(&database, &"-wal".clone());
    let super_journal = concat(&database, &"-mj".clone());
    FilenameHandle {
        database: database,
        journal: journal,
        wal: wal,
        super_journal: super_journal,
    }
}

fn concat(a: &Text, b: &Text) -> Text {
    let mut out = "".clone();
    out.reserve(a.as_bytes().len() + b.as_bytes().len());
    out.push_str(a);
    out.push_str(b);
    out
}
