// =============================================================================
// core/database/sqlite/native/synchronous_pragma/mod.vr
// =============================================================================
// PRAGMA synchronous — fsync() aggressiveness. 4 levels:
//  0 OFF — never call fsync (database may corrupt on power loss)
//  1 NORMAL — fsync on critical writes (rollback default in WAL)
//  2 FULL — fsync after every commit (default in legacy modes)
//  3 EXTRA — like FULL, plus fsync the directory after rename
// Spec §15.4.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.database.sqlite.native.synchronous_pragma;

public module level;
