// =============================================================================
// core/database/sqlite/connection.vr — Spindle SQLite connection façade
// =============================================================================
// Layer: 3 (Database — sqlite façade)
// Spec: internal/specs/database.md §6.2
// =============================================================================
//
// `SqliteConnection` is the user-facing handle for the Spindle SQLite
// adapter. It wraps loom's L7 `Database` (synchronous, in-memory or
// file-backed via PosixVfs once that lands) and surfaces the unified
// `core.database.common.error.DbError` shape so user code is portable.
//
// Surface (vendor-idiomatic, sync — SQLite is local I/O):
//
//   * `SqliteConnection.open_in_memory(mode)` / `open_path(path, mode)`
//   * `.execute(sql)`              — DDL / DML / TX statements
//   * `.execute_with(sql, params)` — same with positional bindings
//   * `.query_first(sql)`          — first row as `List<Value>`
//   * `.query_all(sql)`            — all rows as `List<List<Value>>`
//   * `.begin()` / `.begin_immediate()` / `.commit()` / `.rollback()`
//   * `.close()`                   — affine consume (loom Database is
//                                    `move`-by-construction)
//
// `SqliteValue` is the protocol-neutral cell type for a row column —
// the variants mirror SQLite's storage classes (Null / Int / Real /
// Text / Blob).  Higher-level user types (Email, UserId, Timestamp)
// decode via the future `Row` derive once T12 (sql#) lands; in the
// meantime authors decode by hand.
// =============================================================================

module core.database.sqlite.connection;

mount core.*;
mount base.{Result, Ok, Err, Text, Maybe, None, Some};
mount collections.List;
mount core.database.common.error.{DbError, AdapterId, AdapterSpecific};
mount core.database.sqlite.error.dberr_from_loom;

// Loom L7 — re-exports we drive directly. We do NOT bring loom's
// `DbError` into scope (sibling-name collision with common's); we
// reach for it via the full path inside `dberr_from_loom`.
mount core.database.sqlite.native.l7_api.{
    Database,
    Transaction, TxKind, TkDeferred, TkImmediate, TkExclusive,
    open_memory_db, open_readonly, open_readwrite, open_admin,
    open_path, open_path_readonly, open_path_readwrite, open_path_admin,

    // Backup
    BackupSession,
    backup_init_to_path, backup_init_into,
    backup_step, backup_finish, backup_abandon,
    backup_to_path_in_one_go,

    // Pragma
    PragmaValue, PvNull, PvInt, PvText, PvBool,
    pragma_get as loom_pragma_get,
    pragma_set as loom_pragma_set,
    pragma_get_int as loom_pragma_get_int,
    pragma_set_int as loom_pragma_set_int,
    pragma_get_text as loom_pragma_get_text,
    pragma_set_text as loom_pragma_set_text,
    pragma_get_bool as loom_pragma_get_bool,
    pragma_set_bool as loom_pragma_set_bool,

    // Hooks
    set_commit_hook    as loom_hooks_set_commit,
    clear_commit_hook  as loom_hooks_clear_commit,
    has_commit_hook    as loom_hooks_has_commit,
    set_rollback_hook  as loom_hooks_set_rollback,
    has_rollback_hook  as loom_hooks_has_rollback,
    set_update_hook    as loom_hooks_set_update,
    has_update_hook    as loom_hooks_has_update,
    set_pre_update_hook as loom_hooks_set_pre_update,
    set_authorizer     as loom_hooks_set_authorizer,
    has_authorizer     as loom_hooks_has_authorizer,
    set_busy_handler   as loom_hooks_set_busy,
    set_progress_handler as loom_hooks_set_progress,
    set_trace_hook     as loom_hooks_set_trace,
};
mount core.database.sqlite.native.pragmas.registry.{PragmaKind};
mount core.database.sqlite.native.backup_api.outcome.{BackupOutcome};
mount core.database.sqlite.native.backup_api.request.{BackupStepRequest};
mount core.database.sqlite.native.ext.hooks.{
    CommitHook, RollbackHook, UpdateHook, PreUpdateHook,
    AuthorizerHook, BusyHandler, ProgressHandler, TraceHook,
};
mount core.database.sqlite.native.l6_session.{
    ConnectionMode, CmRead, CmWrite, CmAdmin,
};
mount core.database.sqlite.native.l4_vdbe.{Register, RNull, RInt, RReal, RText, RBlob, RRowId};

// -----------------------------------------------------------------------------
// SqliteValue — protocol-neutral cell.
// -----------------------------------------------------------------------------

/// A single column value as it sits in a SQLite record. Mirrors
/// SQLite's five storage classes (NULL / INTEGER / REAL / TEXT /
/// BLOB).  We keep this distinct from `loom.Register` so the public
/// surface is independent of loom's internal layout.
public type SqliteValue is
      SvNull
    | SvInt(Int)
    | SvReal(Float64)
    | SvText(Text)
    | SvBlob(List<Byte>);

implement SqliteValue {
    /// Promote a loom Register to the public value shape. SQLite's
    /// rowid is just an `Int` from the user's perspective, so we fold
    /// `RRowId` into `SvInt` here — the storage-class distinction is a
    /// VDBE-internal concern.
    public fn from_register(r: Register) -> SqliteValue {
        match r {
            RNull       => SvNull,
            RInt(i)     => SvInt(i as Int),
            RReal(x)    => SvReal(x),
            RText(t)    => SvText(t),
            RBlob(b)    => SvBlob(b),
            RRowId(i)   => SvInt(i as Int),
        }
    }

    /// Demote a public value to a loom Register for binding.
    public fn to_register(self) -> Register {
        match self {
            SvNull      => RNull,
            SvInt(i)    => RInt(i as Int64),
            SvReal(x)   => RReal(x),
            SvText(t)   => RText(t),
            SvBlob(b)   => RBlob(b),
        }
    }

    public fn is_null(&self) -> Bool {
        match self {
            SvNull => true,
            _      => false,
        }
    }
}

// -----------------------------------------------------------------------------
// SqliteCapability — vendor-side capability marker, mirrors loom's
// ConnectionMode and is convertible from common-side capability tokens.
// -----------------------------------------------------------------------------

public type SqliteCapability is
      ScRead
    | ScReadWrite
    | ScAdmin;

implement SqliteCapability {
    public fn to_loom_mode(&self) -> ConnectionMode {
        match self {
            ScRead       => CmRead,
            ScReadWrite  => CmWrite,
            ScAdmin      => CmAdmin,
        }
    }
}

// -----------------------------------------------------------------------------
// SqliteConnection — the public façade.
// -----------------------------------------------------------------------------

/// A live SQLite connection. Wraps a loom `Database` (which itself
/// wraps a session-layer `Connection`); all errors crossing this
/// boundary get translated into the common `DbError`.
public type SqliteConnection is {
    inner: core.database.sqlite.native.l7_api.database.Database,
};

implement SqliteConnection {
    // -------------------------------------------------------------------------
    // Open
    // -------------------------------------------------------------------------

    /// Open an in-memory database with the given capability. Use
    /// `ScReadWrite` for the typical OLTP workload; `ScRead` for
    /// readonly views that must refuse writes by type-construction.
    public fn open_in_memory(cap: SqliteCapability) -> Result<SqliteConnection, DbError> {
        let mode = cap.to_loom_mode();
        match open_memory_db(mode) {
            Ok(db)  => Ok(SqliteConnection { inner: db }),
            Err(e)  => Err(dberr_from_loom(e)),
        }
    }

    /// Sugar — readonly in-memory.
    public fn open_in_memory_readonly() -> Result<SqliteConnection, DbError> {
        match open_readonly() {
            Ok(db)  => Ok(SqliteConnection { inner: db }),
            Err(e)  => Err(dberr_from_loom(e)),
        }
    }

    /// Sugar — read/write in-memory.
    public fn open_in_memory_readwrite() -> Result<SqliteConnection, DbError> {
        match open_readwrite() {
            Ok(db)  => Ok(SqliteConnection { inner: db }),
            Err(e)  => Err(dberr_from_loom(e)),
        }
    }

    /// Sugar — admin in-memory (allows DDL).
    public fn open_in_memory_admin() -> Result<SqliteConnection, DbError> {
        match open_admin() {
            Ok(db)  => Ok(SqliteConnection { inner: db }),
            Err(e)  => Err(dberr_from_loom(e)),
        }
    }

    // -------------------------------------------------------------------------
    // File-backed open — routes through L7 open_path → L6 open_file →
    // L1 pager_open_file → L0 PosixVfs.
    // -------------------------------------------------------------------------

    public fn open_path_with(path: &Text, cap: SqliteCapability) -> Result<SqliteConnection, DbError> {
        let mode = cap.to_loom_mode();
        match open_path(path, mode) {
            Ok(db)  => Ok(SqliteConnection { inner: db }),
            Err(e)  => Err(dberr_from_loom(e)),
        }
    }

    public fn open_path_ro(path: &Text) -> Result<SqliteConnection, DbError> {
        match open_path_readonly(path) {
            Ok(db)  => Ok(SqliteConnection { inner: db }),
            Err(e)  => Err(dberr_from_loom(e)),
        }
    }

    public fn open_path_rw(path: &Text) -> Result<SqliteConnection, DbError> {
        match open_path_readwrite(path) {
            Ok(db)  => Ok(SqliteConnection { inner: db }),
            Err(e)  => Err(dberr_from_loom(e)),
        }
    }

    public fn open_path_a(path: &Text) -> Result<SqliteConnection, DbError> {
        match open_path_admin(path) {
            Ok(db)  => Ok(SqliteConnection { inner: db }),
            Err(e)  => Err(dberr_from_loom(e)),
        }
    }

    // -------------------------------------------------------------------------
    // Execute / query
    // -------------------------------------------------------------------------

    /// Run a no-result statement (DDL / INSERT / UPDATE / DELETE / TX
    /// control).  Returns `()` on success — for affected-row counts use
    /// the future `execute_with` overload once parameter binding is
    /// wired through the public surface.
    public fn execute(&mut self, sql: &Text) -> Result<(), DbError> {
        match self.inner.execute(sql) {
            Ok(_)   => Ok(()),
            Err(e)  => Err(dberr_from_loom(e)),
        }
    }

    /// Run a SELECT and return its first row (if any) as a list of
    /// public values. Returns `Ok([])` if the query completes with no
    /// rows.
    public fn query_first(&mut self, sql: &Text) -> Result<List<SqliteValue>, DbError> {
        match self.inner.query_first_row(sql) {
            Ok(regs) => Ok(registers_to_values(regs)),
            Err(e)   => Err(dberr_from_loom(e)),
        }
    }

    /// Run a SELECT and collect every row. Acceptable for bounded
    /// result sets; large scans should use the streaming variant once
    /// landed.
    public fn query_all(&mut self, sql: &Text) -> Result<List<List<SqliteValue>>, DbError> {
        match self.inner.query_all(sql) {
            Ok(rows) => {
                let mut out: List<List<SqliteValue>> = [];
                let mut i = 0;
                while i < rows.len() as Int {
                    out.push(registers_to_values(rows[i].clone()));
                    i = i + 1;
                }
                Ok(out)
            }
            Err(e)   => Err(dberr_from_loom(e)),
        }
    }

    // -------------------------------------------------------------------------
    // Transaction — affine handle API (database.md §4.1+§5.5)
    // -------------------------------------------------------------------------
    //
    // Spindle façade forwards directly to the loom L7 affine surface.
    // `Transaction` is exposed under the same name; commit_tx/rollback_tx
    // consume it; `with_transaction(body)` wraps both.

    /// Begin a deferred transaction.  Returns the affine handle the
    /// caller MUST consume via `commit_tx` / `rollback_tx`.
    public fn begin_tx(&mut self) -> Result<Transaction, DbError> {
        match self.inner.begin_tx() {
            Ok(t)  => Ok(t),
            Err(e) => Err(dberr_from_loom(e)),
        }
    }

    public fn begin_tx_immediate(&mut self) -> Result<Transaction, DbError> {
        match self.inner.begin_tx_immediate() {
            Ok(t)  => Ok(t),
            Err(e) => Err(dberr_from_loom(e)),
        }
    }

    public fn begin_tx_exclusive(&mut self) -> Result<Transaction, DbError> {
        match self.inner.begin_tx_exclusive() {
            Ok(t)  => Ok(t),
            Err(e) => Err(dberr_from_loom(e)),
        }
    }

    public fn commit_tx(&mut self, tx: Transaction) -> Result<(), DbError> {
        match self.inner.commit_tx(tx) {
            Ok(_)  => Ok(()),
            Err(e) => Err(dberr_from_loom(e)),
        }
    }

    public fn rollback_tx(&mut self, tx: Transaction) -> Result<(), DbError> {
        match self.inner.rollback_tx(tx) {
            Ok(_)  => Ok(()),
            Err(e) => Err(dberr_from_loom(e)),
        }
    }

    // -------------------------------------------------------------------------
    // Backup — online copy to a destination database
    // -------------------------------------------------------------------------
    //
    // Surface mirrors `core.database.sqlite.native.l7_api.backup` —
    // see that module for full semantics.  Every call forwards through
    // the loom L7 API; the only adapter-side translation is the loom
    // `DbError` (a per-connection sum) into the unified Spindle
    // `DbError` (a cross-vendor sum) via `dberr_from_loom`.

    /// Initialise an online backup that will copy this connection's
    /// data into a fresh database at `dst_path`.  Returns the affine
    /// `BackupSession` the caller MUST consume via `backup_step` +
    /// `backup_finish`.
    public fn backup_init_to_path(&self, dst_path: &Text)
        -> Result<BackupSession, DbError>
    {
        match backup_init_to_path(&self.inner, dst_path) {
            Ok(s)  => Ok(s),
            Err(e) => Err(dberr_from_loom(e)),
        }
    }

    /// Initialise a backup writing into an already-open destination
    /// loom Database.  Used by tests with `:memory:` destinations and
    /// by advanced flows that have already tuned the destination.
    public fn backup_init_into(&self, dst: core.database.sqlite.native.l7_api.database.Database)
        -> Result<BackupSession, DbError>
    {
        match backup_init_into(&self.inner, dst) {
            Ok(s)  => Ok(s),
            Err(e) => Err(dberr_from_loom(e)),
        }
    }

    /// Copy up to `pages` source pages into the destination.  Returns
    /// `BackupOutcome::BoOk` while progress remains, `BoDone` on
    /// completion, `BoFailed { code, reason }` on I/O failure.
    public fn backup_step(
        &mut self,
        session: &mut BackupSession,
        req: BackupStepRequest,
    ) -> BackupOutcome {
        backup_step(session, &mut self.inner, req)
    }

    /// Consume the backup session, returning the destination Database.
    public fn backup_finish(&self, session: BackupSession) -> core.database.sqlite.native.l7_api.database.Database {
        backup_finish(session)
    }

    /// Convenience: open dst, copy everything, finish.
    public fn backup_to_path_in_one_go(&mut self, dst_path: &Text)
        -> Result<core.database.sqlite.native.l7_api.database.Database, DbError>
    {
        match backup_to_path_in_one_go(&mut self.inner, dst_path) {
            Ok(d)  => Ok(d),
            Err(e) => Err(dberr_from_loom(e)),
        }
    }

    // -------------------------------------------------------------------------
    // Hooks — observation surfaces
    // -------------------------------------------------------------------------

    public fn set_commit_hook(&mut self, h: Heap<dyn CommitHook>) {
        loom_hooks_set_commit(&mut self.inner, h);
    }
    public fn clear_commit_hook(&mut self) {
        loom_hooks_clear_commit(&mut self.inner);
    }
    public fn has_commit_hook(&self) -> Bool {
        loom_hooks_has_commit(&self.inner)
    }

    public fn set_rollback_hook(&mut self, h: Heap<dyn RollbackHook>) {
        loom_hooks_set_rollback(&mut self.inner, h);
    }
    public fn has_rollback_hook(&self) -> Bool {
        loom_hooks_has_rollback(&self.inner)
    }

    public fn set_update_hook(&mut self, h: Heap<dyn UpdateHook>) {
        loom_hooks_set_update(&mut self.inner, h);
    }
    public fn has_update_hook(&self) -> Bool {
        loom_hooks_has_update(&self.inner)
    }

    public fn set_pre_update_hook(&mut self, h: Heap<dyn PreUpdateHook>) {
        loom_hooks_set_pre_update(&mut self.inner, h);
    }

    public fn set_authorizer(&mut self, h: Heap<dyn AuthorizerHook>) {
        loom_hooks_set_authorizer(&mut self.inner, h);
    }
    public fn has_authorizer(&self) -> Bool {
        loom_hooks_has_authorizer(&self.inner)
    }

    public fn set_busy_handler(&mut self, h: Heap<dyn BusyHandler>) {
        loom_hooks_set_busy(&mut self.inner, h);
    }
    public fn set_progress_handler(&mut self, h: Heap<dyn ProgressHandler>) {
        loom_hooks_set_progress(&mut self.inner, h);
    }
    public fn set_trace_hook(&mut self, h: Heap<dyn TraceHook>) {
        loom_hooks_set_trace(&mut self.inner, h);
    }

    // -------------------------------------------------------------------------
    // Pragma — typed get / set without raw SQL
    // -------------------------------------------------------------------------
    //
    // Wraps the loom `pragma_api` surface: typed `PragmaKind` /
    // `PragmaValue` instead of `PRAGMA name = value` strings; closes
    // the SQLite-C footgun where typo'd PRAGMAs silently no-op.

    /// Read a PRAGMA by typed kind.
    public fn pragma_get(&mut self, kind: PragmaKind)
        -> Result<PragmaValue, DbError>
    {
        match loom_pragma_get(&mut self.inner, kind) {
            Ok(v)  => Ok(v),
            Err(e) => Err(dberr_from_loom(e)),
        }
    }

    /// Write a PRAGMA by typed kind + value.
    public fn pragma_set(
        &mut self,
        kind: PragmaKind,
        value: PragmaValue,
    ) -> Result<(), DbError> {
        match loom_pragma_set(&mut self.inner, kind, value) {
            Ok(_)  => Ok(()),
            Err(e) => Err(dberr_from_loom(e)),
        }
    }

    /// Typed-shape conveniences — reject mismatched value-shape with
    /// `DbMisuse` rather than silently coercing.
    public fn pragma_get_int(&mut self, kind: PragmaKind) -> Result<Int64, DbError> {
        match loom_pragma_get_int(&mut self.inner, kind) {
            Ok(n)  => Ok(n),
            Err(e) => Err(dberr_from_loom(e)),
        }
    }
    public fn pragma_set_int(&mut self, kind: PragmaKind, n: Int64) -> Result<(), DbError> {
        match loom_pragma_set_int(&mut self.inner, kind, n) {
            Ok(_)  => Ok(()),
            Err(e) => Err(dberr_from_loom(e)),
        }
    }
    public fn pragma_get_text(&mut self, kind: PragmaKind) -> Result<Text, DbError> {
        match loom_pragma_get_text(&mut self.inner, kind) {
            Ok(s)  => Ok(s),
            Err(e) => Err(dberr_from_loom(e)),
        }
    }
    public fn pragma_set_text(&mut self, kind: PragmaKind, s: Text) -> Result<(), DbError> {
        match loom_pragma_set_text(&mut self.inner, kind, s) {
            Ok(_)  => Ok(()),
            Err(e) => Err(dberr_from_loom(e)),
        }
    }
    public fn pragma_get_bool(&mut self, kind: PragmaKind) -> Result<Bool, DbError> {
        match loom_pragma_get_bool(&mut self.inner, kind) {
            Ok(b)  => Ok(b),
            Err(e) => Err(dberr_from_loom(e)),
        }
    }
    public fn pragma_set_bool(&mut self, kind: PragmaKind, b: Bool) -> Result<(), DbError> {
        match loom_pragma_set_bool(&mut self.inner, kind, b) {
            Ok(_)  => Ok(()),
            Err(e) => Err(dberr_from_loom(e)),
        }
    }

    // -------------------------------------------------------------------------
    // Introspection
    // -------------------------------------------------------------------------

    public fn mode(&self) -> ConnectionMode { self.inner.mode() }
    public fn is_in_tx(&self) -> Bool { self.inner.is_in_tx() }
    public fn schema_generation(&self) -> Int { self.inner.schema_generation() }

    // -------------------------------------------------------------------------
    // Close — affine consume.
    // -------------------------------------------------------------------------

    /// Consumes the connection. Further use is a compile error; loom's
    /// underlying Database is moved-out so its destructor releases the
    /// pager actor on drop.
    public fn close(self) {
        self.inner.close()
    }
}

// -----------------------------------------------------------------------------
// Helpers
// -----------------------------------------------------------------------------

fn registers_to_values(regs: List<Register>) -> List<SqliteValue> {
    let mut out: List<SqliteValue> = [];
    let mut i = 0;
    while i < regs.len() as Int {
        out.push(SqliteValue.from_register(regs[i].clone()));
        i = i + 1;
    }
    out
}
